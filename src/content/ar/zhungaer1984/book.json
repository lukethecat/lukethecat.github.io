          "id": "poem-2-12",
          "title": "ليس هذا ضباب الصباح ذو اللون الأسمر",
          "lines": [
            "ليس هذا ضباب الصباح ذو اللون الأسمر —",
            "إنه غبار البناء،",
            "تلك السحابة الذهبية التي أثارتها ألف مجرفة،",
            "بينما يرتفع مبنى آخر",
            "من أرضية الصحراء.",
            "",
            "ليس هذا ضباباً — إنه الأنفاس",
            "لمدينة تولد."
          ]
        },
        {
          "id": "poem-2-13",
          "title": "حراثة شمس حمراء مدورة ومكتملة",
          "lines": [
            "عند حافة المدينة، تستدير الجرارة،",
            "لتحرث شمساً حمراء مدورة ومكتملة",
            "من الأرض الداكنة،",
            "وكأن الأرض ذاتها",
            "كانت تلد النور.",
            "",
            "تلك هي الحدود المتاخمة وقت الفجر،",
            "حيث كل ثلمة هي سطر من قصيدة،",
            "وحيث كل حصاد هو بيت،",
            "والشمس الحمراء تشرق",
            "من نصل المحراث الدوَار."
          ]
        }
      ]
