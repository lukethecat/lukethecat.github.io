            "الشاعر يفكر:",
            "أنا لست الأول هنا،",
            "ولن أكون الأخير،",
            "لكن هذه الشعلة الليلة هي لي،",
            "وهذه الصحراء لي،",
            "وهذه النجوم كذلك."
          ]
        }
