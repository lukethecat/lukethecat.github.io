        {
          "id": "poem-4-4",
          "title": "لقد ملأت الإبريق بالفعل بالماء",
          "lines": [
            "لقد ملأت الإبريق بالفعل بالماء",
            "من قناة الري،",
            "وضوء المساء يعكس القطرات",
            "على ذراعيها البنيتين.",
            "",
            "في غسق جونغار،",
            "يتحول كل شيء إلى ذهب:",
            "الماء، القمح، شعرها،",
            "الغبار على صندلها،",
            "والابتسامة التي تمنحني إياها",
            "دون أن تستدير."
          ]
        },
        {
          "id": "poem-4-5",
          "title": "هل كانت تلك آخر ابتسامة لها لي؟",
          "lines": [
            "هل كانت تلك آخر ابتسامة لها لي؟",
            "انطلقت الشاحنة مبتعدة،",
            "وعبر الغبار خيّل إليّ أني رأيتها تلوح —",
            "أم أن تلك كانت الريح تداعب أشجار الصفصاف الحمراء؟",
            "",
            "لقد عادت إلى سيتشوان،",
            "إلى التلال الخضراء وحقول الأرز،",
            "بعيداً عن الرمال والرياح،",
            "وبعيداً عني.",
            "",
            "هل كانت تلك آخر ابتسامة لها لي؟",
            "لقد كنت أسأل الصحراء منذ ذلك الحين،",
            "والصحراء لا تجيب."
          ]
        },
        {
          "id": "poem-4-6",
          "title": "آه، يا للعندليب في أشجار الصفصاف الحمراء",
          "lines": [
            "آه، يا للعندليب في أشجار الصفصاف الحمراء",
            "تغني الأغنية التي لا أستطيع أن أغنيها،",
            "أغنية الرجل الذي بقي",
            "في حين رحلت المرأة التي أحبها.",
            "",
            "العندليب لا تعرف الوحدة،",
            "لكنها تغني كما لو كانت تعرفها،",
            "وباستماعي لها، أكاد أصدق",
            "أن الجمال والحزن",
            "هما شيء واحد."
          ]
        },
        {
          "id": "poem-4-7",
          "title": "لنسج ألوان الربيع للحدود",
          "lines": [
            "'لنسج ألوان الربيع للحدود' —",
            "قالت أن هذا هو سبب مجيئها،",
            "فتاة من مصانع الحرير في سوتشو،",
            "استبدلت نولها بمجرفة.",
            "",
            "إنها تزرع الزهور على طول ضفة القناة،",
            "القطيفة والختمية،",
            "مشرقة ضد الأرض البنية،",
            "تنسج نوعاً مختلفاً من الحرير:",
            "ألوان الربيع",
            "على القماش الخشن للحدود."
          ]
        },
        {
          "id": "poem-4-8",
          "title": "يتدفق لحن أخضر",
          "lines": [
            "يتدفق لحن أخضر",
            "عبر حزام الحماية المزروع حديثاً،",
            "والريح تعزف بأشجار الحور كالناي،",
            "وكل شجرة هي نغمة في النوتة الموسيقية.",
            "",
            "أستمع وأنا مغمض العينين",
            "وأسمع المستقبل:",
            "ظلّاً يكفي مدينة،",
            "وهدوءاً يكفي مقاطعة،",
            "كل هذا يتدفق من هذا اللحن الأخضر",
            "الذي بدأ كشتلة",
            "في يد جندي."
          ]
        },
        {
          "id": "poem-4-9",
          "title": "آه، أرجوك لا تتركني",
          "lines": [
            "آه، أرجوك لا تتركني،",
            "ليس الآن، ليس والقطن على وشك التفتح،",
            "وليس وخزان المياه ممتلئ تقريباً،",
            "وليس وقد بنينا بالكاد الحياة",
            "التي كنا نتحدث عنها منذ لانغشو.",
            "",
            "ابقِ حتى تصبح أشجار الحور أطول منا،",
            "وابقِ حتى يتم رصف الطريق،",
            "وابقِ حتى تشعر النجوم بأنها أقل غربة",
            "وأكثر جيرة.",
            "",
            "آه، أرجوك لا تتركني.",
            "الصحراء واسعة بما يكفي لاثنين."
          ]
        },
        {
          "id": "poem-4-10",
          "title": "إنها عجلة تتطاير بفعل كثيب رملي حاد",
          "lines": [
            "إنها عجلة تتطاير بفعل كثيب رملي حاد،",
            "ترتد عبر الرمال",
            "كقمر صغير مثير للسخرية.",
            "",
            "تأوهت الشاحنة ومالت،",
            "وتناثرت الإمدادات:",
            "علب الطلاء، ولفائف الأسلاك،",
            "ورسائل الحب",
            "من حقيبة البريد،",
            "تتدحرج في الرمال",
            "تحت السماء اللامبالية."
          ]
        },
        {
          "id": "poem-4-11",
          "title": "آه، يا لتلك الأمواج الثلجية الزرقاء الداكنة",
          "lines": [
            "آه، يا لتلك الأمواج الثلجية الزرقاء الداكنة",
            "تتحطم من تيانشان عند الغسق،",
            "حاملة التنفس البارد للنهر الجليدي",
            "إلى الوادي الدافئ أدناه.",
            "",
            "واقفاً في ضباب الأمواج الثلجية،",
            "أفكر فيكِ،",
            "في فستانك القطني الأزرق الداكن،",
            "في شعرك المتطاير في الريح،",
            "في ضحكتك مثل الماء —",
            "باردة ومشرقة ومندفعة."
          ],
          "annotations": [
            {
              "term": "雪浪",
              "note": "天山融雪汇成的溪流在沙漠边缘奔涌的景象。亦指准噶尔冬季的雪原波涛。在诗中既是自然景观，也是生命力与情感的隐喻。"
            }
          ]
        },
        {
          "id": "poem-4-12",
          "title": "ابتعدت مبتسمة بلطف",
          "lines": [
            "ابتعدت مبتسمة بلطف،",
            "في الطريق المحاط بأشجار الحور،",
            "حقيبتها في يد،",
            "ومستقبلها في الأخرى.",
            "",
            "لم تنظر للخلف —",
            "أو ربما نظرت،",
            "وأخفت أشجار الحور وجهها.",
            "",
            "ابتعدت مبتسمة،",
            "وكأن الرحيل سهل،",
            "وكأن الصحراء",
            "لم تكن قد كتبت",
            "اسمها سلفاً",
            "على قلبها."
          ]
        },
        {
          "id": "poem-4-13",
          "title": "إلى حيث تسكن، أنا ذاهب",
          "lines": [
            "إلى حيث تسكن، أنا ذاهب،",
            "ماراً بالكثبان الرملية ومجاري الأنهار الجافة،",
            "ماراً ببساتين الصفصاف الحمراء،",
            "ماراً بعلامات المسح",
            "والطريق غير المكتمل.",
            "",
            "إلى حيث تسكن، أنا ذاهب،",
            "في المستوطنة الجديدة جنوب التلال،",
            "حيث تدرس عشرين طفلاً",
            "في غرفة مدرسية مبنية من الطوب اللبن.",
            "",
            "إلى حيث تسكن، أنا ذاهب.",
            "الصحراء تمتد لخمسين كيلومتراً فقط.",
            "ومن أجل الحب، فإن بغداد ليست ببعيدة حقاً."
          ]
        },
        {
          "id": "poem-4-14",
          "title": "أمَسِّح برفق هذا الحجر القرمزي الصحراوي",
          "lines": [
            "أمَسِّح برفق هذا الحجر القرمزي الصحراوي،",
            "المصقول بمليون عام من الرياح،",
            "صغير كقلب،",
            "ودافئ من شمس الظهيرة.",
            "",
            "سأعطيها إياه",
            "بدلاً من الخاتم.",
            "",
            "على الحدود",
            "لا نملك صاغة مجوهرات،",
            "لكننا نملك الصحراء،",
            "والصحراء تصنع",
            "جواهرها الخاصة."
          ]
        },
        {
          "id": "poem-4-15",
          "title": "المشي في صمت",
          "lines": [
            "المشي في صمت",
            "عبر قربانتونغوت عند الغسق،",
            "والرمال لا تزال دافئة تحت قدمي،",
            "والسماء تتلون بألوان",
            "لا يوجد لها اسم في أي لغة.",
            "",
            "المشي في صمت",
            "لأن بعض المشاعر",
            "أكبر من الكلمات،",
            "وأوسع من الأفواه،",
            "ويجب أن تُحمل",
            "في الصدر،",
            "في الخُطى،",
            "في الصمت ذاته."
          ]
        },
        {
          "id": "poem-4-16",
          "title": "آه، في قلبي قمر لا يغرب أبداً",
          "lines": [
            "آه، في قلبي قمر لا يغرب أبداً،",
            "قمر يضيء عندما تكون السماء ملبدة بالغيوم،",
            "قمر يتوهج في العاصفة الرملية،",
            "قمر يتبعني",
            "من الخندق العسكري إلى الحقل إلى ضفة القناة.",
            "",
            "أنا لا أحتاج",
            "إلى القمر فوق تيانشان،",
            "لأنني أحمل قمري الخاص،",
            "مشرق بذكرى وجهها،",
            "ومكتمل كل ليلة،",
            "ولا يتضاءل أبداً."
          ]
        },
        {
          "id": "poem-4-17",
          "title": "الجدول يتدفق عبر الليل الأزرق الداكن",
          "lines": [
            "الجدول يتدفق عبر الليل الأزرق الداكن،",
            "خيط فضي في الظلام،",
            "يحمل صوت النهر الجليدي",
            "نزولاً إلى الحقول النائمة.",
            "",
            "أجلس بجانبه وأتذكر:",
            "كيف غمست قدميها في هذا الماء،",
            "وكيف ضحكت عندما فاجأتها البرودة،",
            "وكيف قالت: 'حتى الماء هنا",
            "طعم كطعم المغامرة.'",
            "",
            "يواصل الجدول تدفقه",
            "عبر الليل الأزرق الداكن،",
            "حاملاً ضحكتها معه",
            "شرقاً، دائماً نحو الشرق."
          ]
        },
        {
          "id": "poem-4-18",
          "title": "أستطيع الاستغناء عن القمر في السماء",
          "lines": [
            "أستطيع الاستغناء عن القمر في السماء،",
            "أستطيع الاستغناء عن المطر من الغيوم،",
            "أستطيع الاستغناء عن رسائل الوطن.",
            "",
            "لكنني لا أستطيع الاستغناء عن",
            "تفكيري بكِ،",
            "واقفة في المدخل",
            "للمدرسة المبنية من الطوب اللبن،",
            "والطباشير لا يزال على أصابعك،",
            "تُعلمين عشرين طفلاً",
            "كيف يكتبون كلمة 'الربيع'",
            "في أرض من الشتاء الدائم."
          ]
        },
        {
          "id": "poem-4-19",
          "title": "تلك الأصداء العميقة من ليالي الحب الأول",
          "lines": [
            "تلك الأصداء العميقة من ليالي الحب الأول",
            "لا تزال تتردد في هواء الصحراء،",
            "في المساحات بين الكثبان الرملية،",
            "في الفجوات بين النجوم.",
            "",
            "كنا شباباً آنذاك،",
            "نشيطون كالشتلات التي زرعناها،",
            "وخُضر كالقمح الذي سقيناه،",
            "وحمقى كالعندليب",
            "الذي يغني لصحراء خاوية.",
            "",
            "تلك الأصداء العميقة",
            "لم تتوقف أبداً."
          ]
        },
        {
          "id": "poem-4-20",
          "title": "الطائر الذي يبشر بالفجر",
          "lines": [
            "الطائر الذي يبشر بالفجر",
            "يجلس على أعلى غصن",
            "في أطول شجرة حور في حزام الحماية،",
            "ويغني.",
            "",
            "ليس عندليباً هذه المرة،",
            "بل قُبَّرة،",
            "ساطعة الصوت وعادية،",
            "طائر الصباحيات المألوفة،",
            "طائر القهوة والخبز والعمل.",
            "",
            "الطائر الذي يبشر بالفجر",
            "لا يغني عن الحب",
            "وإنما يغني عن الروتين الجميل",
            "لأيام تتبع أياماً أُخَرَ",
            "على الحدود."
          ]
        },
        {
          "id": "poem-4-21",
          "title": "رغم أنه نفس النوع من الحزن",
          "lines": [
            "رغم أنه نفس النوع من الحزن",
            "مثل الليلة التي غادر فيها القطار،",
            "إلا أنه حزن ألطف الآن،",
            "صُقل عبر السنين،",
            "كحجر صحراء غوبي في اليد.",
            "",
            "لقد تعلمت أن أتعايش معه،",
            "هذا الحزن الذي هو أيضاً امتنان،",
            "هذا الشوق الذي هو أيضاً ذكرى،",
            "هذا الغياب الذي هو أيضاً حضور،",
            "هنا، في الصحراء،",
            "حيث كل شيء بعيد",
            "ولا يُنسى أي شيء."
          ]
        },
        {
          "id": "poem-4-22",
          "title": "كعندليب حزين يطير نحوي",
          "lines": [
            "كعندليب حزين يطير نحوي،",
            "تعود ذكراها",
            "في كل مساء صحراوي،",
            "ومع كل هلال قمر.",
            "",
            "أفتح ذراعي لألتقطه،",
            "طائر الذاكرة الداكن هذا،",
            "وأضمه إلى صدري،",
            "وأستمع إلى أغنيته:",
            "",
            "من أجل الحب، فإن بغداد ليست ببعيدة حقاً.",
            "ومن أجل الحب، لا توجد مسافة شاسعة جداً.",
            "ومن أجل الحب، الصحراء ليست بصحراء",
            "بل حديقة تنتظر المطر.",
            "",
            "كعندليب حزين يطير نحوي،",
            "إنها تعود وتعود،",
            "وأنا، أنا من بقيت،",
            "أزداد ثراءً لذلك."
          ]
        }
      ]
    }
  ]
}