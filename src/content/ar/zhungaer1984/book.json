{
  "title": "قصائد من جونغار",
  "author": "لي يوي",
  "year": "1984",
  "chapters": [
    {
      "id": "chapter-1",
      "title": "المجلد الأول: نار المخيم المتراقصة",
      "poems": [
        {
          "id": "poem-1-1",
          "title": "أغنية المنجل الأول",
          "lines": [
            "احصد، احصد، احصد!",
            "احصد مساحة من غروب الشمس، واحصد عشرة آلاف موجة من القمح؛",
            "لقد عشنا أخيراً لنشهد هذا اليوم،",
            "يوم نسترد فيه من الصحراء",
            "هذا المحيط الذهبي"
          ]
        },
        {
          "id": "poem-1-2",
          "title": "تتفتح في اندفاعة",
          "lines": [
            "نبحر في بحر قربانتونغوت،",
            "تنطلق الحصادة المجمعة في ضوء الفجر الخافت،",
            "متجهة نحو الأمواج الذهبية اللامعة؛",
            "عاصفة من الحبوب، أغنية من العرق",
            "في اندفاعة واحدة للحياة"
          ]
        },
        {
          "id": "poem-1-3",
          "title": "رياح الربيع عبرت ممر اليشم منذ زمن طويل",
          "lines": [
            "رياح الربيع عبرت ممر اليشم منذ زمن طويل،",
            "لكن جبال تيانشان الشاهقة لا تزال ترتدي تاجها الكريستالي من الثلج؛",
            "أضف مجرفة أخرى من التربة الخصبة للشتلات الجديدة،",
            "دع الأخضر يزحف إلى أعلى التلال،",
            "حتى تبتسم الجبال البيضاء"
          ],
          "annotations": [
            {
              "term": "玉门关",
              "note": "汉代设置的西北边塞关隘，位于今甘肃敦煌西北，是丝绸之路北道的必经之地。王之涣「春风不度玉门关」使其闻名。此处化用其意，象征新中国建设者挺进西北。"
            }
          ]
        },
        {
          "id": "poem-1-4",
          "title": "التقدم نحو الشمال الغربي العظيم",
          "lines": [
            "لقد تلقيت رسائل من بعيد من قبل،",
            "لكن ليس من مكان بهذا البعد؛",
            "هذه الرسالة ستعبر وسع الأرض،",
            "لتحمل دقات قلب الصحراء",
            "وتدفئ شتاءك"
          ],
          "annotations": [
            {
              "term": "大西北",
              "note": "中国西北地区的泛称，包括新疆、甘肃、青海、宁夏、陕西等省区。1949年后，大批内地青年和部队开赴大西北进行开发建设。"
            }
          ]
        },
        {
          "id": "poem-1-5",
          "title": "قصيدة صغيرة كُتبت في الخندق — يوميات الكثبان الرملية",
          "lines": [
            "سيستغرق الأمر عقوداً، وربما نصف قرن،",
            "قبل أن تصبح نقطة حراسة الكثبان الرملية هذه مدينة؛",
            "لكننا الليلة في الخندق نكتب القصائد على ضوء الشموع،",
            "ونرسم خريطة للغد،",
            "مسترشدين بالنجوم"
          ],
          "annotations": [
            {
              "term": "地窝子",
              "note": "Dugout (dìwōzi) — semi-underground shelters used by early military settlers in Xinjiang, offering protection from sandstorms and extreme temperatures."
            }
          ]
        },
        {
          "id": "poem-1-6",
          "title": "في ضوء قمر تيانشان — إلى عبدو",
          "lines": [
            "يبدو لي أنني أراك واقفاً بجانب الفرن مرة أخرى،",
            "وما زالت قبعتك المطرزة تعكس دخان الجبهة الشمالية الغربية؛",
            "والشرر المتطاير من مطرقتك",
            "ينير الوجوه الحازمة،",
            "ويصوغ طريقاً للصداقة"
          ],
          "annotations": [
            {
              "term": "天山",
              "note": "Tianshan Mountains — a large mountain system in Central Asia running through Xinjiang, stretching about 2,500 km."
            }
          ]
        },
        {
          "id": "poem-1-7",
          "title": "آه، يا شجرة الصفصاف الحمراء",
          "lines": [
            "آه، يا شجرة الصفصاف الحمراء،",
            "تنفرد أوراقك بهدوء في وجه الرياح الغربية،",
            "وتحطم أغصانك غيوم العاصفة بشراسة؛",
            "أنتِ العزيمة المتجذرة في الرمال،",
            "الزهرة الدموية التي لا تذبل أبداً"
          ],
          "annotations": [
            {
              "term": "红柳",
              "note": "Red Willow (tamarisk) — a drought-resistant desert shrub with deep roots, symbolizing resilience of frontier settlers."
            }
          ]
        },
        {
          "id": "poem-1-8",
          "title": "تتلألأ في ضوء القمر",
          "lines": [
            "تتلألأ في ضوء القمر،",
            "تتلألأ في ضوء النجوم؛",
            "أمواج الثلج تتجمع، لتغني أغنيتها الغنائية الليلية،",
            "وتهمس بأسرار تيانشان،",
            "إلى الحراس المستيقظين"
          ]
        },
        {
          "id": "poem-1-9",
          "title": "إشعال نار المخيم المتراقصة — إلى الغزال",
          "lines": [
            "هنا،",
            "نشعل نار مخيم متراقصة،",
            "ومن هذه اللحظة المشرقة يبدأ عصر جديد للصحراء؛",
            "",
            "تراقب الغزلان من بين شجيرات الطرفاء،",
            "وتعكس أعينها ضوء النار؛",
            "إنها لا تخشانا بعد،",
            "نحن الرواد الأوائل،",
            "الذين تفوح منهم رائحة الأرض والعرق",
            "بدلاً من البارود.",
            "",
            "أيتها الغزلان العزيزة — نحن جيرانكم الجدد،",
            "المخلوقات ذات الساقين",
            "التي تغني بنشاز على ضوء النار",
            "ولا تضمر لكم أي أذى."
          ]
        },
        {
          "id": "poem-1-10",
          "title": "حلم أخضر تحت الكثبان الرملية",
          "lines": [
            "لقد ودعنا بالفعل حقول الأرز المطرزة،",
            "لقد ودعنا بالفعل القرى الجديدة المتجمعة —",
            "ليس وطننا جيانغنان،",
            "ولكن مكاناً بدا وكأنه الوطن.",
            "",
            "أما الآن وتحت هذه الكثبان، فنحن نحلم حلماً أخضر،",
            "حلماً بالبساتين والقنوات،",
            "بالمدارس والعيادات،",
            "بأطفال سيعرفون",
            "فقط خضرة الأشياء التي تنمو،",
            "وليس سمرة المسير."
          ]
        },
        {
          "id": "poem-1-11",
          "title": "الليلة يعبرون جسر الصفصاف الأحمر مرة أخرى",
          "lines": [
            "لقد عبرنا جسوراً حجرية من قبل،",
            "ولقد عبرنا جسوراً من لوح واحد من قبل؛",
            "كم عدد الجسور التي عبرناها في حياتنا،",
            "لكن هذا الجسر المصنوع من حزم أغصان الصفصاف الأحمر",
            "هو الجسر الذي سنتذكره دائماً.",
            "",
            "إنه يتمايل تحت أحذيتنا العسكرية،",
            "هذا الجسر الذي بنيناه بأيدينا",
            "من الأخشاب الوحيدة في الصحراء،",
            "شجرة الصفصاف الحمراء التي لا تقهر.",
            "",
            "الليلة يعبرون جسر الصفصاف الأحمر مرة أخرى،",
            "متجهين إلى موقع السد،",
            "متجهين نحو المستقبل."
          ]
        },
        {
          "id": "poem-1-12",
          "title": "اشرب هذا الوعاء من مياه ثلوج تيانشان المذابة",
          "lines": [
            "كان الجنود القدامى يستقبلوننا بهذه الطريقة،",
            "يرحبون بالمجندين الجدد الذين جاؤوا لغزو الصحراء؛",
            "اشرب هذا الوعاء من مياه ثلوج تيانشان المذابة،",
            "صافٍ كالكريستال، وبارد كقلب الجبل.",
            "",
            "هذا هو نبيذنا، ونخب ترحيبنا —",
            "ليس نبيذ العنب، ولا نبيذ الأرز،",
            "بل أنقى مياه على وجه الأرض،",
            "تتدفق مباشرة من النهر الجليدي",
            "إلى شفتيك المشتقتين.",
            "",
            "اشرب — وكن واحداً منا."
          ]
        },
        {
          "id": "poem-1-13",
          "title": "ينادونك بـ \"أوزة الحصاد البرية\"",
          "lines": [
            "تحلقين فوق أحزمة الحماية، وفوق الحقول المخططة،",
            "وبحر قربانتونغوت يثير الغيوم والأمواج؛",
            "أنتِ تجيبين على تحيتي الدافئة",
            "بأزيز محركك،",
            "يا أوزة الحصاد البرية،",
            "أيتها الجرارة والحصادة،",
            "أيها الطائر الميكانيكي الرائد،",
            "الذي يجلب الحبوب."
          ],
          "annotations": [
            {
              "term": "丰收的鸿雁",
              "note": "诗中比喻将丰收喜讯带往远方的使者，化用「鸿雁传书」的典故融入兵团屯垦场景。"
            }
          ]
        },
        {
          "id": "poem-1-14",
          "title": "تخمير حياة حلوة كالعسل",
          "lines": [
            "الواحة تتلألأ كأحجار الكريستال،",
            "وبينما يجهز النحالون خلاياهم لرحلة الجنوب.",
            "ينتقلون كل خريف مع النحل،",
            "ملاحقين الأزهار عبر الجبال.",
            "",
            "يخمرون حياة حلوة كالعسل،",
            "هؤلاء البدو رُحل الحلاوة،",
            "وهؤلاء الملاحقون للأزهار،",
            "الذين يعرفون كل وادٍ",
            "من طعم رحيقه."
          ]
        },
        {
          "id": "poem-1-15",
          "title": "آه، يا أجراس الإبل المجلجلة",
          "lines": [
            "لم نكد نجد وقتاً لحديث نابع من القلب",
            "حتى انطلقوا من جديد؛",
            "آه، يا أجراس الإبل المجلجلة",
            "لفريق الإصلاح المتنقل،",
            "يعبر الصحراء بقطع الغيار والشحوم،",
            "ورشة متنقلة",
            "على ظهر جمل.",
            "",
            "في شساعة جونغار،",
            "حتى مهام الإصلاح تتطلب رحلة."
          ]
        },
        {
          "id": "poem-1-16",
          "title": "الرمال تضرب صدغي أنور",
          "lines": [
            "الرمال تضرب صدغي أنور،",
            "الرمال تضرب تنورة أنور،",
            "الصحراء ذات اللون البني الرمادي تمتد بلا نهاية.",
            "",
            "تمشي في مواجهة الريح",
            "وكأن الريح لا شيء،",
            "هذه الفتاة الأويغورية التي اختارت البقاء",
            "عندما اختار الآخرون الرحيل.",
            "",
            "يتطاير وشاح رأسها خلفها",
            "كراية شجاعة هادئة."
          ]
        },
        {
          "id": "poem-1-17",
          "title": "أُداعب برفق أمواج بحر الصحراء الشاسعة",
          "lines": [
            "أمَسِّح برفق على أمواج بحر الصحراء الشاسعة،",
            "هنا، وبكل خشوع، ألقي تحية الاحترام على الأطلال.",
            "أين قمر سلالة تشين؟",
            "وأين نيران إنذار سلالة هان؟",
            "",
            "تحت أقدامي يكمن تاريخ",
            "من القوافل والفاتحين،",
            "ومن المدن التي نهضت وسقطت",
            "كأمواج في محيط الرمال هذا.",
            "",
            "أُداعب الصحراء برفق",
            "وأشعر بألفي عام من خطوات الأقدام."
          ],
          "annotations": [
            {
              "term": "瀚海",
              "note": "指古尔班通古特沙漠或广义的大漠戈壁。古诗中常以「瀚海」指代北方大漠。"
            }
          ]
        },
        {
          "id": "poem-1-18",
          "title": "المشي نحو العاصفة الرملية في أرض أجنبية بعيدة — حلم الرائد",
          "lines": [
            "أشجار حور تتمايل،",
            "مياه ثلوج مندلعة،",
            "الأفق العائم؛",
            "",
            "في أرض أجنبية بعيدة، يمشي نحو العاصفة الرملية،",
            "يحلم الرائد بمدينة",
            "لا وجود لها بعد،",
            "بطرق ما تزال مسارات للإبل،",
            "بحدائق ما تزال صحراء.",
            "",
            "لكن الحلم حيّ جداً",
            "لدرجة أنه يشم رائحة أزهار المشمش",
            "ويسمع جرس المدرسة يقرع",
            "في المدينة التي ستنهض",
            "من الرمال التي تحت قدميه."
          ],
          "annotations": [
            {
              "term": "拓荒者",
              "note": "Pioneers (tuōhuāngzhě) — soldiers who became farmers, reclaiming desert land for agriculture in the Xinjiang Production and Construction Corps."
            }
          ]
        },
        {
          "id": "poem-1-19",
          "title": "توديع هذه الأطلال في الوقت الراهن",
          "lines": [
            "توديع هذه الأطلال في الوقت الراهن،",
            "دعني أحلّق بأجنحة الخيال.",
            "لا يمكن استحلاب المطر من الغيوم هنا،",
            "لذا سنحفر القنوات عوضاً عن ذلك.",
            "",
            "في الصحراء، يحفر الحالمون.",
            "توديع الأطلال",
            "يعني استقبال المستقبل،",
            "وبالمجرفة في اليد."
          ]
        },
        {
          "id": "poem-1-20",
          "title": "ياقوتة زرقاء مرصعة في الواحة الرائدة",
          "lines": [
            "يتأمل المسافر من سفينته في صحراء غوبي،",
            "ياقوتة زرقاء مرصعة في الواحة الرائدة؛",
            "هل من الممكن أن تكون بحيرة صيرم البعيدة قد تدحرجت إلى هنا؟",
            "",
            "لا — هذا خزان مياه،",
            "حُفر باليد، ومُلئ بمياه الثلوج المذابة،",
            "جوهرة صنعناها بأنفسنا",
            "في الإطار البني للصحراء."
          ]
        },
        {
          "id": "poem-1-21",
          "title": "تلك أمي تلوح بذراعيها",
          "lines": [
            "من رسم مسحة من دخان الطهي في مساء الصحراء؟",
            "الشمس الغاربة تطفو على البحيرة حيث تلمع الثعابين الذهبية؛",
            "كان ينبغي أن تعود قوارب الصيد الآن —",
            "",
            "تلك أمي تلوح بذراعيها",
            "من على ضفة خزان المياه الجديد،",
            "تنادي أطفالها للعودة لتناول العشاء،",
            "كما تفعل الأمهات",
            "منذ أن أُشعلت أول نار."
          ]
        },
        {
          "id": "poem-1-22",
          "title": "منسوجة بخيوط عديدة من المشاعر العميقة",
          "lines": [
            "يخفي الليل التاج الكريستالي الثلجي المهيب لجبال تيانشان،",
            "ويخفي أمواج مياه الثلوج المندفعة،",
            "ويخفي القارب الآلي الرشيق.",
            "",
            "لكنه لا يستطيع إخفاء الأغاني",
            "المنسوجة بخيوط عديدة من المشاعر العميقة،",
            "والمتصاعدة من الثكنات،",
            "أغاني الوطن والشوق،",
            "أغاني تسافر أبعد من الضوء",
            "عبر ظلام الحدود."
          ]
        },
        {
          "id": "poem-1-23",
          "title": "آه، يا له من امتداد واسع لضباب الصباح الأزرق الفاتح",
          "lines": [
            "انزلق القمر من سماء الغسق،",
            "وانزلقت النجوم من سماء الغسق،",
            "آه، يا له من امتداد واسع لضباب الصباح الأزرق الفاتح.",
            "",
            "الصحراء عند الفجر",
            "هي بلد آخر تماماً،",
            "بارد ولطيف وأزرق،",
            "قبل أن تصل الشمس",
            "بمطرقتها الذهبية."
          ]
        },
        {
          "id": "poem-1-24",
          "title": "التحديق عبر المزواة",
          "lines": [
            "رصد طائر يحلق على ارتفاع منخفض،",
            "رصد الشتلات الخضراء،",
            "التحديق عبر المزواة؛",
            "",
            "يرسم المساح خريطة المستقبل",
            "بأخذ القياسات قياساً تلو الآخر،",
            "ويخطط الطرق والقنوات وخطوط الكهرباء",
            "عبر طبيعة لم تعرف",
            "سوى الرياح والرمال",
            "لألف عام."
          ]
        },
        {
          "id": "poem-1-25",
          "title": "الطائر الصغير مرتدياً تاجاً طويلاً من الريش",
          "lines": [
            "بعد أن حلقت للتو فوق هذا القفار البني،",
            "وبعد أن وصلت للتو إلى واحة المستقبل هذه،",
            "تمشط مياه ثلوج تيانشان ريشك؛",
            "",
            "أيها الهدهد الصغير، أيها الرسول المتوَّج،",
            "لقد وصلت قبل الأشجار،",
            "وقبل الحدائق والظلال،",
            "وكأنك تعرف",
            "ما كنا نبنيه",
            "وأردت أن تكون الأول."
          ]
        },
        {
          "id": "poem-1-26",
          "title": "فقط للتنافس من أجل الربيع",
          "lines": [
            "أين اختبأ القمح الشتوي الأخضر؟",
            "أين اختبأت أحزمة الحماية الرمادية الفضية؟",
            "لقد ابتلعت أمواج العاصفة الثلجية الواحة التي طورناها،",
            "",
            "لكن ذلك فقط حتى الربيع —",
            "فقط حتى الربيع،",
            "حينما ينفجر اللون الأخضر من الأبيض",
            "كصرخة نصر،",
            "وحين تظهر أحزمة الحماية مجدداً",
            "ويقف القمح من جديد،",
            "فقط للتنافس من أجل الربيع."
          ]
        },
        {
          "id": "poem-1-27",
          "title": "المطاردة على طول مسار الرياح",
          "lines": [
            "صحراء قربانتونغوت مهيبة كالبحر،",
            "والسماء الصافية زرقاء كلون الأزوريٹ؛",
            "نفحة الريح لا يمكنها الهروب من العين اليقظة،",
            "",
            "فهؤلاء كشافة تثبيت الرمال،",
            "يطاردون على طول مسار الرياح،",
            "ويزرعون العشب وشجيرات الطرفاء",
            "في آثار أقدام الرياح،",
            "ويصطادون الكثبان الرملية في شباك خضراء",
            "من تصميمهم الخاص."
          ]
        },
        {
          "id": "poem-1-28",
          "title": "'النقطة أ — النقطة أ...'",
          "lines": [
            "الكثبان السمراء تلتقي بالسماء السمراء،",
            "قارب وحيد يبحر في بحر الصحراء الهائج؛",
            "ولحن أغنية مسيرة يطوف في الهواء،",
            "",
            "والمساح ينادي بإحداثياته",
            "'النقطة أ — النقطة أ...'",
            "يحدد الموقع",
            "الذي ستقف فيه مدرسة،",
            "أو مستشفى،",
            "أو حديقة بها أشجار وضحكات أطفال،",
            "بعد عشرين عاماً —",
            "أو بعد خمسين —",
            "'النقطة أ — النقطة أ...'"
          ]
        },
        {
          "id": "poem-1-29",
          "title": "حبات الثلج المتفتحة قد ذبلت بالفعل",
          "lines": [
            "حبات الثلج المتفتحة قد ذبلت بالفعل،",
            "ذبلت بصمت من السماء المعلقة على مستوى منخفض؛",
            "تتساقط على خزان الصحراء الصلب — قمم تيانشان الجليدية،",
            "",
            "ليتم تخزينها وحفظها",
            "من أجل الصيف الطويل الحار،",
            "وحين تشرب القنوات مياه الأنهار الجليدية",
            "وتحمل عذوبتها الباردة",
            "نزولاً إلى الحقول،",
            "نزولاً إلى البساتين،",
            "نزولاً إلى الحلم الأخضر",
            "الذي يبنيه الشتاء بهدوء."
          ]
        }
      ]
    },
    {
      "id": "chapter-2",
      "title": "المجلد الثاني: الجنرال والمدينة",
      "poems": [
        {
          "id": "poem-2-1",
          "title": "مات قبل الفجر",
          "lines": [
            "مات قبل الفجر،",
            "الجنرال الذي بنى المدينة،",
            "الذي حول الجنود إلى بنائين وفلاحين،",
            "الذي قال: 'لن نغادر هذا المكان'.",
            "",
            "تَصاعَدَ نَفَسه الأخير",
            "كدخان نار مخيم تنطفئ،",
            "والمدينة التي بناها",
            "استمرت من دونه،",
            "وفاضت شوارعها بنور الصباح."
          ],
          "annotations": [
            {
              "term": "黎明前",
              "note": "此组诗写新疆解放前夕为革命牺牲的先烈。「黎明前」既指时间，亦喻新疆和平解放（1949年9月）前最黑暗的时刻。"
            }
          ]
        },
        {
          "id": "poem-2-2",
          "title": "لقد أصبحت هي أيضاً إشارة موجية ذهبية داكنة",
          "lines": [
            "سافرت إشارتها اللاسلكية خارج الغرفة الصغيرة،",
            "عبر ليل تيانشان،",
            "عبر تشويش المسافات —",
            "لقد أصبحت هي أيضاً إشارة موجية ذهبية داكنة،",
            "هذه المرأة من الحدود،",
            "والتي بثت قراءات الطقس",
            "ومواقع القوات",
            "ورسائل الحب",
            "عبر طنين أثير الصحراء وطقطقته."
          ]
        },
        {
          "id": "poem-2-3",
          "title": "أضاء بروميثيوس ستارة الليل الثقيلة",
          "lines": [
            "أضاء بروميثيوس ستارة الليل الثقيلة —",
            "أم تُراه كان الكهربائي القادم من شاندونغ",
            "والذي مد أول خط كهرباء",
            "عبر صحراء قربانتونغوت،",
            "جالباً النور الكهربائي",
            "إلى مكان لم يعرف",
            "سوى الشموع ونيران المخيمات والنجوم؟",
            "",
            "أضاء بروميثيوس ستارة الليل الثقيلة،",
            "وطرفت الصحراء بعينيها",
            "في دهشة متناهية."
          ],
          "annotations": [
