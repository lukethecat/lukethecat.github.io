[
    {
        "id": "hanxuema-soul",
        "lines": [
            "诗魂还在奔驰",
            "突然想到要写一首诗",
            "当然是豪壮的",
            "是一首战争诗",
            "确只以挥动骑刀的手",
            "匆匆抚摩了一下腰中的诗囊"
        ],
        "source": "《汗血马》· 诗魂还在奔驰",
        "author": "李瑜"
    },
    {
        "id": "hanxuema-wild-poppy",
        "lines": [
            "她再也没有看到那枚",
            "载着她童心的红叶了",
            "她面前的伊犁河",
            "没有那枚载着她童心的红叶",
            "只有野罂粟的落英",
            "虽然也是红色的"
        ],
        "source": "《汗血马》 · 野罂粟",
        "author": "李瑜"
    },
    {
        "id": "zhungaer-bonfire-night",
        "lines": [
            "夜也不平静，生命都在滋长，",
            "欢腾的雪浪是准噶尔跳跃的血浆；",
            "苞谷拔节的声音这么清脆，",
            "惊走了调皮的小鹿、胆小的黄羊。"
        ],
        "source": "《准噶尔诗草》 · 卷之一：飘动的篝火",
        "author": "李瑜"
    }
]