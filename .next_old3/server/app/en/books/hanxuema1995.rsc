","6",{"className":"min-h-[1.5em] ","children":"Where the fortress fell"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"A caravanserai will stand"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Where soldiers bled"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Merchants will bargain"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"On this path where silk once gleamed"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"A young city is about to rise"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"As cities always do"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"On the graves of older cities"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"On the road that never dies"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Small Lonely Fortress"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}]]]}],["$","div","chapter-15",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"Emerald-Green Yarkand"}],[["$","article",null,{"id":"poem-15-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Carrying That Lamp / Of Holy Oil from Jerusalem"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Carrying that lamp"}],["$","p","1",{"className":"min-h-[1