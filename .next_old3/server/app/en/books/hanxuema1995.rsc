n-h-[1.5em] ","children":"Would write more history"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Than the sword that captured him"}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Listen — the Talas River still whispers"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"The sound of water over paper"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"The sound of a world transforming"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"One sheet at a time"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","O, the Battle of Talas"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-13-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"A Blue-Brown Speck of Light / Sweeping Across the Chaotic Earth and Chaotic Sky"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"A blue-brown speck of light"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Sweeping across the chaotic earth and chaotic sky"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"A rider fleeing the battlefield"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Carrying in his saddlebag"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Not gold, not jade"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"But a wooden printing block"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Carved with characters"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"That spell a Buddhist sutra"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"He rides through the night"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Through the carnage and the smoke"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"This fragment of civilization"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Clutched to his chest"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Like a child"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"A blue-brown speck of light"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Sweeping across the vast darkness"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Of an empire in retreat"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"But the characters survive"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"The sutra survives"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"The written word survives"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"Everything"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","O, the Battle of Talas"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-13-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, the Crescent Moon and Morning Star / The Crescent Moon and Morning Star of Islam"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"After Talas, the crescent moon rose"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Over the western reaches of the Silk Road"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"O, the crescent moon and morning star"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"The crescent moon and morning star of Islam"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Where Buddhist temples had stood"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Mosques would rise"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Where Sanskrit was chanted"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Arabic would be spoken"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Not conquest — but gradual change"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Like the slow turning of a river"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"The faith came with merchants"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Not with armies"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"And the Silk Road went on"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Under new banners"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"With new prayers"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"But the same camel bells"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"The same starlight"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"The same human longing"}],["$","p","21",{"cl