,"7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"As though a hundred thousand armored men"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"A mournful, desolate melody flows"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Through the pass, through the corridor"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Through the thirty years of exile"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"He died within a month of his return"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"As though his body had been waiting"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Only for the sight of home"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Beacon-Fires Have Died"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-8-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Already Locked in Close Combat / Killing in Silence"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"After Ban Chao left, the beacons dimmed"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"The small garrisons grew smaller"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Already locked in close combat"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Killing in silence"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Without his presence"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"The Western Regions fractured"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Kingdom by kingdom"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Like a string of jade beads"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Whose thread has snapped"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"The silence after Ban Chao"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Was louder than any battle"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"The silence of an empire retreating"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"From the world's edge"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Beacon-Fires Have Died"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-8-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Morning Star Is Fading / The Beacon-Fires Have Died"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The morning star is fading"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"The beacon-fires have died"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Along the road from Dunhuang to Kashgar"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Only wind moves now"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"The watchtowers crumble"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Their smoke signals long extinguished"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"The sentries have gone home"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Or been buried in the sand"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"But the road remains"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Worn into the earth by centuries"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Of silk and jade and spice"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Of armies and monks and merchants"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"The morning star is fading"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"But it will rise again"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"As it has always risen"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Over the passes of the Pamir"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Over the plains of Central Asia"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"The beacon-fires have died"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"But the road endures"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"The road endures"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"The Silk Road endures"}],["$","p","25",{"className":"min-h-[1.5em] ","children":"One flame at a time"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","ch