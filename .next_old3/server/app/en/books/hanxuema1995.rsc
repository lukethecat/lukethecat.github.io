","p","2",{"className":"min-h-[1.5em] ","children":"Every stone a story"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Every ruin a chapter"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"In the longest poem ever written"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"By geography and time"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Who in the Western Regions Does Not Know Thee?"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-21-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Clouds Obscure the Tianshan Moon / You Softly Wipe Away Your Tears"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Clouds obscure the Tianshan moon"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"You softly wipe away your tears"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"For this land that has seen"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"So much courage and so much sorrow"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"So much silk and so much blood"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Who in the Western Regions Does Not Know Thee?"]}],"$undefined"]}],["$","p",null,{"className":"