thousand years"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Waves of the Tarim River"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-10-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Anaerguli on Horseback / Gazing into the Distance"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Anaerguli on horseback"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Gazing into the distance"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The Uyghur girl rides along the canal"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"That the Han soldiers dug"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"She does not know their names"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"But drinks the water they channeled"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Eats the fruit of trees"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Whose ancestors they planted"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"The Tarim flows on"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Carrying all their stories"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Han and Uyghur, soldier and farmer"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"All drinking from the same river"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"All gazing at the same moon"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Waves of the Tarim River"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-10-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Still Gazing Down / Still Gazing Down"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"From the cliffs above the Tarim"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"The carved Buddha gazes down"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Still gazing down"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Still gazing down"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"He has seen the armies come and go"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"The caravans laden with jade"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"The monks chanting sutras"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The farmers planting wheat"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Still gazing down"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"With the same serene smile"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"At the river that never stops"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"At the desert that never sleeps"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"At the road that never ends"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Two thousand years of gazing"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"And still the world turns"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Beneath his stone eyes"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"The Tarim flows on"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"The waves of the Tarim River"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Carry all"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"Carry all"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Waves of the Tarim River"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}]]]}],["$","div","chapter-11",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"The Mendicant Who Crossed the Border in Secret"}],[["$","article",null,{"id":"poem-11-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Is This the Night at the Frontier? / So Hushed and Still"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Is this the night at the frontier?"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"So hushed and still"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Only the distant call of a night bird"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"And the rustle of sand grains shifting"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Xuanzang pressed his body against the cold earth"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"A fugitive from his own empire"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"A monk who dared defy the emperor's ban"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"On leaving the realm"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"His crime: to seek the truth"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"His weapon: a walking staff"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"His armor: faith"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"In a land beyond the horizon"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Mendicant Monk"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Mendicant Monk — referencing the Tang Dynasty monk Xuanzang (602–664). Because he left China illegally in defiance of an imperial travel ban to seek Buddhist scriptures, he was, initially, a stowaway mendicant."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gr