m] ","children":"'How far did you walk?'"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Gan Ying calculated in his mind:"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"From Luoyang to here — forty thousand li"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Seven years of walking"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Through every kingdom between"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"'I have walked,' he said,"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"'From where the sun rises to where it begins to set.'"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"The king laughed"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"And poured him wine"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"Dark as the Persian Gulf"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"Fragrant as a road without end"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Dark-Blue Persian Gulf"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-9-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Wind from the Zagros Mountains, Damp / Blowing toward Him with a Briny Tang"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":["The wind from the ",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"Zagros Mountains — a major mountain range in western Iran, stretching from the Persian Gulf to eastern Turkey, acting as a natural barrier on the Silk Road to Mesopotamia.","children":["Zagros Mountains",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],", damp"]}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Blowing toward him with a briny tang"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Carried whispers of the sea beyond"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"He could almost smell Rome"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Could almost see its marble columns"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Rising from the foam"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"But the Parthians would not let him cross"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"They held the middle of the road"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"The brokers of silk and glass"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Who profited from the distance"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Between East and West"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[