text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"A Dark-Brown Wild Poppy Has Withered / Yet Its Petals Still Release a Heady Fragrance"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"A dark-brown wild poppy has withered"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Yet its petals still release a heady fragrance"}],["$","p","2",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Time has turned the crimson to brown"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Yet cannot erase the perfume"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"She pressed the petals between the pages"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Of a letter she would send to Chang'an"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"But there was no courier to the east"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"No wild goose that far"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"So the fragrance stayed"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Stayed in the valley of the Ili"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Stayed in the windswept steppe"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Even now, two thousand years later"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Wild Poppies"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-3-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Before Her, the Ili River / Has No Trace of That Crimson Leaf That Carried Her Childhood Heart"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"On the day she left Chang'an"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"A child pressed a red leaf into her hand"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"She placed it on the water of the Wei River"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"And watched it drift westward"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Through the Hexi Corridor"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Through the Jade Gate Pass"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Across deserts she had never imagined"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The leaf in her memory kept drifting"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"She never saw that leaf again —"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"That red leaf carrying her childhood heart"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Before her, the Ili River"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Has no trace of that crimson leaf"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Only the fallen petals of wild poppies"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Though they too are red"}],["$","p","16",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","17",{"className":"min-h-[1.5em] ","children":"The Wusun king is old"}],["$","p","18",{"clas