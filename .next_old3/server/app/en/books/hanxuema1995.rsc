":"min-h-[1.5em] ","children":"But the memory of silk"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"The memory of a road"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"That once connected"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Every civilization on earth"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Emerald-Green Yarkand"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}]]]}],["$","div","chapter-16",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"The Silent Liupan Mountains"}],[["$","article",null,{"id":"poem-16-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Shooting into the Deep Forest / Shooting at the Terrified Quarry"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Genghis Khan hunted in these mountains"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Shooting into the deep forest"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Shooting at the terrified quarry"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"The greatest conqueror the world had known"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Paused here, in the Liupan Mountains"}],["$","p","6",{"c