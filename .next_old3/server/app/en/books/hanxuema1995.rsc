t-gray-400 ml-px select-none","children":1}]]}]," licked his cracked lips"]}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Licked the beading blood"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Huo Qubing"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Huo Qubing (140–117 BC) — brilliant young Han general who defeated the Xiongnu at Qilian, securing the Hexi Corridor. He died prematurely at age 24."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Beneath Qilian, Silence Has Fallen"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-2-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Is That the Long-Dreamed Crescent Moon Lake? / The Crescent Lake That Once Graced His Dreams?"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Still galloping"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Into the deep night"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Only the drumming of hooves"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Mingling with the wind's drizzle"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":[["$","span","0",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"Dunhuang — an ancient oasis city at the westernmost end of the Hexi Corridor, a hub of the ancient Silk Road, world-renowned for its Mogao Caves.","children":["Dunhuang",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}]," in March"]}],["$","p","6",{"className":"min-h-[1.5em] ","children":"The wind is still biting"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Iron-grey thickets, not yet budding with elm coins,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Steeped in darkness, sweep past"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Wave-like iron-grey dunes sweep past"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Their outlines so faint"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"The night sky, too, is iron-grey"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Wild pigeons startle into flight"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Those startled pigeons are iron-grey too"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"The beating of their wings fades in an instant"}],["$","p","16",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Ahead, a crescent moon rises"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"In the iron-grey night sky"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Glimmering with a pale, spectral light"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Is that the Crescent Moon Lake he has long dreamed of?"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"The crescent lake that once graced his dreams?"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Dunhuang"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Dunhuang — an ancient oasis city at the westernmost end of the Hexi Corridor, a hub of the ancient Silk Road, world-renowned for its Mogao Caves."]}]]}],["$","li","1",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[2,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Crescent Lake"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Crescent Lake (Yueyaquan) — located at the foot of the Mingsha Mountains in Dunhuang, named for its crescent moon shape, historically praised as 'the first spring in the desert'."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Beneath Qilian, Silence Has Fallen"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-2-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Carrier Pigeon Circled Hurriedly for a Moment / Then Flew Eastward"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The soldier had just fallen"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"When he hastily tore open his black tunic"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"A carrier pigeon rose from his breast"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"His hot blood"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Had already stained the white plumage crimson"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Still glistening wet"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Skimming past the steeds that galloped by the soldier"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Past the sand-grains lifted like mist"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Past the overcast sky, dull as sand"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Soaring upward"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Lying face-up on the embattled earth"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Iron cavalry thundering across his body"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Like storm clouds sweeping before his eyes"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"His clenched hands go slack"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Yet his eyes still gaze at the vast heavens"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"The carrier pigeon circled hurriedly for a moment"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Then flew eastward"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"Across the reflection in his pupils — of flashing blades and gleaming swords —"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"It cast a dark-brown shadow"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Beneath Qilian, Silence Has Fallen"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-2-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, Son of the Tianshan / Torrent of Snow-Melt"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"In the spring breeze"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"The young general's crimson cloak"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Rises like a red cloud from the saddle"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Even the retreating enemy riders turn to look —"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"As though a red lotus had bloomed"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"On the darkened horizon"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"O, son of the Tianshan"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Torrent of snow-melt"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Even the Qilian Mountains tremble"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"At the war drum in your breast"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Four hundred leagues of wilderness spring into green"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"In the wake of galloping hooves"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Beneath Qilian, Silence Has Fallen"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-2-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"His Phantom-Like Black Steed / Stands Frozen as a Statue Beneath Qilian"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Beneath Qilian, silence has fallen"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"His phantom-like black steed"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Stands frozen as a statue beneath Qilian"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Beneath Qilian, all is silent"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"He still gazes at the icy peak before him"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"So crystalline and cool"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"As though that peak were his eternal monument"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"He still gazes at the grasslands before him"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Boundless as the sea"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"As though those grasslands were his eternal bed"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"The wind whispers against his crimson cloak"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Like the rustling of silk banners"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Like the murmur of his mother's lullaby"}],["$","p","16",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","17",{"className":"min-h-[1.5em] ","children":"He was only twenty-four when he"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Let the reins slip from his fingers"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Only twenty-four"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"When he closed his eyes for the last time"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"But the war drum in his breast still thunders"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"Thunder upon thunder"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"Resounding through the Hexi Corridor"}],["$","p","25",{"className":"min-h-[1.5em] ","children":"Through the vast deserts and grasslands of the Western Regions"}],["$","p","26",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","27",{"className":"min-h-[1.5em] ","children":"His phantom-like black steed"}],["$","p","28",{"className":"min-h-[1.5em] ","children":"Still stands beneath Qilian"}],["$","p","29",{"className":"min-h-[1.5em] ","children":"Like a sculpture"}],["$","p","30",{"className":"min-h-[1.5em] ","children":"Motionless as a mountain"}],["$","p","31",{"className":"min-h-[1.5em] ","children":"The earth is silent"}],["$","p","32",{"className":"min-h-[1.5em] ","children":"Beneath Qilian, silence has fallen"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Beneath Qilian, Silence Has Fallen"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-2-6","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Standing in the Wine-Sweet, Dark-Gold Sunset / Standing in the Future Bazaars of the Silk Road"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The setting sun paused a moment before slipping away"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Still gilding the young general's bronze cheeks"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The wind-worn, time-struck features of his face"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Still bore the flush of that last battle"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"His war horse bent down to drink from the spring"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Ripples spread across the water"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Like the silk road unfurling toward the west"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}]