6",{"className":"min-h-[1.5em] ","children":"And thought of the sea"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Of burning ships and burning opium"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Of an empire that punished him for being right"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"No wonder the mountains hide"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Even they are ashamed"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Of what the court has become"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Frontier's Devoted Son Weeps in Anguish"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-20-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Beneath the Frontier Moon / A Gleaming Arrow Flies Swift"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Beneath the frontier moon"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"A gleaming arrow flies swift"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Lin Zexu's will was an arrow"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Shot from exile toward justice"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"He would never see Canton again"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"He 