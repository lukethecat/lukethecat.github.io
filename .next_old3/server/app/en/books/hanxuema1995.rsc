","p","6",{"className":"min-h-[1.5em] ","children":"By deserts the Venetian had never imagined"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"By bazaars more magnificent"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Than the markets of the Rialto"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"In emerald-green Yarkand"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"West met East not once"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"But endlessly"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Century after century"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Merchant after merchant"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Emerald-Green Yarkand"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-15-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"And There Is Yarkand's / Iron Cross of St. John's Church Towering High"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"And there is Yarkand's"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Iron cross of St. John's Church towering high"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Above the minarets"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Above the Buddhist stupas"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p