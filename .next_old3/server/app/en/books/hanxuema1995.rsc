rom his blood-stained hand"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Across the Gobi"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Across the Yellow River"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Across the years"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"And Chang'an heard"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"And remembered"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"A man it had given up for dead"}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"When Su Wu walked through the city gates at last"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"White-haired, thin as a ghost"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Still clutching his bare staff"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"The emperor wept"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"The ministers wept"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"The common people lined the streets and wept"}],["$","p","25",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","26",{"className":"min-h-[1.5em] ","children":"Not because he was a hero"}],["$","p","27",{"className":"min-h-[1.5em] ","children":"But because he had simply"}],["$","p","28",{"className":"min-h-[1.5em] ","children":"Refused to forget"}],["$","p","29",{"className":"min-h-[1.5em] ","children":"Who he was"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children"