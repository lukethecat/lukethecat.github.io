n",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Yangguan Pass — a Han Dynasty border fortress southwest of Dunhuang, an essential checkpoint on the southern route of the Silk Road. Made famous by Wang Wei's poem 'West of Yangguan is no old friend'."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","In the Vast Yarkand"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-7-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"That Ash-Brown Horizon / Moving Slowly Forward"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"That ash-brown horizon"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Moving slowly forward"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"As the camel train advances"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Through the shimmer of heat"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"The road stretches on"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Beyond what the eye can hold"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Beyond what the heart can bear"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"She looks back once"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"At the towers receding into dust"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"At the land she will never see again"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Then forward, only forward"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Through the ash-brown haze"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Into the unknown kingdom"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Of Khotan"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","In the Vast Yarkand"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-7-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Crescent Moon Above the Great Mosque / May Also Glow with a Pale, Mysterious Radiance"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The crescent moon above the great mosque"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"May also glow with a pale, mysterious radiance"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Above the minarets of Yarkand"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Where silk and jade have made"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"A city of many faiths"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"A crossroads of prayers"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"In every tongue that travels the road"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"The muezzin calls at dusk"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"And the silk weavers pause"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Their shuttles stilled"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Beneath the crescent moon"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"In the vast Yarkand"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","In the Vast Yarkand"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-7-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"That Song Dissolves into the Waves of the Yarkand River / And the Symphony of Rustling Mulberry Groves"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"She taught them to unwind the cocoon"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Thread by thread, patient as prayer"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The women of Khotan learned quickly"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Their dark fingers nimble on the loom"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"From the mulberry groves that she had planted"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"The silkworms spun their golden thread"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"And Khotan silk, they say,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Rivaled even Chang'an's finest"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"That song dissolves into the waves"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Of the Yarkand River"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"And the symphony of rustling mulberry groves"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Where every leaf remembers"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"A princess far from home"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Century after century"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"The looms of Khotan wove on"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Until the sand swallowed them"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"And only the song remained"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"Drifting in the desert wind"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Like a silk thread unraveling"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","In the Vast Yarkand"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-7-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Amber Glow of Silk / Shining in King Axihan's Amber-Colored Dream"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"King Axihan of Khotan"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Stood at his city gate"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Gazing east toward the shimmering road"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"He had asked for a bride from the Han court"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"And they had sent him a princess"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"With a secret sewn into her crown"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The amber glow of silk"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Shining in Axihan's amber-colored dream"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"A vision of his kingdom"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Draped in luminous thread"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"When the crown was opened"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"And the tiny eggs were found"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"He did not punish her"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"He thanked her"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"For she had brought not just herself"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"But an entire civilization's craft"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"Wrapped in love and cunning"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"The mulberry groves spread across Khotan"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"The silkworms multiplied"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"And the Silk Road earned its name"}],["$","p","25",{"className":"min-h-[1.5em] ","children":"Not from merchants alone"}],["$","p","26",{"className":"min-h-[1.5em] ","children":"But from a princess"}],["$","p","27",{"className":"min-h-[1.5em] ","children":"Who dared to smuggle dreams"}],["$","p","28",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","29",{"className":"min-h-[1.5em] ","children":"At the foot of the Kunlun Mountains"}],["$","p","30",{"className":"min-h-[1.5em] ","children":"The silk still gleams"}],["$","p","31",{"className":"min-h-[1.5em] ","children":"In the amber light of sunset"}],["$","p","32",{"className":"min-h-[1.5em] ","children":"In the Yarkand River's last reflection"}],["$","p","33",{"className":"min-h-[1.5em] ","children":"Before the desert drinks it dry"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Asikhan"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Asikhan — the legendary King of Khotan (Yutian) who married the Silk Princess that smuggled the silkworm seeds from the Central Plains."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Hors