ildren":"But they press on"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Through Kazakhstan's vast emptiness"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Through snow that swallows everything"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Through winds that strip the skin"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"The Kyrgyz steppe still sleeps"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"But the Torghut do not sleep"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"They walk through the night"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Toward the morning star"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","O, the Morning Star"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-19-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Wooden Wheels of the Cart / Turning Slowly Eastward"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The wooden wheels of the cart"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Turning slowly eastward"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Creaking like old bones"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Like the prayer wheels of their temples"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Each revolution"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"One li closer to home"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"One li farther from exile"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"The wooden wheels turn"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Through snow and mud and memory"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Through seven months of march"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Toward the Ili Valley"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","O, the Morning Star"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-19-6","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, the Waves of Lake Balkhash / Have Long Surged in a Distant, Ethereal Dream"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"O, the waves of Lake Balkhash —"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Have long surged in a distant, ethereal dream"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"And now they surge before their eyes"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Blue and real and weeping with light"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"They have crossed half of Eurasia"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"From the Volga to Lake Balkhash"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Seventy thousand surviving"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"From one hundred and seventy thousand"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"The emperor received them"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"At the Ili River"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"With ceremony and provisions"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"And a place to call home"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"O, the morning star"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"That guided them through the darkest nights"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Now sets in the east"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Where the sun is rising"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Over the Ili Valley"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"Over the Tianshan"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Over the homeland"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"They had dreamed of"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"For a century"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"In exile"}],["$","p","25",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","26",{"className":"min-h-[1.5em] ","children":"The greatest migration in modern history"}],["$","p","27",{"className":"min-h-[1.5em] ","children":"Written not in ink"}],["$","p","28",{"className":"min-h-[1.5em] ","children":"But in blood and snow"}],["$","p","29",{"className":"min-h-[1.5em] ","children":"And the turning"}],["$","p","30",{"className":"min-h-[1.5em] ","children":"Of wooden wheels"}],["$","p","31",{"className":"min-h-[1.5em] ","children":"Toward the morning star"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","O, the Morning Star"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}]]]}],["$","div","chapter-20",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"The Frontier's Devoted Son Weeps in Anguish"}],[["$","article",null,{"id":"poem-20-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"This Moon / Floating on the Dark-Blue Surface of Lake Balkhash"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"This moon"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Floating on the dark-blue surface of Lake Balkhash"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Is the same moon that shone on Lin Zexu"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"When the emperor sent him into exile"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"In the Western Regions"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"The man who burned the opium"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Who defied the British Empire"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Now walks the irrigation canals of Xinjiang"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"A disgraced official"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Doing the work of a common laborer"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"But even in exile"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"He served"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Surveying the land"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Planning canals"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Planting trees"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"This moon witnessed"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"A loyal subject's punishment"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"And a loyal subject's unbroken spirit"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Frontier's Devoted Son Weeps in Anguish"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-20-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Rubbing a Page / Of the Ancient Western Regions' Historical Scroll"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Rubbing a page"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Of the ancient Western Regions' historical 