ny who sail never return.'"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"He gazed at the dark-blue water"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"The waves that separated him from Rome"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"From the western edge of the Silk Road"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"From the empire that wore the silk"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"His own people had woven"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"He turned back"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"The farthest envoy China had sent"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Almost — almost — touching Rome"}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"97 AD"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"The year a Chinese man"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Stood at the Persian Gulf"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"And could go no farther"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Gan Ying"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Gan Ying — a Han military envoy dispatched by Ban Chao in 97 AD to establish contact with Da Qin (the Roman 