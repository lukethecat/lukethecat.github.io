tory and defeat"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"The light, urgent sound of hoofbeats"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Has long since faded"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"But the rustle of paper"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Continues"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Continues"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Across every desk"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"In every study"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"In every civilization"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"That Talas touched"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","O, the Battle of Talas"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}]]]}],["$","div","chapter-14",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"The Small Lonely Fortress"}],[["$","article",null,{"id":"poem-14-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Three Hundred Warriors in Headlong Flight / Still Riding Eastward"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The three hundred warriors in headlong flight"}],["$","p","1",{"cl