.5em] ","children":"So deeply that he must leave it"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"To bring back something greater"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Mendicant Who Crossed the Border in Secret"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-11-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Graceful Flying Apsara / Scatters Rose Petals Damp with Dew"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"At the Mogao Caves he prayed"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Before the painted apsaras"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The graceful flying apsara"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Scatters rose petals damp with dew"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Their scarves floating in painted wind"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Their smiles eternal on the sandstone walls"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"They seemed to say: Go."}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The road is long but the truth is worth it."}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"He lit a candle in the darkness"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"And touched his forehead to the cold stone floor"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Then rose"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"And walked into the desert"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Into the starless night"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Into the unknown"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Toward India"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Toward the sutras"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Toward the light he sensed"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"But could not yet see"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"One thousand three hundred thirty-five volumes"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"He would carry back"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"One by one"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"On the back of a single monk"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","The Mendicant Who Crossed the Border in Secret"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-11-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Yi Yi Yi / This Is a Cloud Damp with Mist"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":