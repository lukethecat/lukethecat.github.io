ame":"min-h-[1.5em] ","children":"Where did the water go?"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"The lake that once mirrored the Kunlun peaks"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Now only salt crystals"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Cracking like the bones of fish"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"The poplar forests still stand"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Hollow and skeletal"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Dead a thousand years but still upright"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"As though waiting for the water to return"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":[["$","span","0",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"Loulan — an ancient Silk Road kingdom near Lop Nur that mysteriously vanished around the 4th century AD primarily due to desertification and changing river courses.","children":["Loulan",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":4}]]}]," vanished in an instant —"]}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Not by sword or fire"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"But by the slow turning of a river's course"}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"Even empires cannot command"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"The path water chooses"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Even prayers cannot summon"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"Rain from an empty sky"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Lop Nur"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Lop Nur — once a vast salt lake in eastern Xinjiang, now a completely dry lake bed. It was the site of the ancient Loulan ruins and later China's nuclear testing ground."]}]]}],["$","li","1",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[2,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Desert Poplar"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Desert Poplar (Populus euphratica) — a highly drought and salt-resistant deciduous tree found around the Taklamakan Desert. It is said to 'live a thousand years, stand dead for a thousand years, and remain un-rotted for a thousand years'."]}]]}],["$","li","2",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[3,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Tamarisk"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Tamarisk (Red Willow) — a common shrub or small tree in northwestern deserts, highly resistant to salt and drought, serving as a crucial plant for windbreaks and sand fixation."]}]]}],["$","li","3",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[4,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Loulan"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Loulan — an ancient Silk Road kingdom near Lop Nur that mysteriously vanished around the 4th century AD primarily due to desertification and changing river courses."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Loulan Vanished in an Instant"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-5-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"This Seed Gathered from the Forests of Lop Nur / Still Damp with Night Dew"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"This seed gathered from the forests of Lop Nur"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Still damp with night dew"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"He carried it a thousand leagues to the east"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Wrapped in a scrap of Loulan silk"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"If planted in Chang'an's soil"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Would it grow?"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Would it remember the salt-crusted shore?"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The cry of migrating birds?"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"The merchant from Loulan"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Stood at the crossroads of civilizations"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Where silk went west and jade came east"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Where languages tangled in the bazaar"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"He pressed the seed to his cheek"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"It was cool, like the nights by the lake"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Cool, like the skin of his daughter"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Whom he had left behind"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"That daughter now plays"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"Among the ruins of a kingdom"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"That will not be found"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"For another eighteen hundred years"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Loulan Vanished in an Instant"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-5-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, Let the Immortal Sound of Lop Nur's Waves / Echo Forever in the Dreams of the Homeland"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"O, let the immortal sound of Lop Nur's waves"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Echo forever in the dreams of the homeland"}],["$","p","2",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Though the waves have long since stilled"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Though the lake bed crackles underfoot"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Somewhere beneath the salt"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"The memory of water persists"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Like a song the sand refuses to forget"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Like a road the wind cannot erase"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Let the poplar's ghost stand witness"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Let the tamarisk hold the dune in place"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Until the river, in some far century,"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Remembers its old path"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"And flows back to Loulan"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Loulan Vanished in an Instant"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}],["$","article",null,{"id":"poem-5-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Crescent-Shaped Lop Nur / Already Set at the Far Edge of a Distant Sky"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Where the caravans once rested"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Where the jade was weighed and the silk was folded"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Where the storyteller told of mountains to the west"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"And seas beyond those mountains"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Now only wind"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Only the dry rattle of dead branches"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Only the yardang ridges"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Carved by centuries of grit"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Crescent-shaped Lop Nur"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Already set at the far edge of a distant sky"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"No longer a lake"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"But a memory of a lake"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"The explorer from Sweden came"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"And brushed the sand from Loulan's face"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"And the world gasped"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"At the beautiful dead"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"Her eyelashes still perfect"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"After four thousand years beneath the salt"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"The Loulan Beauty"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"Sleeping on"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"In a glass case in Ürümqi"}],["$","p","25",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","26",{"className":"min-h-[1.5em] ","children":"While the wind still blows"}],["$","p","27",{"className":"min-h-[1.5em] ","children":"Over the place she was born"}],["$","p","28",{"className":"min-h-[1.5em] ","children":"Where nothing grows"}],["$","p","29",{"className":"min-h-[1.5em] ","children":"Where nothing stirs"}],["$","p","30",{"className":"min-h-[1.5em] ","children":"But the memory of water and light"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Blood-Sweating Horses","》 · ","Loulan Vanished in an Instant"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1995"]}]]}]]}]]]}],["$","div","chapter-6",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"O, at Lake Baikal Autumn Is Already Deep"}],[["$","article",null,{"id":"poem-6-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Green Flame of the Mountain Pasture / Already Burns in the Herdsman's Heart"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Nineteen years at the shore of the North Sea"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Nineteen years with a staff of withered bamboo"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Its yak-tail pennant long since frayed to nothing"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":[["$","span","0",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"Su Wu — a Han Dynasty envoy (c. 140–60 BC) who was held captive by the Xiongnu for 19 years at Lake Baikal, famously clutching his Han imperial staff and refusing to surrender.","children":["Su Wu",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":2}]]}]," tends his flock of rams"]}],["$","p","5",{"className":"min-h-[1.5em] ","children":["On the frozen shore of ",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"Lake Baikal — the deepest and oldest freshwater lake in the world, located in Siberia. It is the historical \"North Sea\" where Han envoy Su Wu was exiled to tend sheep.","children":["Lake Baikal",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}]]}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Where no envoy comes"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Where no message arrives from the south"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Yet every spring"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"When the ice breaks and the green flame"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Of new grass sweeps across the steppe"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"He feels it burn in his heart too"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"The green flame of the mountain pasture"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Already burns in the herdsman's heart"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Not the heart of a herdsman — no —"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"The heart of a Han envoy"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Who will not yield"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"His robes have rotted to rags"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"His hair has silvered like the birch bark"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"But the staff he carries"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"Though bare of pennant and authority"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"He will not set down"}],["$","p","25",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","26",{"className":"min-h-[1.5em] ","children":"Nineteen years"}],["$","p","27",{"className":"min-h-[1.5em] ","children":"The lake has frozen and thawed nineteen times"}],["$","p","28",{"className":"min-h-[1.5em] ","children":"And still he waits"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"classN