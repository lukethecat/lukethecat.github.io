-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"To Weave the Spring Colors of the Frontier"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"'To weave the spring colors of the frontier' —"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"She said that was why she came,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"A girl from the silk factories of Suzhou,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Who traded her loom for a shovel."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"She plants flowers along the canal bank,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Marigolds and hollyhocks,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Bright against the brown earth,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Weaving a different kind of silk:"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"The colors of spring"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"On the frontier's rough cloth."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-8","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"A Green Melody Flows"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"A green melody flows"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Through the newly planted shelter belt,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The wind playing the poplars like a flute,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Each tree a note in the score."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"I listen with my eyes closed"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"And hear the future:"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"A city's worth of shade,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"A province's worth of calm,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"All flowing from this green melody"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"That began as a seedling"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"In a soldier's hand."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-9","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, Please Don't Leave Me"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"O, please don't leave me,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Not now, not when the cotton is about to bloom,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Not when the reservoir is nearly full,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Not when we've almost built the life"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"We've been talking about since Lanzhou."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Stay until the poplars are taller than us,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Stay until the road is paved,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Stay until the stars feel less like strangers"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"And more like neighbors."}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"O, please don't leave me."}],["$","p","12",{"className":"min-h-[1.5em] ","children":"The desert is wide enough for two."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-10","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"That Is a Wheel Sent Flying by a Sharp Dune"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"That is a wheel sent flying by a sharp dune,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Bouncing across the sand"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Like a small, ridiculous moon."}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"The truck groaned and tilted,"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"And the supplies scattered:"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Cans of paint, rolls of wire,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"And love letters"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"From the mail bag,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Tumbling in the sand"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Beneath the indifferent sky."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-11","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, Those Dark-Blue Snow Waves"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"O, those dark-blue snow waves"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Crashing down from the Tianshan at dusk,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Carrying the cold breath of the glacier"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Into the warm valley below."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Standing in the snow waves' mist,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"I think of you,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Your dark-blue cotton dress,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Your hair loose in the wind,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Your laughter like the water —"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Cold and bright and rushing."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Snow Waves"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Snow Waves — referring to the visual of snowmelt streams plunging from the Tianshan Mountains into the desert margins. It serves as a striking metaphor for vitality and impassioned emotion."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-12","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"She Walked Away, Smiling Gracefully"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"She walked away, smiling gracefully,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Down the poplar-lined road,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Her suitcase in one hand,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Her future in the other."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"She did not look back —"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Or if she did,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"The poplars hid her face."}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"She walked away smiling,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"As though leaving were easy,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"As though the desert"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Had not already"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Written its name"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"On her heart."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-13","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"I Am Going to Where She Lives"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"I am going to where she lives,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Past the dunes and the dry riverbeds,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Past the red willow stands,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Past the survey markers"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"And the half-built road."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"I am going to where she lives,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"In the new settlement south of the ridge,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Where she teaches twenty children"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"In a schoolroom made of mud brick."}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"I am going to where she lives."}],["$","p","12",{"className":"min-h-[1.5em] ","children":"The desert is only fifty kilometers."}],["$","p","13",{"className":"min-h-[1.5em] ","children":"For love, Baghdad is not too far."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-14","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"I Gently Stroke This Blood-Red Gobi Stone"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"I gently stroke this blood-red Gobi stone,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Polished by a million years of wind,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Small as a heart,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Warm from the afternoon sun."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"I will give it to her"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Instead of a ring."}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"On the frontier"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"We do not have jewelers,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"But we have the desert,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"And the desert makes"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Its own gems."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-15","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Walking in Silence"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Walking in silence"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Through the Gurbantünggüt at dusk,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The sand still warm beneath my feet,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"The sky turning colors"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"That have no name in any language."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Walking in silence"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Because some feelings"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Are too large for words,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Too wide for the mouth,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"And must be carried"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"In the chest,"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"In the stride,"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"In the silence itself."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-16","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, in My Heart There Is a Moon That Never Sets"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"O, in my heart there is a moon that never sets,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"A moon that shines when the sky is overcast,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"A moon that glows in the sandstorm,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"A moon that follows me"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"From dugout to field to canal bank."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"I do not need"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"The moon above the Tianshan,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"For I carry my own moon,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Bright with the memory of her face,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Full every night,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Never waning."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-17","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Brook Flows through the Dark-Blue Night"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The brook flows through the dark-blue night,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"A silver thread in the darkness,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Carrying the sound of the glacier"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Down to the sleeping fields."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"I sit beside it and remember:"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"How she dipped her feet in this water,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"How she laughed when the cold shocked her,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"How she said: 'Even the water here"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Tastes like adventure.'"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"The brook flows on"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Through the dark-blue night,"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Carrying her laughter with it"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Eastward, always eastward."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-18","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"I Can Do without the Moon in the Sky"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"I can do without the moon in the sky,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"I can do without the rain from the clouds,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"I can do without the letters from home."}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"But I cannot do without"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"The thought of you,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Standing in the doorway"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Of the mud-brick schoolhouse,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The chalk still on your fingers,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Teaching twenty children"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"How to write the word 'spring'"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"In a land of perpetual winter."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-19","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Those Deep Echoes from the Nights of First Love"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Those deep echoes from the nights of first love"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Still reverberate in the desert air,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"In the spaces between the dunes,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"In the gaps between the stars."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"We were young then,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"As young as the saplings we planted,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"As green as the wheat we watered,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"As foolish as the nightingale"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Who sings to an empty desert."}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Those deep echoes"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Have never stopped."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-20","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Bird That Heralds the Dawn"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The bird that heralds the dawn"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Sits on the highest branch"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Of the tallest poplar in the shelter belt,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"And sings."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Not a nightingale this time,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"But a lark,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Bright-voiced and common,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The bird of ordinary mornings,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Of coffee and bread and work."}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"The bird that heralds the dawn"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Sings not of love"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"But of the beautiful routine"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Of days that follow days"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"On the frontier."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-21","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Though It Is the Same Kind of Sadness"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Though it is the same kind of sadness"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"As the night the train pulled away,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"It is a gentler sadness now,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Worn smooth by years,"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Like a Gobi stone in the hand."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"I have learned to live with it,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"This sadness that is also gratitude,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"This longing that is also memory,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"This absence that is also presence,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Here, in the desert,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Where everything is far away"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"And nothing is forgotten."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-22","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Like a Mournful Nightingale Flying toward Me"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Like a mournful nightingale flying toward me,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"The memory of her returns"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"On every desert evening,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"On every crescent moon."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"I open my arms to catch it,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"This dark bird of memory,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"And hold it to my chest,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"And listen to its song:"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"For love, Baghdad is not too far."}],["$","p","11",{"className":"min-h-[1.5em] ","children":"For love, no distance is too great."}],["$","p","12",{"className":"min-h-[1.5em] ","children":"For love, the desert is not a desert"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"But a garden waiting for rain."}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Like a mournful nightingale flying toward me,"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"She returns and returns,"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"And I, who stayed,"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Am the richer for it."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume IV: For Love, Baghdad Is Not Too Far"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}]]]}]]]}]]}]
