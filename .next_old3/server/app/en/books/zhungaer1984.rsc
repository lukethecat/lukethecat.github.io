in-h-[1.5em] ","children":"Now under the dune we dream a green dream,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"A dream of orchards and canals,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Of schools and clinics,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Of children who will know"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Only the green of things growing,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Not the brown of the march."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume I: The Flickering Campfire"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-11","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Tonight They Cross the Red Willow Bridge Again"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"We once crossed stone bridges,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"We once crossed single-plank bridges;"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"How many bridges we have crossed in a lifetime,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"But this bridge of bundled red willow branches"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Is the one we will remember."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"It sways beneath our boots,"}],["$","p","7",{"className":"m