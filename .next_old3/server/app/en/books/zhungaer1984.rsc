ie for Spring"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Where has the green winter wheat hidden?"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Where have the silver-grey shelter belts hidden?"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The snowstorm's waves have swallowed the oasis we developed,"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"But only until spring —"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Only until spring,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"When the green will burst from the white"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Like a shout of triumph,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"And the shelter belts will reappear"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"And the wheat will stand again,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Only to vie for spring."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume I: The Flickering Campfire"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-27","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Chasing along the Trail of the Wind"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The Gurbantünggüt is as solemn as the sea,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"The cloudless sky is clear azurite blue;"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"A wisp of wind cannot escape the watchful eye,"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"For these are sand-fixation scouts,"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Chasing along the trail of the wind,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Planting grass and tamarisk"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"In the wind's own footprints,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Trapping the dunes in green nets"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Of their own devising."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume I: The Flickering Campfire"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-28","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"'Point A — Point A...'"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Tawny dunes meeting tawny sky,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"A lone boat sailing the surging desert sea;"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The melody of a marching song drifts on the air,"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"And the surveyor calls out his coordinates"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"'Point A — Point A...'"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Marking the spot"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Where a school will stand,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Or a hospital,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Or a park with trees and children's laughter,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"In twenty years —"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"In fifty —"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"'Point A — Point A...'"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume I: The Flickering Campfire"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-29","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Blooming Snowflakes Have Already Withered"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The blooming snowflakes have already withered,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Silently withered from the low-hanging sky;"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Falling on the desert's solid reservoir — the Tianshan's icy peaks,"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"cla