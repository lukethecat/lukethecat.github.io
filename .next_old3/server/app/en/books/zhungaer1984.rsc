"children":"The fishing boats should have returned by now —"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"That is Mother waving her arms"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"From the shore of the new reservoir,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Calling her children home for dinner,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"As mothers have done"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Since the first fire was lit."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume I: The Flickering Campfire"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-22","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Woven with So Many Threads of Deep Feeling"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Night hides the majestic crystal snow-crown of the Tianshan,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"And hides the surging snowmelt waves,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"And hides the nimble motor-sailboat."}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"But cannot hide the songs"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Woven with so many threads of deep feeling,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Rising from the barracks,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Songs of home and longing,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Songs that travel farther than light"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Through the darkness of the frontier."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume I: The Flickering Campfire"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-23","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, What a Vast Stretch of Pale Blue Morning Mist"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The moon has slipped from the dusky sky,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"The stars have slipped from the dusky sky,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"O, what a vast stretch of pale blue morning mist."}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"The desert at dawn"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Is another country entirely,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Cool and gentle and blue,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Before the sun arrives"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"With its golden hammer."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border