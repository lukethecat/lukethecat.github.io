me":"min-h-[1.5em] ","children":"The night was long,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"The cold was deep,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"But dawn came, as it always comes,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"With the rooster's cry and the kettle's steam,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"And the first light on the Tianshan snow."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume II: The General and the City"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Arriving in Haste from Afar"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Arriving in haste from afar,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Boots still dusty from the Hexi Corridor,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The new volunteers step off the truck"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Into the blinding light of Junggar."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"They have come from Sichuan, from Hunan,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"From the green hills of Zhejiang,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"To this brown, flat, enormous nowhere"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"That will become their home."}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Arriving in haste from afar"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"With nothing but youth"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"And the government's promise"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Of land."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume II: The General and the City"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-6","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"An Emerald River Flows"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"An emerald river flows"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Through the heart of the new city,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"A canal dug by ten thousand hands"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"From the Tianshan glacier to the cotton fields."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Where once only camels drank,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Now children swim and splash,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"And willows line the banks"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Of this manufactured miracle,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"This emerald river"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"That flows because someone"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Decided it would."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume II: The General and the City"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-7","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"That Dreamland of Life Longed for in Visions"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"That dreamland of life longed for in visions"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Is no longer a vision:"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The cotton fields stretch to the horizon,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"The poplars stand in soldier-straight rows,"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"The school bell rings at eight."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"This was the dream —"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Not of conquest,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"But of cultivation,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Not of empire,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"But of a life worth living"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"On the edge of the world."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume II: The General and the City"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-8","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Deep Affection Has Melted into the Growth Rings of History"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Deep affection has melted into the growth rings of history,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Each ring a year of toil,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"A year of planting and harvesting,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"A year farther from the war,"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"A year closer to ordinary life."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Count the rings of the poplar trees"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"That line the streets of the new city:"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Each ring is a generation,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Each generation a prayer answered."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex j