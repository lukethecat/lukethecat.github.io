n land, walking into the sandstorm,"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"The pioneer dreams of a city"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"That does not yet exist,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Of roads that are still camel tracks,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Of gardens that are still desert."}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"But the dream is so vivid"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"He can smell the apricot blossoms"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"And hear the schoolbell ringing"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"In the city that will rise"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"From the sand beneath his feet."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Pioneers"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Pioneers (tuōhuāngzhě) — referring to the soldiers and youth who became farmers, reclaiming barren desert wastelands for agriculture within the Xinjiang Production and Construction Corps."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volum