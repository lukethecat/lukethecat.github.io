 ","children":"Bringing in the grain."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Swan Geese of Harvest"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Swan Geese of Harvest — a poetic metaphor serving as messengers bringing news of a bumper crop to distant families, adapting the ancient motif of 'swan geese carrying letters' to the modern reclamation context."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume I: The Flickering Campfire"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-14","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Brewing a Life Sweet as Honey"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"The oasis gleams crystalline,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"As the beekeepers ready their hives for the southern journey."}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Each autumn the