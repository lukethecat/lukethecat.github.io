-h-[1.5em] ","children":"A forest floating in the desert,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"An impossible garden"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Rooted in faith."}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"A green cloud drifts from the distance,"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"And the poet, seeing it,"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Weeps."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verses from Junggar","》 · ","Volume III: A Poet in the Gurbantünggüt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-3-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Nocturne of Silk Road Camel Bells Still Sways..."}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"At the heart of the Gurbantünggüt,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Where the ancient northern route once passed,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":["The nocturne of ",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"Silk Road — the ancient network of trade routes connecting China to Central and West Asia, and Europe, named for the Chinese silk that was heavily traded westward.","children":["Silk Road",["$","sup",null,{"className":"text-xs text-gray-400 ml-px sel