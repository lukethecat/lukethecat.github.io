"text-xs text-gray-400 ml-px select-none","children":1}]]}],","]}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Die Grenze hat genug Stille;"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Danke, dass du sie brichst"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Mit deiner kleinen, wilden Stimme."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Nachtigall"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Nachtigall – eine Singvogelart, die häufig im Gestrüpp der roten Weiden Xinjiangs vorkommt. Bei Li Yu ein zentrales lyrisches Medium der Liebe."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Die sanften, unaufhörlichen Regentropfen"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Die sanften, unaufhörlichen Regentropfen"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Fallen auf das Blechdach des Unterstands,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Ein Rhythmus weich wie ein Wiegenlied,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Weich wie ihre Stimme, als sie sagte:"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"„Ich werde auf dich warten.“"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Regen in der Wüste ist ein Wunder,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"So selten wie die Liebe,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Und ebenso willkommen."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Das ist eine Mondsichel hinter der Düne"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Das ist eine Mondsichel hinter der Düne,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Die wie eine silberne Wimper aufsteigt"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Über der braunen Stirn des Sandes."}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","childr