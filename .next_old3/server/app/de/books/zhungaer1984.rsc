}]]}]," entzündete den schweren Vorhang der Nacht,"]}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Und die Wüste blinzelte"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"In blankem Erstaunen."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Prometheus"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Prometheus – der Tytan, der das Feuer brachte. Der Dichter verwendet ihn als Metapher für die revolutionären Pioniergestalten Chinas, die Licht nach Xinjiang brachten."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band II: Der General und die Stadt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Man muss durch die Nacht gehen, um das Ufer der Morgendämmerung zu erreichen"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Man muss durch die Nacht gehen, um das Ufer der Morgendämmerung zu erreichen —"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Das war das Motto"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Jeden Pioniers an der Grenze,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Jeden zum Bauern gewordenen Soldaten,"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Jeder Frau, die ihrem Regiment folgte"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"In den Sand."}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Die Nacht war lang,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Die Kälte war tief,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Doch die Dämmerung kam, wie sie immer kommt,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Mit dem Ruf des Hahns und dem Dampfen des Kessels,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Und dem ersten Licht auf dem Schnee des Tianshan."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band II: Der General und die Stadt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"In Eile von weit her eintreffend"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"In Eile von weit her eintreffend,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Die Stiefel noch staubig vom Hexi-Korridor,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Steigen die neuen Freiwilligen aus dem Lastwagen"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"In das blendende Licht von Junggar."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Sie sind aus Sichuan gekommen, aus Hunan,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Von den grünen Hügeln Zhejiangs,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"In dieses braune, flache, riesige Nirgendwo"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Das ihr Zuhause werden wird."}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"In Eile von weit her eintreffend"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Mit nichts als Jugend"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Und dem Versprechen der Regierung"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Auf eigenes Land."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band II: Der General und die Stadt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-6","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Ein smaragdgrüner Fluss fließt"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Ein smaragdgrüner Fluss fließt"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Durch das Herz der neuen Stadt,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Ein Kanal, gegraben von zehntausend Händen"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Vom Tianshan-Gletscher hin zu den Baumwollfeldern."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Wo einst nur Kamele tranken,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Schwimmen und spritzen nun Kinder,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Und Weiden säumen die Ufer"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Dieses künstlichen Wunders,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Dieses smaragdgrünen Flusses,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Der fließt, weil jemand"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Sich dafür entschied."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band II: Der General und die Stadt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-7","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Jenes in Visionen ersehnte Traumland des Lebens"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Jenes in Visionen ersehnte Traumland des Lebens"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Ist nicht länger eine Vision:"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Die Baumwollfelder erstrecken sich bis zum Horizont,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Die Pappeln stehen in soldatengeraden Reihen,"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Die Schulglocke läutet um acht."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Dies war der Traum —"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Nicht von Eroberung,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Sondern von Kultivierung,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Nicht vom Imperium,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Sondern von einem lebenswerten Leben"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Am Rande der Welt."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band II: Der General und die Stadt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-8","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Tiefe Zuneigung ist in die Jahresringe der Geschichte geschmolzen"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Tiefe Zuneigung ist in die Jahresringe der Geschichte geschmolzen,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Jeder Ring ein Jahr voller Mühen,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Ein Jahr des Pflanzens und Erntens,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Ein Jahr weiter fort vom Krieg,"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Ein Jahr näher am gewöhnlichen Leben."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Zähle die Ringe der Pappeln"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Die die Straßen der neuen Stadt säumen:"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Jeder Ring ist eine Generation,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Jede Generation ein erhörtes Gebet."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band II: Der General und die Stadt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-2-9","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Jene smaragdgrünen Zinnen"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":["Jene smaragdgrünen ",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"Zinnen – hier eine Metapher: Die schützenden Pappeln und Weiden symbolisieren die neuen Lebensräume, die die Soldaten als Festungen aus dem Nichts erschufen.","children":["Zinnen",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}]," —"]}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Nicht aus Stein, sondern aus Pappel und Weide —"}],["$","p","2",{"clas