n der anderen."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Sie blickte nicht zurück —"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Oder falls doch,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Verbargen die Pappeln ihr Gesicht."}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Sie ging lächelnd davon,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Als wäre Gehen einfach,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Als hätte die Wüste nicht"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Schon längst ihren Namen"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"In ihr Herz geschrieben."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-13","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Ich gehe dorthin, wo sie lebt"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Ich gehe dorthin, wo sie lebt,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Vorbei an den Dünen und den trockenen Flussbetten,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Vorbei an den Ständen roter Weiden,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Vorbei an den Vermessungsmarkierungen"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Und der halbfertigen Straße."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Ich gehe dorthin, wo sie lebt,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"In die neue Siedlung südlich des Kamms,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Wo sie zwanzig Kinder unterrichtet"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"In einem Klassenzimmer aus Lehmziegeln."}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Ich gehe dorthin, wo sie lebt."}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Die Wüste ist nur fünfzig Kilometer weit."}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Für die Liebe ist Bagdad nicht zu fern."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-14","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Ich streichle sanft diesen blutroten Gobi-Stein"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Ich streichle sanft diesen blutroten Gobi-Stein,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Poliert durch eine Million Jahre Wind,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Klein wie ein Herz,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Warm von der Nachmittagssonne."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Ich werde ihn ihr geben"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Anstelle eines Rings."}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"An der Grenze"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Haben wir keine Juweliere,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Doch wir haben die Wüste,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Und die Wüste schafft"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Ihre eigenen Edelsteine."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-15","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Walking in Silence"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Walking in silence"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Through the Gurbantünggüt at dusk,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The sand still warm beneath my feet,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"The sky turning colors"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"That have no name in any language."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Walking in silence"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Because some feelings"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Are too large for words,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Too wide for the mouth,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"And must be carried"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"In the chest,"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"In the stride,"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"In the silence itself."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-16","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, in meinem Herzen gibt es einen Mond, der niemals untergeht"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"O, in meinem Herzen gibt es einen Mond, der niemals untergeht,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Ein Mond, der scheint, wenn der Himmel bedeckt ist,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Ein Mond, der im Sandsturm glüht,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Ein Mond, der mir folgt"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Von Erdunterstand zu Feld zu Kanalufer."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Ich brauche den Mond über dem Tianshan nicht,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Denn ich trage meinen eigenen Mond,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Hell mit der Erinnerung an ihr Gesicht,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Jede Nacht voll,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Niemals abnehmend."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-17","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Der Bach fließt durch die dunkelblaue Nacht"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Der Bach fließt durch die dunkelblaue Nacht,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Ein silberner Faden in der Dunkelheit,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Der den Klang des Gletschers"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Hinab in die schlafenden Felder trägt."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Ich sitze daneben und erinnere mich:"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Daran, wie sie ihre Füße in dieses Wasser tauchte,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Wie sie lachte, als die Kälte sie erschreckte,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Wie sie sagte: „Selbst das Wasser hier"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Schmeckt nach Abenteuer.“"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Der Bach fließt weiter"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Durch die dunkelblaue Nacht,"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Und trägt ihr Lächeln mit sich"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Nach Osten, immer nach Osten."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-18","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Ich kann ohne den Mond am Himmel auskommen"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Ich kann ohne den Mond am Himmel auskommen,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Ich kann ohne den Regen aus den Wolken auskommen,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Ich kann ohne die Briefe von zu Hause auskom