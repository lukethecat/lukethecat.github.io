ken zwischen den Sternen."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Wir waren damals jung,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"So jung wie die Setzlinge, die wir pflanzten,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"So grün wie der Weizen, den wir bewässerten,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"So närrisch wie die Nachtigall"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Die für eine leere Wüste singt."}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Jene tiefen Echos"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Haben nie aufgehört."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-20","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Der Vogel, der den Morgengrauen ankündigt"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Der Vogel, der den Morgengrauen ankündigt"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Sitzt auf dem höchsten Ast"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Der stärksten Pappel im Schutzwaldstreifen,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Und singt."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Dieses Mal keine Nachtigall,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Sondern eine Lerche,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Mit heller Stimme und ganz gewöhnlich,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Der Vogel alltäglicher Morgenstunden,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Vor Kaffee und Brot und Arbeit."}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Der Vogel, der den Morgengrauen ankündigt"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Singt nicht von Liebe"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Sondern von der wunderschönen Routine"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"Von Tagen, die auf Tage folgen"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"An der Grenze."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-21","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Auch wenn es dieselbe Art der Traurigkeit ist"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Auch wenn es dieselbe Art der Traurigkeit ist"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Wie in der Nacht, als der Zug abfuhr,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Ist es nun eine sanftere Traurigkeit,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Von den Jahren glatt getragen,"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Wie ein Gobi-Stein in der Hand."}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Ich habe gelernt, mit ihr zu leben,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Dieser Traurigkeit, die auch Dankbarkeit ist,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Dieser Sehnsucht, die auch Erinnerung ist,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Dieser Abwesenheit, die auch Präsenz ist,"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Hier in der Wüste,"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Wo alles weit entfernt liegt"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Und nichts vergessen wird."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-22","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Wie eine trauernde Nachtigall, die mir entgegenfliegt"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Wie eine trauernde Nachtigall, die mir entgegenfliegt,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Kehrt die Erinnerung an sie zurück"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"An jedem Wüstenabend,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Bei jeder Mondsichel."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Ich öffne meine Arme, um ihn einzufangen,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Diesen dunklen Vogel der Erinnerung,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Und halte ihn an meine Brust,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Und lausche seinem Lied:"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Für die Liebe ist Bagdad nicht zu fern."}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Für die Liebe ist keine Distanz zu groß."}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Für die Liebe ist die Wüste keine Wüste"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"Sondern ein Garten, der auf Regen wartet."}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"Wie eine trauernde Nachtigall, die mir entgegenfliegt,"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"Kehrt sie wieder und wieder zurück,"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"Und ich, der blieb,"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"Bin reicher dadurch."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"