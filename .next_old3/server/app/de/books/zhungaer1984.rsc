:"Und spüre das Fußstapfen von zweitausend Jahren."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Weites Meer (Hanhai)"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Hanhai („Weites Meer“) – ein poetischer Begriff der Antike für ausgedehnte Wüsten, symbolisch für das endlose Sandmeer der Wüste Gurbantünggüt."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band I: Das flackernde Lagerfeuer"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-18","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Wandering into the Sandstorm in a Distant Foreign Land — The Pioneer's Dream"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Swaying poplars,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Galloping snowmelt,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The floating horizon;"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"In a distant foreign land, walking into the sandstorm,"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"The pioneer dreams of a city"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"That does not yet exist,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Of roads that are still camel tracks,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Of gardens that are still desert."}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"But the dream is so vivid"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"He can smell the apricot blossoms"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"And hear the schoolbell ringing"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"In the city that will rise"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"From the sand beneath his feet."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"Pioniere"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"Pioniere – bezugnehmend auf die Soldaten, die zu Bauern wurden und die unwirtlichen Wüsten für die Landwirtschaft urbarmachten (im Produktions- und Aufbaukorps Xinjiang)."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["