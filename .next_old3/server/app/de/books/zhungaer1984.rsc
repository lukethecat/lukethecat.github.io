:"min-h-[1.5em] ","children":"Das Lächeln, das sie mir schenkt"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"Ohne sich umzudrehen."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"War das ihr letztes Lächeln für mich?"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"War das ihr letztes Lächeln für mich?"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Der Lastwagen fuhr davon,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Und durch den Staub glaubte ich sie winken zu sehen —"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Oder war es der Wind in den roten Weiden?"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Sie fuhr zurück nach Sichuan,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Zu den grünen Hügeln und den Reisfeldern,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Weg vom Sand und vom Wind,"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Weg von mir."}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"War das ihr letztes Lächeln für mich?"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Ich habe seither die Wüste gefragt,"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"Und die Wüste antwortet nicht."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band IV: Für die Liebe ist Bagdad nicht zu fern"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-4-6","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"O, die Nachtigall in den roten Weiden"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"O, die Nachtigall in den roten Weiden"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Singt jenes Lied, das ich nicht singen kann,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Das Lied eines Mannes, der blieb"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Als die Frau, die er liebte, ging."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"Die Nachtigall kennt keine Einsamkeit,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Doch sie singt, als kenne sie weiche,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"Und lauschend glaube ich beinahe"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"Dass Schönheit und Traurigkeit"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Dasselbe sind."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items