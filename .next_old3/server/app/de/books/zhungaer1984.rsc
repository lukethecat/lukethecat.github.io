-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band I: Das flackernde Lagerfeuer"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-25","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"The Little Bird Wearing a Tall Crown of Feathers"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Just having flown over this brown wasteland,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Just arriving at this future oasis,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The Tianshan snowmelt grooms your feathers;"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"Little hoopoe, crested messenger,"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"You arrived before the trees did,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"Before the gardens and the shade,"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"As though you knew"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"What we were building"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"And wanted to be first."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band I: Das flackernde Lagerfeuer"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs t