",{"className":"min-h-[1.5em] ","children":"Auf dem Rücken eines Kamels"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"In der unermesslichen Weite von Junggar"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Erfordert selbst eine Reparatur eine Reise"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band I: Das flackernde Lagerfeuer"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-16","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"Sand Lashes at Anuer's Temples"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"Sand lashes at Anuer's temples,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Sand lashes at Anuer's skirt,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"The ash-brown desert stretches without end."}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"She walks into the wind"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"As though the wind were nothing,"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"This Uyghur girl who chose to stay"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"When others chose to leave."}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"Her headscarf streams behind her"}]