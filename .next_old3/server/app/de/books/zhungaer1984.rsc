 h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"White peonies,"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"You are the proof"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"That even the desert"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"Has a taste for beauty."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band III: Ein Dichter in der Gurbantünggüt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["Li Yu"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-3-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"In der kalten Nacht, dieses Lagerfeuer entzündend"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"In der kalten Nacht, dieses Lagerfeuer entzündend,"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"Beobachtet der Dichter die Flammen, die sich im Wind neigen,"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"Funken, die spiralförmig der Milchstraße entgegensteigen,"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"Jeder Funke ein Vers,"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","Verse aus Dsungarien","》 · ","Band III: Ein Dichter in der Gurbantünggüt"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","chi