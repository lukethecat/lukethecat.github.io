2:["$","$L8",null,{"book":{"title":"قان تەرلەيدىغان ئاتلار","author":"لى يۈ","year":"1995","chapters":[{"id":"chapter-1","title":"ئاھ، ئوتتۇرا ئاسىيا يېڭى قىتئەسى","poems":[{"id":"poem-1-1","title":"شۇ پارلاق ئوق تېخىچە ئۇچۇۋاتقان بولۇشى كېرەك / يىراق غەربكە قاراپ ئېتىلغان","lines":["قاناقتەك قىزىل پېتىۋاتقان كۈن ئۆلمەكچى،","قارا ئالتۇن رەڭلىك تۈن پەردىسى چۈشمەكچى،","ئەمما جاڭ چيەننىڭ ئوقياسىدىن ئېتىلغان ئوق تېخىچە ئۇچماقتا،","يىراق غەربكە قاراپ، تېخى نامەلۇم يەرلەرگە قاراپ.","","يۈز يىللاپ، مىڭ يىللاپ ئۇچقان ئوق،","تاغلارنى ۋە چۆللەرنى چىكىپ ئۆتتى.","ئۇ بىر يىپەك ئوق،","يەر شارىنىڭ يېرىمىنى بىر-بىرىگە تىككەن."],"annotations":[{"term":"جاڭ چيەن","note":"جاڭ چيەن (م.ب. 164-114-يىللار چامىسى) - خەن سۇلالىسىنىڭ دىپلوماتى ۋە تەكشۈرگۈچىسى، قەيسەرىيىسى بىلەن يىپەك يولى ئېچىپ، غەربىي دىيارغا ئەلچى بولۇپ بارغان باشلامچى."},{"term":"خۇجيا","note":"خۇجيا - قەدىمكى شىمالىي كۆچمەن مىللەتلەرنىڭ قومۇش نەي چالغۇسى، ئاۋازى غېرىبسىنىش ۋە قايغۇلۇق بولۇپ، چېگرا شېئىرىيىتىدە كۆپ قوللىنىلىدۇ."},{"term":"ئۇلۇغ يۆجى","note":"ئۇلۇغ يۆجى - قەدىمكى ئوتتۇرا ئاسىيا كۆچمەن مىللىتى، ئەسلىدە خېشى كارىدورىدا ياشاپ غەربكە كۆچكەن. خەن سۇلالىسى بىلەن بىرلىشىپ ھونلارنى قىسماقچى بولغان."},{"term":"خەن سۇلالىسى تەستىقى","note":"خەن ئەلچىلىك تاياقچىسى - پادىشاھ تەرىپىدىن بېرىلگەن ۋەكىللىك، بامبۇكقا توشقان قۇيرۇقى تىزىلغان بولۇپ ھوقۇققا ۋەكىللىك قىلىدۇ."}]},{"id":"poem-1-2","title":"چىڭ تۇتۇلغان قوللار ئاستا بوشىدى / ياشلانغان كۆزلەر تۇيۇقسىز بۇيرۇلدى","lines":["چەكسىز يايلىق ئۇيقۇغا كەتتى،","قاردىن تاش كىيگەن چىليەن تېغى ئۇيقۇغا كەتتى.","ئەمما جاڭ چيەننىڭ كۆزلىرى ئوچۇق،","چاڭئەننى ئارقىدا قالدۇرۇپ،","يېڭى بىر دۇنياغا يۈزلەندى.","","چىڭ تۇتۇلغان قوللار ئاستا بوشىدى،","ياشلانغان كۆزلەر تۇيۇقسىز بۇيرۇلدى.","خوشلىشىش پەقەت بىر كۆز قىسىشقىلا پاتىدۇ،","تارىخ بولسا ئۇنىڭ ئات تۇياقلىرىدا يېزىلىدۇ."],"annotations":[{"term":"چىليەن تېغى","note":"چىليەن تېغى - گەنسۇ بىلەن چىڭخەي چېگراسىدىكى تاغ، ھون تىلىدا «تەڭرى تېغى» دېگەن مەنىدە بولۇپ، خېشى كارىدورىنىڭ جەنۇبىي توسۇقىدۇر."}]},{"id":"poem-1-3","title":"ئاھ بۈيۈك يۆجى / ئۇ ئون بىر باھار چۈشىدە كۆرگەن مۇقەددەس ماكان","lines":["ئۇنىڭ قانچىلىك ئۇزۇن مىنگەنلىكىنى ئۆزىمۇ بىلمەيدۇ،","تېخىچە مىنىۋاتقانلىقىغىمۇ جەزملەشتۈرەلمەيدۇ.","ئون يىللىق تۇتقۇنلۇق ھاياتى،","ئون يىللىق سۈكۈت ۋە قېچىش.","","ئاھ بۈيۈك يۆجى،","ئۇ ئون بىر باھار چۈشىدە كۆرگەن مۇقەددەس ماكان،","ئاخىرى ئۇنىڭ كۆز ئالدىدا نامايان بولدى،","يىپەكتەك يۇمشاق شەپەق نۇرى ئاستىدا."],"annotations":[{"term":"تاڭ يىفۇ","note":"تاڭ يىفۇ - جاڭ چيەننىڭ سادىق ھون ھەمراھى ۋە يولباشچىسى، ئۇ بىلەن بىللە غەربىي دىيارغا ماڭغان."}]},{"id":"poem-1-4","title":"سالقىن نۇرغا چۆمۈلگەن / كۈندۈز سايىغا تەشنا بولغاندەك","lines":["ئۇ زالىملارچە قىزىغان قۇياش —","ئۆزىنىڭ كۆيدۈرگۈچى ئالتۇن ئوقلىرىنى قاچان قىنىغا سالدى؟","قۇم بارخانلىرى كۈمۈش رەڭگە كىردى،","تۈن كېچە چۆلنى ئۆز قوينىغا ئالدى.","","سالقىن نۇرغا چۆمۈلگەن ھالدا،","كۈندۈز سايىغا تەشنا بولغاندەك،","ئەلچىلەر ئۆتەڭدە ئارام ئالدى."]},{"id":"poem-1-5","title":"يىپەك يولىنىڭ كاشىپى ئات ئۈستىدە تەبەسسۇم قىلدى / غەربكە نەزەر سېلىپ","lines":["خېشى كارىدورىدەك تەر ئەمەس،","بۇرۇلمىلىق چىغىر يولمۇ ئەمەس.","تارىم ئويمانلىقى ئېچىلغان بىر كىتاب مىسالى","جاڭ چيەننىڭ ئالدىدا ياتاتتى.","","يىپەك يولىنىڭ كاشىپى ئات ئۈستىدە تەبەسسۇم قىلدى،","غەربكە نەزەر سېلىپ.","ئۇ پەقەت بىر يولنىلا تاپمىدى،","بەلكى بىر پۈتۈن دۇنيانى تاپتى."],"annotations":[{"term":"خېشى كارىدورى","note":"خېشى كارىدورى - گەنسۇنىڭ غەربىي شىمالىدىكى تار ئۆتكەل، ئوتتۇرا تۈزلەڭلىكتىن غەربىي دىيارغا ئۆتىدىغان بوغۇز يولى."},{"term":"يىپەك يولى","note":"يىپەك يولى - جۇڭگونى ئوتتۇرا ئاسىيا ۋە ياۋروپاغا تۇتاشتۇرىدىغان قەدىمكى سودا يولى تورى، جۇڭگونىڭ يىپەكلىرى نامى بىلەن ئاتالغان."}]}]},{"id":"chapter-2","title":"چىلىيەن تاغ ئاستىدا جىمجىتلىق چۈشتى","poems":[{"id":"poem-2-1","title":"ئۇ كۆزلىرىنى تىكىپ تۇراتتى / يىراقتىكى چىليەن تېغىنىڭ مۇزلۇق چوققىلىرىغا","lines":["تۆمۈر كەلكۈن ئاستا ئاقىدۇ،","بۈيۈك قۇملۇق ئاستا ئاقىدۇ.","خو چۈبىڭنىڭ قوشۇنى","چۆل بورىنىغا يۈزمۇيۈز كېلىۋاتىدۇ.","","ئۇ كۆزلىرىنى تىكىپ تۇراتتى","يىراقتىكى چىليەن تېغىنىڭ مۇزلۇق چوققىلىرىغا،","ياش گېنېرال، ئۆلۈم ۋە شۆھرەت ئارىسىدىكى قىسقا بىر ئۆمۈرنى","ئەڭ ئۇزۇن شېئىر قىلىپ يازدى."],"annotations":[{"term":"خو چيۇبىڭ","note":"خو چيۇبىڭ (م.ب. 140-117) - خەن سۇلالىسىنىڭ ياش ۋە تالانتلىق گېنېرالى، چىليەن تېغىدا ھونلارنى مەغلۇپ قىلغان، 24 يېشىدا ۋاپات بولغان."}]},{"id":"poem-2-2","title":"شۇ چايقاق بۇلاقنىڭ ئۆزى شۇمۇ؟ / ئىلگىرى ئۇنىڭ چۈشلىرىنى بېزىگەن؟","lines":["تېخىچە چاپماقتا","چوڭقۇر كېچىگە قاراپ،","ھىلال ئاي شەكلىدىكى بۇلاق، قۇم ئارىسىدىكى مۆجىزە،","خۇددى چۈشتىكىدەك نامايان بولدى.","","شۇ چايقاق بۇلاقنىڭ ئۆزى شۇمۇ؟","ئىلگىرى ئۇنىڭ چۈشلىرىنى بېزىگەن؟","ئۇنىڭ تاتلىق سۈيى ئاتلارنىڭ ئۇسسۇزلۇقىنى قاندۇردى،","قۇمنىڭ ئىچىدىكى بىر يۇتۇم ئۆمۈر."],"annotations":[{"term":"دۇنخۇاڭ","note":"دۇنخۇاڭ - خېشى كارىدورىنىڭ ئەڭ غەربىدىكى قەدىمكى بوستانلىق شەھىرى، يىپەك يولىنىڭ مۇھىم تۈگۈنى ۋە موگاۋ غارلىرى بىلەن داڭلىق."},{"term":"ئايلىق كۆلچەك","note":"ئايلىق بۇلاق (يۆياچۈەن) - ميڭشا تېغى ئاستىدىكى ھىلال ئاي شەكلىدىكى سۇ بۇلىقى، «قۇملۇقتىكى بىرىنچى بۇلاق» دەپ نام ئالغان."}]},{"id":"poem-2-3","title":"خەۋەرچى كەپتەر بىرئاز ئالدىراش پەرۋاز قىلدى / ئاندىن شەرققە ئۇچتى","lines":["جەڭچى ئەمدىلا يىقىلغاندا،","ئۇ ئالدىراپ ئۆزىنىڭ قارا چەكمىنىنى يىرتتى،","ۋە يۈرىكىنىڭ يېنىدىن كىچىك بىر كەپتەرنى چىقاردى.","","خەۋەرچى كەپتەر بىرئاز ئالدىراش پەرۋاز قىلدى،","خۇننىڭ ئوقلىرىدىن ساقلىنىپ،","ئاندىن شەرققە ئۇچتى،","تىمتاس ئۆلۈمدىن يورۇق ھاياتقا قاپار ئېلىپ بېرىش ئۈچۈن."]},{"id":"poem-2-4","title":"ئاھ، تەڭرىتېغىنىڭ ئوغلى / قار سۈيىنىڭ تاشقىنى","lines":["باھار شامىلىدا","ياش گېنېرالنىڭ قىپقىزىل يېپىنچىسى","ئاھ، تەڭرىتېغىنىڭ ئوغلى، قار سۈيىنىڭ تاشقىنىدەك دولقۇنلايدۇ.","","ياشلىق قانلىرى بۇ تۇپراقنى سۇغاردى،","غەلىبە قاقىر چۆلدە گۈل بولۇپ ئېچىلدى."]},{"id":"poem-2-5","title":"ئۇنىڭ ئەرۋاھتەك قارا سامان ئېتى / چىليەن تېغى ئاستىدا ھەيكەلدەك قېتىپ قالدى","lines":["چىليەن تېغى ئاستىدا تىمتاسلىق ھۆكۈم سۈردى،","ئۇنىڭ ئەرۋاھتەك قارا سامان ئېتى","ئىگىسىز ھالدا ھەيكەلدەك قېتىپ قالدى.","","يىگىرمە تۆت ياش، قالدۇرغان ئىزى مىڭ يىل.","ئات يەنىلا كىشنەيدۇ،","ياش گېنېرالنى ئىزدەپ."]},{"id":"poem-2-6","title":"شاراپتەك تاتلىق، قارا ئالتۇندەك كۈن پېتىش شولىسىدا تۇرۇپ / يىپەك يولىنىڭ كەلگۈسى بازارلىرىدا تۇرۇش","lines":["كۈن پېتىش شولىسى كېتىشتىن بۇرۇن بىر ئاز توختاپ قالدى،","يەنىلا ياش گېنېرالنىڭ مىستەك يۈزلىرىنى ئالتۇن رەڭگە بويىدى.","شاراپتەك تاتلىق، قارا ئالتۇندەك كۈن پېتىش شولىسىدا تۇرۇپ","بىز يىپەك يولىنىڭ كەلگۈسى بازارلىرىنى كۆرەلەيمىز.","خو چۈبىڭنىڭ قىلىچى پارلامدۇ،","ياكى يىپەك جىلۋە قىلامدۇ؟"],"annotations":[{"term":"جيۇچۈەن","note":"جيۇچۈەن - گەنسۇدىكى شەھەر، «ھاراق بۇلىقى» دېگەن مەنىدە بولۇپ، خو چيۇبىڭ ئەسكەرلەرگە تارقىتىلغان ھاراقنى بۇلاققا تۆككەن، دەپ بايان قىلىنىدۇ."}]}]},{"id":"chapter-3","title":"يالغۇز ئاپىيۇن گۈلى","poems":[{"id":"poem-3-1","title":"چېپىۋاتقان ئات تۇياقلىرى ئاستىدا / قىزىلگۈل ياپراقلىرى ئېچىلىدۇ","lines":["ئۇ چوڭقۇر يايلاقتىن چىقىپ كەلدى،","ئېچىلغان قىزىل ۋە زۇمرەت رەڭلىك ياۋا قىزىلگۈللەر ئارىسىدىن.","جىجيەن مەلىكە،","شىيۈنىڭ بورانلىرى ئارىسىدىكى بىر غېرىب چېچەك.","","چېپىۋاتقان ئات تۇياقلىرى ئاستىدا،","قىزىلگۈل ياپراقلىرى ئېچىلىدۇ."],"annotations":[{"term":"كۈنەس","note":"كۈنەس - شىنجاڭنىڭ ئىلى ئوبلاستىدىكى ئېگىز تاغ ئوتلىقى، سۇ ۋە قۇياش نۇرى مول بولۇپ قەدىمكى ئۇسۇن دۆلىتىنىڭ ئەڭ ياخشى يايلىقى ئىدى."},{"term":"شېجۈن مەلىكە","note":"ليۇ شېجۈن مەلىكە - خەن سۇلالىسى مەلىكىسى بولۇپ، ئۇسۇن پادىشاھى (كۈنمو) بىلەن سىياسىي نىكاھ تۈزۈشكە ئەۋەتىلگەن."},{"term":"ئۇسۇن","note":"ئۇسۇن - ئەسلىدىن ئىلى دەريا ۋادىسىدىكى قەدىمكى كۆچمەن پادىشاھلىق، خەن سۇلالىسى بىلەن نىكاھ ئارقىلىق ئىتتىپاقداش بولغان."}]},{"id":"poem-3-2","title":"يەتتىنچى ئاينىڭ كېچىسى / شۇنچە جىمجىت ۋە سۈكۈت ئىچىدە","lines":["يەتتىنچى ئاينىڭ كېچىسى","شۇنچە جىمجىت ۋە سۈكۈت ئىچىدە.","ئىلە دەرياسى بويىدا،","بىر لېنتا يىپەك يەرگە چۈشتى.","چاڭئەننىڭ ئېسىدە قالغانلىرى كۆپ،","ئەمما بۇ قىزنىڭ يۈرىكى يىراقتىكى ۋەتىنىنى ئىستەيدۇ."],"annotations":[{"term":"ئىلى دەرياسى","note":"ئىلى دەرياسى - تەڭرىتېغىدىن بالقاش كۆلىگە قۇيۇلىدىغان مۇھىم دەريا، ئۇسۇن ۋە قازاق مەدەنىيىتىنىڭ بۆشۈكى."}]},{"id":"poem-3-3","title":"قېنىق قوڭۇر رەڭلىك ياۋا قىزىلگۈل سولۇپ كەتتى / ئەمما ئۇنىڭ غۇنچىلىرى يەنىلا خۇش پۇراق چېچىپ تۇرىدۇ","lines":["قېنىق قوڭۇر رەڭلىك ياۋا قىزىلگۈل سولۇپ كەتتى،","ئەمما ئۇنىڭ غۇنچىلىرى يەنىلا خۇش پۇراق چېچىپ تۇرىدۇ.","ۋۇسۈن پادىشاھى قېرىدى،","مەلىكە بولسا كۆز يېشىدا قېرىدى.","ھەر بىر مىسرا شېئىر پۇرايدۇ،","ۋەتەننىڭ يات پۇرىقىنى ئەمەس، بەلكى سېغىنىشنى."]},{"id":"poem-3-4","title":"ئىلە دەرياسى ئالدىدا / ئۇنىڭ بالىلىق يۈرىكىگە يوشۇرۇنغان شۇ قىزىل يوپۇرماقتىن ھېچ بىر ئىز يوق","lines":["چاڭئەندىن ئايرىلغان شۇ كۈنى،","بىر بالا ئۇنىڭ قولىغا قىزىل بىر يوپۇرماق قىسىستۇرۇپ قويدى.","ئەمما ئىلە دەرياسى ئالدىدا،","ئۇنىڭ بالىلىق يۈرىكىگە يوشۇرۇنغان شۇ قىزىل يوپۇرماقتىن ھېچ بىر ئىز يوق.","پەقەت چۈشكەن ياۋا قىزىلگۈل ياپراقلىرىلا بار،","گەرچە ئۇلارمۇ قىزىل بولسىمۇ،","ئۇنىڭ ۋەتەندىكى يوپۇرمىغى ئەمەس."]},{"id":"poem-3-5","title":"ئۇنىڭ «ۋەتەننى سېغىنىش ناداسى» نىڭ قايغۇلۇق مىسرالىرى / يەنىلا سادا بېرىدۇ","lines":["«ئائىلەم مېنى ئاسماننىڭ چېتىگە ياتلىق قىلدى» —","ئۇنىڭ ناخشىسى ئىككى مىڭ يىل بۇرۇندىن سادا قېتىپ كەلگەن.","","«تۇرالغۇم كىز ئۆي، تاملىرى يۇڭدىن،","گۆش يەپ، سۈت ئىچىمىز» —","ئۇنىڭ ناخشىسى تۇپراققا بىللە سىڭىپ كەتكەن،","ھەر بىر ياۋا قىزىلگۈل يىلتىزىغا.","","«سېرىق ئاققۇ بولۇپ ئۇچسامچۇ،","ۋەتىنىمگە قايتىپ قونسامچۇ» —","ئەمما سېرىق ئاققۇ شەرققە ئۇچمىدى،","ئۇ ئىلە دەرياسى ئاسمىنىدا چارلىدى،","تەڭرىتېغى چوققىلىرىدا يىغلىدى.","","ئۇنىڭ «ۋەتەننى سېغىنىش ناداسى» نىڭ قايغۇلۇق مىسرالىرى","يەنىلا سادا بېرىدۇ بىزگە."],"annotations":[{"term":"سېغىنىش ناخشىسى","note":"سېغىنىش ناخشىسى - شېجۈن مەلىكە تەرىپىدىن يېزىلغان قويۇق سېغىنىشنى ئىپادىلەيدىغان بىرىنچى قېتىملىق سىياسىي نىكاھ شېئىرى."},{"term":"سېرىق ئاققۇ","note":"سېرىق ئاققۇ - شېجۈن مەلىكىنىڭ شېئىرىدىكى «سېرىق ئاققۇغا ئايلىنىپ ۋەتىنىمگە قايتسام»، دەپ يېزىلغان قۇش، سېغىنىشنىڭ مەجازى كۆرۈنۈشىگە ئايلانغان."},{"term":"قىزىل ئارداق گۈلى","note":"قىزىل ئارداق گۈلى - قازاق تىلىدا «قىزىل گۈل» دېگەن مەنىدە، ئىلى دەريا ۋادىسىدىكى ياۋا قىزغالدقاق (تېتىتقۇ)نى كۆرسىتىدۇ."}]}]},{"id":"chapter-4","title":"قان تەرلەيدىغان ئاتلار","poems":[{"id":"poem-4-1","title":"ئات ئۈستىدىكى قۇماندان / ئۇنىڭ لەۋلىرىدە ئاچچىق بىر كۈلكە","lines":["ئاتمىش مىڭ كىشىلىك قوشۇن غەربكە يۈرەك شاتلاندۇردى،","كۆپچىلىك ئاڭلاپ باقمىغان بىر دۆلەتكە يۈرۈش قىلدى.","قان تەرلەيدىغان ئاتلارنى ئېلىپ كېلىش ئۈچۈن.","لى گۇاڭلى — قۇمانداننىڭ لەۋلىرىدە ئاچچىق بىر كۈلكە،","چۈنكى ئۇ بىلىدۇ، سەپەرنىڭ باھاسى بەك يۇقىرى."],"annotations":[{"term":"لى گۇاڭلى","note":"لى گۇاڭلى - خەن سۇلالىسى گېنېرالى، دايۈەنگە ئىككى قېتىم ئەسكەر تارتىپ تەرلىسە قان چىقىدىغان ئاتلارنى ئېلىش ئۈچۈن يولغا چىققان."},{"term":"قانتەر ئاتلىرى","note":"قانتەر ئاتلىرى (تەرلەيدىغان قان ئات) - دەرۋازا ۋە فەرغانە ۋادىسىدىن كەلگەن ئەپسانىۋى ئاخال-تېكە ئاتلىرى بولۇپ، چاپقاندا تېرىسىدىن قانغا ئوخشاش تەر ئاقىدۇ."},{"term":"دايۈەن","note":"دايۈەن (فەرغانە) - ئوتتۇرا ئاسىيادىكى قەدىمكى پادىشاھلىق، گۈزەل قانتەر ئاتلىرىنى يېتىشتۈرۈشى بىلەن داڭق چىقارغان."},{"term":"پامىر ئېگىزلىكى","note":"پامىر ئېگىزلىكى - جۇڭگو ۋە ئوتتۇرا ئاسىيانى تۇتاشتۇرىدىغان قەدىمكى يىپەك يولى ئۆتۈشى كېرەك بولغان ئەڭ ئېگىز تەبىئىي توسالغۇ، ئىلگىرى سوڭلىڭ دەپ ئاتالغان."}]},{"id":"poem-4-2","title":"ئاندىن ئادەم كەلكۈنى ئىچىدە تۇيۇقسىز توڭلاپ قالدى / قان تەرلەيدىغان بىر ئات شەكلىدە قاتۇپ قېلىپ، ئاسمانغا قاراپ كىشنىدى","lines":["دايۈەننىڭ دەرۋازىلىرى ئاخىرى ئېچىلدى،","دىپلوماتىيە ئەمەس، بەلكى قىلىچنىڭ كۈچى بىلەن.","ئاندىن ئادەم كەلكۈنى ئىچىدە تۇيۇقسىز توڭلاپ قالدى،","قان تەرلەيدىغان بىر ئات شەكلىدە قاتۇپ قېلىپ، ئاسمانغا قاراپ كىشنىدى.","خۇددى ئۇمۇ بۇ سەپەر ئۈچۈن تۆلەنگەن بەدەلنى بىلىدىغاندەك."]},{"id":"poem-4-3","title":"يىراق غەربكە تەرەپكە / ئۇنتۇلماس غەربكە قاراپ","lines":["غەربكە قاراپ، يىراق غەربكە تەرەپكە،","ئۇنتۇلماس غەربكە قاراپ قايتىش سەپىرى.","ئۈچ مىڭ ئات ۋە بىر چاڭ-توزان دەرياسى.","ھايات قالغانلار ۋە ئۆلگەنلەرنىڭ ئىزلىرى پامىر چوققىلىرىدا ۋە تاكلاماكاندىكى قۇملاردا قالدى."],"annotations":[{"term":"تەكلىماكان قۇملۇقى","note":"تەكلىماكان قۇملۇقى - تارىم ئويمانلىقىنىڭ ئوتتۇرىسىدىكى جۇڭگونىڭ ئەڭ چوڭ قۇملۇقى. ئۇيغۇر تىلىدا «كىرسە چىقالمايدىغان جاي» دېگەن مەنىنى بىلدۈرىدۇ."},{"term":"ئۆزبېك ئېغىزى","note":"ئۆزبېك ۋە پامىر قىرغىزىستان ئارىسىدىكى تاغ ئېغىزى بولۇپ، قەدىمكى يىپەك يولىنىڭ غەربكە چىقىدىغان ئۆتكىلى."},{"term":"ئامۇ دەرياسى","note":"ئامۇ دەرياسى - ئوتتۇرا ئاسىيادىكى ئەڭ ئۇزۇن دەريا. غەربكە كۆچكەندىن كېيىن ئۇلۇغ يۆجى مىللىتى دەل مۇشۇ دەريا ۋادىسىغا ئورۇنلاشقان."}]},{"id":"poem-4-4","title":"ئۇ ئاللىبۇرۇن كۆرەلمەكتە / چاڭئەننىڭ سۈرلۈك ۋە مۇلايىم قەلئەلىرىنى","lines":["ئۇ ئاللىبۇرۇن كۆرەلمەكتە —","ياكى شۇنداق ئويلىماقتا —","چاڭئەننىڭ سۈرلۈك ۋە مۇلايىم قەلئەلىرىنى.","يولدىن ساق قالغان ئاتلارنىڭ ۋە ئەسكەرلەرنىڭ يادنامىسى."],"annotations":[{"term":"خەن ۋۇدى پادىشاھ","note":"خەن ۋۇدى (م.ب. 156-87) - خەن سۇلالىسىنىڭ 7-يۈرۈش پادىشاھى. غەربىي دىيارنى ئېچىپ، يىپەك يولىنى رەسمىي تۇتاشتۇرغان."},{"term":"غەربىي قۇتۇپتىكى تۇلپارلار ناخشىسى","note":"تۇلپارلار ناخشىسى - خەن ۋۇدى پادىشاھ قانتەر ئاتلارنى ئالغاندىن كېيىن ئۆزى يازغان مەدھىيە شېئىرى."}]}]},{"id":"chapter-5","title":"لوۋلان بىر ئاندا يوقالدى","poems":[{"id":"poem-5-1","title":"لوپنۇر كۆلىنىڭ يېنىدا سەجدە قىلىش / ئالىي قۇربانگاھنىڭ گۈلخىنى ئاستىدا سەجدە قىلىش","lines":["لوپنۇر كۆلىنىڭ يېنىدا سەجدە قىلىش،","ئالىي قۇربانگاھنىڭ گۈلخىنى ئاستىدا سەجدە قىلىش.","كروران كوھىنى يوچۇق بىر تىلدا تىلاۋەت قىلىدۇ،","ئۇنىڭ سايىسى تۇزلۇق تۈزلەڭلىكلەرگە سوزۇلغان.","سۇ نەگە كەتتى؟ بىر دەريانىڭ يۆنىلىشى ئۆزگىرىشى بىلەن جەۋھەرلەر غايىب بولدى."],"annotations":[{"term":"لوپنۇر كۆلى","note":"لوپنۇر كۆلى - شىنجاڭدىكى قۇرۇپ كەتكەن غايەت زور كۆل تامى، قەدىمكى كروران شەھىرىنىڭ خارابىسى ۋە يادرو سىناق مەيدانى."},{"term":"توغراق","note":"توغراق دەرىخى - قۇرغاقچىلىق ۋە تۇزغا چىداملىق دەل-دەرەخ. «مىڭ يىل ياشايدۇ، ئۆلگەندىن كېيىن مىڭ يىل يىقىلمايدۇ، يىقىلغاندىن كېيىن مىڭ يىل چىرىمەيدۇ» دەپ ئاتالغان."},{"term":"يۇلغۇن","note":"يۇلغۇن (تۇز ئوتى) - چۆللۈك ۋە قۇملۇقلاردىكى كۆپ ئۇچرايدىغان ياشاش كۈچى كۈچلۈك ئۆسۈملۈك. بوراندىن مۇداپىئە كۆرۈش ۋە قۇمنى مۇستەھكەملەشنىڭ مۇھىم قورالى."},{"term":"كروران","note":"كروران - قەدىمكى يىپەك يولى ۋە لوپنۇر كۆلى بويىدىكى سەلتەنەتلىك پادىشاھلىق. 4-ئەسىردە سەۋەبى نامەلۇم ھالدا تۇيۇقسىز غايىب بولغان."}]},{"id":"poem-5-2","title":"لوپنۇر ئورمانلىقىدىن يىغىلغان بۇ ئۇرۇق / شەبنەم يېشى بىلەن تېخىچە نەم","lines":["لوپنۇر ئورمانلىقىدىن يىغىلغان بۇ ئۇرۇق،","شەبنەم يېشى بىلەن تېخىچە نەم.","ئۇ ئۇنى مىڭ چاقىرىم شەرققە ئېلىپ ماڭدى،","بىر پارچە كروران يىپىكىگە يۆگەپ."]},{"id":"poem-5-3","title":"ئاھ، لوپنۇر دولقۇنلىرىنىڭ ئۆلمەس ساداسى / ۋەتەننىڭ چۈشلىرىدە مەڭگۈ ئەكس ئەتسۇن","lines":["ئاھ، لوپنۇر دولقۇنلىرىنىڭ ئۆلمەس ساداسى","ۋەتەننىڭ چۈشلىرىدە مەڭگۈ ئەكس ئەتسۇن.","گەرچە دولقۇنلار ئاللىقاچان تىنجىپ كەتكەن بولسىمۇ،","سۇنىڭ ئەسلىمىسى تۇز ئاستىدا ساقلانماقتا."]},{"id":"poem-5-4","title":"يېرىم ئاي شەكلىدىكى لوپنۇر / ئاللىبۇرۇن يىراق بىر ئاسماننىڭ چېتىگە چۆكۈپ بولدى","lines":["كارۋانلار ئارام ئالغان يەرلەردە،","قاشتېشى ئۆلچىنىپ، يىپەكلەر قاتلانغان يەرلەردە.","ھازىر پەقەت بورانلا بار.","يېرىم ئاي شەكلىدىكى لوپنۇر،","ئاللىبۇرۇن يىراق بىر ئاسماننىڭ چېتىگە چۆكۈپ بولدى.","كروران گۈزىلى، تۆت مىڭ يىلدىن بېرى تۇز ئاستىدا ئۇخلىماقتا."]}]},{"id":"chapter-6","title":"ئاھ، بايكال كۆلىدە كۈز چوڭقۇرلاشتى","poems":[{"id":"poem-6-1","title":"شىمالىي دېڭىز بويىدا ئون توققۇز يىل / پەقەت كونىراپ كەتكەن خانلىق ھاسىسىلا ئەسلەيدۇ","lines":["شىمالىي دېڭىز بويىدا ئون توققۇز يىل،","ئوت-چۆپ ئۆسمەيدىغان، يازمۇ ئىسسىتمايدىغان يەر،","سۇ ۋۇ قوتان قوي بېقىشقا سۈرگۈن قىلىنغان،","ھېچقاچان تۇغمايدىغان قويلارنى، قار ئېرىمەيدىغان زېمىندا.","","ئۇلار ئۇنىڭ قىلىچىنى تارتىۋالدى، يىپەكلىرىنىمۇ تارتىۋالدى،","ئەمما ئۇنىڭ ساداقىتىنى تارتىۋالالمىدى.","پەقەت كونىراپ كەتكەن خانلىق ھاسىسىلا ئەسلەيدۇ،","ئۇنىڭغا بېرىلگەن بۇيرۇقنىڭ قىممىتىنى.","","سىبىرىيە قېرىنىڭ ئون توققۇز يىلى،","بىر ۋاقىتلاردا ياش بولغان ئەرنىڭ بۇرۇتىدا،","بىر ۋاقىتلاردا پۆپۈكلىرى چاقناپ تۇرىدىغان ھاسىدا."],"annotations":[{"term":"بايقال كۆلى","note":"بايقال كۆلى - دۇنيادىكى ئەڭ چوڭقۇر ۋە سىبىرىيەدىكى قەدىمكى تاتلىق سۇ كۆلى، خەن ئەلچىسى سۇ ۋۇ سۈرگۈن قىلىنىپ قوي باققان جاي."},{"term":"سۇ ۋۇ","note":"سۇ ۋۇ - كۆچمەن ھونلار تەرىپىدىن بايقال كۆلىدە 19 يىل تۇتۇلۇپ، سوغۇققىمۇ باش ئەگمىگەن مەشھۇر سادىق ئەلچى."}]},{"id":"poem-6-2","title":"ئۇنىڭغا ئۆيىگە قايتالايدىغانلىقىنى ئېيتقاندا / قايغۇلۇق قار ئۇچقۇنلىرىدەك تۆكۈلدى","lines":["ئۇنىڭغا ئۆيىگە قايتالايدىغانلىقىنى ئېيتقاندا،","ئۇنىڭ ئاقارغان نېپىز كىرپىكلىرى قايغۇلۇق قار ئۇچقۇنلىرىدەك تۆكۈلدى.","ئون توققۇز يىل — بوران بىلەن ئۆلچەنگەن بىر ئۆمۈر،","ھېچقاچان ئورۇلمايدىغان بۇغداي بىلەن ئۆلچەنگەن بىر ھايات.","","چاڭئەن يەنىلا ئۇ بىلىدىغان چاڭئەنمۇ؟","خان تېخىچە ئۇنىڭ ئىسمىنى ئەستە چىڭ ساقلامدۇ؟","سۇ ۋۇ يىغلىدى، زايە بولغان يىللار ئۈچۈن قايغۇرۇپ ئەمەس،","بەلكى خانلىق ھاسىسىنىڭ ئاخىرى قايتىدىغانلىقىدىن،","ئۇنىڭغا تاپشۇرۇلغان شۇ زېمىنغا."]},{"id":"poem-6-3","title":"لى لىڭ ئايرىلىش زىياپىتىدە ئۇنى كۆرگىلى كەلدى / لى لىڭ، سۈرگۈن قىلىنغان جياڭجۈن","lines":["لى لىڭ خوشلىشىش زىياپىتىدە ئۇنى كۆرگىلى كەلدى،","سۈرگۈن قىلىنغان جياڭجۈن لى لىڭ،","ئۆلۈمنىڭ ئورنىغا تەسلىم بولۇشنى تاللىغان،","ۋە ھازىر ھونلار تۇغى ئاستىدا ھۆكۈمرانلىق قىلىۋاتقان.","","ئۇلار سۈكۈت ئىچىدە شاراب ئىچتى،","چاڭئەندىن كەلگەن ئىككى ئەر.","بىرى تەسلىم بولغان، يەنە بىرى بولمىغان،","بىرى شەرققە قاراپ ئاتلىق قايتىدۇ،","يەنە بىرى قاراڭغۇ يايلىقتا كۆمۈلۈپ قالىدۇ.","","سۇ ۋۇ كەتكەندە لى لىڭ يىغلىدى،","چۈنكى ئۇ شۇ دەقىقىدە چۈشەندىكى،","بەزى نەرسىلەر ھونلارنىڭ ئاتلىرىدىنمۇ قەيسەر،","ئۇلارنىڭ قىلىچلىرىدىنمۇ قاتتىق،","بەزى نەرسىلەر ھەرگىز سۇنمايدۇ."],"annotations":[{"term":"لى لىڭ","note":"لى لىڭ - داڭلىق گېنېرال لى گۇاڭنىڭ نەۋرىسى، پۈتۈن ئوقياسى تۈگەپ خوتۇنلىرى ئالدىدا ھونلارغا قارشى پىداكارلىق بىلەن ئۆلۈمدىن ساقلىنىپ تەسلىم بولغان."}]},{"id":"poem-6-4","title":"ئەپسانىلەردە ئېيتىلىشىچە / ئۇنىڭ ئاۋازىنى تېخىچە ئاڭلىغىلى بولىدۇ","lines":["ئەپسانىلەردە ئېيتىلىشىچە،","ئۇنىڭ ئاۋازىنى تېخىچە ئاڭلىغىلى بولىدىكەن،","بايقال كۆلىنىڭ مۇزلىرىدا — شىمالىي دېڭىزدا،","بوران يەنىلا سىم توساقلار ئارىسىدا ئۇۋلايدىغان جايدا.","","سۇ ۋۇ چاڭئەنگە قايتتى،","چاچلىرى كوئىنلۇن چوققىلىرىدەك ئاقارغان ھالدا.","ئەمما ئۇنىڭ ئەرۋاھى شۇ يەردە قالدى،","قار-بوران ئىچىدە قوي بېقىپ،","ئەبەدىي گۇۋاھچى بولۇپ،","ھېچقاچان ئۇنتۇمىغان بىر ئەرگە."],"annotations":[{"term":"ياۋا غاز","note":"ياۋا غاز (قاز) - قەدىمكى رىۋايەتتە ھونلارغا خەت يەتكۈزگەن دەپ تارقالغان خەتتات غاز، خەت ۋە پوچتىنىڭ سىمۋولىغا ئايلانغان."}]}]},{"id":"chapter-7","title":"كەڭ يارقەنتتە","poems":[{"id":"poem-7-1","title":"قۇپقۇرۇق ياڭگۇەن پاسىدىن ئۇچۇپ ئۆتكەن كەپتەرلەر توپى / ئوتتۇرا يەر دېڭىزى ئەينىكىنىڭ ئۇرۇقلىرىنى قايتۇرۇپ كېلىدۇ","lines":["يالغۇز ياڭگۇەن پاسىدىن ئۇچۇپ ئۆتكەن كەپتەرلەر توپى،","شۈبھىسىزكى ئوتتۇرا يەر دېڭىزى ئەينىكىنىڭ ئۇرۇقلىرىنى قايتۇرۇپ كېلىدۇ،","ۋە پەرغانە ئۈزۈمىنىڭ ئۇرۇقلىرىنى،","پارسنىڭ ئانار دەرەخلىرىنى،","ۋە شۇ يەرنىڭ مۇقاملىرىدا چېلىنىپ باقمىغان ناملارنى.","","يىپەك يولى پەقەتلا سودا تاسمىسى ئەمەس،","ئۇ بىر ئۇرۇق تاسمىسى،","ئىمپېرىيەلەرنى تۇتىۋېلىپ ئۇلارنى تېرىيدىغان،","پۈتۈنلەي ناتونۇش تۇپراقلارغا."],"annotations":[{"term":"يەكەن","note":"يەكەن - قەدىمكى غەربىي دىياردىكى ۋە كۈنلۈك شىنجاڭ يەكەن ناھىيەسى. تارىم دەرياسىنىڭ ئاساسلىق تارماقلىرىدىن بىرى."},{"term":"يىپەك مەلىكە","note":"يىپەك مەلىكە - خوتەن پادىشاھىغا ياتلىق بولغاندا تاجىسىغا يىپەك قۇرتىنى يوشۇرۇپ، يىپەك تېخنىكىسىنى غەربكە يەتكۈزۈپ بەرگەن رىۋايەتتىكى مەلىكە."},{"term":"ياڭگۈەن","note":"ياڭگۈەن ئۆتكىلى - دۇنخۇاڭنىڭ غەربىي جەنۇبىدىكى خەن سۇلالىسى چېگرا غولى. يىپەك يولىنىڭ جەنۇبىي تۇتۇشى بولۇپ شېئىرلاردا كۆپ مەدھىيەلەنگەن."}]},{"id":"poem-7-2","title":"بۇ قارا-ئالتۇن رەڭلىك ئۇپۇق / قۇمۇش نەيلەرنى ۋە ساۋۇتلۇق ئاتلارنى يۇتۇۋەتكەن","lines":["بۇ قارا-ئالتۇن رەڭلىك ئۇپۇق،","بىر ۋاقىتلاردا قۇمۇش نەيلەرنى ۋە ساۋۇتلۇق ئاتلارنى يۇتۇۋەتكەن،","چېدىرلار ۋە كارۋانلار،","مەلىكىلەر ۋە راھىبلار.","","ھازىر ئۇنىڭ ئالماشتۇرىدىغىنى،","پەقەت شامالنىڭ كۈچى ۋە قۇمنىڭ رەھىمسىزلىكى،","ۋە كېچىدە سۆزلىنىدىغان ھېكايىلەر،","گۈلخان يورۇقىدا.","","يىپەك يولى بىر دەريا،","ئاللىبۇرۇن قۇرۇپ كەتكەن،","پەقەت قاشتېشى ياتقۇزۇلغان ئېقىن قەھرىلا قالغان."]},{"id":"poem-7-3","title":"چوڭ مەسچىت ئۈستىدىكى ھىلال ئاي / ھېلىھەم بۇ قەدىمكى بازارغا قارايدۇ","lines":["چوڭ مەسچىت ئۈستىدىكى ھىلال ئاي،","ھېلىھەم بۇ قەدىمكى بازارغا قارايدۇ.","بىر چاغدا يىپەك بىلەن سېتىۋېلىنغان نەرسىلەر،","ئەمدى قەغەز پۇلغا سېتىلىدۇ.","ئەمما يۈزلەر ھېچ ئۆزگەرمىدى.","","سەمەرقەنتلىك سودىگەرلەر،","قەشقەرلىك بۇدۇنلار،","ئۇلارنىڭ كۆزلىرىدە ئوخشاشلا ھېسابلاش بار،","قوللىرىدا ئوخشاشلا تېتىتقۇلار ئالماشتۇرۇلىدۇ،","سودىنىڭ ئاشۇ قوپال، گۈزەل تىلىدا سۆزلىشىدۇ."]},{"id":"poem-7-4","title":"ئۇلارغا پىلە يېشىشنى ئۆگەتكەن / خوتەننىڭ خەنزۇ مەلىكىسى","lines":["ئۇلارغا پىلە يېشىشنى ئۆگەتكەن،","خوتەننىڭ ياتلىق قىلىنغان مەلىكىسى،","ئۈجمە ئۇرۇقى ۋە غوزا قۇرتى تۇخۇمىنى ئەكەلگەن،","چاچ پاسونىنىڭ ئىچىگە يوشۇرۇپ.","","يىپەك سىرىنى شەرققە ئېلىپ كەلدى،","يېڭى پادىشاھلىقى ئۆز شان-شەرىپىنى توقۇيالىسۇن دەپ.","كونا ئانا ۋەتىنى ئۈچۈن خائىن،","يېڭى ئانا ۋەتىنى ئۈچۈن ئۈمىد.","","ئۇنى قانداقمۇ ئەپۇ قىلماي تۇرالايسىز؟","ئۇ پۈتۈن باھارنى ئۆزى بىلەن بىللە ئەكەلدىغۇ،","چېچىنىڭ ئىچىگە يوشۇرۇپ."]},{"id":"poem-7-5","title":"خوتەن پادىشاھى ئاشىخان / كۆزلىرى لازۇرىتتەك كۆك","lines":["كۆزلىرى لازۇرىتتەك كۆك خوتەن پادىشاھى ئاشىخان،","ئۆز ئەلچىلىرىنى چاڭئەنگە ئەۋەتتى،","قاشتېشى ۋە بۇرۇن ئاڭلاپ باقمىغان مۇزىكىلارنى ئېلىپ.","","يىپەك ئىمپېرىيىسى بار ئىدى، ۋە قاشتېشى ئىمپېرىيىسى،","ئۇ ئىككىسى خوتەندە ئۇچراشتى.","دەريالارنىڭ ئاق ۋە قارا تاشلاردەك ئاقىدىغان يېرى،","ئاشىقلارنىڭ كۆز يېشى بىلەن ئاقىدىغان،","تۆگىلەرنىڭ سۆڭەكلىرى بىلەن ئاقىدىغان يېرى."],"annotations":[{"term":"ئاسىخان","note":"ئاسىخان - يىپەك مەلىكىگە ئۆيلەنگەن خوتەن پادىشاھى، شۇ ئارقىلىق يىپەك قۇرتىنى مەخپىي قولغا كىرگۈزگەنلىكى رىۋايەت قىلىنىدۇ."}]}]},{"id":"chapter-8","title":"مۇنار ئوتلىرى ئۆچتى","poems":[{"id":"poem-8-1","title":"ئوتتۇز ئالتە ئەر غەربىي يۇرتلارغا يۈرۈش قىلدى / پۈتۈن بىر ئىمپېرىيە","lines":["ئوتتۇز ئالتە ئەر غەربىي يۇرتلارغا يۈرۈش قىلدى،","پۈتۈن بىر ئىمپېرىيە،","ئوتتۇز ئالتە ئاتنىڭ مۈرىسىدە.","","بەن چاۋ قەلىمىنى تاشلاپ قويدى،","ۋە دېدىكى: «بۈيۈك ئەر يات ئەللەردە ئۆز قىممىتىنى يارىتىشى كېرەك،","مۆي قەلەم ۋە سىياھ بىلەن ئەمەس،","بەلكى قىلىچ ۋە تەر بىلەن.»","","ئۇنىڭ ئادەملىرى مىڭلىغان قوشۇندەك نەرە تارتتى،","ھەتتا راۋان ئات تۇياقلىرىنىڭ ئاۋازىنىمۇ بېسىپ چۈشتى،","يامغۇردەك ياغقان بوراندەك.","","تاڭ ئېتىشقا يېقىن، ھونلارنىڭ ئەلچىلىرى ئۆلگەنىدى،","پىشەن پادىشاھى بولسا،","خەن سۇلالىسىنىڭ تۇغى ئالدىدا تىز پۈككەنىدى.","","بەن چاۋ تەبەسسۇم قىلدى،","بىر ئۆلىمانىڭ تەبەسسۇم قىلغىنىدەك،","توغرا خەت ئاخىرى،","ئۆز ئورنىغا چۈشكەندە.","","بەن چاۋ غەربتىكى يۇرتلاردا ئوتتۇز يىل تۇردى،","ئوتتۇز ئالتە ئەر بىلەن ئوتتۇز يىل،","بىر ئىمپېرىيەنىڭ قەلئەسىگە ئايلانغان،","دۇنيانىڭ چېتىدە.","","ئۇ ياققان نۇر-ئوتلار،","قەدىمكى يىپەك يولىنى بويلاپ،","ئوتتۇز يىل يېنىپ تۇردى،","ئاندىن بىر-بىرلەپ ئۆچتى."],"annotations":[{"term":"بەن چاۋ","note":"بەن چاۋ (م. 32-102-يىللار) - خەن سۇلالىسىنىڭ داڭلىق گېنېرالى. پەقەتلا 36 ئەسكەر بىلەن غەربىي دىيارنى تولۇق بويسۇندۇرۈپ ئەندىشىدىن قۇتۇلدۇرغان."},{"term":"پىچان (پىشامشان)","note":"پىشامشان (پىچان) - قەدىمكى لوبنۇر ئەتراپىدىكى يىپەك يولى دۆلىتى (لۇلاننىڭ كېيىنكى ئىسمى). بەن چاۋنىڭ ھونلار ۋەكىللىرىنى كېچىدە ئۆلتۈرگەن تۇنجى جەڭ مەيدانى."}]},{"id":"poem-8-2","title":"گۇيا يۈز مىڭ ساۋۇتلۇق لەشكەردەك / بىر قايغۇلۇق، خىلۋەت كۈي ياڭرايدۇ","lines":["قېرىغاندا، بەن چاۋ ئۆيىگە قايتىشنى تەلەپ قىلدى،","ئۇنىڭ پادىشاھقا يازغان خېتىدە مۇنداق جۈملىلەر بار ئىدى:","«جيۇچۈەنگە تىرىك يېتىپ بېرىشنى ئۈمىد قىلالمايمەن،","ئۇستىخانلىرىمنىڭ قاشتېشى قوۋۇقتىن كىرىشىنىلا تىلەيمەن.»","","پادىشاھ خەتنى ئوقۇپ يىغلىدى،","ۋە ئۇنىڭ تەلىپىگە قوشۇلدى.","","گۇيا يۈز مىڭ ساۋۇتلۇق لەشكەردەك،","بىر قايغۇلۇق، خىلۋەت كۈي ياڭرايدۇ،","پاس ئارقىلىق، كارىدور ئارقىلىق،","ئوتتۇز يىللىق سۈرگۈنلۈك ئارقىلىق.","","ئۇ قايتىپ كېلىپ بىر ئايدىن كېيىن ئالەمدىن ئۆتتى،","خۇددى ئۇنىڭ جەسىتى،","پەقەت ئۆيىنى كۆرۈشنىلا كۈتۈپ تۇرغاندەك."]},{"id":"poem-8-3","title":"ئاللىبۇرۇن يېقىن جەڭگە كىرگەن / سۈكۈت ئىچىدە ئۆلتۈرۈش","lines":["بەن چاۋ كەتكەندىن كېيىن، نۇر-ئوتلار خىرەلەشتى،","كىچىك قاراۋۇلخانىلار كىچىكلەپ كەتتى،","ئاللىبۇرۇن يېقىن جەڭگە كىرگەن،","سۈكۈت ئىچىدە ئۆلتۈرۈش.","","ئۇ يوق يەردە،","غەربىي يۇرتلار پارچىلاندى،","پادىشاھلىق ئارقىدىن پادىشاھلىق،","يىپى ئۈزۈلگەن قاشتېشى مارجاندەك.","","بەن چاۋدىن كېيىنكى سۈكۈت،","ھەرقانداق جەڭدىن يۇقىرى ئىدى،","بىر ئىمپېرىيەنىڭ چېكىنىش سۈكۈتى،","دۇنيانىڭ قىرغىقىدىن."]},{"id":"poem-8-4","title":"تاڭ يۇلتۇزى غۇۋالاشماقتا / نۇر-ئوتلار ئۆچتى","lines":["تاڭ يۇلتۇزى غۇۋالاشماقتا،","نۇر-ئوتلار ئۆچتى،","دۇنخۇاڭدىن قەشقەرگىچە بولغان يولدا،","پەقەتلا شامال ھەرىكەتلىنىدۇ.","","قاراۋۇل مۇنارلىرى گۈمۈرۈلۈپ چۈشتى،","ئۇلارنىڭ ئىس-تۈتەكلىرى ئاللىقاچان ئۆچكەن،","كۆزەتچىلەر ئۆيلىرىگە قايتتى،","ياكى قۇمغا كۆمۈلدى.","","ئەمما يول قالدى،","ئەسىرلەر بويى يەرگە سىڭىپ كەتكەن،","يىپەك ۋە قاشتېشى ۋە تېتىتقۇلار بويىچە،","قوشۇنلار، راھىبلار ۋە سودىگەرلەر بويىچە.","","تاڭ يۇلتۇزى غۇۋالاشماقتا،","ئەمما ئۇ يەنە كۆتۈرۈلىدۇ،","بورۇنقىدەكلا كۆتۈرۈلىدۇ،","پامىر پاسلىرىنىڭ ئۈستىدە،","ئوتتۇرا ئاسىيا يايلىقلىرى ئۈستىدە.","","نۇر-ئوتلار ئۆچتى،","ئەمما يول بەرداشلىق بېرىدۇ،","يول بەرداشلىق بېرىدۇ،","يىپەك يولى بەرداشلىق بېرىدۇ،","بىر قېتىمدا بىر يالقۇن."]}]},{"id":"chapter-9","title":"قاپقارا كۆك فارس قولتۇقى","poems":[{"id":"poem-9-1","title":"يىراق غەربكە قاراپ جىمجىت دۇئا قىلىش / شۇ مۇقەددەس ماكان","lines":["گەن يىڭ دۇنيانىڭ بىلىنگەن چېتىدە تۇراتتى،","قۇرۇقلۇق تۈگەپ، دېڭىز باشلانغان يەردە،","يىراق غەربكە قاراپ جىمجىت دۇئا قىلىش،","شۇ مۇقەددەس ماكان — رىم — داچىن.","","پارس سودىگەرلىرى بېشىنى چايقىدى:","«دېڭىز بىپايان. سەپەرگە نەچچە ئاي كېتىدۇ.»","«پەرۋاز قىلغانلارنىڭ كۆپىنچىسى ھېچ قايتىپ كەلمەيدۇ.»","","ئۇ قارا-كۆك سۇغا قارىدى،","ئۇنى رىمدىن ئايرىپ تۇرىدىغان دولقۇنلارغا،","يىپەك يولىنىڭ غەربىي چېتىدىن،","ئۆز خەلقى توقۇغان يىپەكنى كىيگەن ئىمپېرىيەدىن.","","ئۇ ئارقىسىغا قايتتى،","جۇڭگو ئەۋەتكەن ئەڭ يىراققا بارغان ئەلچى،","ئازراقلا — ئازراقلا — رىمغا تېگىشەلمەي.","","مىلادى 97-يىلى،","بىر جۇڭگولۇق ئەرنىڭ،","پارس قولتۇقىدا تۇرۇپ،","ئۇنىڭدىن نېرىغا ئۆتەلمىگەن يىلى."],"annotations":[{"term":"گەن يىڭ","note":"گەن يىڭ - مىلادى 97-يىلى بەن چاۋ تەرىپىدىن رىم (داچىن)غا ئەلچىلىككە ئەۋەتىلگەن ۋە پارس قولتۇقىغا يېتىپ بارغان ھەربىي ئەلچى."}]},{"id":"poem-9-2","title":"ئالتۇن كەكلىكلەر قونغان شاخلار ئارىسىدىن / شىلدىرلىغان ئاۋاز بىلەن ئېغىر قىزىل يامغۇر ياغىدۇ","lines":["كتېسىفون باقلىرىدا،","ئانارلار پانۇستەك ئېسىلىپ تۇراتتى،","ئالتۇن كەكلىكلەر قونغان شاخلار ئارىسىدىن،","شىلدىرلىغان ئاۋاز بىلەن ئېغىر قىزىل يامغۇر ياغىدۇ.","","گەن يىڭ بۇ يات باغلاردا ماڭدى،","ئۆزى ئىسىم قويمىغان پۇراقلارنى پۇراپ،","ھېچبىر جۇڭگو تۇپرىقىدا ئۆسمەيدىغان مېۋىلەرنى تېتىپ.","","پارس پادىشاھى ئۇنى قىزىقىش بىلەن كۈتۈۋالدى:","«سەن يىپەك دۆلىتىدىن كەلدىڭمۇ؟»","«سەن قانچىلىك يىراقتىن ماڭدىڭ؟»","","گەن يىڭ ئىچىدە ھېسابلىدى:","لويياڭدىن بۇ يەرگىچە — قىرىق مىڭ چاقىرىم،","يەتتە يىللىق پىيادە مېڭىش،","ئارىدىكى ھەر بىر پادىشاھلىقتىن ئۆتۈپ.","","«مەن ماڭدىم»، دېدى ئۇ،","«قۇياش چىققان يەردىن، قۇياش پاتىدىغان يەرگىچە.»","","پادىشاھ كۈلدى،","ۋە ئۇنىڭغا شاراپ قۇيدى،","پارس قولتۇقىدەك قارا تاماق،","تۈگىمەس يولدەك خۇش پۇراقلىق."]},{"id":"poem-9-3","title":"زاگروس تاغلىرىدىن كەلگەن نەم شامال / تۇزلۇق پۇراق بىلەن ئۇنىڭغا قاراپ چىقىدۇ","lines":["زاگروس تاغلىرىدىن كەلگەن নەم شامال،","تۇزلۇق پۇراق بىلەن ئۇنىڭغا قاراپ چىقىدۇ،","ئۇنىڭدىن ئۆتكەن دېڭىزنىڭ پىچىرلىشىرىنى ئېلىپ كېلىپ.","","ئۇ خۇددى رىمنى پۇرىغاندەك قىلدى،","خۇددى ئۇنىڭ مەرمەر تۈۋرۈكلىرىنى كۆرگەندەك قىلدى،","كۆپۈكلەر ئىچىدىن ئۆرلىگەن.","","ئەمما پارسلار ئۇنى ئۆتكۈزمىدى،","ئۇلار يولنىڭ ئوتتۇرىسىنى تۇتۇپ تۇراتتى،","يىپەك ۋە ئەينەكنىڭ ۋاستىچىلىرى،","شەرق ۋە غەرب ئوتتۇرىسىدىكى ئارىلىقتىن مەنپەئەت ئالىدىغان."],"annotations":[{"term":"زاگروس تاغلىرى","note":"زاگروس تاغلىرى - پارس قولتۇقىدىن تۈركىيەگىچە سوزۇلغان، قەدىمكى يىپەك يولىنىڭ مېسسوپوتامىيەگە ئۆتۈشىدىكى تەبىئىي توسالغۇ بولغان تاغ."},{"term":"پارس قولتۇقى","note":"پارس قولتۇقى - ئەرەب يېرىم ئارىلى ۋە ئىران تۇتىشىدىغان قولتۇق جەنۇبى دېڭىز. گەن يىڭ مۇشۇ يەرگىچە بارغان دەپ خاتىرىلەنگەن."}]},{"id":"poem-9-4","title":"ئاچچىق دېڭىز سۈيى ئاچچىق كۆز ياشلار بىلەن ئارىلىشىپ / قارا-كۆك پارس قولتۇقىغا قايتا تۆكۈلدى","lines":["ئۇ سۇ بويىدا ئۇزاق تۇردى،","دولقۇنلار ئۇنىڭ كونا تېرە ئۆتۈكلىرىدىن ئېشىپ كەتتى،","ئاچچىق دېڭىز سۈيى ئاچچىق كۆز ياشلار بىلەن ئارىلىشىپ،","قارا-كۆك پارس قولتۇقىغا قايتا تۆكۈلدى.","","ئۇ شۇنچە يىراقتىن كەلگەنىدى،","پامىرنىڭ مۇزلۇق داۋانلىرىدىن ئۆتۈپ،","تاكلاماكاننىڭ قۇملىرى ئارقىلىق،","ئالىملارمۇ ئىسىملىرىنى ئۇنتۇپ كەتكەن خانلىقلارنىڭ خارابىلىكلىرى يېنىدىن ئۆتۈپ.","","ۋە بۇ يەردە، رىمنىڭ بوسۇغىسىدا،","ئۇ كەينىگە قايتۇرۇلدى،","بىر قوشۇن تەرىپىدىن ئەمەس،","بەلكى بىر سودىگەرنىڭ يالغانچىلىقى بىلەن.","","«دېڭىزدا ئىككى يىل كېتىدۇ»، دېدى ئۇلار،","پەقەت بىر نەچچە ھەپتە كېتىدىغانلىقىنى بىلىپ تۇرۇپ،","شەرققە غەرب بىۋاسىتە ئۇچراشسا،","ئۇلارنىڭ ۋاسىتىچىلىك بايلىقىنىڭ يوقىلىدىغانلىقىنى بىلىپ تۇرۇپ.","","گەن يىڭ شەرققە بۇيرۇلدى،","ئۇنىڭ سايىسى پارس قولتۇقىغا چۈشتى،","جۇڭگونىڭ غەربكە تاشلىغان ئەڭ ئۇزۇن سايىسى.","","ئۇ خەۋەرلەرنى ئەكەلدى،","نەپەستەك پۈۋلەپ ياسىغىلى بولىدىغان ئەينەكلەر ھەققىدە،","ئاكروياتلار ۋە ئوت يۇتۇۋاتقانلار ھەققىدە،","ئۆزىنىڭكىگە تڭ كېلىدىغان بىر ئىمپېرىيە ھەققىدە.","","ئىككى ئىمپېرىيە، بىر-بىرىدىن خەۋەرسىز،","چۆل ۋە ئالدامچىلىق بىلەن ئايروپ تاشلانغان،","ۋە بىر ئەر،","سەل ئاز قالغاندا — سەل ئاز قالغاندا —","ئارىلىقنى كۆپۈكلەشتۈرگەن،","پارس قولتۇقىنىڭ قارا-كۆك دولقۇنلىرىدا توپتىغىچە تۇرۇپ،","مىلادى 97-يىلى."]}]},{"id":"chapter-10","title":"تارىم دەريا دولقۇنلىرى","poems":[{"id":"poem-10-1","title":"ئۇنىڭ ئۈچ مىڭ دۇنخۇاڭ ئەسكەرلىرىمۇ / دەريا بويىغا يىقىلىپ چۈشتى","lines":["سۇ لې ئۈچ مىڭ ئادەمنى دۇنخۇاڭدىن يېتەكلەپ كەلدى،","كۆيۈپ تۇرغان تاكلاماكان ئارقىلىق،","تارىم دەرياسىنىڭ قىرغاقلىرىغا.","","دەريا ئۇلارنىڭ ھاياتلىق لىنىيىسى ئىدى —","قارا سۇ، كۆرەلمەيدىغان تاغلارنىڭ،","ئېرىگەن قارلىرىدىن ئېتىلىپ چىققان.","","ئۇنىڭ ئۈچ مىڭ دۇنخۇاڭ ئەسكەرلىرىمۇ","دەريا بويىغا يىقىلىپ چۈشتى،","يۈزلىرىنى سۇغا بېسىپ،","خۇددى قايتا ئىچمەيدىغاندەك ئىچىشتى.","","ئاندىن ئۇلار قوپۇپ دېھقانچىلىق قىلىشقا باشلىدى،","بۇ قىلىچ كۆتۈرگەن ئەسكەرلەر،","ئەمدى قوشلارنى كۆتۈردى.","","غەربىي يۇرتلاردىكى تۇنجى ھەربىي دېھقانچىلىق مەيدانلىرى،","قانغا بويالغان تۇپراققا تېرىلغان،","ئېرىگەن قار سۈيى بىلەن سۇغىرىلغان،","ئۆيلىرىنى سېغىنغان ئەرلەر تەرىپىدىن قوغدالغان.","","بۇ باھساسى ئىدى —","بىڭتۈەننىڭ ئەجدادى،","ئىككى مىڭ يىلدىن كېيىن ئۆسۈپ چىقىدىغان ئۇرۇق،","چېگرا شەھەرلىرىگە ئايلىنىدىغان."],"annotations":[{"term":"تارىم دەرياسى","note":"تارىم دەرياسى - ئۇزۇنلۇقى 2137 كىلومېتىر كېلىدىغان جۇڭگونىڭ ئەڭ ئۇزۇن ئىچكى قۇرۇقلۇق دەرياسى. غەربىي دىياردىكى ئەسكىرىي بوز يەر ئېچىشلارنىڭ قېنى ۋە جېنى ئىدى."},{"term":"سۇ ماي","note":"سۇ ماي - شەرقىي خەن سۇلالىسى گېنېرالى. تارىم دەرياسى بويلىرىدا كەڭ كۆلەمدە بوز يەر ئېچىپ، غەربىي دىياردا ئەسكىرىي تېرىقچىلىقنىڭ باشلامچىسى بولغان."},{"term":"ئەسكىرىي تېرىقچىلىق","note":"بوز يەر ئېچىش (جۈنكېن) - قىسمىنى تولۇقلاش ئۈچۈن قىسىم ئەسكەرلىرىنىڭ چۆللۈك دەل-دەرەخ تېرىشى بولۇپ، ھازىرقى شىنجاڭ ئىشلەپچىقىرىش قۇرۇلۇش بىڭتۇەنىنىڭ تارىخىي مەنبەسىدۇر."}]},{"id":"poem-10-2","title":"كۆزلەر ئاستا يۇمۇلدى / يىراقتىن يېشىل بىر بۇلۇت لەيلەپ كەلدى","lines":["كۆزلەر ئاستا يۇمۇلدى،","يىراقتىن يېشىل بىر بۇلۇت لەيلەپ كەلدى،","تۈشىدە، تارىم قىرغىقى،","ئەمدى قاقاس ئەمەس.","","ئۇپۇققا قەدەر سوزۇلغان بۇغداي سېپلىرى،","ئۆستەڭلەر قۇملۇقتىن ئۆتىدۇ،","تاشتىكى كۈمۈش تومۇرلارغا ئوخشاش.","","ئۇ كۆرەلمەيدىغان بىر كەلگۈسىنى كۆرىدۇ،","باغلار ۋە پاختىنىڭ كەلگۈسىنى،","يوللار ۋە مەكتەپلەرنىڭ،","قالقانغا تېگىشكەن قىلىچ ئاۋازىنى مېڭە ئاڭلىمايدىغان بالىلارنىڭ.","","كۆزلەر ئاستا يۇمۇلدى،","ئۇ تۈشىدە دېھقانچىلىق قىلىدۇ،","مەڭگۈلۈك دېھقانچىلىق،","شان-شەرەپتىن كۆرە تىنچلىقنى ئارزۇ قىلىدىغان،","ھەر بىر ئەسكەرنىڭ چۈشى."]},{"id":"poem-10-3","title":"تارىمنىڭ قارا دولقۇنلىرى بىلەن بىرلىشىپ / سېرىق ئاي نۇرى ئاستىدا توختاۋسىز كۆپۈكلەيدۇ","lines":["كېچىدە دەريا سۆزلەيدۇ،","ھەر قانداق ئىمپېرىيەدىن كونا بىر تىلدا،","تارىمنىڭ قارا دولقۇنلىرى بىلەن بىرلىشىپ،","سېرىق ئاي نۇرى ئاستىدا توختاۋسىز كۆپۈكلەيدۇ.","","ئەسكەرلەر ئاڭلايدۇ،","بەزىلىرى ئۆيلىرىگە خەت يازىدۇ،","ياغاچ پارچىلىرىغا،","سولغاچ سىياھ بىلەن.","","«مەن ياخشى»، دەپ يازىدۇ ئۇلار،","«بۇ يىلكى ھوسۇل ياخشى بولدى.»","«مەن بىر تېرەك تىكتىم.»","«ئۇ ماڭا ۋېي دەرياسى بويىدىكى سەۋرە تاللارنى ئەسلىتىدۇ.»","","دەريا ئۇلارنىڭ ئاۋازىنى ئېلىپ ماڭىدۇ،","شەرققە، ھەمىشە شەرققە،","چۆل كېچىسى ئارقىلىق،","ئىككى مىڭ يىل ئارقىلىق."]},{"id":"poem-10-4","title":"ئانارگۈلى ئات ئۈستىدە / يىراقلارغا نەزەر سالىدۇ","lines":["ئانارگۈلى ئات ئۈستىدە،","يىراقلارغا نەزەر سالىدۇ،","ئۇيغۇر قىزى ئۆستەڭنى بويلاپ مىنىدۇ،","خەن ئەسكەرلىرى قازغان ئۆستەڭنى.","","ئۇ ئۇلارنىڭ ئىسىملىرىنى بىلمەيدۇ،","ئەمما ئۇلار ئاققۇزغان سۇنى ئىچىدۇ،","پۇشتىنى ئۇلار تىككەن دەرەخلەرنىڭ،","مېۋىسىنى يەيدۇ.","","تارىم ئېقىۋېرىدۇ،","ئۇلارنىڭ بارلىق ھېكايىلىرىنى كۆتۈرۈپ،","خەن ۋە ئۇيغۇر، ئەسكەر ۋە دېھقان،","ھەممىسى ئوخشاش بىر دەريادىن ئىچىپ،","ھەممىسى بىر ئايغا قاراپ."]},{"id":"poem-10-5","title":"تېخىچە پەسكە قاراپ / تېخىچە پەسكە قاراپ","lines":["تارىمنىڭ ئۈستىدىكى قىيالاردىن،","ئويۇلغان بۇددا پەسكە قارايدۇ،","تېخىچە پەسكە قاراپ،","تېخىچە پەسكە قاراپ.","","ئۇ قوشۇنلارنىڭ كېلىپ كېتىشىنى كۆردى،","قاشتېشى بېسىلغان كارۋانلارنى،","سۇترا ئوقۇۋاتقان راھىبلارنى،","بۇغداي تېرىۋاتقان دېھقانلارنى.","","تېخىچە پەسكە قاراپ،","ئوخشاشلار نۇرانە تەبەسسۇم بىلەن،","ھېچقاچان توختاپ قالمايدىغان دەرياغا،","ھېچقاچان ئۇخلىمايدىغان چۆلگە،","ھېچقاچان تۈگىمەيدىغان يولغا.","","ئىككى مىڭ يىللىق تىكىلىپ قاراش،","دۇنيا يەنىلا ئونىڭ تاش كۆزلىرى ئاستىدا ئايلىنىدۇ،","تارىم ئېقىۋېرىدۇ،","تارىم دەرياسىنىڭ دولقۇنلىرى،","ھەممىنى كۆتۈرىدۇ،","ھەممىنى كۆتۈرىدۇ."]}]},{"id":"chapter-11","title":"چېگرىنى يوشۇرۇن ئاشقان تەلەپچى","poems":[{"id":"poem-11-1","title":"ئەمما ئەپسانىلەردە ئېيتىلىشىچە / چاڭئەندىن يولغا چىقىپ","lines":["ئەمما ئەپسانىلەردە ئېيتىلىشىچە،","چاڭئەندىن يولغا چىقىپ، كۈن پاتارغا قاراپ،","تاڭ شۈەنزاڭ غەربكە سەپەر قىلغان،","ئات بىلەن ئەمەس، ئەجدىھا-ئات بىلەن،","مەسئۇلىيەت ئۈچۈن ئەمەس، بەلكى ھەقىقەت ئۈچۈن.","","ئۇ ئۆزى بىلەن ئىمپېرىيەنىڭ خېتىنى ئېلىپ ماڭمىدى،","پەقەت تىلەك ۋە بىر ھاسا ئېلىپ ماڭدى،","ۋە ئالتە پەنجىرىلىك بىر چۈشنى."],"annotations":[{"term":"دەرۋىش مۇخلىس","note":"بىمەننەت موخلىس (ياكى سەيياھ راھىب) - غەربكە ئوغرىلىقچە چىقىپ نوم تىلىگەن شۈەنزاڭ (تاڭ سېڭ) نى كۆرسىتىدۇ."}]},{"id":"poem-11-2","title":"شۇنىڭدىن ئېتىبارەن / بېسىقتۇرۇپ ۋە كۆمۈپ تاشلاپ","lines":["شۇنىڭدىن ئېتىبارەن، بورانلار كەلدى،","بېسىقتۇرۇپ ۋە دۆلەتلەرنى قۇمغا كۆمۈپ تاشلاپ،","ئەمما خۇدادىن كەلگەن بۇ راھىبنى توختىتالمىدى.","","تاكلاماكان ئۇنىڭغا ئەجدىھانى كۆرسەتتى،","ئەمما ئۇنىڭ دىتى تېخىمۇ چوڭقۇر ئىدى.","ئۇ قۇمنىڭ ئىچىدىكى تۆت يەردە گۈل پەيدا قىلدى."]},{"id":"poem-11-3","title":"ئۇ پەقەتلا ئالدىدىكى يولنىڭ / غەربىي جەننەتكە ئاپىرىدىغان-ئاپارمايدىغانلىقىنىلا سورىدى","lines":["قوچو پادىشاھى ئۇنى قېلىشقا يالۋۇردى،","يېرىم پادىشاھلىقنى سوۋغات قىلىشنى ۋەدە قىلدى،","ئەمما شۈەنزاڭ بېشىنى چايقىدى.","","ئۇ پەقەتلا ئالدىدىكى يولنىڭ","غەربىي جەننەتكە ئاپىرىدىغان-ئاپارمايدىغانلىقىنىلا سورىدى،","تاج ئۇنىڭ نىشانى ئەمەس ئىدى،","پەقەتلا سۇترا، ئۆلۈمدىن قۇتۇلدۇرىدىغان بەتلىكلەر."]},{"id":"poem-11-4","title":"ھەقىقىي نوملارنى ئەكېلىش ئۈچۈن / قۇم بورىنىدىن ئۆتۈشۈڭ شەرت","lines":["«ھەقىقىي نوملارنى ئەكېلىش ئۈچۈن،","قۇم بورىنىدىن ئۆتۈشۈڭ شەرت.»","","بۇ يول سۆڭەكلەر بىلەن يېزىلغان،","ئۇنىڭدىن بۇرۇن ئۆتكەنلەرنىڭكى بىلەن،","ئەمما ئۇنىڭ قەدىمى ئېغىر، بەلگىلىك ئىدى،","تەڭرىتېغىدىكى مۇزدەك مۇستەھكەم."]},{"id":"poem-11-5","title":"جىمجىت چۆل كېچىسى ئارقىلىق / ئۇ بۇددانىڭ ئاۋازىنى ئاڭلىدى","lines":["جىمجىت چۆل كېچىسى ئارقىلىق،","ئۇ بۇددانىڭ ئاۋازىنى ئاڭلىدى،","شامالدا ئەمەس، يۇلتۇزدا ئەمەس،","بەلكى قەلبىنىڭ ئىچىدىن.","","ئون يەتتە يىل سەپەر،","ياقا يۇرتلاردىن قايتىش،","چاڭئەننىڭ جاڭلىرى سادا بوپ چالغاندا،","يىپەك ئەمەس، بەلكى بىلىمنىڭ ئەكېلىنگەنلىكىنى جاكارلىدى."]},{"id":"poem-11-6","title":"ئىسسىقكۆلنىڭ دولقۇنلىرى / ئۇنىڭ ئېسىدە تېخىچە كۆپۈكلەپ ۋە چېچىلىۋاتىدۇ","lines":["ئىسسىقكۆلدە دېڭىز سۈيى ئىسسىق ئىدى،","گەرچە قار بىلەن قاپلانغان تاغلار بولسىمۇ،","ئىسسىقكۆلنىڭ دولقۇنلىرى،","ئۇنىڭ ئېسىدە تېخىچە كۆپۈكلەپ ۋە چېچىلىۋاتىدۇ.","","غەربىي تۈركلەرنىڭ يابغۇ قاغانى،","ئۇنى زىياپەتلەر ۋە ھۆرمەت بىلەن كۈتۈۋالدى،","قوغدىغۇچىلار ۋە ئاتلار تەقدىم قىلدى،","ۋە بىخەتەر ئۆتۈش خېتىنى.","","چېگرانى مەخپىي بېسىپ ئۆتكەن دەۋرىش شۈەنزاڭ،","ئەمدى ئىمپېراتورغا لايىق مۇھاپىزەتچىلەر بىلەن ماڭدى.","","سەمەرقەنتتىن بەلخقىچە،","بەلختىن گەنداراغىچە،","گەندارادىن نالانداغىچە،","دۇنيا بىلىدىغان ئەڭ ئۇلۇغ ئۇنىۋېرسىتېتقىچە.","","ئۇ ئۇ يەردە بەش يىل ئوقۇدى،","ئۇستازلار بىلەن مۇنازىرە قىلدى،","سۇترالارنى تەرجىمە قىلدى،","ۋە خۇشاللىقتىن يىغلىدى.","","ئۆيگە قايتىش سەپىرىگە يەنە يەتتە يىل كەتتى،","پامىردىن، قەشقەردىن ئۆتۈپ،","ئۇنى ئازلا قالغاندا ئۆلتۈرىدىغان ئاشۇ چۆلدىن ئۆتۈپ.","","لېكىن ئەمدى ئۇ نوملارنى ئېلىپ ماڭدى،","بىر مىڭ ئۈچ يۈز ئوتتۇز بەش توملۇق،","مەرىپەتنىڭ ئېغىرلىقىنى يالغۇز راھىب ئۆز دۈمبىسىگە ئارتتى."],"annotations":[{"term":"سۇياب","note":"سۇياب - قەدىمكى كۇچا-ئەنشى ئۆتكىلى تۆت تۈگۈنىدىن بىرى (ھازىرقى قىرغىزىستان توخماق) بولۇپ، مەشھۇر شائىر لى بەينىڭ تۇغۇلغان يېرى."},{"term":"ئىسسىق كۆل","note":"ئىسسىق كۆل - قىرغىزىستاننىڭ شەرقىدىكى دۇنيادىكى ئىككىنچى چوڭ ئېگىز تاغ سۈزۈك كۆلى بولۇپ، شۈەنزاڭ شۇ يەردىن ئۆتكەن."},{"term":"يابغۇ قاغان","note":"يابغۇ قاغان - غەربىي تۈرك قاغانلىقىنىڭ ئەمىرى، ئەلچى شۈەنزاڭغا دوستلارچە مېھماندوستلۇق قىلىپ يول خېتى تۆت يازغان."},{"term":"شۈەنزاڭ","note":"شۈەنزاڭ (تۇرسۇن) (602-664) - خەن سۇلالىسىنىڭ داڭلىق دىنىي سەيياھى. 17 يىللىق ھىندىستان سەپىرى مىللىي مەدەنىيەت «غەربكە ساياھەت»كە ئاساس بولغان."}]}]},{"id":"chapter-12","title":"شائىرنىڭ روھى تېخى چاپماقتا","poems":[{"id":"poem-12-1","title":"ئوتتۇز يىل ئۇ تۇردى / چېگرادا","lines":["ئوتتۇز يىل ئۇ تۇردى","چېگرادا، سەنسەن قۇملۇقىنىڭ يېنىدا،","بىر شائىر قىلىچنى كۆتۈرۈپ،","يالغۇزلۇقنى شېئىرغا ئالماشتۇردى.","","سېن سەن چېگرانىڭ سوغۇقىنى يازدى،","ئەۋلادلارنىڭ يۈرەكلىرىنى توڭلاتقۇدەك،","ئەمما ئۇنىڭ مىسرالىرىدىكى جەسۇرلۇق،","گۈلخاندەك ئىسسىق."],"annotations":[{"term":"سېن سەن","note":"سېن سەن (تەخمىنەن 715-770) - تاڭ سۇلالىسىدىكى تەڭپۇداشسىز چېگرا شائىرى، يىپەك يولىدىكى كاتتا ۋە تىكەن جەڭ مەيدانىنى تونۇشتۇرغان."}]},{"id":"poem-12-2","title":"گاۋ شيەنجى ئۆز قوشۇنلىرىنى يېتەكلەپ / داۋانلاردىن ئۆتكەندە","lines":["گاۋ شيەنجى ئۆز قوشۇنلىرىنى يېتەكلەپ","داۋانلاردىن ئۆتكەندە، پامىر ئارقىلىق،","شائىر مىسرالار بىلەن ئۇزىتىپ قويدى.","","تېز ئاتتىكى باش سەركەردە،","تارىخقا نامىنى قالدۇردى،","ئەمما شائىرنىڭ سىياھى ئۇنىڭ قىلىچىدىن،","ئۇزۇنراق ياشىدى."]},{"id":"poem-12-3","title":"شاداق رەڭلىك گۈلخان تېخىچە چاقنايدۇ / بىر مىڭ ئىككى يۈز يىلدىن ھالقىپ","lines":["شاداق رەڭلىك گۈلخان تېخىچە چاقنايدۇ،","بىر مىڭ ئىككى يۈز يىلدىن ھالقىپ،","ئۆچمەيدۇ، كېچىدىمۇ، كۈندۈزدىمۇ،","ياكى پەسىللەرنىڭ ئالمىشىشىدىمۇ.","","چۈنكى ئۇ سۆزلەر بىلەن يېقىلغان،","تونۇشلارنىڭ خوشلىشىشى بىلەن ياقتۇرۇلغان."]},{"id":"poem-12-4","title":"شۇنچە جىمجىتكى سەن ئاڭلىيالايسەن / شائىرنىڭ كۆز ياشلىرىنىڭ تۆكۈلگەنلىكىنى","lines":["سېن سەن چېگرادىن كەتكەندە،","تەڭرىتېغىغا ئارقىسىغا قارىدى،","شۇنچە جىمجىتكى سەن ئاڭلىيالايسەن،","شائىرنىڭ كۆز ياشلىرىنىڭ تۆكۈلگەنلىكىنى.","","ئۇ بېيدادۆڭدىن قورقۇپ كەلگەن،","ئەمما ئۇنى سۆيۈپ كەتتى،","بۇ زېمىن ئۇنى ياراتتى، شائىر قىپ ياراتتى."]},{"id":"poem-12-5","title":"خۇددى ئايالى قىيغان قىزىل قەغەزدەك / ئۇلارنىڭ توي كېچىسىدە","lines":["ئۇ ئۆيىنى چۈشىدە كۆرەتتى،","ئايالىنىڭ چىراغ نۇرىدىكى يۈزىنى،","خۇددى ئايالى قىيغان قىزىل قەغەزدەك،","ئۇلارنىڭ توي كېچىسىدە.","","شۇ قىزىل قەشقىر چېگرانىڭ سوغۇقىنى يەڭدى،","ئۇنى دوپپىسىغا سېلىپ، تارىخقا سىڭدۈردى."]}]},{"id":"chapter-13","title":"ئاھ، تالاس ئۇرۇشى","poems":[{"id":"poem-13-1","title":"خۇددى قوشۇنىنىڭ چېپىپ كېتىۋاتقانلىقىنى كۆرگەندەك قىلىدۇ / تالاس دەرياسىنىڭ قىرغاقلىرىنى بويلاپ","lines":["تالاس جېڭى، مىلادى 751-يىل،","تاڭ ئىمپېرىيەسى ئابباسىيلار خەلىپىلىكى بىلەن ئۇچراشقاندا،","ئۆت ۋە قان ئارقىلىق شەرق غەرب بىلەن يۈزلەشتى.","","خۇددى قوشۇنىنىڭ چېپىپ كېتىۋاتقانلىقىنى كۆرگەندەك قىلىدۇ،","تالاس دەرياسىنىڭ قىرغاقلىرىنى بويلاپ.","داڭلىق لەشكەرلەر چېكىندى،","ئەمما مەغلۇبىيەت ئىچىدىن زەپەر چىقتى،","قەغەز ياساش سىرى سەمەرقەنتكە ئۆتتى."]},{"id":"poem-13-2","title":"تالاسنىڭ ئۇنتۇلماس يازىنى ئاڭلاش / شۇنچە قايغۇلۇق ئەمما نەپىس بىر مەرسىيە","lines":["تالاس دەرياسى بويىدا يازدا،","تېرەكلەر ئۇزۇن سايىلارنى تاشلايدۇ،","تالاسنىڭ ئۇنتۇلماس يازىنى ئاڭلاش،","شۇنچە قايغۇلۇق ئەمما نەپىس بىر مەرسىيە.","","ئۇ يەردە يىقىلغان لەشكەرلەر ئۈچۈن،","سۆڭەكلىرى دەريا قەھرىگە ئايلانغانلار ئۈچۈن.","مۇشۇ يەردىن باشلىنىپ ئىلىم جاھانغا پۇت تىكتى."]},{"id":"poem-13-3","title":"كۆك-قوڭۇر رەڭلىك بىر نۇر چاقنىشى / تەرتىپسىز يەر ۋە تەرتىپسىز ئاسماننى سۈپۈرۈپ ئۆتىدۇ","lines":["كۆك-قوڭۇر رەڭلىك بىر نۇر چاقنىشى،","تەرتىپسىز يەر ۋە تەرتىپسىز ئاسماننى سۈپۈرۈپ ئۆتىدۇ،","جەڭ مەيدانىدىن قاچقان بىر چەۋەنداز،","ئۆز خورجۇنىدا ئېلىپ مېڭىپتۇ.","","ئالتۇن ياكى قاشتېشى ئەمەس،","بەلكى ياغاچ باسما تاختىسىنى،","مەدەنىيەتنىڭ بۆلىكىنى."]},{"id":"poem-13-4","title":"ئاھ، ھىلال ئاي ۋە تاڭ يۇلتۇزى / ئىسلامنىڭ ھىلال ئېيى ۋە تاڭ يۇلتۇزى","lines":["تالاستىن كېيىن، ھىلال ئاي كۆتۈرۈلدى،","يىپەك يولىنىڭ غەربىي قىرغاقلىرىغا.","ئاھ، ھىلال ئاي ۋە تاڭ يۇلتۇزى،","ئىسلامنىڭ ھىلال ئېيى ۋە تاڭ يۇلتۇزى.","","بۇددا بۇتخانىلىرى ئورنىدا مەسچىتلەر قەد كۆتۈرىدۇ،","سانسكرىت ئورنىدا ئەرەبچە ياڭرايدۇ،","بويسۇندۇرۇش ئەمەس، ئاققۇزۇپ كىرىش بىلەن ئۆزگەردى."]},{"id":"poem-13-5","title":"يەڭگىل، جىددىي ئات تۇياقلىرىنىڭ ئاۋازى / تالاس دەرياسىنىڭ سىمفونىيەسى تەرىپىدىن كۆمۈلۈپ كەتتى","lines":["يەڭگىل، جىددىي ئات تۇياقلىرىنىڭ ئاۋازى،","تالاس دەرياسىنىڭ سىمفونىيەسى تەرىپىدىن كۆمۈلۈپ كەتتى.","چېكىنگەن قوشۇن تارىختا سۇسلاپ كەتتى.","","ئەمما تارىخ ئاخىرلاشمايدۇ،","ئۇ پەقەت بىر بەتنى ئۆرۈيدۇ.","قەغەز ياسىغۇچىنىڭ ساداسى تارقالدى جاھانغا ئاستا."]}]},{"id":"chapter-14","title":"كىچىك يالغۇز قەلئە","poems":[{"id":"poem-14-1","title":"يۈز ئۆرۈپ قېچىۋاتقان ئۈچ يۈز جەڭچى / تېخىچە شەرققە چېپىۋاتىدۇ","lines":["يۈز ئۆرۈپ قېچىۋاتقان ئۈچ يۈز جەڭچى،","تېخىچە شەرققە چېپىۋاتىدۇ،","تالاستىن كېيىن، تەڭرىتېغىغا قاراپ،","تاڭ ئىمپېرىيەسىنىڭ ئاخىرقى قاراۋۇلخانىسىغا.","","ئۇلارنىڭ سەركەردىسى دېريادە قۇربان بولدى،","ئەمما ئۇلار توختىمىدى، يەنە شەرققە.","مۇستەھكەم يۈرەك ۋە قوغدىنىش بىلەن."]},{"id":"poem-14-2","title":"قار ئاق كېپىلەكلەردەك ياغىدۇ / غۇۋالىشىۋاتقان ئاي ئاستىدىكى جەڭ مەيدانىدا ئۇسسۇل ئويناپ","lines":["قار ئاق كېپىلەكلەردەك ياغىدۇ،","غۇۋالىشىۋاتقان ئاي ئاستىدىكى جەڭ مەيدانىدا ئۇسسۇل ئويناپ،","جەسەتلەرگە سوغۇق رەھىم يېپىنچىسىنى يېپىپ.","","قار قارغۇ ۋە رەھىمسىز گۈزەللىك،","تېرەك ۋە قىلىچ ئۈستىگە ئوخشاشلا چۈشىدۇ."]},{"id":"poem-14-3","title":"ئۇ چوقۇم ئىسسىقكۆلنىڭ دولقۇنلىرىنى ئاڭلىغاندۇ / ئات ئۈستىدىن تىڭشاپ","lines":["ئۇ چوقۇم ئىسسىقكۆلنىڭ دولقۇنلىرىنى ئاڭلىغاندۇ،","ئات ئۈستىدىن تىڭشاپ،","قوشۇن قالدۇقى غەربىي تەڭرىتېغىدىن ئۆتكەندە.","","تېز سۈرئەتتە ئۆتكەندىمۇ،","ئۇ مۇزدەك كۆلنىڭ ئاۋازىنى سېزىدى،","ھاياتنىڭ تىنچلىقىنى ئۈمىد قىلدى يەنە."]},{"id":"poem-14-4","title":"بىر ۋاقىتلاردا يىپەك جىلۋە قىلغان بۇ يولدا / ياش بىر شەھەر قەد كۆتۈرمەكچى","lines":["بىر ۋاقىتلاردا يىپەك جىلۋە قىلغان بۇ يولدا،","ياش بىر شەھەر قەد كۆتۈرمەكچى،","ئۇرۇش خارابىلىكىدىن ئەمەس،","بەلكى ئادەمنىڭ ياشاش ئىستىكىدىن.","","قەلئەلەر يىقىلغان يەردە كارۋانسارايلار بىنە بولىدۇ،","تارىخ توختىماي ئايلىنىدۇ گىلەمدەك."]}]},{"id":"chapter-15","title":"زۈمرەت يېشىل يارقەنت","poems":[{"id":"poem-15-1","title":"ئۇ چىراغنى كۆتۈرۈپ / قۇددۇسنىڭ مۇقەددەس يېغىنىڭ","lines":["ئۇ چىراغنى كۆتۈرۈپ،","قۇددۇسنىڭ مۇقەددەس يېغىنىڭ،","نەستۇرىي راھىبى يىپەك يولىدىن شەرققە يۈردى،","خوتەن پادىشاھلىقى تەرەپكە.","","ئۇنىڭ خورجۇنىدا خرىستنىڭ ھېكايىسى،","يىپەك ۋە دورا-دەرمان يېنىدا."]},{"id":"poem-15-2","title":"ۋېنىتسىيەنىڭ كۆك ئۆستىڭى / شۇ كىچىك شەھەر كۆزدىن غايىب بولغان ئاللىقاچان","lines":["ماركو پولو بۇ يەردىن ئۆتكەن،","ۋېنىتسىيەنىڭ كۆك ئۆستىڭى،","شۇ كىچىك شەھەر كۆزدىن غايىب بولغان ئاللىقاچان.","","ئۇ يەرلەرنى قۇملۇقلار، تۈزلەڭلىكلەر چۈمدۈرگەن،","ياشاۋاتقان بازارلار يەكەنگە يەتتى نەچچە ئەسىر."]},{"id":"poem-15-3","title":"ۋە ئۇ يەردە يەكەننىڭ / قۇدۇق چېركاۋىنىڭ تۆمۈر كرېستى ئېگىز كۆتۈرۈلۈپ تۇرىدۇ","lines":["ۋە ئۇ يەردە يەكەننىڭ،","قۇدۇق چېركاۋىنىڭ تۆمۈر كرېستى ئېگىز كۆتۈرۈلۈپ تۇرىدۇ،","مۇنارلاردىن ھۈپپىدە،","بۇددا راۋاقلىرىدىن ئېگىز.","","ئۈچ ئېتىقاد بىر بوستانلىقتا،","ئۈچ دۇئا بىر ئاسمانغا،","يىپەك يولىنىڭ سوۋغىسى: خىلمۇ-خىللىق."]},{"id":"poem-15-4","title":"توختاۋسىز ئېتىش / قۇملۇققا ئاق تاتىرىغان، سوغۇق ئوقلارنى","lines":["يەكەننىڭ ئۈستىدىكى ئاي،","توختاۋسىز ئېتىش،","قۇملۇققا ئاق تاتىرىغان، سوغۇق ئوقلارنى.","","يولنىڭ ئۆزىنى يىرتىپ، يىپەكنى ئەسلىتىپ،","كارۋانلار ئۆتكەن دەۋرىنى،","بارلىق مەدەنىيەتلەرنى ئۇلاشتۇرغان چاغنى تېپىپ."]}]},{"id":"chapter-16","title":"جىم ليۇپان تاغلىرى","poems":[{"id":"poem-16-1","title":"ئەمما كىممۇ ئىشىنەر / يېرىم ئەسىر بۇرۇن","lines":["ئەمما كىممۇ ئىشىنەر، يېرىم ئەسىر بۇرۇن،","چىڭگىزخاننىڭ ياۋروپاغا يۈرۈشى،","دۇنيانى تىترىتىشكە باشلىدى.","","مۇڭغۇل ئاتلىقلىرى بۇ تاغلاردىن ئۆتكەن،","پايتەختلەرنى ۋە پادىشاھلىقلارنى قىل ئۈستىدە قويۇپ،","ئۇلارنىڭ ئىزلىرى چۆلگە قېزىپ قويۇلغان."]},{"id":"poem-16-2","title":"چىڭگىزخاننىڭ تۆمۈر ئاتلىقلىرىنىڭ بۇ خارابىلىكلىرىنى كۆرگەندە","lines":["چىڭگىزخاننىڭ تۆمۈر ئاتلىقلىرىنىڭ بۇ خارابىلىكلىرىنى كۆرگەندە،","بىز ئەسكەرلەرنىڭ ئالقىشلىرىنى ۋە قىلىچ ئاۋازلىرىنى سېزەلەيمىز.","","ياغاچ جەسەتلەر چىرىدى،","ئەمما ئەپسانە يەنىلا تىرىك.","داۋانلاردىن ئۆتۈۋاتقان شامال قەدىمكى زامانلارنى پىچىرلايدۇ."]},{"id":"poem-16-3","title":"قۇملۇقتىن يولغا چىقىپ","lines":["قۇملۇقتىن يولغا چىقىپ،","تۈگىمەس تاكلاماكاندىن،","چيۇ چۈجى، تېيولوگ ۋە شائىر،","تاغقا سەپەر قىلدى.","","ئۇ خاننى تېپىشقا باردى،","ئۇنىڭغا ئۆلمەسلىكنى ئەمەس، بەلكى رەھىم-شەپقەتنى ئۆگىتىش ئۈچۈن.","قۇملۇقتىن يولغا چىقىپ، كەلگۈسىگە قاپار ئەكەلدى."]},{"id":"poem-16-4","title":"ئۇ ھېچقاچان كۈتمىگەن ئىدى","lines":["ئۇ ھېچقاچان كۈتمىگەن ئىدى،","قان ئىچەر فاتىھنىڭ قۇلاق سېلىشىنى.","","بىر قېرى راھىب بىر بۈيۈك پادىشاھ بىلەن،","ئىككى خىل قۇدرەت باش قوشتى ھىندىقۇشتا.","شەمشەر بىلەن نوم چۈشەنچىسى ھەقىقىي بىر مۇجادىلە قىلدى."]},{"id":"poem-16-5","title":"ئۇ ئاپىسى ئېيتىپ بېرىدىغان ناخشا ئىدى / ئاتتا چېپىپ كېتىۋېتىپ ئېيتىلغان","lines":["ئۇ ئاپىسى ئېيتىپ بېرىدىغان ناخشا ئىدى،","ئاتتا چېپىپ كېتىۋېتىپ ئېيتىلغان،","ئوچۇق يايلىقنىڭ مەرسىيەسى،","بۈركۈت تەڭ تۇرىدىغان، كىيىك ۋە تۈگىمەس ئاسماننىڭ.","","ئۇنى ئەمدى غۇڭقۇلداپ ئېيتىۋاتىدۇ،","نۇر ئۆچۈۋاتقان چەتتە،","ليۇپەن تاغلىرىدا،","ئۆزى تۇغۇلغان يايلىقتىن يىراقتا.","","ئۇ ئاپىسى ئېيتىپ بېرىدىغان ناخشا ئىدى،","ئەمدى بولسا، ئۇنىڭ ئۆلۈمىگىمۇ جۆر ئېيتقان شۇ ناخشا."]},{"id":"poem-16-6","title":"ئۇنىڭ ئېتى / تېخىچە غۇۋالىشىۋاتقان ئاي ئاستىدا تالماي جەۋرەيدۇ","lines":["ئۇنىڭ ئېتى،","تېخىچە غۇۋالىشىۋاتقان ئاي ئاستىدا تالماي جەۋرەيدۇ،","ئىگىسى كەتكەندىن كېيىنمۇ،","ئۇ قۇرغان ئىمپېرىيە، ئەپسانىگە ئايلىنىپ گۈمۈرۈلگەندىن كېيىنمۇ.","","ئات تارىخنى بىلمەيدۇ،","پەقەتلا ئالدىدىكى يولنى بىلىدۇ،","قەدىمكى تاشلارغا چۈشكەن تۇياق رېتىمىنى بىلىدۇ.","","ئۇنىڭ ئېتى تېخىچە چاپىدۇ،","ليۇپەن تاغلىرى ئارقىلىق،","تارىخ بەتلىرى ئارقىلىق،","يايلىقتا ئات مىنگەن ھەر قانداق كۆچمەننىڭ چۈشلىرى ئارقىلىق."]}]},{"id":"chapter-17","title":"ئېقىپ تۇرغان ئىلى دەريا","poems":[{"id":"poem-17-1","title":"بورانلار تارىخنىڭ چاڭ-توزانلىرىنى ئۇچۇرىدىغان جايدا","lines":["بورانلار تارىخنىڭ چاڭ-توزانلىرىنى ئۇچۇرىدىغان جايدا،","ئىلى دەرياسى بويىدا،","قەدىمكى شەرەپ ۋە قان توپا ئاستىغا كۆمۈلگەن.","","ئوتنى تۇتاشتۇرۇشقا بوۋاقلاردەك كېرەك ئىدى،","ئەمما ھەممىسى چاڭ-توزانغا ئايلاندى،","بوران پەقەتلا ھەپتىكى ھېكايىسىنى پىچىرلاپلا قالىدۇ."]},{"id":"poem-17-2","title":"ئۇ تېخىچە قەد كۆتۈرۈپ تۇرىدۇ / ھاۋارايىدا سۇسلاپ","lines":["ئۇ تېخىچە قەد كۆتۈرۈپ تۇرىدۇ،","ھاۋارايىدا سۇسلاپ،","قەلئە تاشلىرى قەدىمكى جەسۇرلۇق بىلەن گۇۋاھلىق بېرىپ.","","قىزىلمۇ ئۆچۈپ كەتتى، ئىدىيەلىرىمۇ،","ئەمما تاشلار قېرىسسىمۇ خارابلاشمايدۇ،","ياڭراق ياڭراق داۋام نامى گۇڭشىلاپ."]},{"id":"poem-17-3","title":"تېخىچە قەد كۆتۈرۈپ تۇرىدۇ، ھاۋارايىدا سۇسلاپ","lines":["تېخىچە قەد كۆتۈرۈپ تۇرىدۇ، ھاۋارايىدا سۇسلاپ،","ئويما خەتلەر زەپەرنى بايان قىلىدۇ،","ئەمما تاغ سۈكۈت قىلىدۇ،","شامال ئۇنتۇشنى سۆزلەيدۇ،","ئىلى دەرياسى ئېقىشنى سۆزلەيدۇ.","","يىراقتىكى گېگېن تېغى مۇشۇنداق قىلىدۇ،","ئۇرۇش بىر ئابىدىگە، ئابىدە بىر تاشقا، تاش بولسا تاغقا ئايلاندى."]},{"id":"poem-17-4","title":"ئۇنىڭ يىگىرمە ئىككى جەسۇر جەڭچىسى يىگىرمە ئىككى قارا بۇلۇتقا ئوخشايتتى / ئازادە ۋە تېز لەيلەپ","lines":["ئۇنىڭ يىگىرمە ئىككى جەسۇر جەڭچىسىلىرى يىگىرمە ئىككى قارا بۇلۇتقا ئوخشايتتى،","ئازادە ۋە تېز لەيلەپ،","ئىلى جىلغىسىدىن كېسىپ چىقىپ،","جۇڭغار قەلئەسىگە قاراپ.","","گېنېرال جاۋ خۇي،","ئۆزىنىڭ بۇ كىچىك، ئەمما يامان قوشۇنى بىلەن،","بىرلا يازدا ئاسىيانىڭ خەرىتىسىنى ئۆزگەرتتى.","","نۇرغۇن جەڭلەرگە شاھىت بولغان ئىلى،","ئېقىۋېرىدۇ داۋاملىق،","يا جەڭچى بولۇشى، ياكى پەقەت ئاسمان بولۇشى مۇمكىن بولغان،","قارا بۇلۇتلارنىڭ ئەكسىنى ئېلىپ مېڭىپ."]},{"id":"poem-17-5","title":"يىراقتىكى گېگېن تېغى / شۇ كارامەت جەڭ سىمفونىيەسىنى ئەمدى ئاڭلىغىلى بولمايدۇ","lines":["يىراقتىكى گېگېن تېغى،","شۇ كارامەت جەڭ سىمفونىيەسىنى ئەمدى ئاڭلىغىلى بولمايدۇ.","ئىمپېراتور ئورناتقان ئابىدە،","تېخىچە قەد كۆتۈرۈپ تۇرىدۇ، ھاۋارايىدا سۇسلاپ.","","خەت ئويما زەپەرنى سۆزلەيدۇ،","ئەمما تاغ سۈكۈتنى سۆزلەيدۇ،","شامال ئۇنتۇشنى سۆزلەيدۇ،","ئىلى دەرياسى ئېقىۋېرىشنى سۆزلەيدۇ.","","يىراقتىكى گېگېن تېغىدىكى ئاڭسىز ئۇرۇشمۇ،","ئاھ بىر ئابىدىگە، بىر تاشقا، تاش بولسا تاغقا ئايلاندى،","ئۆزىنى تۇتۇپ تۇرغان تۇپراقتىن پەرقسىز."]}]},{"id":"chapter-18","title":"جىگدە گۈلىدەك خۇشبوي مايمۇرە ئەزىم","poems":[{"id":"poem-18-1","title":"ئاھ، گۈزەل تەڭرىتېغى ئېيى / دەسسەپ-تەپلىنىپمۇ تەڭرىتېغى ئېيى يەنىلا گۈزەل","lines":["ئاھ، گۈزەل تەڭرىتېغى ئېيى،","دەسسەپ-تەپلىنىپمۇ تەڭرىتېغى ئېيى يەنىلا گۈزەل.","ئۇ مايمۇرەلنىڭ يۈزىنى يورۇتتى،","شۇ ئۇيغۇر ناخشىچىسىنىڭ يىپەكتەك ئاۋازى،","شامال بىلەن جىلغىنى كەزدى."]},{"id":"poem-18-2","title":"ئىنچىكە بارماقلار / بىر نەچچە سېرىقجىگدە مېۋىسىنى سىيپىلاپ","lines":["ئىنچىكە بارماقلار،","بىر نەچچە سېرىقجىگدە مېۋىسىنى سىيپىلاپ،","ئۇ مۇھەببەت ۋە يوقاتقانلار ھەققىدە ناخشا ئېيتىدۇ،","ئىككى ئىمپېرىيە ئوتتۇرىسىدا قالغان ۋەتىنى ھەققىدە،","ئۇنىڭ ئاۋازى ئۆزىنىڭ يېگانە تۇغىدۇر."]},{"id":"poem-18-3","title":"بۇلبۇل ئۇچۇپ كەتتى / ئۆلمەس بىر مۇھەببەت ناخشىسىنى ئېيتىپ","lines":["بۇلبۇل ئۇچۇپ كەتتى،","ئۆلمەس بىر مۇھەببەت ناخشىسىنى ئېيتىپ،","بىر ئەپسانەگە ئايلانماقچى:","ئىپارخان — خۇش بۇيلۇق خانىش،","بېيجىڭغا كۆتۈرۈپ كېتىلدى شەرققە،","خۇددى چۆل يۈرىكىدىن كەلگەن نادىر بىر پۇراقتەك."]},{"id":"poem-18-4","title":"كۆك ياقۇت كۆزلەر / تۇيۇقسىز چاقنىدى","lines":["كۆك ياقۇت كۆزلەر،","تۇيۇقسىز چاقنىدى،","ئىمپېرىيە خانىشىنىڭ چىراق يورۇقىدا،","ئۇ سېرىقجىگدە باقلىرىنى ئەسلەيدۇ،","قەشقەرنىڭ ئاي نۇرلۇق كېچىلىرىنى،","تەڭ قاتلىۋاتقان سۇبھى ساداسىنى.","","ئۇ چەكلەنگەن شەھەردە تۇرىدۇ،","بىر باقتىن يەنە بىر باغقا يۆتكەلگەن گۈلدەك،","تېخىچە ئېچىلغان بولسىمۇ،","چۆل ھاۋاسىنى تىلەپ."]},{"id":"poem-18-5","title":"كەلگۈسى ئىپارخاننىڭ بۈيۈك شەرققە يۈرۈشىنىڭ مۇقەددىمىسىنى توقۇش","lines":["كەلگۈسى ئىپارخاننىڭ بۈيۈك شەرققە يۈرۈشىنىڭ","مۇقەددىمىسىنى توقۇش،","تارىخ ئۆز ئەپسانىلىرىنى","ئۇلار يۈز بېرىشتىن بۇرۇنلا تەييارلايدۇ.","","قەشقەرنىڭ سېرىقجىگدە باقلىرىدا،","بىر قىز ناخشا ئېيتىدۇ،","غەربىي يۇرتلارنىڭ ئەڭ داڭلىق ئايالىغا","ئايلىنىدىغانلىقىنى بىلمەستىن.","","ئۇنىڭ خۇش پۇرىقى — مەيلى ھەقىقەت ياكى خىيال بولسۇن —","ئىمپېرىيە سارايلىرىنى ۋە شېئىر بەتلىرىنى،","مەڭگۈلۈك قاپلايدۇ."]}]},{"id":"chapter-19","title":"ئاھ، تاڭ يۇلتۇزى","poems":[{"id":"poem-19-1","title":"ئاھ، 1771-يىل / ئېدىل (ۋولگا) يايلىقىدىكى بۇ قاراڭغۇ قىش كېچىسى","lines":["ئاھ، 1771-يىل،","ئېدىل يايلىقىدىكى بۇ قاراڭغۇ قىش كېچىسى،","تورغۇت مۇڭغۇللىرى يوشۇرۇنچە توپلىنىشتى،","ئۇلارنىڭ بۈيۈك كۆچۈشى باشلىنىش ئالدىدا.","","يۈز يەتمىش مىڭجان،","روس قىشىدا شەرققە يۈزلەندى،","كۆپىنچىسى كۆرۈپ باقمىغان، ئەمما ناخشىلاردا ئاڭلىغان ۋەتىنىگە."]},{"id":"poem-19-2","title":"بۇ يايىق دەرياسىمۇ؟ / يۈزىدە چايقىلىدىغان دولقۇنلاردىن ئەسەرمۇ يوق","lines":["بۇ يايىق دەرياسىمۇ؟","يۈزىدە چايقىلىدىغان دولقۇنلاردىن ئەسەرمۇ يوق،","پەقەتلا قېلىن ۋە خەتەرلىك مۇزلا،","ئۆتۈشنىڭ بەدىلى ئېغىر بولدى.","","ھارۋىلار سۇندى، بالىلار يوقالدى،","قېرىلار قار ئۈستىدە ئولتۇرۇپ ئۆمۈرنى ئاخىرلاشتۇردى،","قايتىپ قوپماسلىق شەرتى بىلەن."]},{"id":"poem-19-3","title":"چىچېگىنىڭ ئارتۇق كۆز يېشى قالمىدى / ئۇ ئات ئۈستىدە بۇرۇلۇپ يىراقلارغا قارايدۇ","lines":["چىچېگىنىڭ ئارتۇق كۆز يېشى قالمىدى،","ئۇ ئات ئۈستىدە بۇرۇلۇپ يىراقلارغا قارايدۇ،","بەكمۇ ئۇزۇن يولنى بېسىپ كەلدى، بەسەيدىغان يەنە ئۇزۇن يول بار.","","يېرىمى يولدا ھاياتىدىن ئايرىلدى،","كېسەللىك، ئاچارچىلىق، كازاكلار ھۇجۇمى،","روس قوشۇنلىرى كۆك بۆرىدەك ئارقىسىدىن قوغلادى."]},{"id":"poem-19-4","title":"قىرغىز يايلىقى ۋە توڭلىغان كىچىك دەريا تېخىچە ئۇخلاۋاتىدۇ","lines":["قىرغىز يايلىقى ۋە توڭلىغان كىچىك دەريا تېخىچە ئۇخلاۋاتىدۇ،","ئەمما ئۇلارنىڭ يۈرۈشى ئىزچىل داۋاملاشتى.","","قازاقىستاننىڭ چەكسىز بوشلۇقلىرى ئارقىلىق،","ھەممىنى يۇتۇۋالىدىغان قارلار ئارقىلىق،","تېرىسىنى سويۇلىۋاتقان شامال ئارقىلىق.","","تورغۇتلار تاڭ يۇلتۇزىغا قاراپ ماڭدى."]},{"id":"poem-19-5","title":"ھارۋىنىڭ ياغاچ چاقلىرى / شەرققە ئاستا ئايلىنىدۇ","lines":["ھارۋىنىڭ ياغاچ چاقلىرى،","شەرققە ئاستا ئايلىنىدۇ،","قېرى سۆڭەكلەردەك غىچىرلاپ،","بۇتخانىلىرىدىكى دۇئا چاقلىرىدەك.","","ھەر بىر ئايلىنىش، ساپ ۋەتەنگە بىر چاقىرىم يېقىنلاشتۇرىدۇ،","ھەر بىر ئايلىنىش، سۈرگۈنلۈكتىن يىراقلاشتۇرىدۇ.","","قار-پاتقاق ئارقىلىق كېچە-كۈندۈز يەتتە ئاي،","ئىلى جىلغىسىغا يېقىنلاشتى."]},{"id":"poem-19-6","title":"ئاھ، بالخاش كۆلىنىڭ دولقۇنلىرى / يىراق، خىيالىي بىر چۈشتە كۆپۈكلەنگىلى ئۇزۇن بولغان","lines":["ئاھ، بالخاش كۆلىنىڭ دولقۇنلىرى —","يىراق، خىيالىي بىر چۈشتە كۆپۈكلەنگىلى ئۇزۇن بولغان،","ھازىر ئۇلارنىڭ كۆز ئالدىدا، كۆك ۋە ھەقىقىي.","","ئۇلار ياۋرو-ئاسىيانىڭ يېرىمىنى كېسىپ ئۆتتى،","مۇز كۆكتىن بالخاشقىچە،","يۈز يەتمىش مىڭنىڭ پەقەت يەتمىش مىڭىلا ساق قالدى.","","ئىمپېراتور ئۇلارنى ئىلى دەرياسى بويىدا كۈتۈۋالدى.","داڭلىق تاڭ يۇلتۇزى ئەمدى شەرققە قۇندى،","چۈنكى تەڭرىتېغى ۋە ئىلى جىلغىسى ئۈستىدە تەڭ كۆتۈرۈلۈپ،","يېڭى بىر ماكان ياراتتى."]}]},{"id":"chapter-20","title":"چېگرا ساداقەتلىك ئوغلى ئاھ-زار بىلەن يىغلايدۇ","poems":[{"id":"poem-20-1","title":"بالخاش كۆلىنىڭ قارا-كۆك يۈزىدە لەيلەپ يۈرگەن بۇ ئاي","lines":["بالخاش كۆلىنىڭ قارا-كۆك يۈزىدە لەيلەپ يۈرگەن بۇ ئاي،","لىن زېشۈگە چۈشكەن ئوخشاش،","ئىمپېراتور ئۇنى غەربىي يۇرتلارغا سۈرگۈنگە ئەۋەتكەندە.","","ئەپيۈننى كۆيدۈرگەن، ئىمپېرىيەگە جەڭ ئېلان قىلغان كىشى،","ھازىر شىنجاڭنىڭ ئۆستەڭلىرىدە ئاددىي بىر ئىشچىدەك ماڭىدۇ.","","ئەمما سۈرگۈندىمۇ ئۇ خىزمەت قىلدى،","يەر ئۆلچەپ، ئۆستەڭ لايىھەلەپ، دەرەخ تىكىپ.","بۇ ئاي ساداقەتمەننىڭ چېكىنىشىنى ۋە سۇنماس ئىرادىسىنى كۆردى."]},{"id":"poem-20-2","title":"قەدىمكى غەربىي يۇرتلارنىڭ تارىخىي كىتابىنىڭ بىر بېتىنى ئۇۋۇلاپ","lines":["قەدىمكى غەربىي يۇرتلارنىڭ تارىخىي كىتابىنىڭ بىر بېتىنى ئۇۋۇلاپ،","لىن زېشۈ كونا ئۆستەڭلەرنى ئىزلىدى،","ئىككى مىڭ يىل بۇرۇن خەن ئەسكەرلىرى قازغان.","","تارىخ تەكرارلىنىدۇ، سۇ كونا يولنى تاپىدۇ،","دېڭىز بويىدىن كەلگەن بىرەيلەن، ਚيۆলنىڭ تىلىنى ئۆگەندى."]},{"id":"poem-20-3","title":"ھەيران قالارلىق ئەمەس / سۈرلۈك چوققىنىڭ ئۆز يورۇق يۈزىنى كۆرسەتمەسلىكى","lines":["ھەيران قالارلىق ئەمەس،","سۈرلۈك چوققىنىڭ ئۆز يورۇق يۈزىنى كۆرسەتمەسلىكى،","تەڭرىتېغى ئىمپېرىيەنىڭ قېرىشىدىن قايغۇرۇپ بۇلۇتلار كەينىگە يوشۇرۇندى.","","لىن زېشۈ دۆلەت ئۈچۈن قىلىنغان گۇناھسىز جازا ھەققىدە،","تاغلار تەرىپىدىنمۇ چۈشىنىلدى."]},{"id":"poem-20-4","title":"چېگرا ئېيى ئاستىدا / يالتىراپ تۇرغان بىر ئوق تېز ئۇچىدۇ","lines":["چېگرا ئېيى ئاستىدا،","يالتىراپ تۇرغان بىر ئوق تېز ئۇچىدۇ،","لىن زېشۈنىڭ ئىرادىسى ئوق بولۇپ، يول سىزدى.","","ئۇ پەقەتلا ھەپتىكى ۋە نەپىقكە دۇچ كەلدى،","ئەمما شىنجاڭنىڭ تارىم يېشىللىقى ۋە ئىلى ئۆستەڭلىرى،","يەنىلا ئۇنى ئەسلەيدۇ ۋە تىرىك ساقلايدۇ."]}]},{"id":"chapter-21","title":"غەربىي دىياردا سېنى كىم تونۇمايدۇ؟","poems":[{"id":"poem-21-1","title":"قازاق پادىچىسى بەرگەن كۈل رەڭ بۈركۈت پەيلىرىنى / مېھرىبانلىق بىلەن سىيپىلاپ","lines":["قازاق پادىچىسى بەرگەن كۈل رەڭ بۈركۈت پەيلىرىنى،","مېھرىبانلىق بىلەن سىيپىلاپ،","سۈرگۈن قىلىنغانلار يىپەك يولىنىڭ ئاخىرقى قىسمىدا ماڭدى.","","ئىككى مىڭ يىللىق قەدەملەر،","ھەر بىرى بۇ جاينى بىلىدۇ ۋە ھۆرمەتلەيدۇ."]},{"id":"poem-21-2","title":"ئاياغ ئاستىدا سوزۇلغان قەدىمكى پوچتا يولى / چېگرادا قايغۇلۇق ناخشا ئېيتىپ","lines":["ئاياغ ئاستىدا سوزۇلغان قەدىمكى پوچتا يولى،","چېگرادا قايغۇلۇق ناخشا ئېيتىپ،","ھەر بىر تاش بىر ھېكايە، ھەر بىر خارابىلىك بىر باپ.","مۇشۇ رەھىمسىز چېگرا تۇپرىقىدا ھايات كەچكەنلەر ئۈچۈن."]},{"id":"poem-21-3","title":"بۇلۇتلار تەڭرىتېغى ئېيىنى توسۇۋالدى / سەن ئاستا كۆز ياشلىرىڭنى سۈرىسەن","lines":["بۇلۇتلار تەڭرىتېغى ئېيىنى توسۇۋالدى،","سەن ئاستا كۆز ياشلىرىڭنى سۈرىسەن،","چۈنكى بۇ تۇپراق شۇنچە شان-شەرەپنى كۆردى،","ئەمما قان ۋە يىپەك بىلەن، يىغلاپ كەلگەنلەر بىلەنمۇ تولۇق."]},{"id":"poem-21-4","title":"لەي لەي لەي / مېھرىبان سايرام كۆلى خۇش پۇراق شاراپقا تولغان","lines":["لەي لەي لەي،","مېھرىبان سايرام كۆلى خۇش پۇراق شاراپقا تولغان،","تاغلارغا قەدەھ كۆتۈرۈڭ، قاتلانغان يوللارغا،","بۇ زېمىندىن ئۆتكەن ھەر بىر مۇساپىرغا مەرھابا."]},{"id":"poem-21-5","title":"جەنۇبتىكى كۆك دېڭىزنى بىر چاغلاردا سۆيگەن / ۋە غەربتىكى بۇ مىڭلىغان كرىستال چوققىلارنىمۇ سۆيىدۇ","lines":["جەنۇبتىكى كۆك دېڭىزنى بىر چاغلاردا سۆيگەن،","ۋە غەربتىكى بۇ مىڭلىغان كرىستال چوققىلارنىمۇ سۆيىدۇ،","ئىككى خىل مەنزىرە، بىرلا يۈرەك.","","شەرق ۋە غەرب تارىخقا تەڭ شاھىت،","غەربىي يۇرتلاردىكى بۇ داستان ھەر جايدا داۋام ئېتەر،","تارىمدىن ئىلىغىچە، ياپيېشىل بەتلىكتە پۈتۈلۈپ. يىپەك يولى ئەسلەيدۇ، كۈلدۇرۇلگەن چۆل قۇمنى، يۈز ئاچقان غەربنى."]}]}]},"children":[["$","div",null,{"className":"fixed top-4 right-4 z-50","children":["$","$L9",null,{"currentLocale":"ug"}]}],["$","div",null,{"className":"max-w-4xl mx-auto pb-32","children":[["$","header",null,{"className":"pt-24 pb-12 px-8 text-center border-b border-gray-100 mb-12","children":[["$","h1",null,{"className":"text-4xl font-serif font-bold text-gray-900 mb-4","children":"قان تەرلەيدىغان ئاتلار"}],["$","p",null,{"className":"text-sm text-gray-400 font-sans","children":["لى يۈ"," / ","1995"]}]]}],[["$","div","chapter-1",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"ئاھ، ئوتتۇرا ئاسىيا يېڭى قىتئەسى"}],[["$","article",null,{"id":"poem-1-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"شۇ پارلاق ئوق تېخىچە ئۇچۇۋاتقان بولۇشى كېرەك / يىراق غەربكە قاراپ ئېتىلغان"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"قاناقتەك قىزىل پېتىۋاتقان كۈن ئۆلمەكچى،"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"قارا ئالتۇن رەڭلىك تۈن پەردىسى چۈشمەكچى،"}],["$","p","2",{"className":"min-h-[1.5em] ","children":["ئەمما ",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"جاڭ چيەن (م.ب. 164-114-يىللار چامىسى) - خەن سۇلالىسىنىڭ دىپلوماتى ۋە تەكشۈرگۈچىسى، قەيسەرىيىسى بىلەن يىپەك يولى ئېچىپ، غەربىي دىيارغا ئەلچى بولۇپ بارغان باشلامچى.","children":["جاڭ چيەن",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"نىڭ ئوقياسىدىن ئېتىلغان ئوق تېخىچە ئۇچماقتا،"]}],["$","p","3",{"className":"min-h-[1.5em] ","children":"يىراق غەربكە قاراپ، تېخى نامەلۇم يەرلەرگە قاراپ."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"يۈز يىللاپ، مىڭ يىللاپ ئۇچقان ئوق،"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"تاغلارنى ۋە چۆللەرنى چىكىپ ئۆتتى."}],["$","p","7",{"className":"min-h-[1.5em] ","children":"ئۇ بىر يىپەك ئوق،"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"يەر شارىنىڭ يېرىمىنى بىر-بىرىگە تىككەن."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-re