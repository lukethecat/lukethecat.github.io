2:["$","$L8",null,{"book":{"title":"جۇڭغار شېئىرلىرى","author":"لى يۈ","year":"1984","chapters":[{"id":"chapter-1","title":"بىرىنچى توم: يالقۇنلۇق گۈلخان","poems":[{"id":"poem-1-1","title":"تۇنجى ئورغاق ناخشىسى","lines":["ئور، ئور، ئور!","بىر پارچە شەپەقنى ئور، ئون مىڭ دولقۇن بۇغداينى ئور;","ئاخىرى بىز بۇ كۈننى كۆرۈشكە نېسىپ بولدۇق،","ئاخىرى كەڭ چېگرا بىزنىڭ ئالتۇن ئېتىزلىرىمىز بىلەن پارلىدى.","","كېچىمۇ جىمجىت ئەمەس — ھەممە نەرسە ئۆسىدۇ،","شادىيانە قار سۈيى جۇڭغارنىڭ سوقتۇرۇۋاتقان قېنى;","قوناق شاخلىرىنىڭ ئۆسكەن ئاۋازى شۇنچە ئېنىق،","ياۋا كىيىكلەرنى ۋە تارتىنچاق جەرەنلەرنى چۆچۈتىدۇ.","","يىغىلىڭلار — مول ھوسۇل بىزنىڭ تۇغىمىز!","ھەر بىر باش بۇغداي بىر ئوق","قۇملۇققا ئېتىلغان،","«بۇ يەردە ھېچ نەرسە ئۆسمەيدۇ» دېگەن سۆزلەرگە بېرىلگەن كۈچلۈك زەربە."]},{"id":"poem-1-2","title":"بىرلا ئېچىلىش","lines":["گۇربانتۇڭغۇت دېڭىزىدا يەلكەن ئېچىپ،","كومبايىن سۇس سەھەر نۇرىدا قوزغىلىدۇ،","ۋە يالتىراپ تۇرغان، ئالتۇن دولقۇنلار سەپ ھاسىل قىلىدۇ;","","بۇغداي تىغ ئالدىدا تاۋاپ قىلىدۇ،","چېكىنىۋاتقان ئالتۇن دولقۇندەك،","ۋە ئاچقۇچىلار تەنتەنە قىلىدۇ،","ئامبارلار تولغاندا،","يېڭى بىر دۇنيانىڭ نېنى بىلەن،","بىرلا ئېچىلغاندا."]},{"id":"poem-1-3","title":"باھار شامىلى قاشتېشى دەرۋازىسىدىن ئاللىبۇرۇن ئۆتتى","lines":["باھار شامىلى قاشتېشى دەرۋازىسىدىن ئاللىبۇرۇن ئۆتتى،","بىراق ھەيۋەتلىك تەڭرىتېغى تېخىچە ئۆزىنىڭ كرىستال قار تاجىنى كىيگەن;","يېڭى كۆچەتلەر ئۈچۈن يەنە بىر گۈرجەك مۇنبەت تۇپراق قوشۇپ قويۇڭ،","چۈنكى يېشىل رەڭ بولسا بويسۇندۇرۇشنىڭ رەڭگىدۇر،","بۇرۇن پەقەت قۇم ھۆكۈمرانلىق قىلغان بۇ چېگرادا.","","قەدىمكى شېئىردا مۇنداق دېيىلگەن:","«باھار شامىلى يۈمېنگۈەن (قاشتېشى دەرۋازىسى) دىن غەربكە ئۆتمەيدۇ» —","لېكىن بىز باھار شامىلىنى ئۆزىمىز بىلەن بىللە ئەكەلدۇق،","يانچۇقلىرىمىزدا، ناخشىلىرىمىزدا،","بىز كۆتۈرۈپ كەلگەن ئۇرۇقلاردا،","ئىللىق جەنۇبتىن ئاشۇ سوغۇق، نۇرلۇق شىمالغا."],"annotations":[{"term":"يۈمېنگۈەن ئۆتكىلى","note":"يۈمېن ئۆتكىلى (قاشتېشى قاپىقى) - دۇنخۇاڭدىكى قەدىمكى تاغ ئېغىزى، شىمالىي يىپەك يولىنىڭ چىقىش بېشى."}]},{"id":"poem-1-4","title":"بۈيۈك غەربىي شىمالغا يۈرۈش","lines":["بۇرۇن يىراقلاردىن خەتلەرنى تاپشۇرۇپ ئالغانسەن،","ئەمما ھېچقاچان مۇنچىلىك يىراقتىن ئەمەس;","بۇ خەت يەرنىڭ كەڭلىكىدىن كېسىپ ئۆتىدۇ،","سەن پەقەت كىتابلىرىدىنلا ئوقۇغان دەريالار ۋە تاغ تىزمىلىرى قېشىدىن.","","بىز بۇ يەرگە ئەدىياللىرىمىزنى دۈمبىمىزگە ئارتىپ يۈرۈش قىلىپ كەلدۇق،","تۆنۈگۈن ئەسكەر ئىدۇق، بۈگۈن خۇددى قاتما دېھقاندەك;","قۇملۇق بىزن كۈتۈۋالمىدى —","بىز ئۆزىمىزنى ئۆزىمىز كۈتۈۋالدۇق،","گۈرجەك ۋە ناخشىلار بىلەن،","ھەتتا قۇممۇ گۈللەشنى ئۆگىنەلەيدۇ، دېگەن مۇستەھكەم ئېتىقاد بىلەن."],"annotations":[{"term":"ئۇلۇغ غەربىي-شىمال","note":"ئۇلۇغ غەربىي شىمال - شىنجاڭ، گەنسۇ، چىڭخەيگە ۋەكىللىك قىلىدۇ. 1949-يىلىدىن كېيىن كۆپلىگەن ئەسكەرلەر رايوننى گۈللەندۈرۈشكە سەپەرۋەر قىلىندى."}]},{"id":"poem-1-5","title":"يەر ئاستى ئۆيىدە يېزىلغان كىچىك شېئىر — قۇم دۆڭى خاتىرىلىرى","lines":["ئون نەچچە يىل كېتىدۇ، شۈبھىسىز يېرىم ئەسىر،","بۇ قۇم دۆڭىدىكى قاراۋۇلخانا بىر شەھەرگە ئايلانغۇچە;","ئەمما بۈگۈن كېچە يەر ئاستى ئۆيىدە شەم يورۇقىدا شېئىر يازىمىز،","ۋە قۇرغۇچىلارنىڭ چۈشلىرىنى كۆرۈمىز،","قۇم ئىچىدىكى ئېگىز بىنالارنى كۆرەلەيدىغان بۈيۈكلەرنىڭ.","","«قۇم دۆڭى شەھىرى» — بىز بۇ يەرنى شۇنداق ئاتايمىز،","ئىككى قۇم دۆڭى ۋە بىر ئۇچۇم ئەسكەر،","يەر ئاستىدا ئۆڭكۈر چاشقانلىرىدەك ياشاۋاتقان،","ھەربىي قاتمىلارنى يەپ، قار سۈيى ئىچىۋاتقان،","ئۆيگە مۇنداق خەت يازىۋاتقان:","«ھەممە ئىش ئوڭۇشلۇق. كەلگۈسى پارلاق.","بۇ يەردىكى يۇلتۇزلارغا ئىشەنگىسىز.»"],"annotations":[{"term":"يەر ئۆي","note":"يەر ئۆي (يەر كەپە) - قۇم بورىنى ۋە قەھرىتان سوغۇقتىن مۇداپىئەلەنگەن دەسلەپكى بوز يەر ئاچقۇچى تېرىقچىلارنىڭ يېرىم يەر ئاستى ۋاقىتلىق ئۆيى ئىدى."}]},{"id":"poem-1-6","title":"تەڭرىتېغى ئاي نۇرى ئاستىدا — ئابدۇغا","lines":["مەن يەنە سېنىڭ كورىنىڭ يېنىدا تۇرغىنىڭنى كۆرگەندەك قىلىمەن،","سېنىڭ كەشتىلىك بادام دوپپاڭدا تېخىچە غەربىي شىمال فرونتىنىڭ تۈتۈنى ئەكىس ئېتىۋاتىدۇ;","بارسقىنىڭدىن چاچرىغان ئۇچقۇنلار","كېچىنى كىچىك يۇلتۇزلاردەك يورۇتىدۇ.","","ئابدۇ — ئۇيغۇر تۆمۈرچى، قورالداش بۇرادەر —","سەن بىزنىڭ كەتمەنلىرىمىزنى كېرەكسىز تۆمۈرلەردىن سوقتۇڭ،","قۇملۇقنىڭ بېلىنى سۇندۇرىدىغان ئاشۇ قوراللارنى،","سېنىڭ قارىداش ۋە ماھارەتلىك قوللىرىڭ شەكىللەندۈرگەن،","ئوچاقتىكى قىزغۇچ ئىسسىقتىن ئېلىپ،","تەڭرىتېغى ئاي نۇرى ئاستىدا."],"annotations":[{"term":"تەڭرىتېغى","note":"تەڭرىتېغى - ئوتتۇرا ئاسىيادىكى ئۇزۇنلۇقى ۋە جۇڭگو شىنجاڭنى شىمال ۋە جەنۇبقا ئىككىگە بۆلىدىغان غايەت زور يادرولۇق تاغ چوققۇسى ۋە تومۇرى."}]},{"id":"poem-1-7","title":"O, Red Willow","lines":["O, red willow,","Your leaves calmly unfurl against the west wind,","Your branches furiously shatter the storm clouds;","","Deepest root in the alkali flats,","Brightest bloom in the salt-white waste,","You taught us how to live here:","Drink the bitter water","And flower anyway.","","O, red willow,","Soldier of the desert,","Poet of the sand —","We named our roads after you,","And our daughters too."],"annotations":[{"term":"يۇلغۇن","note":"يۇلغۇن دەرىخى - سۇسىزلىق ۋە قۇرغاقچىلىققا چېداملىق دەرەخ، چېگرا ياشلىرىنىڭ قەيسەر ۋە بوشاشماس مەسئۇلىيىتىنىڭ چوڭقۇر ۋە روشەن مەجازىدۇر."}]},{"id":"poem-1-8","title":"ئاي نۇرى بىلەن يالتىراپ","lines":["ئاي نۇرى بىلەن يالتىراپ،","يۇلتۇز نۇرى بىلەن يالتىراپ;","تۆپىلىشىۋاتقان قار دولقۇنلىرى ئۆزىنىڭ لىرىك كېچە ناخشىسىنى ئېيتماقتا،","تەڭرىتېغى نۇرلۇق بىر تامدەك قەد كۆتۈرىدۇ،","بىز بىلەن ئاسمان ئوتتۇرىسىدا.","","كېچە ئۆسۈۋاتقان نەرسىلەرنىڭ پىچىرلىشىگە تولغان،","قاراڭغۇلۇقتا يېرىلىۋاتقان كېۋەز غوزىلىرى،","سۇغىرىش ئۆستەڭلىرىدە غۇرۇلداۋاتقان سۇلار،","ۋە قەيەردىدۇر، شەندۇڭنىڭ بىر كۈيىنى چېلىۋاتقان گارمون،","بۇ يەردە، جۇڭغارنىڭ يۇلتۇزلىرى ئاستىدا."]},{"id":"poem-1-9","title":"چاقناپ تۇرغان گۈلخان يېقىش — كىيىكلەرگە","lines":["بۇ يەردە،","بىز چاقناپ تۇرغان گۈلخان ياقىمىز،","ۋە بۇ پارلاق دەقىقىدىن باشلاپ قۇملۇقنىڭ يېڭى دەۋرى باشلىنىدۇ;","","كىيىكلەر يۇلغۇنزارلىقلاردىن قارايدۇ،","ئۇلارنىڭ كۆزلىرىگە گۈلخان نۇرى چۈشكەن;","ئۇلار بىزدىن تېخى قورقمايدۇ،","بىز بۇ تۇنجى ئاچقۇچىلار،","دورا ئەمەس، بەلكى تۇپراق ۋە تەر پۇرايدىغانلار.","","سۆيۈملۈك كىيىكلەر — بىز سىلەرنىڭ يېڭى قوشناڭلار،","ئىككى پۇتلۇق مەخلۇقلار،","گۈلخان يورۇقىدا رىتىمسىز ناخشا ئېيتىدىغان،","ۋە سىلەرگە ھېچقانداق يامانلىق ئويلىمايدىغان."]},{"id":"poem-1-10","title":"قۇم دۆڭى ئاستىدا يېشىل بىر چۈش كۆرۈش","lines":["بىز ئاللىبۇرۇن كەشتىلەنگەندەك شاللىقلار بىلەن خوشلاشتۇق،","بىز ئاللىبۇرۇن توپلاشقان يېڭى كەنتلەر بىلەن خوشلاشتۇق —","جيياڭنەن ۋەتىنىمىز ئەمەس،","ئەمما خۇددى ۋەتىنىمىزدەك بىلىنگەن بىر جاي.","","ھازىر قۇم دۆڭى ئاستىدا بىز يېشىل بىر چۈش كۆرۈۋاتىمىز،","باغلار ۋە ئۆستەڭلەرنىڭ چۈشىنى،","مەكتەپلەر ۋە شىپاخانىلارنىڭ چۈشىنى،","يۈرۈشنىڭ قوڭۇر رەڭگىنى ئەمەس،","بەلكى ئۆسۈۋاتقان نەرسىلەرنىڭ يېشىللىقىنىلا بىلىدىغان بالىلارنىڭ چۈشىنى."]},{"id":"poem-1-11","title":"بۈگۈن كېچە ئۇلار يەنە يۇلغۇن كۆۋرۈكتىن ئۆتىدۇ","lines":["بىز ئىلگىرى تاش كۆۋرۈكلەردىن ئۆتكەن،","بىز ئىلگىرى يەككە ياغاچ كۆۋرۈكلەردىن ئۆتكەن;","بىر ئۆمۈردە قانچىلىك كۆۋرۈكتىن ئۆتكەندىمىز،","ئەمما بىرلەشتۈرۈلگەن يۇلغۇن شاخلىرىدىن ياسالغان بۇ كۆۋرۈك،","ئەستە ساقلايدىغان بىردىنبىر كۆۋرۈكتۇر.","","ئۇ ئۆتۈكلىرىمىز ئاستىدا تەۋرىنىدۇ،","قۇملۇقنىڭ بىردىنبىر ياغىچىدىن،","يىمىرىلمەس يۇلغۇندىن، ئۆزىمىز ياسىغان بۇ كۆۋرۈك.","","بۈگۈن كېچە ئۇلار يەنە يۇلغۇن كۆۋرۈكتىن ئۆتىدۇ،","توسما قۇرۇلۇش مەيدانىغا قاراپ،","كەلگۈسىگە قاراپ."]},{"id":"poem-1-12","title":"بۇ بىر قاچا تەڭرىتېغى قار سۈيىنى ئىچىڭ","lines":["پېشقەدەم ئەسكەرلەر بىزنى بىر چاغلاردا مۇشۇنداق كۈتۈۋالغان،","قۇملۇقنى بويسۇندۇرۇشقا كەلگەن يېڭى ئەسكەرلەرنى كۈتۈۋېلىپ;","بۇ بىر قاچا تەڭرىتېغى قار سۈيىنى ئىچىڭ،","كرىستالدەك سۈزۈك، تاغنىڭ يۈرىكىدەك سوغۇق.","","بۇ بىزنىڭ شارابىمىز، بىزنىڭ كۈتۈۋېلىش قەدىھىمىز —","ئۈزۈم شارابى ئەمەس، گۈرۈچ شارابى ئەمەس،","بەلكى يەر يۈزىدىكى ئەڭ پاكىز سۇ،","بىۋاسىتە نەزەرلەرىڭلىق مۇزلۇقتىن،","سىلەرنىڭ يېرىلغان لەۋلىرىڭلەرگە تومغان.","","ئىچىڭ — ۋە سەپدېشىمىزغا ئايلىنىڭ."]},{"id":"poem-1-13","title":"ئۇلار سېنى «مول ھوسۇل ياۋا غازى» دەپ ئاتايدۇ","lines":["ئورمان بەلۋاغلىرى ئۈستىدىن، يوللۇق ئېتىزلار ئۈستىدىن سىيرىلىپ ئۆتۈپ،","گۇربانتۇڭغۇت دېڭىزى بۇلۇتلار ۋە دولقۇنلارنى كۆتۈرىدۇ;","ئۇ سېنىڭ قىزغىن سالىمىمغا،","ماتورۇڭنىڭ گۈرۈلدىشى بىلەن جاۋاب بېرىسەن،","ياۋا غاز، مول ھوسۇلنىڭ ياۋا غازى،","تراكتور ۋە كومبايىن،","چېگرانىڭ مېخانىك قۇشى،","بۇغداينى توشۇۋاتقان."],"annotations":[{"term":"مول ھوسۇللۇق ياۋا غازلار","note":"مول ھوسۇل سىمۋولى بولغان ياۋا غاز (قاز) - كۆچمەن پوچتىغا ئىجازەت بولۇپ، ئەتراپ ۋە يىراق مەھەللىلەرگە ياخشى ھوسۇلنىڭ خۇش خەۋەرلىرىنى يەتكۈزۈشنى بىلدۈرىدۇ."}]},{"id":"poem-1-14","title":"ھەسەلدەك تاتلىق ھاياتنى دەملەش","lines":["بوستانلىق كرىستالدەك پارلايدۇ،","ھەسەلچىلەر ھەسەل ھەرىلىرىنى جەنۇبقا بولغان سەپەرگە تەييارلىغاندا.","ھەر كۈز پەسلى ئۇلار باقمىلار بىلەن كۆچىدۇ،","تاغلار ئارا گۈللەرنى قوغلاپ.","","ھەسەلدەك تاتلىق ھاياتنى دەملەش،","بۇ تاتلىقلىقنىڭ كۆچمەنلىرى،","بۇ گۈللەرنىڭ ئەگەشكۈچىلىرى،","ئۇلار ھەر بىر جىلغىنى شىرنىسىنىڭ تەمىدىن بىلىدۇ."]},{"id":"poem-1-15","title":"ئاھ، جىرىڭلايدىغان تۆگە قوڭغۇراقلىرى","lines":["بىزنىڭ يۈرەكتىن سىردىشىشقا ئارانلا ۋاقتىمىز بولدى،","ئۇلار يەنە يولغا چىقىشتىن بۇرۇن;","ئاھ، جىرىڭلايدىغان تۆگە قوڭغۇراقلىرى،","كۆچمە رېمونت ئەترىتىنىڭ،","قۇملۇقتىن زاپاس زاپچاسلار ۋە ماي بىلەن ئۆتۈۋاتقان،","بىر سەييارە سېخ،","تۆگىنىڭ دۈمبىسىدە.","","جۇڭغارنىڭ كەڭلىكىدە،","رېمونت قىلىشمۇ بىر سەپەر تەڭدىشى ئەتەر."]},{"id":"poem-1-16","title":"قۇم ئەنۋەرنىڭ مەڭزىگە ئۇرىدۇ","lines":["قۇم ئەنۋەرنىڭ مەڭزىگە ئۇرىدۇ،","قۇم ئەنۋەرنىڭ يوپكىسىغا ئۇرىدۇ،","كۈل-قوڭۇر قۇملۇق تۈگىمەستىن سوزۇلىدۇ.","","ئۇ شامالغا يۈزلىنىپ ماڭىدۇ","خۇددى شامال ئو ھېچنېمىدەك ئەمەستەك،","بۇ ئۇيغۇر قىزى، قالغۇنى تاللىغان باشقىلار كەتكەندە.","","ئۇنىڭ ياغلىقى ئارقىسىدا لەپىلدەيدۇ","خۇددى ئۈنسىز جەسۇرلۇقنىڭ تۇغىدەك."]},{"id":"poem-1-17","title":"مەن قۇملۇق دېڭىزىنىڭ غايەت دولقۇنلىرىنى ئاستا سىيپىلايمەن","lines":["مەن قۇملۇق دېڭىزىنىڭ غايەت دولقۇنلىرىنى ئاستا سىيپىلايمەن،","بۇ يەردە، سالاپەت بىلەن بىر خارابىلىككە ھۆرمەت قىلىمەن.","چىن سۇلالىسىنىڭ ئېيى قەيەردە؟","خەن سۇلالىسىنىڭ ئوت سىگناللىرى قەيەردە؟","","ئاياغ ئاستىمدا بىر تارىخ ياتىدۇ","كارۋانلار ۋە فاتىھلەرنىڭ تارىخى،","قەد كۆتۈرگەن ۋە يىقىلغان شەھەرلەرنىڭ تارىخى","خۇددى بۇ قۇم ئوكيانىدىكى دولقۇنلاردەك.","","مەن قۇملۇقنى ئاستا سىيپىلايمەن","ۋە ئىككى مىڭ يىللىق قەدەملەرنى سېزىمەن."],"annotations":[{"term":"كەڭ قۇم دېڭىزى (خەنخەي)","note":"باياۋان (خەنخەي) - شىمالدىكى ئۇپۇقسىز قۇملۇق يەنى گۇربانتۇڭغۇتقا ئوخشاش قاقاس ۋە غايەت چوڭ دېڭىزدەك سۈپەتلەنگەن گوبىي باياۋاننى كۆرسىتىدۇ."}]},{"id":"poem-1-18","title":"يىراق بىر يات ئەلدە قۇم بورىنى ئىچىگە كىرىپ قېلىش — ئاچقۇچىنىڭ چۈشى","lines":["تەۋرىنىۋاتقان تېرەكلەر،","چېپىۋاتقان قار سۈيى،","لەيلەپ تۇرغان ئۇپۇق;","","يىراق بىر يات ئەلدە، قۇم بورىنى ئىچىگە مېڭىش،","ئاچقۇچى بىر شەھەرنى چۈشىدە كۆرىدۇ","تېخى مەۋجۇت بولمىغان،","ھېلىھەم تۆگە يولى بولغان يوللارنى،","ھېلىھەم قۇملۇق بولغان باغلارنى.","","لېكىن چۈش شۇنچە روشەنكى","ئۇ ئۆرۈك گۈللىرىنىڭ پۇرىقىنى ئالالايدۇ","ۋە مەكتەپ دەرۋازىسىنىڭ جىرىڭلىغان ئاۋازىنى ئاڭلىيالايدۇ","قەد كۆتۈرىدىغان شۇ شەھەردە","ئۇنىڭ ئايىغى ئاستىدىكى قۇملاردىن."],"annotations":[{"term":"تېرىقچى باشلامچىلار","note":"تېرىقچى باشلامچى (كەشپىياتچى ئەسكەرلەر) - شىنجاڭ ئىشلەپچىقىرىش ۋە قۇرۇلۇش بىڭتۇەنىنىڭ قۇملۇقنى بوستانلىققا ۋە كۆكتاتزارلىققا ئايلاندۇرغان تۇنجى بوز يەر ئاچقۇچىلىرى."}]},{"id":"poem-1-19","title":"بۇ خارابىلىكلەر بىلەن ۋاقتىنچە خوشلىشىش","lines":["بۇ خارابىلىكلەر بىلەن ۋاقتىنچە خوشلىشىش،","تەسەۋۋۇر قاناتلىرىغىمۇ كىيگۈزەي ئۆزۈمنى.","بۇ يەردىكى بۇلۇتلاردىن يامغۇر سىقىپ چىقارغىلى بولمايدۇ،","شۇڭا بىز ئۇنىڭ ئورنىغا ئۆستەڭ قازىمىز.","","قۇملۇقتا، چۈش كۆرگۈچىلەر قازىدۇ.","خارابىلىكلەر بىلەن خوشلىشىش","كەلگۈسىنى كۈتۈۋېلىشتۇر،","قولىدا گۈرجەك بىلەن."]},{"id":"poem-1-20","title":"ئاچقۇچىلار بوستانلىقىدىكى كۆك ياقۇت","lines":["مۇساپىر گوبى دېڭىزىدىكى كېمىسىدىن قارايدۇ،","ئاچقۇچىلار بوستانلىقىغا ئورنىتىلغان كۆك ياقۇت;","يىراقتىكى سايرام كۆلى مۇشۇ يەرگىچە دۇمىلىغانمىدۇ؟","","ياق — بۇ بىر سۇ ئامبىرى،","قولدا قېزىلغان، قار سۈيى بىلەن تولدۇرۇلغان،","بىز ئۆزىمىز ياسىغان مەرۋايىت","قۇملۇقنىڭ قوڭۇر ئارقا كۆرۈنۈشىدە."]},{"id":"poem-1-21","title":"شۇ ئاپامنىڭ قول ئىزى","lines":["كىم قۇملۇق كېچىسىدە تۈتۈننىڭ بىر سىزىقىنى سىزغان؟","پېتىۋاتقان قۇياش ئالتۇن يىلانلار پارقىراۋاتقان كۆل يۈزىدە لەيلەۋاتىدۇ;","بېلىقچى كېمىلىرى ھازىرغىچە قايتىپ كېلىشى كېرەك ئىدى —","","ئەنە ئاپام قوللىرىنى پۇلاڭلىتىپ","يېڭى سۇ ئامبىرىنىڭ قىرغىقىدىن،","باش بالىلىرىنى كەچلىك تاماقتىن چاقىرىپ،","ئاپىلار يىللاردىن بۇيان قىلغاندەك","تۇنجى گۈلخان يېقىلغاندىن باشلاپ."]},{"id":"poem-1-22","title":"شۇنچە كۆپ چوڭقۇر ھېسسىيات يىپلىرى بىلەن توقۇلغان","lines":["كېچە تەڭرىتېغىنىڭ ھەيۋەتلىك كرىستال قار تاجىنى يوشۇرىدۇ،","ۋە دولقۇنلاۋاتقان قار سۈيىنىقنى يوشۇرىدۇ،","ۋە چاققان ماتورلۇق يەلكەنلىك كېمىنى يوشۇرىدۇ.","","لېكىن ناخشىلارنى يوشۇرالمايدۇ","شۇنچە كۆپ چوڭقۇر ھېسسىيات يىپلىرى بىلەن توقۇلغان،","قاراۋۇلخانىلاردىن كۆتۈرۈلۈۋاتقان،","ۋەتەن ۋە سېغىنىش ناخشىلىرىنى،","يورۇقلۇقتىنمۇ يىراققا بارىدىغان ناخشىلارنى","چېگرانىڭ قاراڭغۇلۇقى ئارقىلىق."]},{"id":"poem-1-23","title":"ئاھ، شۇنچە كەڭ كەتكەن سۇس كۆك تاڭ تۇمانلىرى","lines":["ئاي غۇۋا ئاسماندىن سىيرىلىپ چۈشتى،","يۇلتۇزلار غۇۋا ئاسماندىن سىيرىلىپ توختىدى،","ئاھ، شۇنچە كەڭ كەتكەن سۇس كۆك تاڭ تۇمانلىرى.","","سەھەردىكى قۇملۇق","پۈتۈنلەي باشقا بىر دۆلەتتەك بولىدۇ،","سالقىن ۋە مۇلايىم ۋە كۆك رەڭلىك،","قۇياش ئۆزىنىڭ ئالتۇن بولقىسى بىلەن","كېلىپ باقمىغان ۋاقىتتا."]},{"id":"poem-1-24","title":"تېئودولىت ئارقىلىق قاراش","lines":["پەس ئۇچۇۋاتقان بىر قۇشنى كۆرۈپ،","يېشىل مايسىلارنى كۆرۈپ،","تېئودولىت ئارقىلىق قاراش;","","ئۆلچىگۈچى كەلگۈسىنىڭ خەرىتىسىنى سىزىدۇ","ھەر بىر ئۆلچەش بىلەن تەڭ،","يوللار ۋە ئۆستەڭلەر ۋە توك سىزىقلىرىنى بەلگىلەيدۇ","مىڭ يىلدىن بويى پەقەتلا","شامال ۋە قۇمنى بىلىپ كەلگەن","بىر مەنزىرىدە."]},{"id":"poem-1-25","title":"تاج كىيگەن كىچىك قۇش","lines":["ئۇ قارا قاقاسلىق ئۈستىدىن ئەمدىلا ئۇچۇپ ئۆتۈپ،","بۇ باغلارنىڭ كەلگۈسىسگە ئەمدىلا قونغان،","تەڭرىتېغىنىڭ قار سۈيى پەيلىرىنى تۈزەيدۇ;","","كىچىك ھۆپۈپ، تاجلىق ئەلچى،","سەن دەرەخلەردىن بۇرۇنمۇ يېتىپ كەلدىڭ،","باغلار ۋە سايىلاردىن بۇرۇن،","خۇددى بىزنىڭ نېمە قۇرىۋاتقانلىقىمزنى بىلگەندەك","ۋە بىرىنچى بولۇشنى خالىغاندەك."]},{"id":"poem-1-26","title":"پەقەتلا باھار ئۈچۈن رىقابەتلىشىش","lines":["يېشىل كۈزدىكى بۇغدايلار قەيەرگە يوشۇرۇندى؟","كۈمۈش-كۈل رەڭ پاناھلىق بەلۋاغلىرى قەيەرگە يوشۇرۇندى؟","قار بورىنى دولقۇنلىرى بىز ئاچقان بوستانلىقنى يۇتۇۋالدى،","","لېكىن باھار كەلگۈچە پەقەت —","باھار كەلگۈچە پەقەت،","شۇ چاغدا يېشىل رەڭ ئاقتىن يېرىپ چىقىدۇ","خۇددى زەپەر ناداسىدەك،","ۋە پاناھلىق بەلۋاغلىرى قايتىپ كېلىپ","بۇغدايلار يېقىنلىشىدۇ يەنە قەد كۆتۈرىدۇ،","پەقەتلا باھار ئۈچۈن رىقابەتلىشىش ئۈچۈن."]},{"id":"poem-1-27","title":"شامال ئىزىنى بويلاپ قوغلاش","lines":["گۇربانتۇڭغۇت دېڭىزدەك سالاپەتلىك،","بۇلۇتسىز ئاسمان كۆك ھەم نۇرلۇق;","بىر سىقىم شامالمۇ ھوشيار كۆزدىن قېچىپ قۇتۇلالمايدۇ،","","چۈنكى بۇلار قۇم مۇستەھكەملەش كۆزەتچىلىرى،","شامال ئىزىنى بويلاپ قوغلايدىغان،","شامالنىڭ ئىزلىرىغا ئوت-چۆپ ۋە يۇلغۇن تىكىدىغان،","قۇم دۆڭلىرىنى يېشىل تورلارغا قامايدىغان","ئۆزلىرى لايىھەلىگەن."]},{"id":"poem-1-28","title":"'ئا نۇقتىسى — ئا نۇقتىسى...'","lines":["قىزغۇچ سېرىق قۇم دۆڭلىرى قىزغۇچ ئاسمان بىلەن قوشۇلدى،","دولقۇنلاۋاتقان قۇملۇق دېڭىزىدا سۇس دولقۇن ئۈستىدىكى يالغۇز كېمە;","مارش ناخشىسىنىڭ رىتىمى ھاۋادا لەيلەيدۇ،","","ۋە ئۆلچىگۈچى كوردىناتلىرىنى توۋلايدۇ","'ئا نۇقتىسى — ئا نۇقتىسى...'","ئورۇننى بەلگىلەيدۇ","بىر مەكتەپ قەد كۆتۈرىدىغان جاينى،","يە بىر دوختۇرخانامۇ،","ياكى دەرەخلەر ۋە بالىلار كۈلكىسى بار باغچىمۇ،","يىگىرمە يىلدىن كېيىن —","ئەللىك يىلدىن كېيىن —","'ئا نۇقتىسى — ئا نۇقتىسى...'"]},{"id":"poem-1-29","title":"ئېچىلغان قار ئۇچقۇنلىرى ئاللىبۇرۇن سولۇپ كەتتى","lines":["ئېچىلغان قار ئۇچقۇنلىرى ئاللىبۇرۇن سولۇپ كەتتى،","پەس سېلىنغان ئاسماندىن پەرۋاسىزلىق بىلەن سولۇپ چۈشتى;","قۇملۇقنىڭ مۇستەھكەم سۇ ئامبىرىغا — تەڭرىتېغىنىڭ مۇز چوققىلىرىغا چۈشتى،","","ساقلاش ۋە زاپاس قىلىش ئۈچۈن","ئۇزۇن، ئىسسىق ياز ئۈچۈن،","شۇ چاغدا ئۆستەڭلەر مۇزلۇقلارنى ئىچىدۇ","ۋە ئۇلارنىڭ سوغۇق تاتلىقلىقىنى كۆتۈرىدۇ","پەسكە، ئېتىزلارغا،","پەسكە، باغلارغا،","پەسكە، قىش سۈكۈتتە قۇرۇۋاتقان","يېشىل بىر چۈشكەقاراپ."]}]},{"id":"chapter-2","title":"ئىككىنچى توم: سەركەردە ۋە شەھەر","poems":[{"id":"poem-2-1","title":"ئۇ تاڭ ئېتىشتىن بۇرۇن ئالەمدىن ئۆتتى","lines":["ئۇ تاڭ ئېتىشتىن بۇرۇن ئالەمدىن ئۆتتى،","شەھەرنى قۇرغان گېنېرال،","ئەسكەرلەرنى تاشيول قۇرغۇچىلارغا ۋە دېھقانلارغا ئايلاندۇرغان،","«بىز بۇ يەردىن كەتمەيمىز» دېگەن كىشى.","","ئۇنىڭ ئاخىرقى تىنىقى يۇقىرىغا كۆتۈرۈلدى","ئۆچۈۋاتقان گۈلخاننىڭ تۈتۈنىدەك،","ۋە ئۇ قۇرغان شەھەر","ئۇنىڭسىز داۋام قىلدى،","كوچىلىرى سەھەر نۇرى بىلەن تولۇپ."],"annotations":[{"term":"تاڭ ئېتىشتىن بۇرۇن","note":"تاڭ ئېتىشتىن بۇرۇن - 1949-يىلى سېنتەبىردە شىنجاڭنىڭ تىنچلىق بىلەن ئازاد بولۇشىدىن بۇرۇنقى قاراڭغۇ چاغلارنى كۆرسىتىدىغان زامان مەجازى."}]},{"id":"poem-2-2","title":"ئۇمۇ قېنىق ئالتۇن رەڭلىك سىگنال دولقۇنىغا ئايلاندى","lines":["ئۇنىڭ رادىيو سىگنالى كىچىك ئۆيدىن سىرتقا تارقالدى،","تەڭرىتېغى كېچىسى ئارقىلىق،","يىراقنىڭ شاۋقۇنى ئارقىلىق —","ئۇمۇ قېنىق ئالتۇن رەڭلىك سىگنال دولقۇنىغا ئايلاندى،","بۇ چېگرا ئايالى،","ھاۋارايى ئوقۇشلىرىنى يەتكۈزگەندە","ۋە قوشۇن ئورۇنلىرىنى","ۋە مۇھەببەت خەتلىرىنى","قۇملۇق ھاۋا دولقۇنلىرىنىڭ شىرىلداشلىرى ۋې غۇرۇلداشلىرى ئارقىلىق."]},{"id":"poem-2-3","title":"پرومېتېي كېچىنىڭ ئېغىر پەردىسىنى يورۇتتى","lines":["پرومېتېي كېچىنىڭ ئېغىر پەردىسىنى يورۇتتى —","ياكى ئۇ شەندۇڭدىن كەلگەن ئېلېكترىكمىدى،","تۇنجى توك سىزىقىنى تارتماق بولغان،","گۇربانتۇڭغۇت ئارقىلىق،","ئېلېكترونلۇق يورۇقلۇقنى ئېلىپ كەلگەن،","پەقەتلا شەم، گۈلخان ۋە يۇلتۇزنىلا","بىلىدىغان بىر جايغا؟","","پرومېتېي كېچىنىڭ ئېغىر پەردىسىنى يورۇتتى،","ۋە قۇملۇق ھەيرانلىق بىلەن كۆزىنى قىسىپ قويدى."],"annotations":[{"term":"پرومېتېي","note":"پرومېتېي - ئىنسانلار ئۈچۈن قۇربان بولۇپ ئوت ئوغۇرلىغان گىرېك ئەپسانىسىدىكى تەڭرى. ئۇلارنىڭ نۇرى قۇملۇققا ئۈمىد بىلەن كەلگەن جەسۇر ئەسكەرلەردۇر."}]},{"id":"poem-2-4","title":"تاڭ قىرغىقىغا يېتىش ئۈچۈن كېچىنى كېسىپ ئۆتۈش شەرت","lines":["تاڭ قىرغىقىغا يېتىش ئۈچۈن كېچىنى كېسىپ ئۆتۈش شەرت —","بۇ شۇئار ئىدى","چېگرادىكى ھەر بىر ئاچقۇچىنىڭ،","دېھقانغا ئايلانغان ھەر بىر ئەسكەرنىڭ،","قوشۇنىغا ئەگىشىپ قۇملۇققا","كىرگەن ھەر بىر ئايالنىڭ.","","كېچە ئۇزۇن ئىدى،","سوغۇق چوڭقۇر ئىدى،","ئەمما تاڭ ئاتتى، باشتىن-ئاخىرقىدەكلا،","خورازنىڭ چىللىشى ۋە چەينەكنىڭ ھورى بىلەن،","ۋە تەڭرىتېغى قارلىرىدىكى تۇنجى نۇر بىلەن."]},{"id":"poem-2-5","title":"يىراقتىن ئالدىراپ يېتىپ كېلىش","lines":["يىراقتىن ئالدىراپ يېتىپ كېلىش،","خېشى كارىدورىدىن كەلگەن چاڭ-توزانلىق ئۆتۈكلەر بىلەن،","يېڭى پىدائىيلار يۈك ماشىنىسىدىن چۈشتى،","جۇڭغارنىڭ كۆزنى خىرەلەشتۈرىدىغان نۇرى ئىچىگە.","","ئۇلار سىچۈەندىن، خۇنەندىن كەلگەن،","جېجياڭنىڭ يېشىل تاغلىرىدىن كەلگەن،","بۇ قوڭۇر رەڭلىك، تۈز، غايەت زور يوقلۇققا،","ئۇلارنىڭ ۋەتىنىگە ئايلىنىدىغان جايغا.","","يىراقتىن ئالدىراپ يېتىپ كېلىش،","پەقەتلا ياشلىق بىلەن","ۋە ھۆكۈمەتنىڭ يەر ۋەدىسى بىلەن."]},{"id":"poem-2-6","title":"زۇمرەتتەك سۇ دەرياسى ئاقىدۇ","lines":["زۇمرەتتەك سۇ دەرياسى ئاقىدۇ،","يېڭى شەھەرنىڭ مەركىزىدىن،","ئون مىڭ قول قازغان ئۆستەڭ،","تەڭرىتېغى مۇزلۇقلىرىدىن كېۋەزلىكلەرگىچە.","","ئىلگىرى پەقەتلا تۆگىلەر سۇ ئىچكەن جايدا،","ھازىر بالىلار ئۈزۈپ ئوينايدۇ،","ۋە مەجنۇنتاللار قىرغاقلارنى تىزىپ تۇرىدۇ","بۇ سۈنئىي مۆجىزىنىڭ،","بۇ زۇمرەتتەك دەريانىڭ،","بىرسى ئاقىدۇ دەپ قارار قىلغانلىقى ئۈچۈنلا ئاققان."]},{"id":"poem-2-7","title":"كۆز ئالدىمىزدا ئارزۇ قىلىنغان شۇ گۈزەل ھايات","lines":["كۆز ئالدىمىزدا ئارزۇ قىلىنغان شۇ گۈزەل ھايات","ئەمدى پەقەتلا ئارزۇ ئەمەس:","كېۋەزلىكلەر ئۇپۇققىچە سوزۇلغان،","تېرەكلەر ئەسكەرلەردەك تۈز قاتار تۇرىدۇ،","مەكتەپ قوڭغۇرىقى سائەت سەككىزدە چېلىنىدۇ.","","بۇ شۇ ئارزۇ ئىدى —","بويسۇندۇرۇش ئارزۇسى ئەمەس،","بەلكى تېرىقچىلىق ئارزۇسى،","ئىمپېرىيە ئارزۇسى ئەمەس،","بەلكى ياشاشقا ئەرزىيدىغان بىر ھايات،","دۇنيانىڭ چېتىدە."]},{"id":"poem-2-8","title":"چوڭقۇر مۇھەببەت تارىخنىڭ يىلھالقىلىرىغا سىڭىپ كەتتى","lines":["چوڭقۇر مۇھەببەت تارىخنىڭ يىلھالقىلىرىغا سىڭىپ كەتتى،","ھەر بىر ھالقا بىر يىللىق جاپا-مۇشەققەت،","بىر يىللىق تېرىش ۋە ھوسۇل ئېلىش،","ئۇرۇشتىن بىر يىل يىراقلىشىش،","ئاددىي ھاياتقا بىر يىل يېقىنلاشتۇرۇش.","","تېرەك دەرەخلىرىنىڭ ھالقىلىرىنى ساناپ بېقىڭ،","يېڭى شەھەرنىڭ كوچىلىرىنى قاتار تىزغان:","ھەر بىر ھالقا بىر ئەۋلاد،","ھەر بىر ئەۋلاد ئىجابەت بولغان بىر دۇئا."]},{"id":"poem-2-9","title":"شۇ زۇمرەت پاناھلىق تاملىرى","lines":["شۇ زۇمرەت پاناھلىق تاملىرى —","تاشتىن ئەمەس، بەلكى تېرەك ۋە مەجنۇنتالدىن —","شەھەر ئەتراپىدا قاراۋۇللۇق قىلىدۇ،","ئەسكەرلەر قۇرغان شەھەرنى.","","بۇ يەردە زەمبىرەك ئوقى يوق،","پەقەتلا يوپۇرماقلارنىڭ شىرىلداشلىرى،","پەقەتلا سايىدا ئويناۋاتقان بالىلارنىڭ","ئاۋازىلا بار،","تاملار دەرەخلەر بولغاندا،","قەلئەلەر ئورمانلار بولغاندا."],"annotations":[{"term":"پاناھلىق تاملار (قەلئەلەر)","note":"زۇمرەت تاملار قەلئەسى - پاناھلىق بەرگۈچى تېرەكلەر قەلئەگە ئوخشىتىلىپ، ئۇلارنىڭ شەھەرلەر ۋە ئەۋلادلارنى توپا ۋە بوراندىن سادىق قوغدايدىغانلىقى تەستىقلانغان."}]},{"id":"poem-2-10","title":"ئوتتىن قايتا تۇغۇلغان گۈزەل سۇمرۇغتەك","lines":["ئوتتىن قايتا تۇغۇلغان گۈزەل سۇمرۇغتەك،","بۇ شەھەر قۇملۇقتىن قەد كۆتۈردى،","شىخەنزە، تاشلىق دەريا —","دەريا ئاستىدىكى تاشلارنىڭ ئىسمى بىلەن ئاتالغان،","يوقلۇقتىن باشلاشنى بىلىدىغان","كىشىلەر تەرىپىدىن قۇرۇلغان.","","سۇمرۇغتەك،","ئۇ مەۋجۇت بولماسلىقى كېرەك ئىدى،","ئەمما ئۇ شۇنداق،","يېشىل ۋە پارقىراق،","جۇڭغارنىڭ قوڭۇر يۈرىكىدە."]},{"id":"poem-2-11","title":"يېشىل ئوق ئالدىغا تېز ئۇچىدۇ","lines":["يېشىل ئوق ئالدىغا تېز ئۇچىدۇ —","گوبىدىن كېسىپ ئۆتكەن يېڭى بىر تاشيول،","شەھەرنى شەھەرگە ئۇلايدىغان،","ئارزۇنى ئارزۇغا.","","بىر چاغلاردا تۆگە قوڭغۇراقلىرى قەدەملەرنى بەلگىلەيتتى،","ھازىر ماتورلار گۈرۈلدەيدۇ،","ۋە تەرەققىياتنىڭ يېشىل ئوقى","ئالدىغا تېز ئۇچىدۇ،","ئۈرۈمچىدىن شىخەنزىگە، ئاندىن چېگراغا،","شامالدىنمۇ تېز،","ئەمما ئۇنچىلىك قەدىمكى ئەمەس."]},{"id":"poem-2-12","title":"ئۇ قوڭۇر سەھەر تۇمانلىرى ئەمەس","lines":["ئۇ قوڭۇر سەھەر تۇمانلىرى ئەمەس —","ئۇ قۇرۇلۇشنىڭ چاڭ-توزىنى،","مىڭلىغان گۈرجەكلەر كۆتۈرگەن ئالتۇن بۇلۇت،","قۇملۇق يۈزىدىن تېخىمۇ كۆپ بىنالار،","قەد كۆتۈرگەندە.","","ئۇ تۇمان ئەمەس — بەلكى","تۇغۇلۇۋاتقان بىر شەھەرنىڭ تىنىقىدۇر."]},{"id":"poem-2-13","title":"تولۇق، يۇمىلاق قىزىل قۇياشنى ھەيدەپ چىقىرىش","lines":["شەھەرنىڭ چېتىدە تراكتور بۇرۇلۇپ،","تراكتور تولۇق، يۇمىلاق قىزىل قۇياشنى شەكىللەندۈرىدۇ،","قارا تۇپراقتىن ھەيدەپ چىقارغاندەك،","خۇددى تۇپراق ئۆزى","يورۇقلۇقنى تۇغۇۋاتقاندەك.","","بۇ سەھەردىكى چېگرا،","ھەر بىر ئېرىق بىر مىسرا شېئىر بولغان جايدا،","ھەر بىر ھوسۇل بىر شېئىر بولغان جايدا،","ۋە قىزىل قۇياش كۆتۈرۈلىدۇ","ئايلىنىۋاتقان تىغدىن."]}]},{"id":"chapter-3","title":"ئۈچىنچى توم: گۇربانتۈڭگۈتتىكى بىر شائىر","poems":[{"id":"poem-3-1","title":"سېنى «دوست» دەپ ئاتاي","lines":["سېنى «دوست» دەپ ئاتاي،","چۈنكى بۇ سۆز چۆللۈكتە","سۇدەك ياكى سايىدەك شۇنچىلىك قەدىرلىك.","بىز تەۋە بولغان كەڭ بوشلۇقتا،","ئىسىملار پەقەتلا ئاۋاز بەگىلىكىدۇر،","ئەمما «دوست» دېسە ئىنساننىڭ يۈرىكى يۇمرانلىشىدۇ،","شۇنى بىلكى، قوللار كۆرۈشكەندە تاغلار ئۇچرىشىدۇ،","ماڭغان يولىمىز پەقەت ئوخشاش بىر تەرەپكە،","تەڭرىتېغى ئاستىغا، ياشلىشىش پەسلىگە قاراپ."],"annotations":[{"term":"گۇربانتۇڭغۇت","note":"گۇربانتۇڭغۇت قۇملۇقى - شىنجاڭنىڭ شىمالىدىكى جۇڭغار ئويمانلىقىنىڭ بىپايان ۋە دېڭىزدەك مەيدانىدىكى جۇڭگونىڭ ئىككىنچى ئاساسلىق قۇملۇقى."}]},{"id":"poem-3-2","title":"ئۇنىڭ كىچىك چېدىرى","lines":["ئۇنىڭ كىچىك چېدىرى،","كەڭ مەيداندا ئۇخلاپ ياتقان ئاق كەپتەردەك،","ھېيتقا سېلىنغان شامالدەك تەۋرىنىپ تۇرىدۇ.","","ئىچىدە پەقەت يوغان چۈشلەر،","گۈللەنگەن بوستانلىقلارنىڭ، يېڭى شەھەرنىڭ چۈشلىرى،","سىرتىدا بولسا ئۇچۇرۇۋاتقان قۇملار.","بۇ چېدىر دەل كەلگۈسىگە قاپىلانغان مۇستەھكەم قەلئەدۇر."]},{"id":"poem-3-3","title":"ئېتىم دەريا بويىدا ئەركىن ئوتلايدۇ","lines":["ئېتىم دەريا بويىدا ئەركىن ئوتلايدۇ،","سۇلار سۆزلەيدۇ، يوپۇرماقلار پىچىرلىشىدۇ.","بۇ يېشىل چۆپ پەقەت شۇنىڭ ئۈچۈن،","ئېتىم ۋە مەن يولدىن توختاپ ئارام ئالىمىز،","شۇ بوشلۇقتىكى ھۆرلۈكتىن ھۇزۇرلىنىمىز.","","سەپەر ئۇزۇن دەيدۇ كۆپچىلىك،","ئەمما بۇ يەردە تۇرۇپ باقساق شەھەر ۋە ۋەتەن بار،","پەقەتلا كۆڭۈلنىڭ خۇشاللىقىدىن،","توسالغۇسىز مېڭىش تارىخقا ۋەيرانى ئەمەستۇر."],"annotations":[{"term":"يىپەك يولى","note":"يىپەك يولى - جۇڭگونى ئوتتۇرا ئاسىيا ۋە ياۋروپاغا تۇتاشتۇرىدىغان قەدىمكى سودا يولى تورى، جۇڭگونىڭ يىپەكلىرى نامى بىلەن ئاتالغان."}]},{"id":"poem-3-4","title":"ئىشىكىمنىڭ ئالدىدا سۈزۈك بىر بۇلاق سۈيى ئاقىدۇ","lines":["ئىشىكىمنىڭ ئالدىدا سۈزۈك بىر بۇلاق سۈيى ئاقىدۇ،","تىنچ، جىمجىت، توختاۋسىز كىرىستالدەك.","مەن ھەر تاڭ ئۇنىڭدا يۈزۈمنى يۇيىمەن،","ۋە چۆلدىكى كۈننىمۇ يۇيۇپ تاشلايمەن.","","ئۆمۈر مۇشۇ سۇدەك ئاددىي ئۆتسە ئەگەر،","قاغجىراق بۇ قۇملۇق يەنىلا ياشارغان بولاتتى،","كۆڭۈل ۋە تۇپراق ئوخشاشلا سۇغىرىلىپ،","سۆيگۈ، ئۈمىد بىلەن پورەكلەپ ئېچىلىپ."]},{"id":"poem-3-5","title":"ئاھ، ئۇپۇققىچە قېزىلغان ئۇزۇن ئۆستەڭ","lines":["ئاھ، ئۇپۇققىچە قېزىلغان ئۇزۇن ئۆستەڭ،","بىزنىڭ تەرىمىز ۋە كۈلكىمىز قانىتى بىلەن.","مانا قارا، سۇ ئاقىدۇ يىراقتىن،","ھاياتلىق شىرىسىدەك چۆلگە قۇيۇلۇپ.","","يوقلۇقتىن بارلىققا، قۇملۇقتىن يېشىللىققا،","بۇ ئۇزۇن ئۆستەڭ سەپىرىمىزنىڭ ئىسپاتى.","ئۇپۇق سىزىقى ئەمدى قۇردۇم ئەمەس،","بەلكى بىپايان يېشىل ئاقما دېڭىزدۇر."]}]},{"id":"chapter-4","title":"تۆتىنچى توم: مۇھەببەت ئۈچۈن باغداد يىراق ئەمەس","poems":[{"id":"poem-4-1","title":"پەقەت بىز ئوخشاش بىر پارچە يەردە ئىشلىگىنىمىز ئۈچۈنمۇ","lines":["پەقەت بىز ئوخشاش بىر پارچە يەردە ئىشلىگىنىمىز ئۈچۈنمۇ،","قۇياش چىققاندىن تارتىپ پاتقىچە،","يۈرەكلىرىمىز شۇنچە كۆپ نەرسىلەرنى ئۆز-ئارا،","تۇپراق ۋە سۇغىرىش سۈيىدەك چۈشىنىشىدۇ.","","قارايمەن سېنىڭ مايسا تىكىپ يۈرگەن قوللىرىڭغا،","ۋە سېنىڭ ماڭا بېغىشلىغان شۇ بىر مىنۇت تەبەسسۇمۇڭغا.","ئىشلىدۇق تەڭ، كۈلدۇق تەڭ، مۇھەببەت —","بۇ سۆز بىزنىڭ زېمىنىمىزدە ئەڭ ياخشى ئۆسىدىغان مېۋىدۇر."],"annotations":[{"term":"بۇلبۇل","note":"بۇلبۇل - يۇلغۇن ۋە توغراقلار ئارىسىدىكى جىلۋىلىك ۋە نازۇك قۇش، چۆل شېئىرلىرىدا لىرىكا ۋە رومانتىك سۆيگۈنىڭ مۇھىم ۋەكىلىدۇر."}]},{"id":"poem-4-2","title":"مەن يامغۇردا رازىلىق بىلەن كۈتىمەن","lines":["مەن يامغۇردا رازىلىق بىلەن كۈتىمەن،","تامچىلار مەڭزىمگە ۋە كىيىمىمگە چۈشكەندە،","ھەر بىر تامچە شۇنچە يۇمران،","خۇددى سېنىڭ ئاۋازىڭدەك: «مەن سېنى كۈتىمەن».","","چۆلدە يامغۇرنىڭ يېغىشى بىر مۆجىزىدۇر،","مۇھەببەتكە ئوخشاشلا تېپىلغۇسىز،","ۋە شۇنچىلىك ئارزۇ قىلىنغان.","مەن رادىئودىكى بۇ خەتكە ئوخشاشلا كۈتىمەن يامغۇردا سېنى."]},{"id":"poem-4-3","title":"ئۇ قۇم دۆڭى كەينىدىكى ھىلال ئاي","lines":["ئۇ قۇم دۆڭى كەينىدىكى ھىلال ئاي،","كۈمۈش كىرپىكتەك كۆتۈرۈلۈۋاتىدۇ،","تۇپراقنىڭ قوڭۇر قېشى ئۈستىدە.","","بۇ ھىلال ئاي ئاستىدا،","قۇمنىڭ ئۈستىگە ئىسمىڭنى يازىمەن،","شامالنىڭ ئۇنى سەھەردە ئۆچۈرۈۋېتىدىغانلىقىنى بىلىپ تۇرۇپمۇ،","ئەتە كېچە ئۇنى يەنە يازىدىغانلىقىمنى بىلىپ تۇرۇپمۇ."]},{"id":"poem-4-4","title":"ئۇ كوزىنى ئاللىبۇرۇن سۇ بىلەن تولدۇردى","lines":["ئۇ كوزىنى ئاللىبۇرۇن سۇ بىلەن تولدۇردى،","ئۆستەڭ سۈيىدىن سۈزۈپ،","گۇگۇم نۇرى تامچىلىرى ئۇنىڭ","قوڭۇر غوللىرىغا چۈشكەندە.","","جۇڭغارنىڭ گۇگۇمىدا،","ھەممە نەرسە ئالتۇنغا ئايلىنىدۇ:","سۇ، بۇغداي، ئۇنىڭ چېچى،","ئۆتۈكلىرىدىكى چاڭ-توزان،","ئۆزى بۇرۇلمايلا، ماڭا قالدۇرغان تەبەسسۇمى."]},{"id":"poem-4-5","title":"بۇ ئۇنىڭ ماڭا بېغىشلىغان ئاخىرقى تەبەسسۇمىمىدى؟","lines":["بۇ ئۇنىڭ ماڭا بېغىشلىغان ئاخىرقى تەبەسسۇمىمىدى؟","يۈك ماشىنىسى قوزغالدى،","توزان ئىچىدە ئۇنىڭ قول پۇلاڭلاتقانلىقىنى كۆرگەندەك قىلدىم —","ياكى يۇلغۇندىكى شامالمىدى ئۇ؟","","ئۇ سىچۈەنگە قايتتى،","شۇ يېشىل تاغلار ۋە شاللىقلارغا،","قۇم ۋە بوراندىن يىراقلاشتى،","مەندىن يىراقلاشتى.","","بۇ ئۇنىڭ ماڭا بېغىشلىغان ئاخىرقى تەبەسسۇمىمىدى؟","مەن چۆلدىن شۇنىڭدىن بېرى سوراۋاتىمەن،","ئەمما چۆل ھېچ جاۋاب بەرمەيدۇ."]},{"id":"poem-4-6","title":"ئاھ، يۇلغۇنزارلىقتىكى بۇلبۇل","lines":["ئاھ، يۇلغۇنزارلىقتىكى بۇلبۇل،","مەن ئېيتالمىغان ناخشىنى ئېيتىدۇ،","ئۆزى سۆيگەن قىز كەتكەندە ئۆزى قېپقالغان بىر يىگىتنىڭ ناخشىسىنى.","","بۇلبۇل يالغۇزلۇقنى بىلمەيدۇ،","بىراق ئۇ خۇددى بىلىدىغاندەكلا سايرايدۇ،","ئۇنى ئاڭلاپ مەنمۇ ئىشىنىپ قالغىلىۋاتىمەنكى،","گۈزەللىك بىلەن قايغۇنىڭ،","ئوخشاش بىر نەرسە ئىكەنلىكىگە."]},{"id":"poem-4-7","title":"چېگرانىڭ باھار رەڭلىرىنى توقۇش","lines":["«چېگرانىڭ باھار رەڭلىرىنى توقۇش» —","ئۇ مانا مۇشۇنىڭ ئۈچۈن كەلگەنلىكىنى ئېيتتى،","سۇجۇنىڭ يىپەك زاۋۇتلىرىدىن كەلگەن بىر قىز،","توقۇمىچىلىق ماشىنىسىنى گۈرجەككە ئالماشتۇرغان.","","ئۇ ئۆستەڭ قىرغاقلىرىغا گۈللەرنى تىكتى،","چوقا گۈللىرى ۋە قىزىل گۈللەر،","قوڭۇر تۇپراق ئۈستىدە شۇنچە چاقناپ تۇرىدىغان،","بىر خىل باشقىچە يىپەكنى توقۇۋاتقاندەك:","چېگرانىڭ يىرىك رەختىدىكى","باھارنىڭ گۈزەل رەڭلىرى."]},{"id":"poem-4-8","title":"يېشىل بىر كۈي ئاقىدۇ","lines":["يېشىل بىر كۈي ئاقىدۇ،","يېڭىلا تىكىلگەن پاناھلىق ئورمان بەلۋېغىدىن،","شامال تېرەكلەرنى خۇددى نەيدەك چېلىۋاتقاندا،","ھەر بىر دەرەخ بىر نوطىدەك ئاۋاز چىقىرىدۇ.","","مەن كۆزلىرىمنى يۇمۇپ تىڭشايمەن،","ۋە كەلگۈسىنى ئاڭلايمەن:","بىر شەھەرگە يەتكۈدەك سايە،","بىر ئۆلكىگە يەتكۈدەك تىنچلىق،","ھەممىسى بىر مايسىدىن باشلانغان بۇ كۈيدىن،","بىر ئەسكەرنىڭ قولىدىكى ئۇرۇقتىن."]},{"id":"poem-4-9","title":"ئاھ، مېنى تاشلاپ كەتمەڭ","lines":["ئاھ، مېنى تاشلاپ كەتمەڭ،","ھازىر ئەمەس، كېۋەزلەر ئېچىلاي دەپ قالغاندا،","سۇ ئامبىرى سۇغا تولىياي دەپ قالغاندا،","لەنجۇدىن بېرى بىز ئارزۇ قىلغاندەك","ھاياتنى ئاساسەن قۇرۇپ چىققاندا.","","تېرەكلەر بىزدىن ئېگىز بولغۇچە قېلىڭ،","يوللارغا ئاسفالت ياتقۇزۇلغۇچە قېلىڭ،","يۇلتۇزلار ناتونۇشلاردەك كۆرۈنمەس بولغۇچە،","بەلكى قوشنىلاردەك كۆرۈنگۈچە قېلىڭ.","","ئاھ، مېنى تاشلاپ كەتمەڭ.","بۇ قۇملۇق ئىككىمىزگە ئەركىن يېتىدۇ."]},{"id":"poem-4-10","title":"بۇ ئۆتكۈر قۇم دۆڭى تەرىپىدىن ئۇچۇرۇلغان چاق","lines":["بۇ ئۆتكۈر قۇم دۆڭى تەرىپىدىن ئۇچۇرۇلغان چاق،","قۇمنىڭ ئۈستىدە سەكرەپ كېتىۋاتىدۇ،","كىچىك، كۈلكىلىك بىر ئايدەك.","","يۈك ماشىنىسى غىچىرلاپ شەلپىيىپ كەتتى،","ئەشيا-ماتېرىياللار چېچىلدى:","بوياق قۇتىلىرى، سىم ئوراملىرى،","ۋە خەت خالتىسىدىن","مۇھەببەت خەتلىرى،","لاپەرۋا ئاسمان ئاستىدا قۇمدا غىلىم-غىلىم بوپ چۈشۈپ تۇرۇپتۇ."]},{"id":"poem-4-11","title":"ئاھ، شۇ قارا-كۆك قار دولقۇنلىرى","lines":["ئاھ، شۇ قارا-كۆك قار دولقۇنلىرى،","كەچقۇرۇن تەڭرىتېغىدىن پارتىلاپ چۈشكەن،","مۇزلۇقنىڭ سوغۇق تىنىقىنى","ئىسسىق جىلغىغا ئېلىپ كەلگەن.","","قار دولقۇنلىرىنىڭ تۇمانلىرى ئىچىدە تۇرۇپ،","مەن سېنى ئويلايمەن،","سېنىڭ كۆك رەڭلىك پاختا كۆينىكىڭنى،","شامالدا يېيىلىپ كەتكەن چېچىڭنى،","كىچىككىنە كۈلكەڭنى خۇددى سۇدەك —","سوغۇق ۋە كىرىستالدەك پارلاپ، تېز ئېقىۋاتقان كۈلكەڭنى كۆز ئالدىمغا كەلتۈرىمەن."],"annotations":[{"term":"قار دولقۇنلىرى","note":"قار دولقۇنلىرى - تەڭرىتېغىدىكى ئېرىگەن سۈزۈك مۇز سۈيى دولقۇنلىرى، ھاياتلىق، خۇشاللىق ۋە تىرىشچانلىقنىڭ پارقىراق شەرقلىق ئېقىمى."}]},{"id":"poem-4-12","title":"ئۇ نەپىس تەبەسسۇم قىلىپ كېتىپ قالدى","lines":["ئۇ كېتىپ قالدى، نەپىس تەبەسسۇم قىلىپ،","تېرەكلەر تىزىلغان يولنى بويلاپ،","بىر قولىدا جامادان،","يەنە بىر قولىدا ئۇنىڭ كەلگۈسى.","","ئۇ كەينىگە قارىمىدى —","ياكى قارىغان بولسىمۇ،","تېرەكلەر ئۇنىڭ يۈزىنى يوشۇرۇپ قالدى.","","ئۇ تەبەسسۇم بىلەن كېتىپ قالدى،","خۇددى ئايرىلىش شۇنچە ئاساندەك،","خۇددى قۇملۇق ئاللىبۇرۇن ئۇنىڭ يۈرىكىگە","ئۆز ئىسمىنى يېزىپ","بۆلمىگەندەك كېتىپ قالدى."]},{"id":"poem-4-13","title":"مەن ئۇ ياشايدىغان جايغا بارىمەن","lines":["مەن ئۇ ياشايدىغان جايغا بارىمەن،","قۇم دۆڭلىرى ۋە قۇرۇپ كەتكەن دەريا ساھىللىرىدىن ئۆتۈپ،","يۇلغۇنزارلىقلاردىن ئۆتۈپ،","ئۆلچەش پەللىلىرىدىن ۋە","يېرىم قۇرۇلغان يوللاردىن ئۆتۈپ.","","مەن ئۇ ياشايدىغان جايغا بارىمەن،","تاغ تىزمىسىنىڭ جەنۇبىدىكى يېڭى كەنتكە،","ئۇ يەردە كېسەك بىلەن ياسالغان بىر مەكتەپتە","ئۇ يىگىرمە بالىغا دەرس بېرىۋاتىدۇ.","","مەن ئۇ ياشايدىغان جايغا بارىمەن.","قۇملۇق پەقەت ئەللىك كىلومېتىرلا ئارىلىققا ئىگە.","مۇھەببەت ئۈچۈن، باغدادمۇ يىراق ئەمەستۇر."]},{"id":"poem-4-14","title":"بۇ قان-قىزىل گوبى تېشىنى ئاستا سىيپىلايمەن","lines":["بۇ قان-قىزىل گوبى تېشىنى ئاستا سىيپىلايمەن،","بىر مىليون يىللىق شامال تەرىپىدىن پارقىرىتىلغان،","يۈرەكتەك قىپقىزىل ۋە كىچىك،","چۈشتىن كېيىنكى قۇياش نۇرىدىن ئىللىغان.","","مەن ئۇنى ئۈزۈكنىڭ ئورنىدا","ئۇنىڭغا بېرىمەن.","","چېگرادا،","بىزنىڭ زەرگەرلىرىمىز يوق،","ئەمما بىزنىڭ قۇملۇقىمىز بار،","ۋە بۇ قۇملۇق ئۆزىنىڭ","ئۈنچە-مەرۋايىتلىرىنى ئۆزى ياسايدۇ."]},{"id":"poem-4-15","title":"سۈكۈتتە مېڭىش","lines":["سۈكۈتتە مېڭىش،","كەچقۇرۇندىكى گۇربانتۇڭغۇت ئارقىلىق،","قۇم ئاياغلىرىم ئاستىدا ھېلىھەم ئىسسىق،","ئاسمان ھېچقانداق تىلدا ئىسمى يوق رەڭلەرگە","ئايلانماقتا.","","سۈكۈتتە مېڭىش،","چۈنكى بەزى ھېسسىياتلار","سۆزلەر بىلەن ئاڭلىتىشقا بەك چوڭلۇق قىلىدۇ،","ئېغىز بىلەن ئېيتىشقا بەك كەڭلىك قىلىدۇ،","ۋە چوقۇم يۈرەكتە،","قەدەمدە،","سۈكۈتنىڭ ئۆزىدىلا ئېلىپ مېڭىلىشى كېرەك."]},{"id":"poem-4-16","title":"ئاھ، قەلبىمدە پاتمايدىغان بىر ئاي بار","lines":["ئاھ، قەلبىمدە پاتمايدىغان بىر ئاي بار،","ئاسمان تۇتۇلغاندىمۇ نۇر چېچىپ تۇرغان بىر ئاي،","قۇم بورىنىدىمۇ پارقىراپ تۇرغان بىر ئاي،","يەر ئاستى ئۆيىدىن تارتىپ ئېتىزلارغىچە، ئېرىق قىرغاقلىرىغىچە","ماڭا ئەگىشىپ يۈرگەن بىر ئاي خۇددى ئۇتەك.","","ماڭا كېرەك ئەمەس،","تەڭرىتېغى ئۈستىدىكى ئاي،","چۈنكى مەن ئۆز ئېيىمنى ئۆزۈم بىلەن ئېلىپ سۆيگىنىم بىلەن،","ئۇنىڭ يۈزىنىڭ ئەسلىمىسى بىلەن پارقىراپ،","ھەر كېچىسى تولۇن ئايدەك،","ھېچقاچان غۇۋالاشمايدۇ."]},{"id":"poem-4-17","title":"ئېرىق قارا-كۆك كېچە ئارقىلىق ئاقىدۇ","lines":["ئېرىق قارا-كۆك كېچە ئارقىلىق ئاقىدۇ،","قاراڭغۇلۇقتا كۈمۈش بىر يىپتەك،","مۇزلۇقنىڭ ئاۋازىنى كۆتۈرۈپ","ئۇخلاۋاتقان ئېتىزلارغا قاراپ.","","مەن ئۇنىڭ يېنىدا ئولتۇرۇپ ئەسلەيمەن:","ئۇنىڭ ئۆز پۇتلىرىنى بۇ سۇغا تىققانلىقىنى،","سوغۇقنىڭ تەسىرىدىن قاقاقلاپ كۈلگەنلىكلىرىنى،","ۋە: «بۇ يەردىكى سۇنىڭمۇ","تەمى خۇددى سەرگۈزەشتىگە ئوخشايدىكەن» دېگەن سۆزلىرىنى.","","ئېرىق ئاقىۋېرىدۇ داۋاملىق،","قارا-كۆك كېچە ئارقىلىق،","ئۇنىڭ كۈلكىسىنى ئۆزى بىلەن بىللە كۆتۈرۈپ","شەرققە، ھەمىشە شەرققە."]},{"id":"poem-4-18","title":"مەن ئاسماندىكى ئايسىزمۇ ياشىيالايمەن","lines":["مەن ئاسماندىكى ئايسىزمۇ ياشىيالايمەن،","مەن بۇلۇتتىن چۈشكەن يامغۇرسىزمۇ ياشىيالايمەن،","مەن ئۆيدىن كەلگەن خەتلەرسىزمۇ ياشىيالايمەن.","","ئەمما مەن سېنى ئويلىماي ياشىيالمايمەن،","كېسەك مەكتەپنىڭ دەرۋازىسىدا","تۇرغىنىڭنى كۆز ئالدىمغا كەلتۈرىمەن،","بارماقلىرىڭدا ھېلىھەم بۇرنىڭ ئىزلىرى بىلەن،","يىگىرمە بالىغا،","مەڭگۈلۈك قىش زېمىنىدا","«باھار» سۆزىنى قانداق يېزىشنى ئۆگىتىۋاتقىنىڭنى."]},{"id":"poem-4-19","title":"تۇنجى مۇھەببەت كېچىلىرىنىڭ چوڭقۇر ئەكس سادالىرى","lines":["تۇنجى مۇھەببەت كېچىلىرىنىڭ چوڭقۇر ئەكس سادالىرى،","قۇملۇق ھاۋاسىدا تېخىچە ياڭرايدۇ،","قۇم دۆڭلىرى ئارىسىدىكى بوشلۇقلاردا،","يۇلتۇزلار ئارىسىدىكى يوچۇقلاردا.","","ئۇ چاغلاردا بىز ياش ئىدۇق،","بىز تىككەن كۆچەتلەردەك ياش ئىدۇق،","بىز سۇغارغان بۇغدايلاردەك يېشىل ئىدۇق،","قۇرۇق قۇملۇققا ناخشا ئېيتقان","بۇلبۇلدەك دۆت ئىدۇق.","","ئەمما شۇ چوڭقۇر ئەكس سادالار،","ھېچقاچان توختاپ باقمىدى."]},{"id":"poem-4-20","title":"تاڭ خەۋەرچىسى بولغان قۇش","lines":["تاڭ خەۋەرچىسى بولغان شۇ قۇش مۇشۇ،","ئەڭ ئېگىز تېرەكنىڭ ئەڭ ئۈستۈنكى شېخىدا","پاناھلىق ئورمان بەلۋېغىدا ئولتۇرۇپ،","سايرايدۇ.","","بۇ قېتىمقىسى بۇلبۇل ئەمەس،","بەلكى بىر تورغاي،","يورۇق ئاۋازلىق ۋە ئاددىي تورغاي،","ئادەتتىكى سەھەرلەرنىڭ قۇشى،","قەھۋە، نان ۋە خىزمەتنىڭ قۇشى.","","تاڭ خەۋەرچىسى بولغان بۇ قۇش","مۇھەببەتنى ئەمەس،","بەلكى كۈنلەرنىڭ كۈنلەرگە ئەگىشىپ كېلىدىغان","گۈزەل كۈندىلىك تەكرارىنى","چېگرانىڭ قىزغىن ساھىلىدا نامايان قىلىدۇ."]},{"id":"poem-4-21","title":"گەرچە ئۇ ئوخشاش بىر خىل قايغۇ بولسىمۇ","lines":["گەرچە ئۇ ئوخشاش بىر خىل قايغۇ بولسىمۇ،","پويىز ئايرىلغان شۇ كېچىدىكىگە ئوخشاش،","لېكىن ئەمدى ئۇ تېخىمۇ مۇلايىم بىر قايغۇ،","يىللار تەرىپىدىن كۆپ ئوقۇلغان سىلىقلاشتۇرۇلغان،","قولدىكى گوبى تېشىدەك تەكلىپ بىلەن.","","مەن ئۇنىڭ بىلەن بىللە ياشاشنى ئۆگەندىم،","بۇ قايغۇ ئۆز نۆۋىتىدە يەنە بىر مىننەتدارلىق،","بۇ سېغىنىش ئۆز نۆۋىتىدە يەنە بىر ئەسلىمە،","بۇ يوقلۇق ئۆز نۆۋىتىدە يەنە بىر مەۋجۇتلۇق،","بۇ يەردە، قۇملۇقتا غاسىلىقلارمۇ پۇقرا،","ھەممە نەرسە يىراق بولغاندا،","ۋە ھېچنېمە ئۇنتۇلمايدىغان بىر جايدا."]},{"id":"poem-4-22","title":"خۇددى قايغۇلۇق بىر بۇلبۇل ماڭا قاراپ ئۇچۇپ كەلگەندەك","lines":["خۇددى قايغۇلۇق بىر بۇلبۇل ماڭا قاراپ ئۇچۇپ كەلگەندەك،","ئۇنىڭ ئەسلىمىسى قايتىپ كېلىدۇ،","ھەر بىر قۇملۇق كەچقۇرۇندا،","ھەر بىر ھىلال ئاي چىققاندا.","","مەن قولۇمنى ئېچىپ ئۇنى تۇتىمەن،","ئەسلىمىنىڭ بۇ قارا قۇشىنى،","ۋە ئۇنى كۆكرىكىمگە بېسىپ تۇتۇپ،","ئۇنىڭ ناخشىسىنى تىڭشايمەن:","","مۇھەببەت ئۈچۈن، باغدادمۇ يىراق ئەمەستۇر.","مۇھەببەت ئۈچۈن، ھېچقانداق ئارىلىق ئۇزۇن ئەمەستۇر.","مۇھەببەت ئۈچۈن، قۇملۇق ھەرگىزمۇ قۇملۇق ئەمەس،","بەلكى يامغۇر كۈتۈۋاتقان بىر باقتۇر.","","خۇددى قايغۇلۇق بىر بۇلبۇل ماڭا قاراپ ئۇچۇپ كەلگەندەك،","ئۇ يەنە ۋە يەنە قايتىپ كېلىدۇ،","ۋە مەن بۇ جايدا قالغانلىقىم ئۈچۈن،","تېخىمۇ بېيىپ كەتكەنلىكىمنى سېزىۋاتىمەن."]}]}]},"children":[["$","div",null,{"className":"fixed top-4 right-4 z-50","children":["$","$L9",null,{"currentLocale":"ug"}]}],["$","div",null,{"className":"max-w-4xl mx-auto pb-32","children":[["$","header",null,{"className":"pt-24 pb-12 px-8 text-center border-b border-gray-100 mb-12","children":[["$","h1",null,{"className":"text-4xl font-serif font-bold text-gray-900 mb-4","children":"جۇڭغار شېئىرلىرى"}],["$","p",null,{"className":"text-sm text-gray-400 font-sans","children":["لى يۈ"," / ","1984"]}]]}],[["$","div","chapter-1",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"بىرىنچى توم: يالقۇنلۇق گۈلخان"}],[["$","article",null,{"id":"poem-1-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"تۇنجى ئورغاق ناخشىسى"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"ئور، ئور، ئور!"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"بىر پارچە شەپەقنى ئور، ئون مىڭ دولقۇن بۇغداينى ئور;"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"ئاخىرى بىز بۇ كۈننى كۆرۈشكە نېسىپ بولدۇق،"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"ئاخىرى كەڭ چېگرا بىزنىڭ ئالتۇن ئېتىزلىرىمىز بىلەن پارلىدى."}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"كېچىمۇ جىمجىت ئەمەس — ھەممە نەرسە ئۆسىدۇ،"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"شادىيانە قار سۈيى جۇڭغارنىڭ سوقتۇرۇۋاتقان قېنى;"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"قوناق شاخلىرىنىڭ ئۆسكەن ئاۋازى شۇنچە ئېنىق،"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"ياۋا كىيىكلەرنى ۋە تارتىنچاق جەرەنلەرنى چۆچۈتىدۇ."}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"يىغىلىڭلار — مول ھوسۇل بىزنىڭ تۇغىمىز!"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"ھەر بىر باش بۇغداي بىر ئوق"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"قۇملۇققا ئېتىلغان،"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"«بۇ يەردە ھېچ نەرسە ئۆسمەيدۇ» دېگەن سۆزلەرگە بېرىلگەن كۈچلۈك زەربە."}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","جۇڭغار شېئىرلىرى","》 · ","بىرىنچى توم: يالقۇنلۇق گۈلخان"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["لى يۈ"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"بىرلا ئېچىلىش"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className