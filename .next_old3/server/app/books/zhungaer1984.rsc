:"min-h-[1.5em] ","children":["你是在新一代",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"指新疆生产建设兵团的军垦战士。1954年新疆军区生产建设兵团成立，数十万解放军官兵就地转业，在戈壁荒滩上开荒造田、兴修水利、建设城镇。","children":["拓荒者",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"面前；"]}],["$","p","14",{"className":"min-h-[1.5em] ","children":"胡大听不到虔诚的祈祷，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"风沙像巴依一样残暴，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"巴依像风沙一样贪婪。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"白杨树顷刻凝固了，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"雪浪花顷刻凝固了，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"地平线顷刻凝固了；"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"风沙中的今天紧连风沙中的昨天，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"白日的风沙与梦中的风沙连成一片。"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1976年1月"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"拓荒者"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"指新疆生产建设兵团的军垦战士。1954年新疆军区生产建设兵团成立，数十万解放军官兵就地转业，在戈壁荒滩上开荒造田、兴修水利、建设城镇。"]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","