"$","p","20",{"className":"min-h-[1.5em] ","children":"还将载着夜莺的呜啼，"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"还将载着未来绿洲一片吞云吐雾的囱林，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"还将载着千里林带的葱葱新绿。"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1979年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之二：将军与城"]}],["$","span",null,{"children":["页码 ","41"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-2-13","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"犁出一轮浑圆的红日"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"震撼着天穹，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"震撼着星星，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"震撼着红柳；"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"一位腮帮长满胡茬的将军仰天大笑，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"他以钢铁般的肩头拉开了艰难的第一犁。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"犁过逝去的绿洲上丛生的荆棘，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"犁过逝去的村镇上沉积的沙砾，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"还有曾奔腾晶莹雪浪的干涸了的河谷，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"还有曾穿过丝绸之路的褐色的废墟。"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"犁过飘浮过沙漠之舟的沙浪，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"犁过演出过海市蜃楼美丽神话的大地；"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"这儿还刚掠过军刀的狂飙，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"这儿还刚飞溅马蹄的骤雨。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"他在茫茫的古尔班通古特犁呀犁呀，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"犁出一轮浑圆的红日，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"犁出一个崭新的世纪；"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"那笑声还在回荡，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"在定将标上未来中国地图的新城石河子。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"1979年7月"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"---"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之二：将军与城"]}],["$","span",null,{"children":["页码 ","42"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}]]]}],["$","div","chapter-3",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"卷之三：一位诗人在古尔班通古特"}],[["$","article",null,{"id":"poem-3-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"小溪飞溅着褐色的浪涛"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"巍巍沙包在飘浮，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"巍巍沙包在飞旋，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"还有紫色的红柳，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"还有棕色的荆棘；"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"绿色的光斑也在恍惚中闪耀，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"闪耀一片南国的翠碧，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"——故乡的青山……"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"——故乡的绿树……"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"啊，大堰河，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"在地窝子的梦中曾多少次呼唤过呀。"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"拓荒者被簇拥着，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"戴着纸糊的高帽，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"在这个黄昏，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":["在",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"中国第二大沙漠，面积约4.88万平方公里，位于新疆准噶尔盆地中央。因固定和半固定沙丘为主，有较多梭梭、红柳等植被。李瑜长期在此区域的兵团工作生活。","children":["古尔班通古特",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"未来的街市；"]}],["$","p","15",{"className":"min-h-[1.5em] ","children":"混浊的小溪飞溅褐色的浪涛，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"——大漠扬起雾霭般的沙砾，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"载着朦胧的幻觉，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"载着辛酸的回忆，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"流啊流啊，践踏着人的尊严，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"践踏着当代行吟歌手悲怆的诗句。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"1979年8月"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"古尔班通古特"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"中国第二大沙漠，面积约4.88万平方公里，位于新疆准噶尔盆地中央。因固定和半固定沙丘为主，有较多梭梭、红柳等植被。李瑜长期在此区域的兵团工作生活。"]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之三：一位诗人在古尔班通古特"]}],["$","span",null,{"children":["页码 ","43"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-3-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"从远方飘来一片绿色的云"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"夜色渐渐隐去了，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"天幕还缀着暗淡的晨星；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"从遥远的绿洲那边吹拂过来一阵凉风，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"湿漉漉的，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"还飘来一片翡翠般的绿色的云。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"簇拥着的小水珠儿亮晶晶的，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"趁着晨光，在冉冉升腾；"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"低低掠过干涸的大地，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"掠过褐色的沙浪，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"掠过荆棘的丛林。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"向那灰尘包裹着的黄色花蕊的小花临近，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"向那干热包裹着的闪光沙砾的沙包临近；"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"飘过去吧，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"去滋润他们的绿色梦幻，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"在那儿，拧下一阵淋漓的甘霖。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"不久就会升起宽阔的绿色纱帐，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"大漠就要换上青春的衫裙；"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"背着沉重十字架的拓荒者艰难走来，"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"还背着一捆青青的树苗，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"从远方飘来一片绿色的云。"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1979年8月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之三：一位诗人在古尔班通古特"]}],["$","span",null,{"children":["页码 ","44"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-3-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"还摇曳丝绸之路驼铃的夜曲……"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"那条载着戈壁之舟的小径曾穿过这里，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"那条载着丝绸光泽的小径曾穿过这里，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"穿过凝固了的沙包的峰峦，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"穿过燃烧着的红柳的火炬，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"穿过历史的废墟，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"穿过时代的风雨。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"那条小径还穿过二十世纪中叶的战争风云，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"穿过急骤鼓点掠过的茫茫麦浪，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"也穿过无垠瀚海中一个小小的孤岛，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"——诗人居住多年的褐色的地窝子；"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"深深的地窝子囚不住澎湃的心声，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":["听，那诗句还摇曳",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"古代连接中国与中亚、西亚、欧洲的贸易通道。其北道经由准噶尔盆地北缘穿行。诗人在古尔班通古特沙漠行走时，遥想千年前驼队在此经过的情景。","children":["丝绸之路",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"驼铃的夜曲……"]}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"1979年8月"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"丝绸之路"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"古代连接中国与中亚、西亚、欧洲的贸易通道。其北道经由准噶尔盆地北缘穿行。诗人在古尔班通古特沙漠行走时，遥想千年前驼队在此经过的情景。"]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之三：一位诗人在古尔班通古特"]}],["$","span",null,{"children":["页码 ","45"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-3-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"白色的牡丹"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"莫要说春风不渡寂寞的荒滩，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"那儿不是盛开着一朵白色的牡丹？"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"就在那褐黄色的天幕上，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"就在那凝固了的天幕上，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"留下拓荒者袅袅的炊烟。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"在曾摇曳驼铃的大地飘散，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"在曾闪耀丝绸光泽的大地飘散，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"在曾回荡钢铁交响的大地飘散，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"在曾翻腾金黄麦浪的大地飘散。"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"还飘散在抛洒他悲怆泪滴的大地，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"还飘散在响彻他悲怆诗句的大地，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"(那诗句，已化为无数希望的种子，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"将在迟到的春天萌发出翡翠的叶片。)"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"拓荒者从彩色的欧罗巴带回一支画笔，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"曾画下以奶汁哺育过他的大堰河衰老的容颜，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"今天又在褐黄色的天幕画板上，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"又在凝固了的天幕画板上，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"涂抹着古尔班通古特的名花——白色的牡丹。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"1979年8月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之三：一位诗人在古尔班通古特"]}],["$","span",null,{"children":["页码 ","46"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-3-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"在冰冷的夜里燃起这堆篝火"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"在飘动的篝火上再添一把红柳枝，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"深蓝的夜色里闪耀一簇火星；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"惊醒了红柳丛中的梅花鹿，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"像金色的响箭掠过，在远处飞鸣。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"篝火飘动着，火舌轻舔被遗弃的猎物，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"乳白的烟雾在飘散，在冉冉升腾；"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"篝火照映那高高的颧骨，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"篝火照映那灰白的两鬓。"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"又在苍茫的天穹下沉思什么呢？"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"只见那深陷的眼窝里目光炯炯；"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"不要说面前是周口店的“北京人”，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"篝火分明迎着古尔班通古特的寒风。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"在冰冷的夜里燃起这堆篝火，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"燃起澎湃的不灭的诗情；"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"篝火照映着二十世纪末叶的拓荒者，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"照映着曾唱过号角般战歌的饥肠辘辘的诗人。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"1979年8月"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"---"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之三：一位诗人在古尔班通古特"]}],["$","span",null,{"children":["页码 ","47"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}]]]}],["$","div","chapter-4",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"卷之四：为了爱情，巴格达不嫌远"}],[["$","article",null,{"id":"poem-4-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"啊，夜莺"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"月色多么皎洁，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"像水一样清澄，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"水底凝固了的大漠那样浩瀚，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"水底凝固了的大漠那样晶莹；"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"你来了，歌唱星光灿烂的静夜，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"在拓荒者的营地升起你宛转的歌声。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"我也在不倦地歌唱，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"歌唱艰苦的创业，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"歌唱幸福的憧憬；"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"伴着机车的轻柔鸣奏，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"从丰饶的绿洲唱到未来的新城。"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"我的歌，谱着机车写下的抒情诗行，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"飘荡在褐色的沙浪万顷，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"还飘过红柳的纱帐，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"飘过沙峦的群峰；"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"徐徐飘荡呀，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"飘进一位姑娘的窗棂。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":["啊，",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"新疆红柳丛中常见的鸣禽。在李瑜诗中，夜莺是爱情与抒情的象征，贯穿整部诗集，与红柳构成准噶尔自然意象体系的核心。","children":["夜莺",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"，"]}],["$","p","21",{"className":"min-h-[1.5em] ","children":"就在那丛燃烧的红柳那边，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"再越过机车履带碾成的一条小径；"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"飞过去吧，衔着我的一片赤诚的爱，"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"悄悄飞进那位姑娘甜蜜的梦境……"}],["$","p","25",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","26",{"className":"min-h-[1.5em] ","children":"1978年10月"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"夜莺"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"新疆红柳丛中常见的鸣禽。在李瑜诗中，夜莺是爱情与抒情的象征，贯穿整部诗集，与红柳构成准噶尔自然意象体系的核心。"]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","48"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"绵绵的雨滴呀"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"深蓝的夜色将在古尔班通古特升起，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"从远方，飘来一片乳白的云；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"绵绵的雨滴呀，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"洒落在绿色的原野，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"絮絮对我倾泻管天姑娘的不尽深情。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"我就要离开这儿了，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"就要向大漠的腹地挺进，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"绿浪上还闪耀着我的青春，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"——这儿也浸透你的绵绵的雨滴，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"那雨滴，曾将茁壮的新苗滋润。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"即将带去滔滔的雪浪，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"即将带去夜莺的啼鸣；"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"播种理想，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"播种爱情，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"不要说那儿的荒原浩瀚无垠。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"在那儿，会更加思盼你的绵绵的雨滴，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"我干渴的心田更加思盼那生命的甘霖；"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"啊，拓荒者就要离开这儿了，"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"给你捎去信息，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"请逝去的最后一抹流云……"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1978年10月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","49"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-3","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"那是沙包背后的一弯新月"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"不是眺望虚无缥缈的水榭，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"不是眺望虚无缥缈的楼阁；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"在这儿徘徊，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"海市蜃楼的幻景也是美丽的，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"可是沙包背后即将升起的一弯新月一定会更加美丽。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"啊，神秘的夜幕已经降临了，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"正在轻轻飘曳，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"还缀满璀璨的星斗。"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"那弯新月就要如期升腾起来，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"——那是沙包背后的一弯新月；"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"她将从我的脚步碾成的小溪上悄悄升起，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"她将从还萦绕那绵绵絮语的红柳丛悄悄升起。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"她的光芒将驱散拓荒者浩瀚心海的迷雾，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"带着妩媚的光晕，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"晶莹而且皎洁。"}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"1979年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","50"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-4","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"她已在罐里汲满水了"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"一片绛紫的头巾飘过洁白的雪地，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"——洁白的雪地飘过一片绛紫的晨曦；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"飘过洁白的住宅，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"飘过洁白的林带，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"飘过洁白的小桥，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"飘过洁白的大漠，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"飘到了那遥远的地方。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"那儿有一条冰雪覆盖的小溪，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"那是一条波浪已经凝固了的小溪。"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"她已在罐里汲满水了，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"可是她还在涟漪上苦苦寻觅；"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"寻觅雪浪的喧哗，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"寻觅夜莺的歌吟，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"寻觅红柳的涛声，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"寻觅羞涩的私语，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"寻觅一支梦幻般的绵绵夜曲。"}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"那是她丢失在这儿的一支夜曲，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"在那难忘的七月的一个夜晚。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"1979年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","51"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-5","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"那就是她对我的最后微笑么"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"那是朦胧的月夜，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"那是褐黄的沙包，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"从瀚海深处吹来阵阵微风，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"轻轻催动红柳絮絮的涛声；"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"在火焰般燃烧的光波里，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"她曾深情地对我微笑。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"那就是她对我的最后微笑么？"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"我再也没有见到那样的微笑了；"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"虽然我也看过闪光的眼睛，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"瞳孔里也飘动青春的火苗，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"也像褐黄沙包的红柳那样燃烧，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"也像朦胧月夜的红柳那样燃烧。"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"1979年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","52"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-6","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"啊，红柳丛中的那只夜莺"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"希望你快些飞去，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"希望你不要歌唱，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"啊，红柳丛中的那只夜莺。"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"月亮已经睡熟了，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"白云已经睡熟了，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"大漠已经睡熟了。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"一切都静悄悄的、静悄悄的，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"连窗帘都静悄悄的低垂着，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"那是因为风儿不愿将她惊醒。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"她撒下的种子早已萌芽了，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"她撒下的种子正悄悄生长着，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"——我的心坎还摇曳着绿色的涛声。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"快些飞去吧，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"快些飞去吧，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"她一定正羞涩地做着一个绿色的梦哩。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"1979年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","53"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-7","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"为了编织塞上的春色"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"为了编织塞上的春色，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"拖拉机手不倦地划着直线的轨迹；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"将幸福的向往写上斑斓的晨曦，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"将纯真的情谊写上斑斓的晨曦。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"伴着瀚海般澎湃的心声，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"织就的深赭锦带在飘曳，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"在雪浪将要穿过的大地，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"在夜色将要逝去的大地。"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"这犁头织就的锦带是以青春编织的，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"是以理想编织的，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"是以绵绵的经线编织的，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"是以绵绵的纬线编织的。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"将憧憬也编织进去，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"将梦幻也编织进去，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"还有昨夜的絮语，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"——那向恋人发出的红柳般燃烧的誓……"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"1979年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","54"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-8","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"流曳绿色的旋律"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"朦胧的月亮在浩瀚的沙海漂浮，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"山峰般的浪涛漂浮一盏黯淡的灯；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"沙包上，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"流曳绿色的旋律，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"——夜雾里升起抒情的笛声。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"那青春的旋律不息奔腾，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"在岛屿般的沙包上不息奔腾，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"穿过婀娜飘过的乳白的雾，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"穿过乳白的雾留下的倩影。"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"绿色的旋律还穿过白色的炊烟，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"曳着古尔班通古特的习习夜风；"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"轻抚骆驼刺淡黄花瓣上滚动的露珠，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"还有抖颤针叶湿漉漉的沙尘。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"拓荒者曾从绿色的故乡带回这支竹笛，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"不倦地吹奏对姑娘诚挚的恋歌；"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"这支恋歌也送给了飘雾的陌生瀚海，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"送给飘雾的陌生瀚海红柳的树丛，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"送给飘雾的陌生瀚海波涛的山峰。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"1979年8月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","55"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-9","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"啊，你还是不要离开我"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"你到闪光的露珠干涸了再离开我吧，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"你到美丽的夜莺飞去了再离开我吧；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"你到黯淡的星光消逝了再离开我吧，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"你到朦胧的残月西坠了再离开我吧；"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"啊，你还是不要离开我，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"你最好还是不要离开我。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"1979年10月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","56"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-10","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"那是被陡峭沙包碰飞的车轮"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"时而在璀璨的银河中穿行，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"时而在燃烧的红柳中穿行。"}],["$","p","2",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","3",{"className":"min-h-[1.5em] ","children":"绵绵夜曲还在萦绕，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"连归途都弥漫醉人的香馨。"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"刚从童话般的梦境中走来，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"微笑着，还默默思忖。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"恍惚中，红柳丛中滚动一轮硕大的圆月，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"——那是被陡峭沙包碰飞的车轮……"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"1980年5月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","57"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-11","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"啊，那暗蓝的雪浪"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"#### 1"}],["$","p","1",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","2",{"className":"min-h-[1.5em] ","children":["啊，那暗蓝的",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"天山融雪汇成的溪流在沙漠边缘奔涌的景象。亦指准噶尔冬季的雪原波涛。在诗中既是自然景观，也是生命力与情感的隐喻。","children":["雪浪",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"，"]}],["$","p","3",{"className":"min-h-[1.5em] ","children":"收聚了月光，也收聚了星光。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"前面的浪花逝去了，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"后面的浪花却开放得更加妖娆。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"一朵朵浪花簇拥着一朵朵浪花，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"像无数飘动着的暗蓝的火苗。"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"一定是收聚了恋人那片炽热的爱，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"才在苍穹下熊熊燃烧。"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"#### 2"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"簇拥一束红柳的花瓣，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":[["$","span","0",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"天山融雪汇成的溪流在沙漠边缘奔涌的景象。亦指准噶尔冬季的雪原波涛。在诗中既是自然景观，也是生命力与情感的隐喻。","children":["雪浪",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"绕过沙包的山峰。"]}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"玫瑰般的花瓣从我眼前飘过，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"我眼前也飘过玫瑰般的梦境。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"水中的红柳花瓣那样的香馨，"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"梦中的红柳花瓣也那样香馨。"}],["$","p","24",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","25",{"className":"min-h-[1.5em] ","children":"这是她在遥远的上游捎带给我的呢，"}],["$","p","26",{"className":"min-h-[1.5em] ","children":"还是红柳纷飘的落英？"}],["$","p","27",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","28",{"className":"min-h-[1.5em] ","children":"#### 3"}],["$","p","29",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","30",{"className":"min-h-[1.5em] ","children":"不息的爱的旋律在飘曳，"}],["$","p","31",{"className":"min-h-[1.5em] ","children":"穿过湿漉漉的夜雾。"}],["$","p","32",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","33",{"className":"min-h-[1.5em] ","children":"穿过燃烧着的红柳纱帐，"}],["$","p","34",{"className":"min-h-[1.5em] ","children":"穿过铺满晶莹月光的沙包的山谷。"}],["$","p","35",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","36",{"className":"min-h-[1.5em] ","children":["小溪缀着",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"天山融雪汇成的溪流在沙漠边缘奔涌的景象。亦指准噶尔冬季的雪原波涛。在诗中既是自然景观，也是生命力与情感的隐喻。","children":["雪浪",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"的音符，"]}],["$","p","37",{"className":"min-h-[1.5em] ","children":"小溪缀着星星的音符。"}],["$","p","38",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","39",{"className":"min-h-[1.5em] ","children":"不息的爱的旋律在飘曳，"}],["$","p","40",{"className":"min-h-[1.5em] ","children":"不息的溪水就是奔腾着的线谱。"}],["$","p","41",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","42",{"className":"min-h-[1.5em] ","children":"#### 4"}],["$","p","43",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","44",{"className":"min-h-[1.5em] ","children":[["$","span","0",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"天山融雪汇成的溪流在沙漠边缘奔涌的景象。亦指准噶尔冬季的雪原波涛。在诗中既是自然景观，也是生命力与情感的隐喻。","children":["雪浪",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"也有不灭的乡情，"]}],["$","p","45",{"className":"min-h-[1.5em] ","children":"至今还留连冰峰的记忆。"}],["$","p","46",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","47",{"className":"min-h-[1.5em] ","children":"只是为了实现一位姑娘的叮嘱，"}],["$","p","48",{"className":"min-h-[1.5em] ","children":"这才日夜兼程来到陌生的异域。"}],["$","p","49",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","50",{"className":"min-h-[1.5em] ","children":"捎着绿色的和风，"}],["$","p","51",{"className":"min-h-[1.5em] ","children":"捎着忠贞的信息。"}],["$","p","52",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","53",{"className":"min-h-[1.5em] ","children":"终于在这儿留下姑娘的赤诚，"}],["$","p","54",{"className":"min-h-[1.5em] ","children":"——那轻轻拍击沙岸的爱的涟漪……"}],["$","p","55",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","56",{"className":"min-h-[1.5em] ","children":"1980年7月"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"className":"space-y-2","children":[["$","li","0",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[1,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"雪浪"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"天山融雪汇成的溪流在沙漠边缘奔涌的景象。亦指准噶尔冬季的雪原波涛。在诗中既是自然景观，也是生命力与情感的隐喻。"]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","58"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-12","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"她是微笑着姗姗走去的"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"那丛红柳依然火焰般燃烧，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"可是她已经走了。"}],["$","p","2",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","3",{"className":"min-h-[1.5em] ","children":"她是微笑着姗姗走去的，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"她是采摘了一小束红柳花瓣走去的。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"我还看到月光照抚着她的微笑，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"她把红柳花瓣就插在鬓发上。"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"她带着我的希冀走了，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"她带着我的思念走了。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"我再也没有看到过她了，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"虽然我还看到过许多美丽的姑娘。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"虽然也是来采摘红柳花瓣的，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"虽然也把红柳花瓣插在鬓发上。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"她已经走了，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"可是那丛红柳依然火焰般燃烧。"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"1981年1月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","59"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-13","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"我就要到她那儿去"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"我就要到她那儿去，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"那儿有我憧憬的绿洲；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"有陡峭的林墙，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"有荡漾的浓荫，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"有盛开的雪浪。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"我就要到她那儿去，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"那儿有我向往的夜曲；"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"那圣洁的心灵的旋律，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"那多情而又温柔的旋律呀，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"那夜莺般使人沉醉的旋律呀……"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"1981年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","60"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-14","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"我轻抚这枚血红的戈壁石"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"那美好的记忆又从我心中升起，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"每当我轻抚这枚血红的戈壁石。"}],["$","p","2",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","3",{"className":"min-h-[1.5em] ","children":"她早就走了，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"当代的普罗米修斯早就走了。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"可是给我留下了永恒的火种，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"——飘动的火焰是不会熄灭的。"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"那火焰至今还在飘曳，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"还照耀我的心坎。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"像燃烧的红柳花瓣那样，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"璀璨而且赤诚。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"曾伴我度过多雪的严冬，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"曾伴我度过寂寞的长夜。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"谁说相思的红豆只生长多情的南国，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"不也生长古尔班通古特沙包的谷地？"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"1981年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","61"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-15","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"默默地走"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"没有听到夜莺的轻柔歌吟，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"没有听到红柳的轻柔歌吟，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"没有听到沙包的轻柔歌吟。"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"虽然已经陶醉了，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"已经陶醉在这支乐曲里了，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"还专注在音响的海洋寻觅。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"我是在寻觅她那跳荡的心声，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"我是在寻觅她那多情的心声，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"我是在寻觅她那虔诚的心声。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"默默地走，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"默默地走，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"我们默默地走在玫瑰般的红柳丛中。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"1981年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","62"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-16","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"啊，我心中有一轮永远不落的月亮"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"潮儿退了，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"潮儿退了，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"瀚海上空那轮浑圆的月亮已经西坠了。"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"红柳还在摇曳，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"夜莺还在歌吟，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"温柔的夜曲般的絮语还在萦绕。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"她早就离开这儿了，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"如白云般轻盈，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"悄悄离开了这绛紫的纱帐。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"那条小路就像梦中一样漫长，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"我也像梦中那样深情，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"我也像梦中那样张望。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"我的心潮还在上涨，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"我的心潮还在上涨，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"啊，我心中有一轮永远不落的月亮。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"1981年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","63"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-17","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"小溪从湛蓝的夜里流过"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"汨汨的雪浪不息地奔流，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"——那是沉睡大漠跳动的心脏；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"小溪从湛蓝的夜里流过，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"也从我心田流过，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"还散发雪莲的香馨，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"还散发塔松的香馨。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"雪浪来自遥远的冰峰，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"却在这儿绽开，也在这儿凋谢；"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"可是，那零落了的雪浪花还滋润着褐黄色的沙砾，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"滋润着萌芽了的希望的种子，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"滋润着沙包那边的一片绿洲，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"滋润着遥远恋人幸福的梦……"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"1981年7月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","64"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-18","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"我可以不要天上的那轮月亮"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"红柳消逝了，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"沙包消逝了，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"连永远在我面前飘摇的地平线也消逝了，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"光明与黑暗的轮廓都消逝了；"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"我可以不要天上的那轮月亮，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"我是在古尔班通古特的夜里穿行。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"一定是她的光辉照耀着漆黑的夜幕，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"照耀着通往绿洲的这条小径，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"那样明媚，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"那样深情；"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"我可以不要天上的那轮月亮，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"我是在古尔班通古特的夜里穿行。"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"1981年8月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","65"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-19","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"那是初恋那些夜晚的深沉回声"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"沙沙——"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"沙沙——"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"广袤的瀚海已经睡熟了，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"宁静的夏夜只拍击着红柳的涛声。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"殷红的波涛在月下闪耀，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"湿漉漉的露珠浑圆而且晶莹；"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"轻柔地歌唱，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"轻柔地奔腾。"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"灿烂的花瓣还在不息地燃烧，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"起伏的波浪还在不息地燃烧，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"还是那样炽烈，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"还是那样深情。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"沙沙——"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"沙沙——"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"那绵绵的絮语又掠过我的心坎，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"我知道，这是初恋那些夜晚的深沉回声。"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"1982年1月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","66"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-20","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"呼唤黎明的飞鸟"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"哪儿是天幕呀，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"哪儿是大地呀，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"地平线的轮廓还没有显露出来呢；"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"那飞鸟却拍打金色的翅翎，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"深情地呼唤迟来的黎明。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"一定穿过了云的鹿砦，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"一定穿过了云的波涛，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"一定穿过了云的山峰；"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"飞呀飞呀，向远方飞去，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"在无涯的黑暗中向远方飞去。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"分明是朝着沙包那边飞去，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"分明是朝着红柳那边飞去，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"分明是朝着我梦魂缠绕的那边飞去；"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"那儿有一小片依然沉睡着的绿洲，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"那儿也是如此寂静。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"啊，启明星"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"——呼唤黎明的飞鸟，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"衔着第一缕金黑色的曙光，"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"衔着不眠的拓荒者的虔诚思念，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"不倦地飞去，"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"飞到我的恋人童话般的美丽梦境。"}],["$","p","24",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","25",{"className":"min-h-[1.5em] ","children":"1982年1月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","67"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-21","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"虽然也是那样的忧伤"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"在没有月光的夜里飘曳，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"在没有星光的夜里飘曳，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"——那是我的澎湃不息的歌声。"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"穿过前方那座高峻的沙岭，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"穿过前方那片开阔的谷地，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"轻轻地盘旋，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"就在那密密的红柳林。"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"在那盛开着灿烂花瓣的枝条上，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"栖息着一只美丽的夜莺，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"栖息着一只沉默的夜莺。"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"快快飞去，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"快快飞去，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"我的夜曲般的温柔歌声，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"我的夜曲般的深情歌声。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"轻抚着她吧，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"轻抚她的滚动着晶莹泪珠的脸颊，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"轻抚她的沾满着晶莹夜露的羽翎。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"我的澎湃不息的歌声是那么炽热，"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"我的澎湃不息的歌声是那么虔诚，"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"——虽然也是那样的忧伤，"}],["$","p","25",{"className":"min-h-[1.5em] ","children":"将轻抚她那颗破碎的心。"}],["$","p","26",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","27",{"className":"min-h-[1.5em] ","children":"1982年1月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","68"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-4-22","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"象一只悲戚的夜莺向我飞来"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"像一只悲戚的夜莺向我飞来，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"趁着朦胧的月色向我飞来，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"从那绛紫的红柳纱帐向我飞来，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"从那褐黄的沙包山峰向我飞来。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"晶莹的泪珠还在闪耀，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"晶莹的夜雾那样闪耀，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"在那美丽的翎羽上闪耀，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"在那飞翔的翎羽上闪耀。"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"湿漉漉的，湿漉漉的，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"难怪那样的沉重，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"却分明那么执着，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"却分明那么虔诚。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"她的手绢还在绛紫的红柳纱帐里向我摇曳，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"她的手绢还在褐黄的沙包山峰上向我摇曳；"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"像一只悲戚的夜莺向我飞来，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"趁着朦胧的月色向我飞来。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"1982年2月"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"---"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之四：为了爱情，巴格达不嫌远"]}],["$","span",null,{"children":["页码 ","69"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}]]]}]]]}]}]
