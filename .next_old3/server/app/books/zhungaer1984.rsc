m] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"这儿有过闪耀丝绸光泽的小径，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"也会有缚住沙龙的长缨万丈。"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1976年1月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","19"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-20","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"一块蓝宝石在开拓的绿洲镶嵌"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"旅行者在戈壁之舟上遥遥眺望，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"一块蓝宝石在开拓的绿洲镶嵌；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"难道是遥远的赛里木湖飞落这儿？"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"飞扬的渔歌拨动心弦。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"驼铃曾在这儿摇响了好多个世纪，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"伴着高悬的冷月，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"回荡寂寞的人间；"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"也曾见过水榭，也曾见过楼阁，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"——海市蜃楼的幻景常在旅途出现。"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"《一千零一夜》的神话也诞生在这儿，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"诞生在东方的古尔班通古特，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"开拓者实现了缥缈的梦幻；"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"神奇的人工湖注满深情，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"滋润绿洲，滋润心田。"}],["$","p","16",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","17",{"className":"min-h-[1.5em] ","children":"牧歌对着渔歌唱呀，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"来来来，急骤的鼓点飘飞湖面；"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"旅行者在戈壁之舟遥遥眺望，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"一块蓝宝石缝缀在祖国母亲飘曳的裙衫。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"1977年5月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","20"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-21","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"那是阿妈挥动的手臂"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"是谁在大漠的傍晚涂上一抹炊烟？"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"落日轻轻飘浮在金蛇闪耀的湖面；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"捕鱼的人们早该归来了，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"亲人久久伫立岸边。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"船舷都快没在水里了，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"还在那儿盘旋，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"汗珠儿一定挂满喜悦的笑脸。"}],["$","p","8",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","9",{"className":"min-h-[1.5em] ","children":"鱼儿装满舱，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"又是丰收年，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"一只船儿，一座金色的山峦。"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"在这儿耕耘，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"在这儿收获，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"将丰饶的故乡移到了戈壁荒滩。"}],["$","p","16",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","17",{"className":"min-h-[1.5em] ","children":"满天云霞是写下的辉煌战报，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"文化教员就要寄到你们的故乡，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"寄到那遥远的江南。"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"喷香的奶茶已经烧开了三遍，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"亲人默默朝着远方思盼；"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"一抹炊烟——那是阿妈挥动的手臂，"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"落日轻轻飘浮在金蛇闪耀的湖面。"}],["$","p","25",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","26",{"className":"min-h-[1.5em] ","children":"1977年5月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","21"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-22","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"织进多少深情的线"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"夜幕隐去巍巍天山晶莹的雪冠，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"也隐去滔滔的雪浪花，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"也隐去轻捷的机帆船。"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"树影在摇曳，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"渔网在摇曳，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"寒风也扑打她的心坎。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"“‘红星’，‘红星’，你在哪里？”"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"竹梭上的绳儿连着远方，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"这是一个不平静的夜晚。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"鱼儿丰收了，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"果实也丰收了，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"一片红云飘上沉思的脸。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"织呀，织呀，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"织不尽的经经纬纬，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"那渔网，织进多少深情的线。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"一颗闪光的星穿过渔网，"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"一颗闪光的星划破夜幕，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"啊，“红星”的桅灯飞过浪尖……"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1977年5月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","22"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-23","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"啊，好大一片淡蓝的晨雾"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"月亮从苍茫的夜幕上隐去了，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"星星从苍茫的夜幕上隐去了，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"啊，好大一片淡蓝的晨雾。"}],["$","p","3",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","4",{"className":"min-h-[1.5em] ","children":"仍然什么都还在朦胧的微光中，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"看不见燃烧的红柳，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"看不见沙包的山谷。"}],["$","p","7",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","8",{"className":"min-h-[1.5em] ","children":"褐色的地平线隐蔽到哪儿去了？"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"飘摇的地平线隐蔽到哪儿去了？"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"还有火红的机车、蜿蜒的小路。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"好一顶淡蓝的纱帐，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"——这是一顶宽阔的纱帐，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"给我伪装，叫人有目难睹。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"可是，这儿的什么都铭记在拓荒者的心坎，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"我们看过的每一朵野花，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"我们植下的每一棵绿树。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"1978年1月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","23"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-24","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"在经纬仪上瞄呀瞄呀"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"看到了低飞的小鸟，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"看到了青青的树苗，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"在经纬仪上瞄呀瞄呀；"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"一条奔腾的水渠连着雪山和大漠，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"雪浪曳着闪光的珍珠奔腾呼啸……"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"可是，沙的雾帐又在你的眼前升起，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"奇妙的幻景顷刻云散烟消；"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"我们的小鸟呢？"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"我们的树苗呢？"}],["$","p","10",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","11",{"className":"min-h-[1.5em] ","children":"风沙依然拥簇无数奔腾的金字塔，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"——经纬仪外依然屹立无数的沙包；"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"不要以为海市蜃楼最为美丽，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"心中珍藏的蓝图更加妖娆。"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"瞄落了星辰，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"瞄开了雪莲，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"不倦地在绘图板上勾画着A角、B角；"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"一条奔腾的水渠将连着雪山和大漠，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"拓荒者的笑声已伴随心海的雪浪滔滔。"}],["$","p","21",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","22",{"className":"min-h-[1.5em] ","children":"1978年10月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","24"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-25","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"戴着高高花冠的小鸟"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"刚刚飞过这褐色的荒地，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"刚刚飞到这未来的绿洲，"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"天山雪水就为你梳理羽毛；"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"戴着高高花冠的小鸟追逐晶莹的雪浪花，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"晶莹的雪浪花呼唤戴着高高花冠的小鸟。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"不要嫌这儿还没有一片绿色的林海，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"没有红艳艳的花，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"没有绿茵茵的草，"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"也没有燃烧着青春之火的抒情交响乐章，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"——那曾永远伴着你的飒飒风涛。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"留下来吧，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"就在这儿筑下一个小巢，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"这儿就会成为茫茫瀚海中的一个绿岛；"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"虽然这儿只有金字塔般的褐色浮雕，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"可是已经摇曳象征我们定居的翡翠的树苗。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"雪浪花不会凋零，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"永远也不会的，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"还将开遍风沙线那边的褐黄沙包；"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"飞吧，戴着高高花冠的小鸟，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"飘落的翎羽将化为拓荒者丰收的喜报。"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1978年10月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","25"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-26","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"只是为了争春"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"绿色的冬麦隐藏到哪儿去了？"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"银灰的林带隐藏到哪儿去了？"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"风雪的浪涛吞噬了当年开发的绿洲，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"雪浪里却屹立一片翡翠般不沉的岛屿。"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"这儿飘浮乳白的薄雾，"}],["$","p","6",{"className":"min-h-[1.5em] ","children":"这儿飘洒蔚蓝的细雨；"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"农艺师笑了，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"看着以心血浇灌的田畦。"}],["$","p","9",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","10",{"className":"min-h-[1.5em] ","children":"可是她的心坎也曾投下乌云般阴影，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"多少荒芜的春天就在思盼中寂寞地过去；"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"只是为了争春，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"才辛勤地在冬天播下盎然的新绿。"}],["$","p","14",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","15",{"className":"min-h-[1.5em] ","children":"雪雾透过一抹玫瑰色的曙光，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"雪雾闪耀一块翡翠般的宝石；"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"春姑娘戴着头巾匆匆来到塞上，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"温室外，正奔驰那急骤的马蹄。"}],["$","p","19",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","20",{"className":"min-h-[1.5em] ","children":"1978年10月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","26"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-27","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"沿着风的踪迹追撵"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"古尔班通古特像大海般肃穆，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"没有一片云彩的天幕澄澈瓦蓝；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"一缕轻风哪能瞒过警觉的眼睛，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"戴上防风镜；"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"沿着风的踪迹追撵。"}],["$","p","5",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","6",{"className":"min-h-[1.5em] ","children":"默默奔袭，"}],["$","p","7",{"className":"min-h-[1.5em] ","children":"像猎人寻觅野兽的蹄印，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"多少日子已将茫茫大漠踏遍；"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"风的巢穴究竟隐藏在哪儿呢？"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"在治沙的气象图上早已标上这个难点。"}],["$","p","11",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","12",{"className":"min-h-[1.5em] ","children":"穿过冲天的沙柱、干涸的沙滩，"}],["$","p","13",{"className":"min-h-[1.5em] ","children":"往前看，还是沙的山峦、沙的云天；"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"只有茁壮的骆驼草傲对风沙，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"春色正浓哩，"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"摇曳着金色的花冠。"}],["$","p","17",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","18",{"className":"min-h-[1.5em] ","children":"古尔班通古特像大海般汹涌，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"在那沙包下，"}],["$","p","20",{"className":"min-h-[1.5em] ","children":"不就是他梦寐以求的风源？"}],["$","p","21",{"className":"min-h-[1.5em] ","children":"一股气流挟着雷鸣般巨响滚动过来，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"紧攥的风力计在急骤飞旋……"}],["$","p","23",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","24",{"className":"min-h-[1.5em] ","children":"1978年10月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","27"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-28","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"“A点—A点……”"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"褐黄的沙包连着褐黄的云天，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"一叶孤舟在波涛汹涌的瀚海扬帆；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"进行曲的旋律在飘曳，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"进行曲的旋律在回旋，"}],["$","p","4",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","5",{"className":"min-h-[1.5em] ","children":"“A点—A点……”"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"可是，目前，A点在哪儿呢？"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"还只在行军地图上面——"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"大漠屹立一个威武的“A”，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"那外围，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"是光晕般的一个粗犷的红圈。"}],["$","p","12",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","13",{"className":"min-h-[1.5em] ","children":"向往着她，"}],["$","p","14",{"className":"min-h-[1.5em] ","children":"憧憬着她，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"巍巍天山一样的信念从此耸立心坎；"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"又一片绿洲将在那儿崛起，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"雪浪将在被开垦的处女地飞溅。"}],["$","p","18",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","19",{"className":"min-h-[1.5em] ","children":"“A点—A点……”"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"我呼唤着，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":"却只见褐黄的波涛向车窗飞卷；"}],["$","p","23",{"className":"min-h-[1.5em] ","children":"这个“A”是以心血写就的，"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"天山下，又将装扮一个繁花似锦的春天。"}],["$","p","25",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","26",{"className":"min-h-[1.5em] ","children":"1978年10月"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","28"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}],["$","article",null,{"id":"poem-1-29","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"那盛开的雪花已经凋零了"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"那盛开的雪花已经凋零了，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"从低垂的天空无声地凋零了；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"飘落在大漠的固体水库——天山冰峰，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"飘落在拥簇玛瑙般红叶的新林，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"飘落在摇曳翡翠般波涛的冬麦的条田，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"飘落在被开垦的处女地上风化了的土层。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"还像蝴蝶般蹒跚跳着“死亡之舞”，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"晶莹的“象牙之塔”哪能包容一颗赤炽的心；"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"她将融进每一粒萌芽的种子，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"她将融进每一粒干涸的沙尘，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"还将融进拓荒者飘雾的浩瀚的心海，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"融进无垠雪原的澎湃的歌吟……"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"1978年10月"}],["$","p","15",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","16",{"className":"min-h-[1.5em] ","children":"---"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","准噶尔诗草","》 · ","卷之一：飘动的篝火"]}],["$","span",null,{"children":["页码 ","29"]}]]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["李瑜"," / ","1984年"]}]]}]]}]]]}],["$","div","chapter-2",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"卷之二：将军与城"}],[["$","article",null,{"id":"poem-2-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"他在黎明前死去"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"瀚海静静沉淀着无垠的沙砾，"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"硝烟在沙包的谷地轻轻飘浮；"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"他苏醒了，"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"他躺在将军怀里，"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"瞳孔里生命之火还在燃烧，"}],["$","p","5",{"className":"min-h-[1.5em] ","children":"还在飞舞。"}],["$","p","6",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","7",{"className":"min-h-[1.5em] ","children":"一把冰冷的沙砾从他指缝中淌下，"}],["$","p","8",{"className":"min-h-[1.5em] ","children":"烧焦的军衣已让鲜血染透了；"}],["$","p","9",{"className":"min-h-[1.5em] ","children":"一丛翠树从眼前掠过，"}],["$","p","10",{"className":"min-h-[1.5em] ","children":"曾哺育过他的故乡从眼前掠过，"}],["$","p","11",{"className":"min-h-[1.5em] ","children":"还簇拥袅袅的炊烟，"}],["$","p","12",{"className":"min-h-[1.5em] ","children":"还簇拥蓝色的露珠。"}],["$","p","13",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","14",{"className":"min-h-[1.5em] ","children":"为了寻求憧憬多年的灿烂光明，"}],["$","p","15",{"className":"min-h-[1.5em] ","children":"才背井离乡踏上一条漫长而崎岖的路；"}],["$","p","16",{"className":"min-h-[1.5em] ","children":"梦中的故乡永远笼罩凄凉的夜色，"}],["$","p","17",{"className":"min-h-[1.5em] ","children":"连那牧歌，"}],["$","p","18",{"className":"min-h-[1.5em] ","children":"连那绿浪，"}],["$","p","19",{"className":"min-h-[1.5em] ","children":"连那古树。"}],["$","p","20",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","21",{"className":"min-h-[1.5em] ","children":"他躺在将军怀里，"}],["$","p","22",{"className":"min-h-[1.5em] ","children":["他在",["$","span","1",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"此组诗写新疆解放前夕为革命牺牲的先烈。「黎明前」既指时间，亦喻新疆和平解放（1949年9月）前最黑暗的时刻。","children":["黎明前",["$","sup",null,{"className":"text-xs text-gray-400 ml-px select-none","children":1}]]}],"死去；"]}],["$","p","23",{"className":"min-h-[1.5em] ","children":"在遥远的异乡没有看到罂粟花般的朝霞，"}],["$","p","24",{"className":"min-h-[1.5em] ","children":"没有看到浑圆的大漠日出，"}],["$","p","25",{"className":"min-h-[1.5em] ","children":"但以最后一滴血染红了戈壁石，"}],["$","p","26",{"className":"min-h-[1.5em] ","children":"染红了未来石河子坚固如磐的城基。"}],["$","p","27",{"className":"min-h-[1.5em] h-6","children":""}],["$","p","28",{"className":"min-h-[1.5em] ","children":"1979年7月"}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-gray-100","children":[["$","h4",null,{"className":"text-xs font-sans font-semibold text-gray-400 uppercase tracking-widest mb-4","children":"注释"}],["$","ol",null,{"clas