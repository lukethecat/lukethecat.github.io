 text-gray-300","children":"—"}],"تشانغ تشيان - مبعوث ومستكشف من سلالة هان، قاد أولى الرحلات لاستكشاف طريق الحرير إلى آسيا الوسطى بأمر من الإمبراطور وو."]}]]}],["$","li","1",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[2,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"هوجيا"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"هوجيا - آلة قصبية للقبائل البدوية الشمالية القديمة، وتتميز بنغمة حزينة ومقفرة، وغالبًا ما تُستخدم في شعر الحدود."]}]]}],["$","li","2",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[3,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"يوجي الكبرى"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"يوجي الكبرى - شعب بدوي مركزه ممر خيشي، هاجر إلى آسيا الوسطى وكان وجهة تشانغ تشيان لعقد تحالف ضد شيونغنو."]}]]}],["$","li","3",{"className":"flex text-sm text-gray-500 leading-relaxed","children":[["$","span",null,{"className":"text-xs text-gray-400 mr-2 mt-0.5 flex-shrink-0 font-mono","children":[4,"."]}],["$","span",null,{"children":[["$","span",null,{"className":"font-medium text-gray-600","children":"صولجان هان"}],["$","span",null,{"className":"mx-1.5 text-gray-300","children":"—"}],"صولجان هان - عصا من الخيزران يزينها ذيل الياك، ترمز إلى سلطة وتفويض المبعوث الإمبراطوري لسلالة هان."]}]]}]]}]]}],["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","خيول الدم المتعرّق","》 · ","يا قارة آسيا الوسطى الجديدة"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-