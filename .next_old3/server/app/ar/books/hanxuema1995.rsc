2:["$","$L8",null,{"book":{"title":"خيول الدم المتعرّق","author":"لي يوي","year":"1995","chapters":[{"id":"chapter-1","title":"يا قارة آسيا الوسطى الجديدة","poems":[{"id":"poem-1-1","title":"لا بد أن ذلك السهم المجيد لا يزال محلقاً / منطلقاً نحو الغرب البعيد","lines":["شمس الغروب بلون الدم توشك أن تغيب","وستارة الليل بلونها الذهبي الداكن توشك أن تسدل","تشانغ تشيان يسوق قطيعه نحو الديار","بعد ثلاث عشرة سنة من عبور الرمال والصمت","ولم يتبق من شعارات الإمبراطورية سوى عصا بالية بدأت تفقد خيوطها","","لا بد أن ذلك السهم المجيد لا يزال محلقاً","منطلقاً نحو الغرب البعيد","حيث الأرض تنتهي، وتبدأ الأساطير","حيث تدندن أوتار الفضاء لحناً لم يُسمع من قبل","","أيها المبعوث، يا من جعلت من الظل رفيقاً","يا من أشرت نحو جبال الأورال بنظرة لا تلين","يا من زرعت خطاك في قلب طاجيكستان","ها قد طوى الصقيع لحيتك","لكن عينيك لا تزالان ترنوان","أعمق من كل الممالك التي رأيت"],"annotations":[{"term":"تشانغ تشيان","note":"تشانغ تشيان - مبعوث ومستكشف من سلالة هان، قاد أولى الرحلات لاستكشاف طريق الحرير إلى آسيا الوسطى بأمر من الإمبراطور وو."},{"term":"هوجيا","note":"هوجيا - آلة قصبية للقبائل البدوية الشمالية القديمة، وتتميز بنغمة حزينة ومقفرة، وغالبًا ما تُستخدم في شعر الحدود."},{"term":"يوجي الكبرى","note":"يوجي الكبرى - شعب بدوي مركزه ممر خيشي، هاجر إلى آسيا الوسطى وكان وجهة تشانغ تشيان لعقد تحالف ضد شيونغنو."},{"term":"صولجان هان","note":"صولجان هان - عصا من الخيزران يزينها ذيل الياك، ترمز إلى سلطة وتفويض المبعوث الإمبراطوري لسلالة هان."}]},{"id":"poem-1-2","title":"تراخت الأيدي المتشابكة ببطء / واستدارت العيون الدامعة فجأة","lines":["السهب المترامي الأطراف قد غفا","وجبال تشيليان المكللة بالثلج قد غفت","ولابد أن الطفل في الخيمة المصنوعة من اللباد قد غفا هو الآخر","مستمعاً إلى الريح التي تصفر عبر أسلاك السياج","","تراخت الأيدي المتشابكة ببطء","واستدارت العيون الدامعة فجأة","أميرة شونغنو لا تستطيع اللحاق به","والمبعوث من هان لا يسعه البقاء","الإمبراطورية تنتظره","وموطنها يربطها هنا","لقد تركوا قلبهم كرهينة عند الجانب الآخر"],"annotations":[{"term":"جبال تشيليان","note":"جبال تشيليان - جبال بين قانسو وتشينغهاي، تعني 'الجبل السماوي' بلغة شيونغنو، وكانت الحصن الجنوبي لممر خيشي."}]},{"id":"poem-1-3","title":"أيا يوتشي العظيمة / الأرض المقدسة التي طالما حلم بها لأحد عشر ربيعاً","lines":["كم مضى على امتطائه الجواد، هو لا يعلم","وما إذا كان لا يزال يمتطيه، هو غير متأكد","في الظلام، لم يعد حتى الأفق المعتم مرئياً","أيا يوتشي العظيمة، الأرض المقدسة التي طالما حلم بها لأحد عشر ربيعاً","","لقد اجتاز صحراء تاكلامكان وغابات الموت","وجلب الحرير من الأرض الوسطى","أملاً في أن يجد حلفاء ضد الأعداء في الشمال","لكن الملك هناك هز رأسه وقال:","\"دماء الحروب قد جفت.","هذه الأرض خصبة، ورغبتنا هي السلام.\""],"annotations":[{"term":"تانغيي فو","note":"تانغيي فو - مرافق ودليل تشانغ تشيان الوفي من قبائل شيونغنو خلال رحلته المحفوفة بالمخاطر إلى المناطق الغربية."}]},{"id":"poem-1-4","title":"يستحم في ذاك الإشعاع البارد / كما اشتاق النور للظل","lines":["تلك الشمس المستبدة —","متى أودعت أسهمها الذهبية الحارقة في غمدها؟","هلال فوق قمم تيانشان الغربية البعيدة","يستحم في ذاك الإشعاع البارد","كما اشتاق النور للظل","","في ليلة صحراوية باردة وكأنها جليد","ينظر المبعوث نحو النجوم ويفكر في مسقط رأسه","لويانغ تبدو كأنها وهم في هذه الصحراء","بمرور الأيام والسنين، تلاشت في ذاكرة بعيدة"]},{"id":"poem-1-5","title":"رائد طريق الحرير ابتسم من على صهوة جواده / محدقاً غرباً","lines":["لم يعد ضيقاً كممر خشي","لم يعد درباً متعرجاً","محصوراً بين سلاسل الجبال التوأم","","هنا تتسع الأرض كأنها بحر","ويمتد الأفق بلا نهاية","رائد طريق الحرير ابتسم من على صهوة جواده","محدقاً غرباً","حيث تشرق الشموس الجديدة كل مساء","","خطواته الأولى هي التي شقّت الطريق","دماً، ورملاً، وصمتاً","حتى تتمكن قوافل الغد من السير"],"annotations":[{"term":"ممر خيشي","note":"ممر خيشي - ممر تاريخي ضيق في قانسو بين الجبال، كان الرابط الوحيد بين السهول الوسطى والمناطق الغربية على طريق الحرير."},{"term":"طريق الحرير","note":"طريق الحرير - شبكة طرق التجارة القديمة التي تربط الصين بآسيا وأوروبا، وسُميت نسبة إلى الحرير الصيني المصدر."}]}]},{"id":"chapter-2","title":"تحت جبال تشيليان، خيّم الصمت","poems":[{"id":"poem-2-1","title":"أبقى عينيه مثبتتين / على قمم جبال تشيليان الجليدية البعيدة","lines":["السيل الحديدي يتدفق ببطء","والصحراء الكبرى تتدفق ببطء","ناظراً من على صهوة جواده","أبقى عينيه مثبتتين","على قمم جبال تشيليان الجليدية البعيدة","","هوه تشو بينغ، الشاب الذي لم يُهزم قط","الذي لاحقت قواته الفرسان كأنها رياح","صانعاً إمبراطورية بحد السيف"],"annotations":[{"term":"هوو تشيوبينغ","note":"هوو تشيوبينغ (140-117 ق.م) - جنرال عبقري شاب من سلالة هان هزم شيونغنو في جبال تشيليان، وتوفي مبكرًا في عمر 24 عامًا."}]},{"id":"poem-2-2","title":"أهذا هو بحيرة الهلال التي طالما حلم بها؟ / بحيرة الهلال التي زينت أحلامه يوماً؟","lines":["ما زال يควุد جواده مسرعاً","في عمق الليل","حيث وحده قرع الحوافر","يقطع الصمت","أهذا هو بحيرة الهلال التي طالما حلم بها؟","بحيرة الهلال التي زينت أحلامه يوماً؟","ملاذ من الماء العذب وسط محيط من الرمال"],"annotations":[{"term":"دونهوانغ","note":"دونهوانغ - مدينة واحة قديمة تقع في أقصى ممر خيشي، ومركز مهم على طريق الحرير، اشتهرت بكهوف موغاو والفنون البوذية."},{"term":"بحيرة الهلال","note":"بحيرة الهلال - ينبوع عند سفح جبل مينغشا في دونهوانغ، ويُعرف شكلاً كالقمرحول، ويعتبر منذ القديم 'أول ينبوع في الصحراء'."}]},{"id":"poem-2-3","title":"الحمامة الزاجلة حلقت في دوائر للحظة ثم / طارت شرقاً","lines":["لقد سقط الجندي لتوه","حينما شق سترته السوداء بلهفة","وانطلقت من صدره حمامة زاجلة","نحو السماء","","حلقت الحمامة في دوائر للحظة ثم","طارت شرقاً","حاملة رسالة لم تُكتب قط","إلى بيت لن يراه مجدداً"]},{"id":"poem-2-4","title":"آه، يا ابن جبال تيانشان / سيل من ذوبان الثلوج","lines":["في نسيم الربيع","عباءة الجنرال الشاب القرمزية","ترتفع كسحابة حمراء من سرج حصانه","آه، يا ابن جبال تيانشان","سيل من ذوبان الثلوج","الذي صب دماءه في الأرض","لتنمو منها واحات خضراء"]},{"id":"poem-2-5","title":"حصانه الأسود الطيفي / يقف متجمداً كتمثال تحت جبال تشيليان","lines":["تحت جبال تشيليان، خيّم الصمت","حصانه الأسود الطيفي","يقف متجمداً كتمثال تحت جبال تشيليان","ينتظر أمراً لن يأتي أبداً"]},{"id":"poem-2-6","title":"وافقاً في غروب الشمس الذهبي الداكن بنكهة الخمر الحلوة / واقفاً في بازَارات المستقبل لطريق الحرير","lines":["توقفت شمس الغروب للحظة قبل أن تتوارى","كأنها تضيء بخيوط ذهبية وجنتي الجنرال البرونزيتين","ملامحه التي حفرها الزمن وصقلتها الريح","وافقاً في غروب الشمس الذهبي الداكن بنكهة الخمر الحلوة","واقفاً في بازَارات المستقبل لطريق الحرير"],"annotations":[{"term":"جيوتشوان","note":"جيوتشوان ('ينبوع الخمر') - مدينة في قانسو سُميت بعد صب هوو تشيوبينغ للخمر الإمبراطوري في ينبوع ومشاركته مع جنوده."}]}]},{"id":"chapter-3","title":"خشخاش بريّ","poems":[{"id":"poem-3-1","title":"تحت الحوافر المتسابقة / تتكشف أمواج من شقائق النعمان البرية","lines":["تمتطي جوادها آتية من المرتفعات العشبية العميقة","من بين شقائق النعمان البرية، بلون اليشم والقرمزي","ضفائرها تتطاير خلفها","تحت الحوافر المتسابقة","تتكشف أمواج من شقائق النعمان البرية","أميرة هان التي أصبحت ابنة السهوب"],"annotations":[{"term":"كونيس","note":"كونيس - مرج ألبين في سلسلة جبال تيانشان في شينجيانغ، غني بالمياه والعشب، وكان المرعى الأساسي لدولة أوسون القديمة."},{"term":"الأميرة شيجون","note":"ليو شيجون - أرسلها الإمبراطور وو للزواج من ملك أوسون، كجزء من تحالف الزواج السياسي لسلالة هان."},{"term":"أوسون","note":"أوسون - مملكة بدوية في وادي نهر إيلي ارتبطت بالزواج والمصاهرة كحليف دبلوماسي قوي مع سلالة هان."}]},{"id":"poem-3-2","title":"ليلة يوليو / صامتة وساكنة جداً","lines":["ليلة يوليو","صامتة وساكنة جداً","حتى نهر إيلي خفتت همهمته","","إنها تستيقظ من حلم عن تشانغآن","لتجد نفسها في خيمة من اللباد","بعيدة كل البعد عن أشجار الصفصاف، وأزهار الخوخ"],"annotations":[{"term":"نهر إيلي","note":"نهر إيلي - نهر ينبع من تيانشان نحو بحيرة بالكاش، وهو تاريخياً موطن ثقافات أوسون والكازاخ."}]},{"id":"poem-3-3","title":"شقيقة النعمان البرية ذات اللون البني الداكن قد ذبلت / لكن بتلاتها لا تزال تنبعث منها رائحة مُسكرة","lines":["شقيقة النعمان البرية ذات اللون البني الداكن قد ذبلت","لكن بتلاتها لا تزال تنبعث منها رائحة مُسكرة","","تلك هي أميرة التحالف التي أُرسلت بسلام","إلى قلب هذه الأرض القاسية، القاصية","ذبلت في شبابها، لكن ذكراها","لا تزال تفوح بالجمال"]},{"id":"poem-3-4","title":"أمامها، نهر إيلي / لا يحمل أي أثر لتلك الورقة القرمزية التي حملت قلب طفولتها","lines":["في اليوم الذي غادرت فيه تشانغآن","ضغط طفل ورقة حمراء في يدها","وضعتها على مياه نهر وي","لتراها وهي تبحر نحو الشرق","","لكنها الآن في الغرب العميق","لم يتبق سوى بتلات متساقطة من شقائق النعمان البرية","ورغم أنها تميل إلى الحمرة","إلا أنها ليست ورقتها القرمزية","","ملك الأوسون عجوز","خيمته تفوح برائحة لحم الضأن وحليب الخيل المتخمر","من خلال شق الخيمة يمكنها رؤية","جبال تيانشان المكسوة بالثلوج","","طفولتها دُفنت في تشانغآن","وشبابها ضاع على الطريق","ها هي عند حافة العالم المعروف","أميرة بلا مملكة تعود إليها","","أمامها، يتدفق نهر إيلي","حاملاً بتلات شقائق النعمان البرية","ورغم أنها تميل إلى الحمرة أيضاً","لكنها ليست ورقتها القرمزية أبداً"]},{"id":"poem-3-5","title":"عباراتها الحزينة في \"أغنية الحنين إلى الوطن\" / لا تزال يتردد صداها","lines":["زوجتني عائلتي في أطراف السماء —","أغنيتها تنساب منذ ألفي عام","عبر السهوب الفسيحة، وفوق النهر الممتد","","مسكني خيمة من لباد، وجدرانها من صوف","طعامي هو اللحم، وشرابي هو الحليب —","تلك الكلمات التي غنتها تسربت إلى الأرض","إلى جذور كل شقائق النعمان البرية","","أتوق لأن أكون بجعة صفراء","عائدة إلى وطني —","لكن البجعة الصفراء لا تطير شرقاً","بل تحلق في دوائر فوق نهر إيلي","فوق القمم الثلجية لجبال تيانشان","وتبكي","","أغنية الأميرة شي جيون هي","أول قصيدة من قصائد طريق الحرير","كُتبت ليس بالحبر","وإنما بالدموع وبتلات شقائق النعمان البرية","","بعد ألفي عام","لا تزال أزهار كزيارداك القرمزية","تتفتح على ضفاف نهر إيلي","وكأن دموعها","قد تحولت إلى بذور","","عباراتها الحزينة في \"أغنية الحنين إلى الوطن\"","لا تزال يتردد صداها","مع كل ربيع","حينما تتفتح شقائق النعمان البرية من جديد"],"annotations":[{"term":"أغنية الحنين للوطن","note":"أغنية الحنين - كتبتها الأميرة شيجون، تُعبّر عن أسفها للزواج في أرض أجنبية، وهي أقدم أغنية زواج دبلوماسي في الأدب الصيني."},{"term":"البجعة الصفراء","note":"البجعة الصفراء - طائر ورَد في قصيدة الأميرة شيجون، كأمنية أن تصبح بجعة لتعود لوطنها، مما جعله رمزًا كلاسيكيًا للحنين."},{"term":"زهرة كيزيل أرداق","note":"كيزيل أرداق - تعني 'الزهرة الحمراء' باللغة الكازاخية، وتتميز كزهور التوليب البرية الربيعية الحمراء في وادي نهر إيلي."}]}]},{"id":"chapter-4","title":"خيول الدم المتعرّق","poems":[{"id":"poem-4-1","title":"القائد يمتطي جواده / ابتسامة مريرة تعبر شفتيه","lines":["ستون ألف جندي خرجوا نحو الغرب","قاصدين مملكة لم يسمع بها معظهم من قبل","قاصدين خيولاً تتعرق دماً","","لي قوانغ لي، جنرال إيرشي —","شقيق الزوجة الأثيرة للإمبراطور","رجل اعتاد البلاط أكثر من السرج","ها هو الآن قائد لجيش رقيق كالحرير","","انهارت الحملة الأولى","قبل أن تصل إلى أسوار دايوان","جوّعى، وعطشى، ومنكوبين في الصحراء","عاد متجهاً نحو دونهوانغ","ومعه بالكاد عشر رجاله","","ابتسامة مريرة تعبر شفتيه","لمرسوم الإمبراطور الذي ينتظره:","عُد. واجلب الخيول. أو لا تعد أبدًا.","","يتأمل قمم البامير المكسوة بالثلوج","والسماء الممتدة فوق نهر تاريم","والجنود الصرعى الذين أمست عظامهم","علامات على طول الطريق","","الخيول التي تتعرق دماً في دايوان —","هل كانت تستحق كل هذا العناء؟","الإمبراطور يقول إنها تستحق.","والموتى لا يملكون أجوبة.","","وشد لجامه بقوة","زحف الجيش غرباً من جديد","ستون ألفاً مرة أخرى","إلى أتون الجحيم"],"annotations":[{"term":"لي قوانغ لي","note":"لي قوانغ لي - مبعوث سلالة هان الغربية الذي قاد جيوشاً ضخمة إلى دايوان للحصول على خيول 'التعرق كالدماء'."},{"term":"خيول التعرق الدموي","note":"الخيول الدامية - الخيول الأسطورية (أخال تيكي) في فَرغانَة، اعتُقد أن جلدها يُفرز عرقًا يشبه الدم بعد الجري."},{"term":"دايوان","note":"دايوان (فَرغانَة) - مملكة قديمة في وادي فَرغانَة، اشتهرت تاريخيًا بتربية أجود خيول التعرق الدموي."},{"term":"جبال البامير","note":"جبال البامير - منطقة متجمدة عُرفت بـ'جبال البصل'، وكانت الحاجز الجغرافي الأعلى على طول طريق الحرير القديم."}]},{"id":"poem-4-2","title":"ثم تجمد فجأة وسط سيل الرجال / متجمداً في هيئة حصان يتعرق دماً، يصهل نحو السماء","lines":["فُتحت أخيراً أبواب دايوان","ليس بفضل الدبلوماسية، بل بحد السيف","داخل الأسوار، كانت الخيول الأسطورية","تضرب بحوافرها وتخور في إسطبلاتها","","خواصرها تلمع برطوبة قرمزية","وكأنها تبكي دماً في حر الهجير","حدق الجنود مذهولين","أهذه هي الخيول التي حلم بها الإمبراطور؟","","تم اقتياد ثلاثة آلاف حصان","تضرب حوافرها على الطريق الحجري","كدقات طبل من جوف الأرض","","حصان واحد شب على قائميه فجأة وسط سيل الرجال","متجمداً في هيئة حصان يتعرق دماً","يصهل نحو السماء","وكأنه هو الآخر يعرف الثمن الذي دُفع"]},{"id":"poem-4-3","title":"نحو الغرب البعيد / نحو الغرب الذي لا يُنسى","lines":["المسيرة الطويلة نحو الديار","ثلاثة آلاف حصان في نهر من الغبار","عبر ممر ووزي بيلي","وعبر ليالي البامير الباردة كالحديد","","خيول دايوان، غير المعتادة على هذه الأرض","تعثرت في حصى صحراء تاكلامكان","بعضها سقط ولم ينهض مجدداً","وتسربت دماؤها في الرمال","— حمراء كالعرق الذي نزفته حين كانت تعدو","","لم يغنِّ الجنود أي أغانٍ في هذا الطريق","لقد غنوها جميعاً وهم في طريق الذهاب","الآن، لم يتبق سوى الريح تغني","وصرير عربات المؤن من بعيد","","كان لي قوانغ لي يحصي الخيول مع كل فجر","ومع كل فجر كان العدد يتناقص","وكأن الصحراء كانت تبتلعها","","فكر في نهر أمو","حيث كانت المياه عذبة والعشب أخضر","حيث كان شعب يوتشي يرعى قطعانه يوماً","قبل مجيء تشانغ تشيان، وقبل أن يأتي أي أحد","","نحو الغرب البعيد","نحو الغرب الذي لا يُنسى","لقد سافر مدعوماً بقوة الإمبراطورية","وها هو الآن يعود","محملاً بأحزان إمبراطورية بأسرها","","كم حصاناً سينجو ليصل إلى تشانغآن؟","وكم جندياً؟","خيول دايوان التي تتعرق دماً","لا تملك جواباً","اكتفت بالسير قدماً","نحو الشرق","وتطاير عرقها القرمزي ليجف في رياح الصحراء","كآخر حبر على رسالة حريرية","لن يقرأها أحد"],"annotations":[{"term":"صحراء تكلامكان","note":"صحراء تكلامكان - أكبر صحراء في الصين في حوض تاريم، ويُزعم معناها بالويغورية 'المكان الذي لا مخرج منه'."},{"term":"ممر أوزبيل","note":"ممر أوزبيل - معبر جبلي مهم في جبال البامير يفصل الصين عن قيرغيزستان، وكان مخرجًا غربيًا رئيسيًا لطريق الحرير."},{"term":"نهر جيحون","note":"نهر جيحون (آمو داريا) - أطول أنهار آسيا الوسطى، وفيه استقر شعب يوجي الكبرى بعد هجرتهم نحو الغرب."}]},{"id":"poem-4-4","title":"لقد أصبح يرى بالفعل / أبراج تشانغآن الوقورة واللطيفة","lines":["لقد أصبح يرى بالفعل —","أو يخيل له ذلك —","أبراج تشانغآن الوقورة واللطيفة","","الإمبراطور ينتظر عند بوابة شوان وو","ووزراؤه في أثوابهم الحريرية","والمباخر ترسل دوامات زرقاء نحو السماء","","من بين آلاف الخيول الثلاثة التي تتعرق دماً","لم ينج سوى ألف فقط من مشقة الطريق","لا تزال خواصرها تلمع","لكنها الآن أقرب إلى العظم من العضلات","","سيؤلف الإمبراطور \"أغنية الخيول السماوية\" —","\"روحها استثنائية، وقوتها إلهية\" —","وستُعزف بأجراس، ونقر على اليشم","","لكن لي قوانغ لي دائماً سيتذكر","ليس الأجراس","بل صوت سقوط الخيول في الرمال","وليس دقات اليشم","بل الصمت المطبق بعد صرخة آخر جندي","","الخيول التي تتعرق دماً في دايوان","تقف الآن في إسطبلات الإمبراطورية","ولا يزال عرقها القرمزي يتلألأ","كدموع كل رجل لم يعُد أبداً"],"annotations":[{"term":"الإمبراطور وو من هان","note":"الإمبراطور وو أو وو دي (156-87 ق.م) - إمبراطور سلالة هان السابعة الذي قام بالتوسع الاستراتيجي في المناطق الغربية."},{"term":"أغنية الخيول السماوية","note":"أغنية الخيول السماوية - كتبها الإمبراطور وو متغنياً بجمال وحيوية الخيول الدامية التي جُلبت من دايوان."}]}]},{"id":"chapter-5","title":"لوولان اختفت في لحظة","poems":[{"id":"poem-5-1","title":"ساجد بجوار بحيرة لوب نور / ساجد تحت نار المذبح العظيم","lines":["ساجد بجوار بحيرة لوب نور","ساجد تحت نار المذبح العظيم","يرتل كاهن لولان بلسان مجهول","وتمتد خيوط ظله في المسطحات الملحية","","أين ذهبت المياه؟","البحيرة التي عكست يوماً قمم جبال كونلون","لم يتبق منها سوى بلورات ملحية","تتشقق مثل عظام الأسماك","","لا تزال غابات الحور قائمة","جوفاء وتشبه الهياكل العظمية","ميتة منذ ألف عام ولكنها لاتزال منتصبة","وكأنها تنتظر عودة المياه","","اختفت لولان في طرفة عين —","ليس بسيف أو في نار","بل بالتحول البطيء لمسار النهر","","حتى الإمبراطوريات لا تملك أن تأمر","المسار الذي يختاره الماء","وحتى الصلوات لا تملك أن تستجلب","مطرًا من سماء خاوية"],"annotations":[{"term":"لوب نور","note":"لوب نور - بحيرة مالحة أصبحت جافة بالكامل تقريباً، وفيها الآثار القديمة لمملكة لولان ومواقع تجارب ذرية سابقة."},{"term":"حور الفرات","note":"أشجار الحور الصحراوية - شجرة تتميز بمقاومتها المذهلة للجفاف في تكلامكان، ويُقال إنها تحيا وتسقط وتبقى لألف عام دون أن تتعفن."},{"term":"الأثل","note":"الأثل (الصفصاف الأحمر) - شجرة مقاومة للبيئات القاسية القاحلة والملوحة وتشكل عصب مكافحة التصحر وعواصف الرمل."},{"term":"لولان","note":"لولان - مدينة ومملكة رئيسية على طريق الحرير قرب لوب نور، اختفت في القرن الرابع الميلادي بسبب الجفاف."}]},{"id":"poem-5-2","title":"هذه البذرة التي جُمعت من غابات لوب نور / لا تزال مبللة بندى الليل","lines":["هذه البذرة التي جُمعت من غابات لوب نور","لا تزال مبللة بندى الليل","حملها لألف فرسخ نحو الشرق","ملفوفة في قصاصة من حرير لولان","","إذا زُرعت في تراب تشانغآن","هل ستنمو؟","هل ستتذكر الشاطئ المكسو بالملح؟","وصيحات الطيور المهاجرة؟","","التاجر القادم من لولان","وقف عند ملتقى الحضارات","حيث سار الحرير غرباً وجاء اليشم شرقاً","حيث تشابكت اللغات في البازار","","ضغط البذرة على خده","كانت باردة، كليالي البحيرة","باردة، كبشرة ابنته","التي تركها خلفه","","ابنته التي تلعب الآن","بين أطلال مملكة","لن يُعثر عليها","إلا بعد ألف وثمانمائة عام أخرى"]},{"id":"poem-5-3","title":"آه، دع الصوت الخالد لأمواج لوب نور / يتردد للأبد في أحلام الوطن","lines":["آه، دع الصوت الخالد لأمواج لوب نور","يتردد للأبد في أحلام الوطن","","رغم أن الأمواج قد سكنت منذ زمن بعيد","رغم أن قاع البحيرة يتشقق تحت الأقدام","لكن في مكان ما تحت الملح","تستمر ذكرى المياه","","مثل أغنية ترفض الرمال نسيانها","مثل طريق تعجز الرياح عن محوه","","دع شبح شجرة الحور يقف شاهداً","ودع شجرة الطرفاء تغرس جذورها في الكثيب","حتى يأتي النهر في قرن بعيد،","ويتذكر مساره القديم","ويتدفق عائداً إلى لولان"]},{"id":"poem-5-4","title":"بحيرة لوب نور الهلالية / قد غربت بالفعل عند الحافة البعيدة لسماء نائية","lines":["حيث استراحت القوافل يوماً","حيث وُزن اليشم وطُوي الحرير","حيث روى الحكواتي عن جبال في الغرب","وعن بحار خلف تلك الجبال","","الآن لم يتبق سوى الريح","سوى الخشخشة الجافة للأغصان الميتة","سوى تلال الياردانج","التي نحتتها قرون من الحصى","","بحيرة لوب نور الهلالية","قد غربت بالفعل عند الحافة البعيدة لسماء نائية","لم تعد بحيرة","بل مجرد ذكرى بحيرة","","جاء المستكشف من السويد","ونفض الرمال عن وجه لولان","فشهق العالم","لجمال الأموات","","أهدابها لا تزال خالية من العيوب","بعد أربعة آلاف عام تحت الملح","جميلة لولان","تغط في سبات عميق","داخل صندوق زجاجي في أورومتشي","","بينما لا تزال الريح تهب","فوق المكان الذي وُلدت فيه","حيث لا شيء ينمو","حيث لا شيء يتحرك","سوى ذكرى الماء والنور"]}]},{"id":"chapter-6","title":"يا بحيرة بايكال، الخريف عميق","poems":[{"id":"poem-6-1","title":"تسعة عشر عاماً على ضفاف البحر الشمالي / فقط العصا الإمبراطورية البالية تتذكر","lines":["تسعة عشر عاماً على ضفاف البحر الشمالي","حيث لا ينبت عشب ولا يدفئ صيف","أُرسل سو وو ليرعى الأغنام","أغناماً لا تلد مطلقاً، في أرض لا تذوب ثلوجها قط","","صادروا سيفه، وصادروا حريره","لكنهم لم يصادروا ولاءه","فقط العصا الإمبراطورية البالية تتذكر","قيمة الأوامر التي أُعطيت له","","تسعة عشر عاماً من ثلج سيبيريا","على شارب رجل كان يافعاً ذات يوم","على عصا كانت يوماً تتلألأ بالشراشف"],"annotations":[{"term":"بحيرة بايكال","note":"بحيرة بايكال - البحيرة الأقدم والأعمق عالميًا في سيبيريا، ونُفي إليها المبعوث الصيني سو وو الذي أُتخذ راعياً للغنم."},{"term":"سو وو","note":"سو وو - مبعوث سلالة هان أُسر في الشمال لمدة 19 عاماً ولم يستسلم أبدًا، مخلصًا لعصا إمبراطوريته طوال الأسر."}]},{"id":"poem-6-2","title":"حينما أخبروه بأنه يستطيع العودة إلى الديار / سقطت أهدابه البيضاء الخفيفة مثل ندف الثلج الحزينة","lines":["حينما أخبروه بأنه يستطيع العودة إلى الديار","سقطت أهدابه البيضاء الخفيفة مثل ندف الثلج الحزينة","تسعة عشر عاماً — حياة بأكملها مقاسة بالعواصف","عمر بأكمله مقاس بالقمح الذي لم يُحصد قط","","هل تشانغآن لا تزال تشانغآن التي عرفها؟","هل الإمبراطور لا يزال يذكر اسمه؟","بكى سو وو، ليس حزناً على السنوات الضائعة","بل لأن العصا الإمبراطورية ستعود أخيراً","إلى الأرض التي سُلمت له فيها"]},{"id":"poem-6-3","title":"لي لينغ جاء لرؤيته في مأدبة الوداع / لي لينغ، الجنرال المنفي","lines":["لي لينغ جاء لرؤيته في مأدبة الوداع","لي لينغ، الجنرال المنفي","الذي اختار الاستسلام بدلاً من الموت","والذي كان يحكم الآن تحت راية شونغنو","","شربا الخمر في صمت","رجلان من تشانغآن","أحدهما استسلم، والآخر لم يفعل","أحدهما سيركب راجعاً نحو الشرق","والآخر سيُدفن في السهوب المظلمة","","بكى لي لينغ حين غادر سو وو","لأنه أدرك في تلك اللحظة","أن بعض الأشياء أصلب من خيول شونغنو","أصلب من سيوفهم","بعض الأشياء لا تنكسر"],"annotations":[{"term":"لي لينغ","note":"لي لينغ - جنرال وقائد فرسان شجاع من أسرة هان، قاتل بقوة ولكنه استسلم لجيوش شيونغنو بعد نفاد سهامه وإمداداته."}]},{"id":"poem-6-4","title":"وتقول الأسطورة / إن صوته لا يزال يُسمع","lines":["وتقول الأسطورة","إن صوته لا يزال يُسمع","فوق صقيع بحيرة بايكال — البحر الشمالي","حيث لا تزال الريح تصفر عبر أسلاك السياج","","سو وو عاد إلى تشانغآن","بشعرٍ أبيض كقمم جبال كونلون","لكن شبحه ظل هناك","يرعى الأغنام في العاصفة الثلجية","شاهداً أبدياً","على الرجل الذي لم ينسَ قط"],"annotations":[{"term":"بجعة التم","note":"أوزة - في القصة التاريخية الصينية، أُرسلت قصائد سو وو في رسالة ربطها الإمبراطور برجل الطائر، فأصبحت البجعة رمزًا لرسائل البريد."}]}]},{"id":"chapter-7","title":"في يارقند الشاسعة","poems":[{"id":"poem-7-1","title":"سرب الحمام الذي يحلق فوق ممر يانغقوان الموحش / لا بد وأنه يعُيد بذور زجاج البحر الأبيض المتوسط","lines":["سرب الحمام الذي يحلق فوق ممر يانغقوان الموحش","لا بد وأنه يعُيد بذور زجاج البحر الأبيض المتوسط","وبذور العنب من فيرغانا","وأشجار الرمان من بلاد فارس","وموسيقى لم تُعزف قط على قانون محلي","","طريق الحرير ليس مجرد حزام للتجارة","إنه حزام لنقل البذور","يتلقف الإمبراطوريات ويزرعها","في تربة غرباء تماماً"],"annotations":[{"term":"يارقند","note":"نهر يارقند - واحة تاريخية في غرب الصين ومنبع رئيسي لنهر تاريم."},{"term":"أميرة الحرير","note":"أميرة الحرير - هي أميرة صينية هَرَّبت بذور دودة القز من الصين كجزء من جهازها، مُدخلةً الحرير إلى المناطق الغربية."},{"term":"ممر يانغوان","note":"ممر يانغوان - حصن مهم في هان جنوبي دونهوانغ، اشتهر ببيت وانغ وي الشعري حاملاً وداع الصداقة للمسافرين."}]},{"id":"poem-7-2","title":"هذا الأفق ذو اللون العسجدي البني / قد ابتلع ذات مرة نايات القصب والجياد المدرعة","lines":["هذا الأفق ذو اللون العسجدي البني","قد ابتلع ذات مرة نايات القصب والجياد المدرعة","خياماً وقوافل","أميرات وقساوسة","","وكل ما يتبادله الآن","هو طاقة الرياح وقسوة الرمال","وروايات تُروى في الليل","على ضوء نيران المخيم","","طريق الحرير نهر","تبخر منذ أمد بعيد","ولم يتبق سوى القاع المرصوف باليشم"]},{"id":"poem-7-3","title":"الهلال فوق المسجد الكبير / لا يزال ينظر للأسفل نحو هذا البازار العتيق","lines":["الهلال فوق المسجد الكبير","لا يزال ينظر للأسفل نحو هذا البازار العتيق","حيث ما كان يُشترى بالحرير","يُشترى الآن بالأوراق النقدية","لكن الوجوه لم تتغير قط","","تجار من سمرقند","تجار من كاشغر","عيونهم تحمل نفس الحسابات","أيديهم تتبادل نفس التوابل","وتتحدث نفس اللغة الخشنة، الجميلة للتجارة"]},{"id":"poem-7-4","title":"علمتهن كيف يفككن الشرنقة / أميرة خوتان الصينية","lines":["علمتهن كيف يفككن الشرنقة","أميرة خوتان الصينية","التي هربت بذور التوت وبيض دودة القز","مخبأة في تسريحة شعرها","","جلبت سر الحرير شرقاً","لتستطيع مملكتها الجديدة أن تنسج المجد الخاص بها","خائنة لإمبراطوريتها القديمة","آمِلة لإمبراطوريتها الجديدة","","وكيف لك ألا تغفر لها؟","لقد جلبت معها الربيع بأسره","مخبأً في شعرها"]},{"id":"poem-7-5","title":"الملك آشيخان ملك خوتان / ذو العيون الزرقاء كاللازورد","lines":["الملك آشيخان ملك خوتان","ذو العيون الزرقاء كاللازورد","أرسل مبعوثيه إلى تشانغآن","حاملين اليشم وموسيقى لم يُسمع بها من قبل","","كانت هناك أمبراطورية للحرير، وأخرى لليشم","والتقت الاثنتان في خوتان","حيث كانت الأنهار تتدفق بلون أبيض وأسود كالأحجار","وتتدفق بدموع العشاق","وتتدفق بوشردات القوافل"],"annotations":[{"term":"أسيخان","note":"أسيخان - ملك خوتان الرمزي والأمير الذي تزوج أميرة الحرير الصينية ليحصل سراً على بذور دودة القز."}]}]},{"id":"chapter-8","title":"انطفأت نيران الإشارة","poems":[{"id":"poem-8-1","title":"ستة وثلاثون رجلاً ركبوا إلى الأقاليم الغربية / ستوكيلون إمبراطورية بأكملها","lines":["ستة وثلاثون رجلاً ركبوا إلى الأقاليم الغربية","ستوكيلون إمبراطورية بأكملها","على أكتاف ستة وثلاثين حصاناً","","ترك بان تشاو قلمه وراءه","وقال: \"الرجل العظيم يجب أن يثبت جدارته في أرض أجنبية","ليس بالفرشاة والحبر","بل بالسيف والعرق\"","","ورجاله زأروا كجيش قوامه آلاف","يغرقون حتى قرع الحوافر المدوي","مثل عاصفة هابطة","","مع بزوغ الفجر، كان مبعوثو شونغنو قتلى","وملك شانشان","راكعاً أمام راية هان","","ابتسم بان تشاو","كما يبتسم العالِم","حين يقع الحرف الصحيح أخيراً","في مكانه","","بقي في الأراضي الغربية ثلاثين عاماً","ثلاثين عاماً مع الستة والثلاثين رجلاً","الذين أصبحوا درعاً لإمبراطورية","عند أطراف العالم","","ونيران الإنذار التي أشعلها","على طول طريق الحرير القديم","احترقت لثلاثة عقود","ثم انطفأت، الواحدة تلو الأخرى"],"annotations":[{"term":"بان تشاو","note":"بان تشاو - جنرال ودبلوماسي استطاع مع 36 ضابطاً استعادة نفوذ الإمبراطورية الصينية بالكامل في العديد من الممالك الغربية."},{"term":"شانشان","note":"شانشان - مملكة قديمة نجح فيها بان تشاو بتنفيذ خطته ليلًا للقضاء على مبعوثي شيونغنو وتحالف المملكة مع هان."}]},{"id":"poem-8-2","title":"وكأن مائة ألف رجل مدرع / ينشدون لحناً كئيباً ومهجوراً","lines":["في شيخوخته، طلب بان تشاو العودة لتراب الوطن","وكانت رسالته للإمبراطور تنص على:","\"لا أجرؤ على أن آمل بلوغ جيوتشوان حياً","كل ما أتمناه أن تعبر عظامي ممر يويمن\"","","قرأ الإمبراطور الرسالة وبكى","واستجاب لطلبه","","وكأن مائة ألف رجل مدرع","ينشدون لحناً كئيباً ومهجوراً","عبر الممر، عبر الردهة","عبر ثلاثين عاماً من المنفى","","توفي في غضون شهر من عودته","وكأن جسده كان ينتظر","فقط رؤية الوطن"]},{"id":"poem-8-3","title":"مُنخرطون سلفاً في التحام قريب / يقتلون بصمت","lines":["بعد مغادرة بان تشاو، خفتت نيران الإنذار","وتضاءلت الحاميات الصغيرة","مُنخرطون سلفاً في التحام قريب","يقتلون بصمت","","بغیاب حضوره","تصدعت الأقاليم الغربية","مملكة تلو الأخرى","مثل مسبحة من اليشم","انقطع خيطها","","كان الصمت الذي أعقب بان تشاو","أعلى من أي معركة","صمت إمبراطورية تتراجع","من أطراف العالم"]},{"id":"poem-8-4","title":"نجمة الصباح تخبو / ونيران الإنذار قد خمدت","lines":["نجمة الصباح تخبو","ونيران الإنذار قد خمدت","على طول الطريق من دونهوانغ إلى كاشغر","فقط الريح تتحرك الآن","","وتنهار أبراج المراقبة","وقد انطفأت إشارات الدخان منذ زمن بعيد","والحراس قد عادوا لبيوتهم","أو دُفنوا في الرمال","","لكن الطريق لا يزال باقياً","منحوتاً في الأرض بقرون","من الحرير واليشم والتوابل","من الجيوش والرهبان والتجار","","ونجمة الصباح تخبو","لكنها ستشرق مجدداً","كما كانت تشرق دائماً","فوق ممرات البامير","وفوق سهول آسيا الوسطى","","ونيران الإنذار قد خمدت","لكن الطريق صامد","الطريق صامد","طريق الحرير صامد","شعلة بعد شعلة"]}]},{"id":"chapter-9","title":"الخليج الفارسي الأزرق الداكن","poems":[{"id":"poem-9-1","title":"يصلي بصمت باتجاه الغرب البعيد / تلك الأرض المقدسة","lines":["وقف قان ينغ عند حافة العالم المعروف","حيث تنتهي الأرض ويبدأ البحر","يصلي بصمت باتجاه الغرب البعيد","تلك الأرض المقدسة — روما — دا تشين","","وهز التجار البارثيون رؤوسهم:","\"البحر شاسع. والرحلة تستغرق أشهراً.\"","\"والعديد ممن يبحرون لا يعودون أبداً.\"","","تأمل في المياه الزرقاء الداكنة","والأمواج التي فصلته عن روما","عن الحافة الغربية لطريق الحرير","عن الإمبراطورية التي كانت ترتدي الحرير","الذي نسجه شعبه","","وعاد أدراجه","وهو أبعد مبعوث أرسلته الصين","كاد — كاد — أن يلمس روما","","عام 97 بعد الميلاد","السنة التي نقف فيها رجل صيني","عند الخليج الفارسي","ولم يتمكن من المضي أبعد"],"annotations":[{"term":"غان يينغ","note":"غان يينغ - المبعوث العسكري الذي بُعث أبعد نحو الغرب للبحث عن دا تشين (روما) عام 97، ووصل للخليج العربي لكنه عاد."}]},{"id":"poem-9-2","title":"عبر الأغصان حيث جثمت طيور الحجل الذهبية / تسقط أمطار حمراء غزيرة بصوت حفيف","lines":["في حدائق المدائن","عُلق الرمان مثل الفوانيس","عبر الأغصان حيث جثمت طيور الحجل الذهبية","تسقط أمطار حمراء غزيرة بصوت حفيف","","تمشى قان ينغ في تلك الحدائق الغريبة","يستنشق روائح لا أسماء لها عنده","ويتذوق فاكهة لم تنمُ في أي تربة صينية","","استقبله الملك البارثي بفضول","\"أتيت من أرض الحرير؟\"","\"إلى أي مسافة مشيت؟\"","","حسب قان ينغ في ذهنه:","من لويانغ إلى هنا — أربعون ألف لي","سبع سنوات من المشي","عبر كل مملكة بينهما","","وقال: \"لقد مشيت","من حيث تشرق الشمس إلى حيث تبدأ في الغروب.\"","","وضحك الملك","وصب له خمراً","داكناً كالخليج الفارسي","وعطراً كطريق لا نهاية له"]},{"id":"poem-9-3","title":"الريح من جبال زاغروس، رطبة / تهب نحوه بنكهة مالحة","lines":["الريح من جبال زاغروس، رطبة","تهب نحوه بنكهة مالحة","حاملة همسات البحر أبعد من ذلك","","كاد يشتم رائحة روما","وكاد يرى أعمدتها الرخامية","ترتفع من رغوة البحر","","لكن البارثيين لم يسمحوا له بالعبور","فقد أحكموا سيطرتهم على منتصف الطريق","سماسرة الحرير والزجاج","الذين أثروا من المسافة","بين الشرق والغرب"],"annotations":[{"term":"جبال زاغروس","note":"سلسلة جبال زاغروس - جبال طبيعية في غرب إيران امتدت حاجزاً بين الخليج العربي وسهول ما بين النهرين القديمة."},{"term":"الخليج العربي","note":"الخليج العربي - الخليج الذي ذُكر بأن المبعوث الصيني غان يينغ وصل إليه قبل أن يتم إقناعه بنهاية العالم المائية والعودة بسلام."}]},{"id":"poem-9-4","title":"اختلطت مياه البحر المالحة بالدموع المريرة / وأُلقيت مجدداً في الخليج الفارسي الأزرق الداكن","lines":["وقف عند حافة المياه طويلاً","تتكسر الأمواج فوق حذائه الجلدي المهترئ","واختلطت مياه البحر المالحة بالدموع المريرة","وأُلقيت مجدداً في الخليج الفارسي الأزرق الداكن","","لقد أتى من مسافة بعيدة","عبر الممرات المتجمدة لجبال البامير","عبر رمال تاكلامكان","ومروراً بأطلال ممالك","نسي حتى العلماء أسماءها","","وهنا، عند عتبة روما","أُعيد قافلاً","ليس بجيش","وإنما بكذبة تاجر","","\"البحر سيستغرق عامين\"، هكذا قالوا","وهم يعلمون أن الأمر لا يستغرق سوى أسابيع","وهم يعلمون أنه لو التقى الشرق بالغرب مباشرة","لتلاشت ثروتهم كوسطاء","","استدار قان ينغ نحو الشرق","وسقط ظله على الخليج الفارسي","وهو أطول ظل طرحته الصين غرباً","","وحمل معه تقارير العودة","عن زجاج يُنفخ كالأرقاء","وعن بهلوانات وملتليع نيران","وعن إمبراطورية أنداد لإمبراطوريته","","إمبراطوريتان تجهلان بعضهما البعض","يفصل بينهما الصحراء والمكر","ورجل واحد","كاد — كاد — أن","يطوي المسافة","واقفاً تغمره الأمواج الزرقاء الداكنة","لغاية كاحله","في الخليج الفارسي","في عام 97 ميلادي"]}]},{"id":"chapter-10","title":"أمواج نهر تاريم","poems":[{"id":"poem-10-1","title":"جنوده الثلاثة آلاف من دونهوانغ / خروا راكعين أيضاً على ضفة النهر","lines":["قاد سو لي ثلاثة آلاف رجل من دونهوانغ","عبر تاكلامكان الحارقة","إلى ضفاف نهر تاريم","","كان النهر شريان حياتهم —","مياه داكنة تندفع من ذوبان ثلوج","جبال لا يستطيعون رؤيتها","","جنوده الثلاثة آلاف من دونهوانغ","خروا راكعين أيضاً على ضفة النهر","يضغطون وجوههم على الماء","ويشربون وكأنهم لن يشربوا مجدداً","","ثم نهضوا وبدأوا بالزراعة","هؤلاء الجنود الذين حملوا السيوف","صاروا الآن يحملون المحاريث","","كانت أولى المزارع العسكرية في الأقاليم الغربية","زُرعت في أرض مجبولة بالدماء","وُرِّيت بمياه الثلوج المذابة","وحرسها رجال يشتاقون لأوطانهم","","كانت تلك البداية —","أسلاف جنود البينغتوان","والبذرة التي ستنمو","بعد ألفي عام","لتتحول إلى مدن حدودية"],"annotations":[{"term":"نهر تاريم","note":"نهر تاريم - أطول الأنهار الداخلية في الصين يمتد لحوالي 2137 كم، وكان قلب ومصدر الزراعة للممالك الغربية المجاورة القديمة."},{"term":"سو ماي","note":"سو ماي - جنرال عسكري لسلالة هان قاد قوة ضاربة من دونهوانغ لتأسيس أول نظام ري عسكري على نهر تاريم."},{"term":"الزراعة العسكرية","note":"نظام استصلاح عسكري زراعي بدأ في سلالة هان لدعم اقتصاد الحدود، وهو جذور وأساس البناء والإنتاج الحالي في شينجيانغ."}]},{"id":"poem-10-2","title":"أغمض عينيه برفق / سحابة خضراء تنجرف من مسافة بعيدة","lines":["أغمض عينيه برفق","سحابة خضراء تنجرف من مسافة بعيدة","في حلمه، لم يعد شاطئ نهر تاريم","قاحلاً","","حقول القمح تمتد حتى الأفق","والقنوات تخترق الصحراء","كعروق فضية في الصخر","","إنه يرى مستقبلاً لن يعيش ليراه","مستقبلاً من البساتين والقطن","من الطرق والمدارس","من أطفال لن يعرفوا أبداً","صوت السيف يقرع الدرع","","أغمض عينيه برفق","وهو يزرع في حلمه","المزرعة الأبدية","حلم كل جندي","يرجو السلام أكثر من المجد"]},{"id":"poem-10-3","title":"يتحد مع أمواج نهر تاريم الداكنة / يندفع بلا توقف تحت ضوء القمر الشاحب","lines":["في الليل يتحدث النهر","بلغة أقدم من أي إمبراطورية","يتحد مع أمواج نهر تاريم الداكنة","يندفع بلا توقف تحت ضوء القمر الشاحب","","وينصت الجنود","وبعضهم يكتب رسائل للديار","على قصاصات من خشب","بحبر باهت","","يكتبون: \"أنا بخير\"","\"كان الحصاد جيداً هذا العام.\"","\"لقد زرعت شجرة حور.\"","\"وهي تذكرني بأشجار الصفصاف قرب نهر وي.\"","","النهر يحمل أصواتهم","لشرق، دائماً للشرق","عبر ليل الصحراء","وعبر ألفي عام"]},{"id":"poem-10-4","title":"أنارقلي على صهوة جوادها / تحدق في الأفق البعيد","lines":["أنارقلي على صهوة جوادها","تحدق في الأفق البعيد","تمتطي الفتاة الأويغورية حذاء القناة","التي حفرها جنود هان","","هي لا تعرف أسماءهم","لكنها تشرب المياه التي شقوا لها طريقاً","وتأكل ثمار أشجار","زرع أسلافهم بذورها","","ونهر تاريم يواصل التدفق","حاملاً كل قصصهم","من الهان والأويغور، مجندين وفلاحين","الجميع يشربون من نفس النهر","الجميع يحدقون في نفس القمر"]},{"id":"poem-10-5","title":"لا يزال ناظراً للأسفل / لا يزال ناظراً للأسفل","lines":["من المنحدرات المطلة على نهر تاريم","ينظر أسفل بوذا المنحوت","ولا يزال ناظراً للأسفل","ولا يزال ناظراً للأسفل","","لقد شاهد الجيوش تأتي وترحل","القوافل المحملة باليشم","الرهبان يرتلون السوترا","والمزارعين يزرعون القمح","","لا يزال ناظراً للأسفل","وبنفس الابتسامة الهادئة","نحو النهر الذي لا يتوقف","نحو الصحراء التي لا تنام","وإلى الطريق التي لا تنتهي","","ألفا عام من التحديق","ولا يزال العالم يدور","تحت عينيه الحجريتين","نهر تاريم يواصل التدفق","وأمواج نهر تاريم","تحمل الكل","تحمل الكل"]}]},{"id":"chapter-11","title":"المتسوّل الذي عبر الحدود سرّاً","poems":[{"id":"poem-11-1","title":"أهذا هو ليل الحدود؟ / لا تزال يدان ترتعشان من الصقيع في الرياح العاتية","lines":["أهذا هو ليل الحدود؟","لا تزال يدان ترتعشان من الصقيع في الرياح العاتية","تلتفان حول عباءة من فرو الغنم","تحت سماء مرصعة بالنجوم كمحطمة الجليد","","هنا كتب سين تسان، شاعر سلالة تانغ","أشعاره عن الثلج في شهر أغسطس","وعن الرياح المتجمدة كشفرات السيوف","هنا أدرك قسوة الإمبراطورية العظيمة","","هنا ينتهي العالم المعروف","وتبدأ الصحراء المجهولة"],"annotations":[{"term":"الراهب المتسول","note":"يُشير لرحلة الراهب البوذي شوانزانغ غير القانونية بدايةً للبحث عن النصوص، فكان مستكشفاً مجهولاً يواجه الحظر الإمبراطوري."}]},{"id":"poem-11-2","title":"دموع تتلألأ في ضوء النجوم / تتساقط فوق دروع الجنود في ليل الصحراء","lines":["دموع تتلألأ في ضوء النجوم","تتساقط فوق دروع الجنود في ليل الصحراء","دموع رجال تذكروا ديارهم فجأة","عندما دوى صوت ناي بدوي عبر السهوب","","الناي يعزف لحناً من أطراف الأرض","لحناً بارداً كالثلج على جبال تيانشان","كل نغمة، ذكرى","كل صمت، مسافة لا تُعبر"]},{"id":"poem-11-3","title":"في كهوف موغاو صلى طويلاً / طالباً من بوذا الحماية لرحلته","lines":["في كهوف موغاو صلى طويلاً","طالباً من بوذا الحماية لرحلته","الراهب شوانتسانغ، المتجه إلى الهند","بقلب مصمم كصخرة","","آلاف التماثيل تحدق فيه بعيون ساكنة","وآلاف الجداريات تحكي قصص النجاة","لكنه يعلم أن الصحراء أمامه لا تحمل رحمة","سوى الرحمة التي يحملها هو في إيمانه"]},{"id":"poem-11-4","title":"مشى عبر تاكلامكان / حيث لا طير يحلق ولا وحش يخطو","lines":["مشى عبر تاكلامكان","حيث لا طير يحلق ولا وحش يخطو","حيث حتى الريح تبدو وكأنها ضلت طريقها","وسط أمواج الرمال القاحلة","","أيام دون ماء","ليالٍ من صقيع قارص","سراب يرقص على الأفق كشياطين تسخر منه","لكن خطاه لم تتوقف","لأن الحقيقة كانت تنتظره في الغرب"]},{"id":"poem-11-5","title":"يصلي تحت ضوء القمر وعيناه مغمضتان / وقلبه ينبض بإيقاع طريق الحرير","lines":["يصلي تحت ضوء القمر وعيناه مغمضتان","وقلبه ينبض بإيقاع طريق الحرير","تُقرع الأجراس، وتُتلى النصوص المقدسة","تتداخ الأصوات وسط صمت الليل","","هنا على حافة الإمبراطورية","الروح أكثر صفاءً من هواء العاصمة","والله أقرب من أي وقت مضى","تحت تلك النجوم الصحراوية الواسعة"]},{"id":"poem-11-6","title":"في إيسيك كول كان الماء دافئاً / كدموع شوانتسانغ حين رأى الجبال للمرة الأخيرة","lines":["في إيسيك كول كان الماء دافئاً","كدموع شوانتسانغ حين رأى الجبال للمرة الأخيرة","بحيرة كريستالية تعكس السماء والجبال الثلجية","واحة زرقاء بعد جحيم الرمال الصفراء","","توضأ في مياهها وصلى","قبل أن يكمل طريقه عبر قمم البامير","جالباً معه حكمة الشرق للغرب","وستعود معه نصوص الغرب للشرق"],"annotations":[{"term":"سوياب","note":"سوياب - مدينة حصن قديمة بارزة وحاسمة لسلالة تانغ على طريق الحرير ومسقط الرأس الأسطوري للشاعر المبدع الصيني لي باي."},{"term":"بحيرة إيسيك كول","note":"بحيرة إيسيك كول - بحيرة جبَلية عملاقة غير متجمدة في شرق قيرغيزستان عبرها المبعوث شوانزانغ غرباً."},{"term":"يابهو خاقان","note":"يابهو خاقان - زار المبعوث الصيني شوانزانغ هذا الخاقان التابع للأتراك الغربيين الذي استقبله بوثائق سفر وحماية دبلوماسية."},{"term":"شوانزانغ","note":"شوانزانغ - الراهب العظيم الذي أمضى 17 عاماً بالترحال لغرض الوصول إلى الهند والعودة، ملهم الرواية المشهورة رحلة إلى الغرب."}]}]},{"id":"chapter-12","title":"روح الشاعر لا تزال تعدو","poems":[{"id":"poem-12-1","title":"وصل سين تسان إلى الحدود في الخريف / حينما بدأت الأوراق الأولى بالسقوط من أشجار الحور","lines":["وصل سين تسان إلى الحدود في الخريف","حينما بدأت الأوراق الأولى بالسقوط من أشجار الحور","شاعراً بين الجنود","فرشاته كسيفه يقظة حادة","","رأى الثلج يهطل في شهر أغسطس","وشاهد كيف تصبح الريح جلاداً يمزق العباءات","عاش في الخيام المصنوعة من اللباد","وتذوق نبيذ العنب من أكواب اليشم"],"annotations":[{"term":"تسن تسان","note":"تسن تسان - شاعر حدود شهير ورائد في فترة تانغ استوحى أعماله العسكرية وأناشيد الحدود من التضاريس القاسية والباردة لطريق الحرير."}]},{"id":"poem-12-2","title":"بين المعارك، كان يكتب / أبياتاً نقشت الحدود الصينية في الخلود","lines":["بين المعارك، كان يكتب","أبياتاً نقشت الحدود الصينية في الخلود","كلمات أشد برودة من رياح الصحراء","ومعانٍ أكثر دفئاً من نيران المخيم","","كتب عن الوحدة والشجاعة","عن القمر الذي يطل على تشانغآن والسهوب في آن واحد","عن الأبطال الذين لا أسماء لهم","شعر صُهر في نيران القتال، وبُرر بصقيع ليالي الصحراء"]},{"id":"poem-12-3","title":"لا تزال نار المخيم البرتقالية تتلألأ / عبر ألف ومائتي عام","lines":["لا تزال نار المخيم البرتقالية تتلألأ","عبر ألف ومائتي عام","ولن تنطفئ أبداً","","ما دامت أبيات سين تسان تُقرأ","ستبقى تلك النار مشتعلة في قلوبنا","تضيء ليل طريق الحرير الطويل","وتدفئ المسافرين الذين يعبرونه حتى اليوم"]},{"id":"poem-12-4","title":"هادئ جداً لدرجة أنك تستطيع سماع / قطرات دموع الشاعر وهي تتساقط","lines":["حين غادر سين تسان الحدود","التفت لينظر خلفه نحو جبال تيانشان","هادئ جداً لدرجة أنك تستطيع سماع","قطرات دموع الشاعر وهي تتساقط","","لقد وصل خائفاً من البرية","وغادر عاشقاً لها","وصل موظفاً بسيطاً","وغادر شاعراً عظيماً","","صقلته الحدود","كما يصقل النار الفولاذ","البرد والمآفة والوحدة","قد حفرت أبياته","ونحتتها لتبدو كرؤوس الماس","","هادئ جداً لدرجة أنك تستطيع سماع","حتى الآن","صدى فرشاته على الورق","في الريح التي تهب","عبر ممرات تيانشان"]},{"id":"poem-12-5","title":"كقصاصة الورق القرمزية التي صنعتها زوجته / في ليلة زفافهما","lines":["حلم بوطنه","وبوجه زوجته في ضوء المصباح","كقصاصة الورق القرمزية التي صنعتها زوجته","في ليلة زفافهما","","حمراء كغروب الصحراء","ورقيقة كالصقيع على الزجاج","تحمل نمط طيور متزاوجة","وأغصان متشابكة","","طوى قصاصة الورق","ووضعها في جراب قصائده","إلى جانب الأبيات","المكتوبة في ثلج الحدود","","حتى الآن","عندما تقرأ قصائده","تشعر","بدفء تلك القصاصة الورقية","مقابل برد الحدود","حب صمد أمام المسافات","ووطن محمول في حقيبة جلدية","على طول طريق الحرير"]}]},{"id":"chapter-13","title":"يا معركة طلاس","poems":[{"id":"poem-13-1","title":"يبدو وكأنه يرى فرسانه يشنون هجوماً / على ضفاف نهر تالاس","lines":["معركة تالاس، 751 بعد الميلاد","حيث التقت إمبراطورية تانغ بالخلافة العباسية","حيث التقى الشرق بالغرب في الدم والنار","","يبدو وكأنه يرى فرسانه يشنون هجوماً","على ضفاف نهر تالاس","آخر اندفاع عظيم للقوة الصينية غرباً","في قلب العالم الإسلامي","","ضاعت المعركة","وانكسرت جيوش تانغ","وتراجعت الحدود","كوتر قوس منقطع","","لكن من بين أسرى تلك المعركة","سر صناعة الورق","انطلق غرباً إلى سمرقند","إلى بغداد، والقاهرة، وأوروبا","","وتغير العالم للأبد","ليس بسيف المنتصر","وإنما بحرفة الأسير","","معركة تالاس —","هزيمة عسكرية","وانتصار حضاري"]},{"id":"poem-13-2","title":"مستمعاً لصيف تالاس الذي لا يُنسى / أنشودة جنائزية حزينة ولكنها رقيقة","lines":["على ضفاف نهر تالاس في الصيف","تلقي أشجار الحور بظلالها الطويلة","مستمعاً لصيف تالاس الذي لا يُنسى","أنشودة جنائزية حزينة ولكنها رقيقة","","من أجل الجنود الذين سقطوا هنا","والذين أصبحت عظامهم قاعاً للنهر","والذين غذت دماؤهم أشجار الحور","التي لا تزال تقف كحراس","","من بين الأسرى، صانع ورق","علم آسِريه فن الصناعة","فن ضغط لحاء التوت لتحويله لأوراق","فن نثر المعرفة كالبذور","","القلم الذي مكنهم من صنع هذا","سيكتب من التاريخ","أكثر مما حصده السيف الذي أسره","","استمع — نهر تالاس لا يزال يهمس","صوت الماء فوق الورق","صوت عالم يتشكل من جديد","ورقة تلو الأخرى"]},{"id":"poem-13-3","title":"بقعة ضوء زرقاء بنية / تكتسح الأرض الفوضوية والسماء الفوضوية","lines":["بقعة ضوء زرقاء بنية","تكتسح الأرض الفوضوية والسماء الفوضوية","فارس يفر من ساحة المعركة","حاملاً في حقيبة سرجه","","ليس ذهباً ولا يشماً","بل كتلة خشبية للطباعة","منحوتة بحروف","تنطق بسوترا بوذية","","يركب عبر الليل","عبر المذبحة والدخان","وشظية الحضارة هذه","يضمها بقوة إلى صدره","كأنها طفله","","بقعة ضوء زرقاء بنية","تكتسح ظلاماً جليلاً","لإمبراطورية في حالة تراجع","","لكن الحروف تنجو","السوترا تنجو","والكلمة المكتوبة تنجو","لتتجاوز كل شيء"]},{"id":"poem-13-4","title":"آه، يا قمر الهلال ونجمة الصباح / قمر الهلال ونجمة الصباح للإسلام","lines":["بعد تالاس، بزغ الهلال","على الأطراف الغربية لطريق الحرير","آه، يا قمر الهلال ونجمة الصباح","قمر الهلال ونجمة الصباح للإسلام","","حيثما وقفت المعابد البوذية","سترتفع المساجد","وحيثما كانت السنسكريتية تُرتل","ستتحدث الناس بالعربية","","ليس بالغزو — بل بالتغيير التدريجي","كالانعطاف البطيء لمسار النهر","جاء الإيمان مقترناً بالتجار","وليس بالجيوش","","واستمر طريق الحرير","تحت رايات جديدة","بصلوات جديدة","لكن بنفس أجراس الإبل","وبنفس ضوء النجوم","وبنفس الشوق الإنساني","للتواصل عبر المسافات"]},{"id":"poem-13-5","title":"صوت حوافر الخيول الخفيف والمُلح / يغرق بسيمفونية نهر تالاس","lines":["صوت حوافر الخيول الخفيف والمُلح","يغرق بسيمفونية نهر تالاس","ويتلاشى الجيش المنسحب في طيات التاريخ","","لكن التاريخ لا ينتهي","إنه يقلب صفحة جديدة فقط","","على ضفة النهر يجلس أسير","يصنع الورق لآسِريه","ورقة بعد ورقة","بيضاء كالثلوج على جبال تيانشان","رقيقة كالحد الفاصل بين","النصر والهزيمة","","صوت حوافر الخيول الخفيف والمُلح","قد تلاشى منذ أمد بعيد","لكن حفيف الورق","يستمر","ويستمر","عبر كل مكتب","وفي كل دراسة","وفي كل حضارة","لامستها معركة تالاس"]}]},{"id":"chapter-14","title":"القلعة الصغيرة الوحيدة","poems":[{"id":"poem-14-1","title":"المحاربون الثلاثمائة في فرارهم المتهور / ما زالوا يควُدون خيولهم شرقاً","lines":["المحاربون الثلاثمائة في فرارهم المتهور","ما زالوا يควُدون خيولهم شرقاً","بعد تالاس، نحو جبال تيانشان","نحو آخر البؤر الاستيطانية لإمبراطورية تانغ","","سقط قائدهم عند معبر النهر","لكنهم واصلوا الركوب","عبر الجبال المظلمة","عبر الممرات التي تجتاحها الرياح","","ليسوا في تراجع — بل في تحدٍ صريح","يحملون ذكرى الإمبراطورية","في دروعهم المتهالكة","","ثلاثمائة رجل","ضد مد التاريخ المتحول","ما زالوا يควُدون خيولهم شرقاً","عبر ليل لا ينتهي","","على الحافة فوق الوادي","توقفوا","ونظروا للخلف","إلى العالم الذي يتركونه وراءهم","وإلى القرن الذي امتلكوه يوماً","وفقدوه"]},{"id":"poem-14-2","title":"يتساقط الثلج كفراشات بيضاء / يرقص على ساحة المعركة تحت القمر المتضائل","lines":["يتساقط الثلج كفراشات بيضاء","يرقص على ساحة المعركة تحت القمر المتضائل","يغطي الموتى ببطانية","من الرحمة الباردة الناصعة","","بحلول الصباح","ستصبح ساحة المعركة حقلاً أبيض","ولن يعرف أحد","ما حدث هنا","","حتى يكشف ذوبان الربيع","عن الأسهم المكسورة","والسيوف الصدئة","والعظام","","يتساقط الثلج كفراشات بيضاء","جميلاً وقاسياً","كالزمن نفسه","","يغطي تالاس","يغطي الموتى من الجانبين","يغطي الأحياء الهاربين","يغطي صانع الورق الذي بقى","يغطي الجبال الأبدية، التي لا تبالي"]},{"id":"poem-14-3","title":"لابد أنه سمع أمواج إيسيك كول / وهو يستمع من صهوة جواده","lines":["لابد أنه سمع أمواج إيسيك كول","وهو يستمع من صهوة جواده","بينما كان الناجون يعبرون غرب جبال تيانشان","","البحيرة الدافئة في وعائها المكون من الجبال الثلجية","جوهرة لم يتسن لهم التوقف ليرمقوها","جمال تجاوزوه بعدو خيولهم","","لابد أنه سمع أمواجها","وتذكر السلام","وتساءل عما إذا كان","سيعرف السلام مجدداً"]},{"id":"poem-14-4","title":"على هذا الدرب حيث لمع الحرير يوماً / توشك مدينة فتية أن ترتفع","lines":["على هذا الدرب حيث لمع الحرير يوماً","توشك مدينة فتية أن ترتفع","ليس من أطلال الحرب","بل من حاجة البشرية العنيدة","للبناء، والتجارة، والتواصل","","حيثما سقطت القلعة","سينتصب خان للقوافل","وحيثما نزف الجنود","سيتساوم التجار","","على هذا الدرب حيث لمع الحرير يوماً","توشك مدينة فتية أن ترتفع","كما تفعل المدن دوماً","على مقابر المدن الأقدم منها","وعلى طريق لا تموت أبداً"]}]},{"id":"chapter-15","title":"يارقند الزمردية","poems":[{"id":"poem-15-1","title":"حاملاً ذلك المصباح / لزيت مقدس من القدس","lines":["حاملاً ذلك المصباح","لزيت مقدس من القدس","مشى الكاهن النسطوري على طريق الحرير نحو الشرق","باتجاه مملكة خوتان","","وسافرت قصة المسيح في حقيبته","بجانب الحرير والتوابل","الإيمان محفوظ بين بضائع التجارة","والنور بين السلع"]},{"id":"poem-15-2","title":"القناة الزرقاء في البندقية / تلاشت تلك المدينة الصغيرة عن الأنظار","lines":["مر ماركو بولو من هنا","أو هكذا زعم","القناة الزرقاء في البندقية","تلاشت تلك المدينة الصغيرة عن الأنظار","","وحلت محلها آفاق أوسع","صحاري لم يتخيلها البندقي قط","بازارات أكثر روعة","من أسواق الريالتو","","في ياركند الزمردية","التقى الغرب بالشرق، ليس مرة واحدة","بل لمرات لا تنتهي","قرناً بعد قرن","لتاجر في أعقاب تاجر"]},{"id":"poem-15-3","title":"وهناك ذلك الصليب الحديدي / لبرج كنيسة القديس يوحنا في ياركند، يرتفع عالياً","lines":["وهناك ذلك الصليب الحديدي","لبرج كنيسة القديس يوحنا في ياركند، يرتفع عالياً","فوق المآذن","فوق الأبراج البوذية (الستوبا)","","ثلاث ديانات في واحة واحدة","ثلاث صلوات ترتفع إلى سماء مشتركة","كانت هدية طريق الحرير:","ليس التجانس، بل التعددية","","في ياركند، تحدث الله","بكل لغة سلكت هذا الطريق"]},{"id":"poem-15-4","title":"بلا كلل، تقذف / أسهماً باردة شاحبة في الصحراء","lines":["القمر فوق ياركند","بلا كلل، تقذف","أسهماً باردة شاحبة في الصحراء","","تضيء القوافل","التي لا تزال تقطع هذه الأرض العتيقة","حاملة معها الآن، لا حريراً","بل ذكرى الحرير","","ذكرى طريق","ربط في يوم من الأيام","بين كل حضارة على وجه الأرض"]}]},{"id":"chapter-16","title":"جبال ليوبان الصامتة","poems":[{"id":"poem-16-1","title":"اصطاد جنكيز خان في هذه الجبال / بحثاً عن طريدة بحجم إمبراطورية","lines":["اصطاد جنكيز خان في هذه الجبال","بحثاً عن طريدة بحجم إمبراطورية","سنابك خيوله داست على دروب الحرير القديمة","والرياح المنبعثة من سهامه أطفأت كل نار","","لقد ترك وراءه أطلالاً","ومعسكراً لجيشه أصبح في النهاية مدينة","أين ذهبت الطريدة الحريرية؟","لقد ابتلعها ذئب السهوب"]},{"id":"poem-16-2","title":"حينها فقط رسم هذه الدائرة باللون الأحمر / على خريطة المصير المشترك","lines":["حينها فقط رسم هذه الدائرة باللون الأحمر","على خريطة المصير المشترك","خان الخانات جالس في خيمته","يراقب النجوم تدور حول نجمه القطبي","","العالم صغير جداً على ظهر حصان","والحدود مجرد خطوط في الرمال","بانتظار أن تُمحى بشحنة قوية واحدة","هكذا قال، ونظر مجدداً إلى جبال تيانشان"]},{"id":"poem-16-3","title":"فقط في أيام الطفولة البعيدة / كانت السهوب تبدو بهذا الاتساع","lines":["فقط في أيام الطفولة البعيدة","كانت السهوب تبدو بهذا الاتساع","قبل أن تصبح الإمبراطورية عبئاً","وقبل أن تصبح المذبحة مسألة روتينية","","حتى الخان يتذكر","أياماً قبل الحرب","عندما كان راعياً بسيطاً","ينام تحت النجوم، ولا يخشى سوى الذئاب","وليس تاريخه الخاص"]},{"id":"poem-16-4","title":"ملأت تشيتشيغه الوعاء المنقوش بماء النهر / لتغسل جراح المقاتل","lines":["ملأت تشيتشيغه الوعاء المنقوش بماء النهر","لتغسل جراح المقاتل","المياه التي شربتها الخيول للتو","الباردة والمنحدرة من ثلوج الجبال","","عيناها كبحيرتين هادئتين","وسط جنون الفتوحات","ويداها رقيقتان","في عالم يمجّد فقط القوة"]},{"id":"poem-16-5","title":"لقد كانت الأغنية التي اعتادت والدته أن تغنيها / قبل أن يبدأ كل هذا السفك للدماء","lines":["لقد كانت الأغنية التي اعتادت والدته أن تغنيها","قبل أن يبدأ كل هذا السفك للدماء","شعر الفارس بارتعاشة سيفه","وهو يسمع اللحن عبر نيران المخيم","","أغنية عن العشب والمطر","وعن الصقر الذي يعود دائماً","أغنية هزمت شجاعته","وذكرته بأنه قبل أن يكون محارباً، كان ابناً"]},{"id":"poem-16-6","title":"صهوة جواده / كانت عرشه، وملاذه، وقبره","lines":["صهوة جواده","كانت عرشه، وملاذه، وقبره","لم يعرف سريراً سواه","ولم يأمن لحارس سواه","","تحت الحوافر، تحولت الجبال القديمة لمجرد حجارة","وتحولت الحضارات لمجرد رماد","وحده الجواد لم يسأله لماذا","وحده الجواد كان يركض دون حساب للتاريخ"]}]},{"id":"chapter-17","title":"نهر إيلي المتدفق","poems":[{"id":"poem-17-1","title":"من أعلى نهر إيلي / تنحدر العاصفة كالسوط","lines":["من أعلى نهر إيلي","تنحدر العاصفة كالسوط","خالعة الأشجار التي زرعها الآباء","وجالبة معها رائحة الغبار والحديد","","هنا، في الوديان العميقة","يتعلم الناس الصبر","ويتأملون في النهر الذي لا ينقطع سريانه","رغم كل العابثين بمجراه"]},{"id":"poem-17-2","title":"غروب الشمس الدموي / يتلاشى في بحر من الظلام","lines":["غروب الشمس الدموي","يتلاشى في بحر من الظلام","والجبال العالية تبدو كأشباح","تسهر على أرواح الذين ماتوا في هذه السهوب","","الوداع لا يكون أبداً بكلمات","غالبًا ما يكون بصمت يغلف كل شيء","ورحلة طويلة نحو مجهول بارد"]},{"id":"poem-17-3","title":"مبتسماً / وهو يشد لجامه الأخير","lines":["مبتسماً","وهو يشد لجامه الأخير","لا أحد يعلم ماذا رأى في الأفق","ربما نداء الأجداد","أو ربما سراب النصر","","الموت على هذه الأراضي","ليس إلا عودة للبطون التي أخرجت هؤلاء الجياد","وهو يعرف ذلك جيداً","لأنه ابتسم"]},{"id":"poem-17-4","title":"محاربوه الـ 22 الشجعان / يقفون كعشرين صخرة في مهب الريح","lines":["محاربوه הـ 22 الشجعان","يقفون كعشرين صخرة في مهب الريح","لا يهابون الليل القادم","ولا يحصون أعداءهم","","في التلال العالية","حيث أصبحت الحرب نصباً تذكارياً","وأصبح النصب صخرة","وأصبحت الصخرة جزءاً من الجبل","لا يمكن تفريقها","عن الأرض التي تحتضنها"]},{"id":"poem-17-5","title":"جبل جيجين البعيد / يراقب السهوب كحارس أبدي","lines":["جبل جيجين البعيد","يراقب السهوب كحارس أبدي","الثلج على قمته كشيب الحكماء","والعواصف حوله كصوت التاريخ","","توالت الأجيال","وتكسرت السيوف","وبقي هو صامتاً","مستمتعاً بنهر إيلي وهو يعزف لحن البقاء"]}]},{"id":"chapter-18","title":"مايمور عزيز، عبقة كزهر الزيزفون","poems":[{"id":"poem-18-1","title":"آه، يا قمر تيانشان الجميل / حتى وإن تم دهسك، يظل قمر تيانشان جميلاً","lines":["آه، يا قمر تيانشان الجميل","حتى وإن تم دهسك، يظل قمر تيانشان جميلاً","ساطعاً على وجه مايموري","المغنية الأويغورية التي يحمل صوتها","عبر الوادي كالحرير في الريح"]},{"id":"poem-18-2","title":"أصابع رشيقة / تداعب بضع ثمار الزيتون الكهرمانية","lines":["أصابع رشيقة","تداعب بضع ثمار الزيتون الكهرمانية","تغني عن الحب والفقدان","وعن وطن عالق بين إمبراطوريات","وصوتها هو الراية الوحيدة التي تحتاج إليها"]},{"id":"poem-18-3","title":"لقد حلقت العندليب / لتغني أغنية حب خالدة","lines":["لقد حلقت العندليب","لتغني أغنية حب خالدة","والتي ستصبح","الأساس لأسطورة:","شينغ في — المحظية العطرة","حُمِلت شرقاً إلى بكين","كعطر نادر","من قلب الصحراء"]},{"id":"poem-18-4","title":"عيون زرقاء ياقوتية / تبرق فجأة","lines":["عيون زرقاء ياقوتية","تبرق فجأة","في ضوء مصباح الغرفة الإمبراطورية","تتذكر بساتين الزيتون","والليالي المقمرة في كاشغر","وصوت الأذان عند الفجر","","تقف في المدينة المحرمة","زهرة نُقلت","من حديقة إلى أخرى","لا تزال تتفتح","لكنها تتوق لهواء الصحراء"]},{"id":"poem-18-5","title":"نسج المقدمة / لمسيرة المحظية العطرة المستقبلية العظيمة نحو الشرق","lines":["نسج المقدمة","لمسيرة المحظية العطرة المستقبلية العظيمة نحو الشرق","التاريخ يهيئ أساطيره","قبل حدوثها بوقت طويل","","في بساتين الخشخاش في كاشغر","فتاة تغني","غير مدركة أنها ستصبح","المرأة الأكثر شهرة","في الأقاليم الغربية","","عطرها — سواء أكان حقيقياً أم متخيلاً —","سيملأ قاعات الإمبراطورية","وصفحات الشعر","إلى الأبد"]}]},{"id":"chapter-19","title":"يا نجمة الصباح","poems":[{"id":"poem-19-1","title":"آه، 1771 / ليلة شتاء شديدة السواد على سهوب نهر الفولغا","lines":["آه، 1771","ليلة شتاء شديدة السواد على سهوب نهر الفولغا","يتجمع مغول الأويرات في سرية","وهجرتهم الكبرى توشك أن تبدأ","","مائة وسبعون ألف روح","يتوجهون غرباً في الشتاء الروسي","نحو وطن لم يره معظمهم قط","لكنهم سمعوا عنه جميعاً في الأغاني"]},{"id":"poem-19-2","title":"أهذا هو نهر الأورال؟ / لا أمواج متدحرجة على سطحه","lines":["أهذا هو نهر الأورال؟","لا أمواج متدحرجة على سطحه","فقط جليد كثيف وغادر","لقد كلفهم العبور غالياً","","سقطت العربات عبر الجليد","وفُقد الأطفال","واستسلم كبار السن وجلسوا في الثلج","لألا ينهضوا أبداً"]},{"id":"poem-19-3","title":"تشيتشيغه ليس لديها مزيد من الدموع / التفتت وهي على صهوة جوادها لتحدق في الأفق","lines":["تشيتشيغه ليس لديها مزيد من الدموع","التفتت وهي على صهوة جوادها لتحدق في الأفق","إلى المسافة التي قطعوها","والمسافة التي لا يزال يتعين عليهم قطعها","","نصف شعبهم ماتوا على الطريق","بالمرض والمجاعة وهجمات القوزاق","والجيش الروسي يطاردهم","كالذئاب التي تطارد قطيعاً ضعيفاً"]},{"id":"poem-19-4","title":"سهوب قيرغيزستان لا تزال نائمة / والنهر الصغير المتجمد","lines":["سهوب قيرغيزستان لا تزال نائمة","والنهر الصغير المتجمد","بالكاد يسيل ماؤه تحت الجليد","لكنهم يواصلون التقدم","","عبر فراغ كازاخستان الشاسع","عبر الثلوج التي تبتلع كل شيء","عبر الرياح التي تمزق الجلد","","سهوب قيرغيزستان لا تزال نائمة","لكن الأويرات لا ينامون","يسيرون طوال الليل","نحو نجمة الصباح"]},{"id":"poem-19-5","title":"العجلات الخشبية للعربة / تدور ببطء نحو الشرق","lines":["العجلات الخشبية للعربة","تدور ببطء نحو الشرق","تئن كعظام قديمة","كدواليب الصلاة في معابدهم","","كل دورة","تُقربهم ليّاً واحداً من الوطن","وتبعدهم ليّاً واحداً عن المنفى","","وتدور العجلات الخشبية","عبر الثلج والوحل والذكريات","عبر سبعة أشهر من المسير","نحو وادي إيلي"]},{"id":"poem-19-6","title":"آه، أمواج بحيرة بالكاش / التي طالما تماوجت في حلم بعيد وأثيري","lines":["آه، أمواج بحيرة بالكاش —","التي طالما تماوجت في حلم بعيد وأثيري","والآن تتماوج أمام أعينهم","زرقاء وحقيقية وتبكي بالنور","","لقد عبروا نصف أوراسيا","من نهر الفولغا إلى بحيرة بالكاش","سبعون ألفاً نجوا","من أصل مائة وسبعين ألفاً","","استقبلهم الإمبراطور","عند نهر إيلي","بمراسم ومؤن","ومكان يدعونه وطناً","","آه، يا نجمة الصباح","التي قادتهم عبر أحلك الليالي","والتي تغرب الآن في الشرق","حيث تشرق الشمس","فوق وادي إيلي","وفوق جبال تيانشان","وفوق الوطن","الذي حلموا به","لقرن من الزمان","في المنفى","","أعظم هجرة في التاريخ الحديث","لم تُكتب بالحبر","وإنما بالدم والثلج","وبدوران","العجلات الخشبية","نحو نجمة الصباح"]}]},{"id":"chapter-20","title":"ابن الثغر الوفي يبكي حزناً","poems":[{"id":"poem-20-1","title":"هذا القمر / يطفو على السطح الأزرق الداكن لبحيرة بالكاش","lines":["هذا القمر","يطفو على السطح الأزرق الداكن لبحيرة بالكاش","هو ذات القمر الذي أضاء على لين زيكسو","حين نفاه الإمبراطور","إلى الأقاليم الغربية","","الرجل الذي أحرق الأفيون","والذي تحدى الإمبراطورية البريطانية","يمشي الآن بمحاذاة قنوات الري في شينجيانغ","كمسؤول أُشيع عنه العار","ويقوم بعمل العمال البُسَطاء","","لكنه حتى في المنفى","خدم بكرامة","مسح الأراضي","وخطط للقنوات","وزرع الأشجار","","هذا القمر شَهد","عقاباً لخادم وفي","وروحاً لم تنكسر لذلك الخادم"]},{"id":"poem-20-2","title":"مسح صفحة / من المخطوطة التاريخية للأقاليم الغربية القديمة","lines":["مسح صفحة","من المخطوطة التاريخية للأقاليم الغربية القديمة","لين زيكسو تتبع القنوات القديمة","التي حفرها جنود هان قبل ألفي عام","","التاريخ يكرر نفسه","والمياه تجد قنواتها القديمة","ورجل من الساحل","يتعلم لغة الصحراء"]},{"id":"poem-20-3","title":"لا عجب أن القمة الصارمة / لا تريد أن تظهر وجهها المشرق","lines":["لا عجب أن القمة الصارمة","لا تريد أن تظهر وجهها المشرق","تتخفى جبال تيانشان خلف السحب","وكأنها تبكي على حال الإمبراطورية","","نظر لين زيكسو إلى أعلى نحو الجبال","وفكر في البحر","في السفن المحترقة والأفيون المحترق","وفي إمبراطورية عاقبته لكونه على حق","","لا عجب أن الجبال تتخفى","فحتى هي تشعر بالخجل","مما آل إليه البلاط"]},{"id":"poem-20-4","title":"تحت قمر الحدود / سهم لامع يطير مسرعاً","lines":["تحت قمر الحدود","سهم لامع يطير مسرعاً","كانت إرادة لين زيكسو كالسهام","مُصوبة من المنفى نحو العدالة","","لم يكن ليرى كانتون مجدداً","كان ليموت في طريق العودة من النفي","رجل عجوز في عربة مستعارة","","لكن القنوات التي خطط لها","لا تزال تحمل المياه","في وادي إيلي","وفي حوض تاريم","","وتحت قمر الحدود","السهم اللامع لإرثه","يواصل التحليق","يواصل التحليق"]}]},{"id":"chapter-21","title":"من في الأقاليم الغربية لا يعرفك؟","poems":[{"id":"poem-21-1","title":"يداعب برقة / ريشة النسر ذات اللون البني الرمادي التي أهداها له راعٍ كازاخي","lines":["يداعب برقة","ريشة النسر ذات اللون البني الرمادي التي أهداها له راعٍ كازاخي","والمنفي يمشي في الطريق الأخير","من قصيدة طريق الحرير الطويلة","","ألفا عام من خطوات الأقدام","خطوات الأقدام وقرع الحوافر وآثار العجلات","كلها قادت إلى هنا، إلى هذه اللحظة","لرجل يداعب ريشة نسر","في شفق الإمبراطورية"]},{"id":"poem-21-2","title":"يغني بحزن عند الحدود / طريق البريد القديم الذي يمتد تحت قدميه","lines":["يغني بحزن عند الحدود","طريق البريد القديم الذي يمتد تحت قدميه","كل حجر هو قصة","وكل أثر هو فصل","في أطول قصيدة كُتبت على الإطلاق","بأنامل الجغرافيا والزمن"]},{"id":"poem-21-3","title":"الغيوم تحجب قمر تيانشان / وأنت تمسح دموعك برفق","lines":["الغيوم تحجب قمر تيانشان","وأنت تمسح دموعك برفق","لأجل هذه الأرض التي شهدت","العديد من الشجاعة والكثير من الأسى","الكثير من الحرير والكثير من الدم"]},{"id":"poem-21-4","title":"لاي لاي لاي / بحيرة صيرم المُحبة تفيض بالنبيذ العطري","lines":["لاي لاي لاي","بحيرة صيرم المُحبة تفيض بالنبيذ العطري","ارفع كأسك للجبال","للطريق","لكل مسافر مرّ","عبر أرض الثلج والنار هذه"]},{"id":"poem-21-5","title":"لقد أحب يوماً بحراً أزرقاً في الجنوب / ويحب أيضاً بآلاف القمم الكريستالية في الغرب","lines":["لقد أحب يوماً بحراً أزرقاً في الجنوب","ويحب أيضاً بآلاف القمم الكريستالية في الغرب","مشهدان طبيعيان","وقلب واحد","","منحه الجنوب الدفء","ومنحه الغرب العظمة","وكلاهما منحه الشعر","","مَن في الأقاليم الغربية لا يعلمك؟","بعد ألفي عام","من الحرير والدموع","من خيول تتعرق دماً وشقائق نعمان برية","من رهبان وجنرالات وأميرات","من صناع ورق أُسروا في تالاس","من مبعوثين أبوا الركوع","","مَن في الأقاليم الغربية لا يعلمك؟","طريق الحرير يعلم","وجبال تيانشان تعلم","ونهر إيلي يعلم","وكل حبة رمل في الصحراء تعلم"]}]}]},"children":[["$","div",null,{"className":"fixed top-4 right-4 z-50","children":["$","$L9",null,{"currentLocale":"ar"}]}],["$","div",null,{"className":"max-w-4xl mx-auto pb-32","children":[["$","header",null,{"className":"pt-24 pb-12 px-8 text-center border-b border-gray-100 mb-12","children":[["$","h1",null,{"className":"text-4xl font-serif font-bold text-gray-900 mb-4","children":"خيول الدم المتعرّق"}],["$","p",null,{"className":"text-sm text-gray-400 font-sans","children":["لي يوي"," / ","1995"]}]]}],[["$","div","chapter-1",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"يا قارة آسيا الوسطى الجديدة"}],[["$","article",null,{"id":"poem-1-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"لا بد أن ذلك السهم المجيد لا يزال محلقاً / منطلقاً نحو الغرب البعيد"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"شمس الغروب بلون الدم توشك أن تغيب"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"وستارة الليل بلونها الذهبي الداكن توشك أن تسدل"}],["$","p","2",{"className":"min-h-[1.5em] ","children":[["$","span","0",{"className":"annotation-term border-b border-dotted border-gray-400 cursor-help","title":"تشانغ تشيان - مبعوث ومستكشف من سلالة هان، قاد أولى الرحلات لاستكشاف طريق الحرير إلى آسيا الوسطى بأمر من الإمبراطور وو.","children":["تشا