2:["$","$L8",null,{"book":{"title":"قصائد من جونغار","author":"لي يوي","year":"1984","chapters":[{"id":"chapter-1","title":"المجلد الأول: نار المخيم المتراقصة","poems":[{"id":"poem-1-1","title":"أغنية المنجل الأول","lines":["احصد، احصد، احصد!","احصد مساحة من غروب الشمس، واحصد عشرة آلاف موجة من القمح؛","لقد عشنا أخيراً لنشهد هذا اليوم،","يوم نسترد فيه من الصحراء","هذا المحيط الذهبي"]},{"id":"poem-1-2","title":"تتفتح في اندفاعة","lines":["نبحر في بحر قربانتونغوت،","تنطلق الحصادة المجمعة في ضوء الفجر الخافت،","متجهة نحو الأمواج الذهبية اللامعة؛","عاصفة من الحبوب، أغنية من العرق","في اندفاعة واحدة للحياة"]},{"id":"poem-1-3","title":"رياح الربيع عبرت ممر اليشم منذ زمن طويل","lines":["رياح الربيع عبرت ممر اليشم منذ زمن طويل،","لكن جبال تيانشان الشاهقة لا تزال ترتدي تاجها الكريستالي من الثلج؛","أضف مجرفة أخرى من التربة الخصبة للشتلات الجديدة،","دع الأخضر يزحف إلى أعلى التلال،","حتى تبتسم الجبال البيضاء"],"annotations":[{"term":"ممر يومين","note":"ممر يومين (بوابة اليشم) - حصن حدودي قديم أُنشئ أيام سلالة هان، ونقطة عبور محورية شمالية بطريق الحرير خلدها الشعراء دوماً."}]},{"id":"poem-1-4","title":"التقدم نحو الشمال الغربي العظيم","lines":["لقد تلقيت رسائل من بعيد من قبل،","لكن ليس من مكان بهذا البعد؛","هذه الرسالة ستعبر وسع الأرض،","لتحمل دقات قلب الصحراء","وتدفئ شتاءك"],"annotations":[{"term":"الشمال الغربي العظيم","note":"الشمال الغربي - شينجيانغ والمقاطعات المحيطة، حيث استُدعي الشباب والمزارعون العسكريون لبنائها وتطوير الصحراء منذ 1949."}]},{"id":"poem-1-5","title":"قصيدة صغيرة كُتبت في الخندق — يوميات الكثبان الرملية","lines":["سيستغرق الأمر عقوداً، وربما نصف قرن،","قبل أن تصبح نقطة حراسة الكثبان الرملية هذه مدينة؛","لكننا الليلة في الخندق نكتب القصائد على ضوء الشموع،","ونرسم خريطة للغد،","مسترشدين بالنجوم"],"annotations":[{"term":"خندق السكن","note":"الخنادق - مساكن وملاجئ شبه تحت أرضية للمزارعين كجزء من نظام حماية المنازل في بدايات حفر شينجيانغ، واقية من العواصف والمناخ الغدار."}]},{"id":"poem-1-6","title":"في ضوء قمر تيانشان — إلى عبدو","lines":["يبدو لي أنني أراك واقفاً بجانب الفرن مرة أخرى،","وما زالت قبعتك المطرزة تعكس دخان الجبهة الشمالية الغربية؛","والشرر المتطاير من مطرقتك","ينير الوجوه الحازمة،","ويصوغ طريقاً للصداقة"],"annotations":[{"term":"جبال تيانشان","note":"جبال تيانشان - الجبال السماوية الشامخة والعملاقة، تُعتبر العمود الفقري الأهم الذي يمر في مركز ونصف إقليم شينجيانغ."}]},{"id":"poem-1-7","title":"آه، يا شجرة الصفصاف الحمراء","lines":["آه، يا شجرة الصفصاف الحمراء،","تنفرد أوراقك بهدوء في وجه الرياح الغربية،","وتحطم أغصانك غيوم العاصفة بشراسة؛","أنتِ العزيمة المتجذرة في الرمال،","الزهرة الدموية التي لا تذبل أبداً"],"annotations":[{"term":"الصفصاف الأحمر","note":"شجيرة الصفصاف الأحمر (الأثل) - رمز للتحدي والمثابرة، يضرب جذوره القوية بالرمل ومثّل صبر وإرادة البنائين العسكريين ببيئة الحصار القاحلة."}]},{"id":"poem-1-8","title":"تتلألأ في ضوء القمر","lines":["تتلألأ في ضوء القمر،","تتلألأ في ضوء النجوم؛","أمواج الثلج تتجمع، لتغني أغنيتها الغنائية الليلية،","وتهمس بأسرار تيانشان،","إلى الحراس المستيقظين"]},{"id":"poem-1-9","title":"إشعال نار المخيم المتراقصة — إلى الغزال","lines":["هنا،","نشعل نار مخيم متراقصة،","ومن هذه اللحظة المشرقة يبدأ عصر جديد للصحراء؛","","تراقب الغزلان من بين شجيرات الطرفاء،","وتعكس أعينها ضوء النار؛","إنها لا تخشانا بعد،","نحن الرواد الأوائل،","الذين تفوح منهم رائحة الأرض والعرق","بدلاً من البارود.","","أيتها الغزلان العزيزة — نحن جيرانكم الجدد،","المخلوقات ذات الساقين","التي تغني بنشاز على ضوء النار","ولا تضمر لكم أي أذى."]},{"id":"poem-1-10","title":"حلم أخضر تحت الكثبان الرملية","lines":["لقد ودعنا بالفعل حقول الأرز المطرزة،","لقد ودعنا بالفعل القرى الجديدة المتجمعة —","ليس وطننا جيانغنان،","ولكن مكاناً بدا وكأنه الوطن.","","أما الآن وتحت هذه الكثبان، فنحن نحلم حلماً أخضر،","حلماً بالبساتين والقنوات،","بالمدارس والعيادات،","بأطفال سيعرفون","فقط خضرة الأشياء التي تنمو،","وليس سمرة المسير."]},{"id":"poem-1-11","title":"الليلة يعبرون جسر الصفصاف الأحمر مرة أخرى","lines":["لقد عبرنا جسوراً حجرية من قبل،","ولقد عبرنا جسوراً من لوح واحد من قبل؛","كم عدد الجسور التي عبرناها في حياتنا،","لكن هذا الجسر المصنوع من حزم أغصان الصفصاف الأحمر","هو الجسر الذي سنتذكره دائماً.","","إنه يتمايل تحت أحذيتنا العسكرية،","هذا الجسر الذي بنيناه بأيدينا","من الأخشاب الوحيدة في الصحراء،","شجرة الصفصاف الحمراء التي لا تقهر.","","الليلة يعبرون جسر الصفصاف الأحمر مرة أخرى،","متجهين إلى موقع السد،","متجهين نحو المستقبل."]},{"id":"poem-1-12","title":"اشرب هذا الوعاء من مياه ثلوج تيانشان المذابة","lines":["كان الجنود القدامى يستقبلوننا بهذه الطريقة،","يرحبون بالمجندين الجدد الذين جاؤوا لغزو الصحراء؛","اشرب هذا الوعاء من مياه ثلوج تيانشان المذابة،","صافٍ كالكريستال، وبارد كقلب الجبل.","","هذا هو نبيذنا، ونخب ترحيبنا —","ليس نبيذ العنب، ولا نبيذ الأرز،","بل أنقى مياه على وجه الأرض،","تتدفق مباشرة من النهر الجليدي","إلى شفتيك المشتقتين.","","اشرب — وكن واحداً منا."]},{"id":"poem-1-13","title":"ينادونك بـ \"أوزة الحصاد البرية\"","lines":["تحلقين فوق أحزمة الحماية، وفوق الحقول المخططة،","وبحر قربانتونغوت يثير الغيوم والأمواج؛","أنتِ تجيبين على تحيتي الدافئة","بأزيز محركك،","يا أوزة الحصاد البرية،","أيتها الجرارة والحصادة،","أيها الطائر الميكانيكي الرائد،","الذي يجلب الحبوب."],"annotations":[{"term":"رسالة البجع لحسن الحصاد","note":"بجعة الحصاد - رسالة استعارية لحمل الأخبار السارة بالمحصول الوفير لعائلات المزارعين في الوطن الأم."}]},{"id":"poem-1-14","title":"تخمير حياة حلوة كالعسل","lines":["الواحة تتلألأ كأحجار الكريستال،","وبينما يجهز النحالون خلاياهم لرحلة الجنوب.","ينتقلون كل خريف مع النحل،","ملاحقين الأزهار عبر الجبال.","","يخمرون حياة حلوة كالعسل،","هؤلاء البدو رُحل الحلاوة،","وهؤلاء الملاحقون للأزهار،","الذين يعرفون كل وادٍ","من طعم رحيقه."]},{"id":"poem-1-15","title":"آه، يا أجراس الإبل المجلجلة","lines":["لم نكد نجد وقتاً لحديث نابع من القلب","حتى انطلقوا من جديد؛","آه، يا أجراس الإبل المجلجلة","لفريق الإصلاح المتنقل،","يعبر الصحراء بقطع الغيار والشحوم،","ورشة متنقلة","على ظهر جمل.","","في شساعة جونغار،","حتى مهام الإصلاح تتطلب رحلة."]},{"id":"poem-1-16","title":"الرمال تضرب صدغي أنور","lines":["الرمال تضرب صدغي أنور،","الرمال تضرب تنورة أنور،","الصحراء ذات اللون البني الرمادي تمتد بلا نهاية.","","تمشي في مواجهة الريح","وكأن الريح لا شيء،","هذه الفتاة الأويغورية التي اختارت البقاء","عندما اختار الآخرون الرحيل.","","يتطاير وشاح رأسها خلفها","كراية شجاعة هادئة."]},{"id":"poem-1-17","title":"أُداعب برفق أمواج بحر الصحراء الشاسعة","lines":["أمَسِّح برفق على أمواج بحر الصحراء الشاسعة،","هنا، وبكل خشوع، ألقي تحية الاحترام على الأطلال.","أين قمر سلالة تشين؟","وأين نيران إنذار سلالة هان؟","","تحت أقدامي يكمن تاريخ","من القوافل والفاتحين،","ومن المدن التي نهضت وسقطت","كأمواج في محيط الرمال هذا.","","أُداعب الصحراء برفق","وأشعر بألفي عام من خطوات الأقدام."],"annotations":[{"term":"بحر الرمال (هانهاي)","note":"بحر الرمال (هانهاي) - مُصطلح للصحاري الشاسعة وتحديداً صحراء أوربانقنغت كأنها بحر بلا ماء، ومجاز شعري قديم لكثبان الرمل الممتدة."}]},{"id":"poem-1-18","title":"المشي نحو العاصفة الرملية في أرض أجنبية بعيدة — حلم الرائد","lines":["أشجار حور تتمايل،","مياه ثلوج مندلعة،","الأفق العائم؛","","في أرض أجنبية بعيدة، يمشي نحو العاصفة الرملية،","يحلم الرائد بمدينة","لا وجود لها بعد،","بطرق ما تزال مسارات للإبل،","بحدائق ما تزال صحراء.","","لكن الحلم حيّ جداً","لدرجة أنه يشم رائحة أزهار المشمش","ويسمع جرس المدرسة يقرع","في المدينة التي ستنهض","من الرمال التي تحت قدميه."],"annotations":[{"term":"الرواد المبادرون","note":"الرواد (توهوانغ تشه) - إشارة إلى الجنود الشباب الصينيين في السلك الإنتاجي القدامى كأول من شرع لبث الحياة الخضراء والبناء بالواحات الصحراوية العذراء."}]},{"id":"poem-1-19","title":"توديع هذه الأطلال في الوقت الراهن","lines":["توديع هذه الأطلال في الوقت الراهن،","دعني أحلّق بأجنحة الخيال.","لا يمكن استحلاب المطر من الغيوم هنا،","لذا سنحفر القنوات عوضاً عن ذلك.","","في الصحراء، يحفر الحالمون.","توديع الأطلال","يعني استقبال المستقبل،","وبالمجرفة في اليد."]},{"id":"poem-1-20","title":"ياقوتة زرقاء مرصعة في الواحة الرائدة","lines":["يتأمل المسافر من سفينته في صحراء غوبي،","ياقوتة زرقاء مرصعة في الواحة الرائدة؛","هل من الممكن أن تكون بحيرة صيرم البعيدة قد تدحرجت إلى هنا؟","","لا — هذا خزان مياه،","حُفر باليد، ومُلئ بمياه الثلوج المذابة،","جوهرة صنعناها بأنفسنا","في الإطار البني للصحراء."]},{"id":"poem-1-21","title":"تلك أمي تلوح بذراعيها","lines":["من رسم مسحة من دخان الطهي في مساء الصحراء؟","الشمس الغاربة تطفو على البحيرة حيث تلمع الثعابين الذهبية؛","كان ينبغي أن تعود قوارب الصيد الآن —","","تلك أمي تلوح بذراعيها","من على ضفة خزان المياه الجديد،","تنادي أطفالها للعودة لتناول العشاء،","كما تفعل الأمهات","منذ أن أُشعلت أول نار."]},{"id":"poem-1-22","title":"منسوجة بخيوط عديدة من المشاعر العميقة","lines":["يخفي الليل التاج الكريستالي الثلجي المهيب لجبال تيانشان،","ويخفي أمواج مياه الثلوج المندفعة،","ويخفي القارب الآلي الرشيق.","","لكنه لا يستطيع إخفاء الأغاني","المنسوجة بخيوط عديدة من المشاعر العميقة،","والمتصاعدة من الثكنات،","أغاني الوطن والشوق،","أغاني تسافر أبعد من الضوء","عبر ظلام الحدود."]},{"id":"poem-1-23","title":"آه، يا له من امتداد واسع لضباب الصباح الأزرق الفاتح","lines":["انزلق القمر من سماء الغسق،","وانزلقت النجوم من سماء الغسق،","آه، يا له من امتداد واسع لضباب الصباح الأزرق الفاتح.","","الصحراء عند الفجر","هي بلد آخر تماماً،","بارد ولطيف وأزرق،","قبل أن تصل الشمس","بمطرقتها الذهبية."]},{"id":"poem-1-24","title":"التحديق عبر المزواة","lines":["رصد طائر يحلق على ارتفاع منخفض،","رصد الشتلات الخضراء،","التحديق عبر المزواة؛","","يرسم المساح خريطة المستقبل","بأخذ القياسات قياساً تلو الآخر،","ويخطط الطرق والقنوات وخطوط الكهرباء","عبر طبيعة لم تعرف","سوى الرياح والرمال","لألف عام."]},{"id":"poem-1-25","title":"الطائر الصغير مرتدياً تاجاً طويلاً من الريش","lines":["بعد أن حلقت للتو فوق هذا القفار البني،","وبعد أن وصلت للتو إلى واحة المستقبل هذه،","تمشط مياه ثلوج تيانشان ريشك؛","","أيها الهدهد الصغير، أيها الرسول المتوَّج،","لقد وصلت قبل الأشجار،","وقبل الحدائق والظلال،","وكأنك تعرف","ما كنا نبنيه","وأردت أن تكون الأول."]},{"id":"poem-1-26","title":"فقط للتنافس من أجل الربيع","lines":["أين اختبأ القمح الشتوي الأخضر؟","أين اختبأت أحزمة الحماية الرمادية الفضية؟","لقد ابتلعت أمواج العاصفة الثلجية الواحة التي طورناها،","","لكن ذلك فقط حتى الربيع —","فقط حتى الربيع،","حينما ينفجر اللون الأخضر من الأبيض","كصرخة نصر،","وحين تظهر أحزمة الحماية مجدداً","ويقف القمح من جديد،","فقط للتنافس من أجل الربيع."]},{"id":"poem-1-27","title":"المطاردة على طول مسار الرياح","lines":["صحراء قربانتونغوت مهيبة كالبحر،","والسماء الصافية زرقاء كلون الأزوريٹ؛","نفحة الريح لا يمكنها الهروب من العين اليقظة،","","فهؤلاء كشافة تثبيت الرمال،","يطاردون على طول مسار الرياح،","ويزرعون العشب وشجيرات الطرفاء","في آثار أقدام الرياح،","ويصطادون الكثبان الرملية في شباك خضراء","من تصميمهم الخاص."]},{"id":"poem-1-28","title":"'النقطة أ — النقطة أ...'","lines":["الكثبان السمراء تلتقي بالسماء السمراء،","قارب وحيد يبحر في بحر الصحراء الهائج؛","ولحن أغنية مسيرة يطوف في الهواء،","","والمساح ينادي بإحداثياته","'النقطة أ — النقطة أ...'","يحدد الموقع","الذي ستقف فيه مدرسة،","أو مستشفى،","أو حديقة بها أشجار وضحكات أطفال،","بعد عشرين عاماً —","أو بعد خمسين —","'النقطة أ — النقطة أ...'"]},{"id":"poem-1-29","title":"حبات الثلج المتفتحة قد ذبلت بالفعل","lines":["حبات الثلج المتفتحة قد ذبلت بالفعل،","ذبلت بصمت من السماء المعلقة على مستوى منخفض؛","تتساقط على خزان الصحراء الصلب — قمم تيانشان الجليدية،","","ليتم تخزينها وحفظها","من أجل الصيف الطويل الحار،","وحين تشرب القنوات مياه الأنهار الجليدية","وتحمل عذوبتها الباردة","نزولاً إلى الحقول،","نزولاً إلى البساتين،","نزولاً إلى الحلم الأخضر","الذي يبنيه الشتاء بهدوء."]}]},{"id":"chapter-2","title":"المجلد الثاني: الجنرال والمدينة","poems":[{"id":"poem-2-1","title":"مات قبل الفجر","lines":["مات قبل الفجر،","الجنرال الذي بنى المدينة،","الذي حول الجنود إلى بنائين وفلاحين،","الذي قال: 'لن نغادر هذا المكان'.","","تَصاعَدَ نَفَسه الأخير","كدخان نار مخيم تنطفئ،","والمدينة التي بناها","استمرت من دونه،","وفاضت شوارعها بنور الصباح."],"annotations":[{"term":"ما قبل الفجر","note":"قبل الفجر - استعارة زمنية دالة على الفترة المليئة بالصعاب وتضحية الشهداء المخلصين للثورة قبل سلام وازدهار وتحرير إقليم شينجيانغ المُشرق في عام 1949."}]},{"id":"poem-2-2","title":"لقد أصبحت هي أيضاً إشارة موجية ذهبية داكنة","lines":["سافرت إشارتها اللاسلكية خارج الغرفة الصغيرة،","عبر ليل تيانشان،","عبر تشويش المسافات —","لقد أصبحت هي أيضاً إشارة موجية ذهبية داكنة،","هذه المرأة من الحدود،","والتي بثت قراءات الطقس","ومواقع القوات","ورسائل الحب","عبر طنين أثير الصحراء وطقطقته."]},{"id":"poem-2-3","title":"أضاء بروميثيوس ستارة الليل الثقيلة","lines":["أضاء بروميثيوس ستارة الليل الثقيلة —","أم تُراه كان الكهربائي القادم من شاندونغ","والذي مد أول خط كهرباء","عبر صحراء قربانتونغوت،","جالباً النور الكهربائي","إلى مكان لم يعرف","سوى الشموع ونيران المخيمات والنجوم؟","","أضاء بروميثيوس ستارة الليل الثقيلة،","وطرفت الصحراء بعينيها","في دهشة متناهية."],"annotations":[{"term":"بروميثيوس","note":"بروميثيوس - أسطورة جالب النور، مُقاربًا لأفعال التنويريون والرواد الذين أضاءوا المستقبل وأعطوا الروح لصحراء وتطوير شينجيانغ."}]},{"id":"poem-2-4","title":"يجب على المرء أن يمر عبر الليل ليصل إلى شاطئ الفجر","lines":["يجب على المرء أن يمر عبر الليل ليصل إلى شاطئ الفجر —","كان هذا هو شعار","كل رائد على الحدود،","وكل جندي تحول إلى فلاح،","وكل امرأة تبعت فرقتها","إلى الرمال.","","كان الليل طويلاً،","والبرد عميقاً،","لكن الفجر جاء، كما يأتي دائماً،","بصياح الديك وبخار الغلاية المائي،","ومع الضوء الأول على ثلج تيانشان."]},{"id":"poem-2-5","title":"الوصول في عجلة من بعيد","lines":["الوصول في عجلة من بعيد،","والأحذية لا تزال مغبرة من ممر هيكسي،","يخْطُ المتطوعون الجدد من شاحناتهم","إلى ضوء جونغار الساطع.","","لقد جاؤوا من سيتشوان، ومن هونان،","ومن تلال تشجيانغ الخضراء،","إلى أرض العدم، البنية الفسيحة والمسطحة هذه","التي ستغدو لهم وطناً.","","الوصول في عجلة من بعيد","فقط ومعهم شبابهم","ووعد الحكومة","بمنحهم الأرض."]},{"id":"poem-2-6","title":"يتدفق نهر زمردي","lines":["يتدفق نهر زمردي","عبر قلب المدينة الجديدة،","قناة حفرتها عشرة آلاف يد","من نهر تيانشان الجليدي إلى حقول القطن.","","حيث كانت الإبل وحدها تشرب يوماً،","يسبح الآن الأطفال ويتراشقون بالماء،","وتصطف أشجار الصفصاف على ضفاف","هذه المعجزة المصنوعة،","هذا النهر الزمردي","الذي يتدفق لأن أحدهم","قرر أنه سيتدفق."]},{"id":"poem-2-7","title":"أرض الأحلام تلك التي طالما تاقت إليها الرؤى","lines":["أرض الأحلام تلك التي طالما تاقت إليها الرؤى","لم تعد رؤيّة بعد الآن:","فحقول القطن تمتد حتى الأفق،","وأشجار الحور تقف في صفوف مستقيمة كالجند،","وجرس المدرسة يقرع في الثامنة.","","لقد كان هذا هو الحلم —","ليس حلم الفتوحات،","بل الحراثة،","ليس الإمبراطورية،","بل حياة تستحق أن تعاش","على حافة العالم."]},{"id":"poem-2-8","title":"ذابت العاطفة العميقة في الحلقات السنوية للتاريخ","lines":["ذابت العاطفة العميقة في الحلقات السنوية للتاريخ،","وكل حلقة تمثل عاماً من الكدح،","عاماً من الزراعة والحصاد،","عاماً يبعد عن الحرب،","وعاماً يقترب من الحياة العادية.","","عُدَّ حلقات أشجار الحور","التي تصطف في شوارع المدينة الجديدة:","كل حلقة تمثل جيلاً،","وكل جيل هو صلاة مستجابة."]},{"id":"poem-2-9","title":"تلك الأسوار الزمردية","lines":["تلك الأسوار الزمردية —","ليست من حجر، بل من حور وصفصاف —","تقف كحرس حول المدينة","التي بناها الجنود.","","لا نيران مدافع هنا،","سوى حفيف الأوراق،","سوى أصوات الأطفال","وهم يلعبون في الظل","الذي ترميه جدران هي أشجار،","وقلاع هي غابات."],"annotations":[{"term":"أسوار المدينة","note":"أسوار المدينة الجدارية - هنا الجدران تشير للأحزمة والأعمدة الخضراء من الأشجار والحور المرزوعة كسياج واقي يقف للريح ولعواصف صحراء المدينة الحديثة المحاربة."}]},{"id":"poem-2-10","title":"كعنقاء جميلة تولد من جديد من النار","lines":["كعنقاء جميلة تولد من جديد من النار،","نهضت المدينة من الصحراء،","شيهيزي، أو نهر الحجر —","سُميت تيمناً بالأحجار المتواجدة في قاع النهر،","وبناها رجال عرفوا","معنى أن نبدأ من الصفر.","","وكعنقاء،","كان من المفترض ألا يكون لها وجود،","لكنها مع ذلك موجودة فعلاً،","خضراء ومشرقة،","في قلب جونغار البني."]},{"id":"poem-2-11","title":"السهم الأخضر ينطلق بسرعة للأمام","lines":["السهم الأخضر ينطلق بسرعة للأمام —","طريق سريع جديد يشق صحراء غوبي،","ليربط مدينة بأخرى،","وحلماً بآخر.","","حيثما كانت أجراس الإبل تحدد السرعة يوماً،","تطن المحركات الآن،","وينطلق السهم الأخضر","للتقدم مسرعاً،","من أورومتشي إلى شيهيزي إلى الحدود،","أسرع من الرياح،","لكنه ليس قديماً قدمها."]},{"id":"poem-2-12","title":"ليس هذا ضباب الصباح ذو اللون الأسمر","lines":["ليس هذا ضباب الصباح ذو اللون الأسمر —","إنه غبار البناء،","تلك السحابة الذهبية التي أثارتها ألف مجرفة،","بينما يرتفع مبنى آخر","من أرضية الصحراء.","","ليس هذا ضباباً — إنه الأنفاس","لمدينة تولد."]},{"id":"poem-2-13","title":"حراثة شمس حمراء مدورة ومكتملة","lines":["عند حافة المدينة، تستدير الجرارة،","لتحرث شمساً حمراء مدورة ومكتملة","من الأرض الداكنة،","وكأن الأرض ذاتها","كانت تلد النور.","","تلك هي الحدود المتاخمة وقت الفجر،","حيث كل ثلمة هي سطر من قصيدة،","وحيث كل حصاد هو بيت،","والشمس الحمراء تشرق","من نصل المحراث الدوَار."]}]},{"id":"chapter-3","title":"المجلد الثالث: شاعر في غوربانتونغوت","poems":[{"id":"poem-3-1","title":"كوخها الخشبي الصغير / في بستان أشجار الحور","lines":["كوخها الخشبي الصغير","في بستان أشجار الحور،","الضوء منزلق من نافذتها","كشريط من الحرير الذهبي.","","إنها راصدة الطقس،","فتاة تقرأ الغيوم وتقيس الرياح،","ترسل رسائلها اليومية إلى العاصمة","من هذا الكوخ الخشبي","وسط لا مكان.","","هنا، في بستان أشجار الحور،","تطول وتتلاشى فصولها."],"annotations":[{"term":"كربان تونغوت","note":"صحراء كربان تونغوت - ثاني أكبر صحارى الصين في حوض جونغغار الشمالي وتشتهر ببحارها المتموجة وثبات كثبانها وحرارتها."}]},{"id":"poem-3-2","title":"فُتحت بوابة درب التبانة / والغيوم البيضاء تتطاير","lines":["فُتحت بوابة درب التبانة","والغيوم البيضاء تتطاير —","لا، بل هو الماء","المندفع من خزان سد شيهيزي،","يتحرر من بوابات التحكم","ويزأر نزولاً إلى القنوات بقوة آلاف الخيول.","","لا يرى المزارع في الوادي الفيروزي اللون","سوى مياه الثلوج المذابة الكرستالية","تتدفق في حقله لتسقي أشجار القطن.","ونحن نرى مستقبلاً،","يتدفق كنهر درب التبانة،","نحو الأرض."]},{"id":"poem-3-3","title":"ذلك القارب الآلي الصغير / لا يزال يشق الأمواج","lines":["ذلك القارب الآلي الصغير","لا يزال يشق الأمواج","عبر بحيرة خزان المياه العظيم التي حفرناها بأيدينا.","","إنه يحمل فرق المسح، وعمال البناء،","والمهندسين الذين يخططون لقناة جديدة.","إنه قاربنا إلى المستقبل،","يشق بحر صحراء غوبي المتموج،","مبحراً نحو واحات","لم نزرع بذورها بعد."],"annotations":[{"term":"طريق الحرير","note":"طريق الحرير - شبكة طرق التجارة القديمة التي تربط الصين بآسيا وأوروبا، وسُميت نسبة إلى الحرير الصيني المصدر."}]},{"id":"poem-3-4","title":"القصر الكريستالي تحت الجسر العميق / مع صف أشجار الحور الأبيض","lines":["القصر الكريستالي تحت الجسر العميق","مع صف أشجار الحور الأبيض —","ليس قصراً في الحقيقة، وإنما محطة طاقة كهرومائية","مبنية في قلب الصخر،","ومُخبأة عن العواصف الرملية.","","تطن التوربينات، مولدة تياراً","يسقي العيادات والمدارس والثكنات.","القصر الكريستالي يضيء الحدود بأكملها،","ليس بالسحر، بل بالكهرباء.","يا لها من معجزة ساطعة!"]},{"id":"poem-3-5","title":"إشعال هذه النار في ليلة باردة","lines":["إشعال هذه النار في ليلة باردة،","الشاعر يراقب النيران وهي تميل مع الريح،","والشرر يتصاعد نحو درب التبانة،","كل شرارة هي بيت شعر،","وكل بيت شعر هو شرارة.","","هذه هي أقدم قصيدة —","نار في الظلام،","ويد إنسان تمتد بالدفء","نحو النجوم اللامبالية.","","إشعال هذه النار في ليلة باردة،","الشاعر يفكر:","أنا لست الأول هنا،","ولن أكون الأخير،","لكن هذه الشعلة الليلة هي لي،","وهذه الصحراء لي،","وهذه النجوم كذلك."]}]},{"id":"chapter-4","title":"المجلد الرابع: من أجل الحب، بغداد ليست بعيدة","poems":[{"id":"poem-4-1","title":"درب التبانة فوق الرؤوس","lines":["درب التبانة فوق الرؤوس،","نهر من النجوم الباردة التي لا يحصى عددها،","أقرب بكثير هنا","مما كانت عليه في سماء جيانغنان الملبدة بالغيوم.","","أتمدد على الرمال الدافئة لأنظر للأعلى،","وأشعر بضآلة الإنسان","في صحراء جونغار الشاسعة.","لكنني أدرك كذلك عظمة الإنسان:","نحن من جلبنا الزراعة","إلى هذا المكان الذي لم يعرف سوى النجوم والرمال."],"annotations":[{"term":"العندليب","note":"طائر العندليب - عصفور شاسع الغناء يعيش في غابات الأحمر (الأثل). وفي الشعر الجونغغاري هو الممثل الصادق والناقل لصوت ومراسيل الحب الممتزج بمشقة الحياة."}]},{"id":"poem-4-2","title":"المطر يندفع من صحراء غوبي","lines":["المطر يندفع من صحراء غوبي،","عاصفة مفاجئة وسريعة، محملة بقطرات ثقيلة","تسقط على السقف الصفيحي للخندق العسكري،","بإيقاع هادئ كأغنية تهويدة،","وناعم كصوتها عندما قالت:","'سأنتظرك.'","","المطر في الصحراء معجزة،","نادر كالحب،","ومرحب به مثله تماماً."]},{"id":"poem-4-3","title":"إنه هلال خلف الكثبان الرملية","lines":["إنه هلال خلف الكثبان الرملية،","يرتفع كرمش فضي","فوق حاجب الرمال البني.","","وتحت هذا الهلال،","أكتب اسمها على الرمال،","وأنا أعلم أن الريح ستمحوه بحلول الصباح،","وأعلم أنني سأكتبه مجدداً في الليلة القادمة."]},{"id":"poem-4-4","title":"لقد ملأت الإبريق بالفعل بالماء","lines":["لقد ملأت الإبريق بالفعل بالماء","من قناة الري،","وضوء المساء يعكس القطرات","على ذراعيها البنيتين.","","في غسق جونغار،","يتحول كل شيء إلى ذهب:","الماء، القمح، شعرها،","الغبار على صندلها،","والابتسامة التي تمنحني إياها","دون أن تستدير."]},{"id":"poem-4-5","title":"هل كانت تلك آخر ابتسامة لها لي؟","lines":["هل كانت تلك آخر ابتسامة لها لي؟","انطلقت الشاحنة مبتعدة،","وعبر الغبار خيّل إليّ أني رأيتها تلوح —","أم أن تلك كانت الريح تداعب أشجار الصفصاف الحمراء؟","","لقد عادت إلى سيتشوان،","إلى التلال الخضراء وحقول الأرز،","بعيداً عن الرمال والرياح،","وبعيداً عني.","","هل كانت تلك آخر ابتسامة لها لي؟","لقد كنت أسأل الصحراء منذ ذلك الحين،","والصحراء لا تجيب."]},{"id":"poem-4-6","title":"آه، يا للعندليب في أشجار الصفصاف الحمراء","lines":["آه، يا للعندليب في أشجار الصفصاف الحمراء","تغني الأغنية التي لا أستطيع أن أغنيها،","أغنية الرجل الذي بقي","في حين رحلت المرأة التي أحبها.","","العندليب لا تعرف الوحدة،","لكنها تغني كما لو كانت تعرفها،","وباستماعي لها، أكاد أصدق","أن الجمال والحزن","هما شيء واحد."]},{"id":"poem-4-7","title":"لنسج ألوان الربيع للحدود","lines":["'لنسج ألوان الربيع للحدود' —","قالت أن هذا هو سبب مجيئها،","فتاة من مصانع الحرير في سوتشو،","استبدلت نولها بمجرفة.","","إنها تزرع الزهور على طول ضفة القناة،","القطيفة والختمية،","مشرقة ضد الأرض البنية،","تنسج نوعاً مختلفاً من الحرير:","ألوان الربيع","على القماش الخشن للحدود."]},{"id":"poem-4-8","title":"يتدفق لحن أخضر","lines":["يتدفق لحن أخضر","عبر حزام الحماية المزروع حديثاً،","والريح تعزف بأشجار الحور كالناي،","وكل شجرة هي نغمة في النوتة الموسيقية.","","أستمع وأنا مغمض العينين","وأسمع المستقبل:","ظلّاً يكفي مدينة،","وهدوءاً يكفي مقاطعة،","كل هذا يتدفق من هذا اللحن الأخضر","الذي بدأ كشتلة","في يد جندي."]},{"id":"poem-4-9","title":"آه، أرجوك لا تتركني","lines":["آه، أرجوك لا تتركني،","ليس الآن، ليس والقطن على وشك التفتح،","وليس وخزان المياه ممتلئ تقريباً،","وليس وقد بنينا بالكاد الحياة","التي كنا نتحدث عنها منذ لانغشو.","","ابقِ حتى تصبح أشجار الحور أطول منا،","وابقِ حتى يتم رصف الطريق،","وابقِ حتى تشعر النجوم بأنها أقل غربة","وأكثر جيرة.","","آه، أرجوك لا تتركني.","الصحراء واسعة بما يكفي لاثنين."]},{"id":"poem-4-10","title":"إنها عجلة تتطاير بفعل كثيب رملي حاد","lines":["إنها عجلة تتطاير بفعل كثيب رملي حاد،","ترتد عبر الرمال","كقمر صغير مثير للسخرية.","","تأوهت الشاحنة ومالت،","وتناثرت الإمدادات:","علب الطلاء، ولفائف الأسلاك،","ورسائل الحب","من حقيبة البريد،","تتدحرج في الرمال","تحت السماء اللامبالية."]},{"id":"poem-4-11","title":"آه، يا لتلك الأمواج الثلجية الزرقاء الداكنة","lines":["آه، يا لتلك الأمواج الثلجية الزرقاء الداكنة","تتحطم من تيانشان عند الغسق،","حاملة التنفس البارد للنهر الجليدي","إلى الوادي الدافئ أدناه.","","واقفاً في ضباب الأمواج الثلجية،","أفكر فيكِ،","في فستانك القطني الأزرق الداكن،","في شعرك المتطاير في الريح،","في ضحكتك مثل الماء —","باردة ومشرقة ومندفعة."],"annotations":[{"term":"أمواج الثليج","note":"نهر أمواج الثليج - الأمواج البديعة لماء التيانشان المذابة كالموج المتبلور الأبيض الحامل لرونق الفرح المتجه لتروية غرس الصحراء."}]},{"id":"poem-4-12","title":"ابتعدت مبتسمة بلطف","lines":["ابتعدت مبتسمة بلطف،","في الطريق المحاط بأشجار الحور،","حقيبتها في يد،","ومستقبلها في الأخرى.","","لم تنظر للخلف —","أو ربما نظرت،","وأخفت أشجار الحور وجهها.","","ابتعدت مبتسمة،","وكأن الرحيل سهل،","وكأن الصحراء","لم تكن قد كتبت","اسمها سلفاً","على قلبها."]},{"id":"poem-4-13","title":"إلى حيث تسكن، أنا ذاهب","lines":["إلى حيث تسكن، أنا ذاهب،","ماراً بالكثبان الرملية ومجاري الأنهار الجافة،","ماراً ببساتين الصفصاف الحمراء،","ماراً بعلامات المسح","والطريق غير المكتمل.","","إلى حيث تسكن، أنا ذاهب،","في المستوطنة الجديدة جنوب التلال،","حيث تدرس عشرين طفلاً","في غرفة مدرسية مبنية من الطوب اللبن.","","إلى حيث تسكن، أنا ذاهب.","الصحراء تمتد لخمسين كيلومتراً فقط.","ومن أجل الحب، فإن بغداد ليست ببعيدة حقاً."]},{"id":"poem-4-14","title":"أمَسِّح برفق هذا الحجر القرمزي الصحراوي","lines":["أمَسِّح برفق هذا الحجر القرمزي الصحراوي،","المصقول بمليون عام من الرياح،","صغير كقلب،","ودافئ من شمس الظهيرة.","","سأعطيها إياه","بدلاً من الخاتم.","","على الحدود","لا نملك صاغة مجوهرات،","لكننا نملك الصحراء،","والصحراء تصنع","جواهرها الخاصة."]},{"id":"poem-4-15","title":"المشي في صمت","lines":["المشي في صمت","عبر قربانتونغوت عند الغسق،","والرمال لا تزال دافئة تحت قدمي،","والسماء تتلون بألوان","لا يوجد لها اسم في أي لغة.","","المشي في صمت","لأن بعض المشاعر","أكبر من الكلمات،","وأوسع من الأفواه،","ويجب أن تُحمل","في الصدر،","في الخُطى،","في الصمت ذاته."]},{"id":"poem-4-16","title":"آه، في قلبي قمر لا يغرب أبداً","lines":["آه، في قلبي قمر لا يغرب أبداً،","قمر يضيء عندما تكون السماء ملبدة بالغيوم،","قمر يتوهج في العاصفة الرملية،","قمر يتبعني","من الخندق العسكري إلى الحقل إلى ضفة القناة.","","أنا لا أحتاج","إلى القمر فوق تيانشان،","لأنني أحمل قمري الخاص،","مشرق بذكرى وجهها،","ومكتمل كل ليلة،","ولا يتضاءل أبداً."]},{"id":"poem-4-17","title":"الجدول يتدفق عبر الليل الأزرق الداكن","lines":["الجدول يتدفق عبر الليل الأزرق الداكن،","خيط فضي في الظلام،","يحمل صوت النهر الجليدي","نزولاً إلى الحقول النائمة.","","أجلس بجانبه وأتذكر:","كيف غمست قدميها في هذا الماء،","وكيف ضحكت عندما فاجأتها البرودة،","وكيف قالت: 'حتى الماء هنا","طعم كطعم المغامرة.'","","يواصل الجدول تدفقه","عبر الليل الأزرق الداكن،","حاملاً ضحكتها معه","شرقاً، دائماً نحو الشرق."]},{"id":"poem-4-18","title":"أستطيع الاستغناء عن القمر في السماء","lines":["أستطيع الاستغناء عن القمر في السماء،","أستطيع الاستغناء عن المطر من الغيوم،","أستطيع الاستغناء عن رسائل الوطن.","","لكنني لا أستطيع الاستغناء عن","تفكيري بكِ،","واقفة في المدخل","للمدرسة المبنية من الطوب اللبن،","والطباشير لا يزال على أصابعك،","تُعلمين عشرين طفلاً","كيف يكتبون كلمة 'الربيع'","في أرض من الشتاء الدائم."]},{"id":"poem-4-19","title":"تلك الأصداء العميقة من ليالي الحب الأول","lines":["تلك الأصداء العميقة من ليالي الحب الأول","لا تزال تتردد في هواء الصحراء،","في المساحات بين الكثبان الرملية،","في الفجوات بين النجوم.","","كنا شباباً آنذاك،","نشيطون كالشتلات التي زرعناها،","وخُضر كالقمح الذي سقيناه،","وحمقى كالعندليب","الذي يغني لصحراء خاوية.","","تلك الأصداء العميقة","لم تتوقف أبداً."]},{"id":"poem-4-20","title":"الطائر الذي يبشر بالفجر","lines":["الطائر الذي يبشر بالفجر","يجلس على أعلى غصن","في أطول شجرة حور في حزام الحماية،","ويغني.","","ليس عندليباً هذه المرة،","بل قُبَّرة،","ساطعة الصوت وعادية،","طائر الصباحيات المألوفة،","طائر القهوة والخبز والعمل.","","الطائر الذي يبشر بالفجر","لا يغني عن الحب","وإنما يغني عن الروتين الجميل","لأيام تتبع أياماً أُخَرَ","على الحدود."]},{"id":"poem-4-21","title":"رغم أنه نفس النوع من الحزن","lines":["رغم أنه نفس النوع من الحزن","مثل الليلة التي غادر فيها القطار،","إلا أنه حزن ألطف الآن،","صُقل عبر السنين،","كحجر صحراء غوبي في اليد.","","لقد تعلمت أن أتعايش معه،","هذا الحزن الذي هو أيضاً امتنان،","هذا الشوق الذي هو أيضاً ذكرى،","هذا الغياب الذي هو أيضاً حضور،","هنا، في الصحراء،","حيث كل شيء بعيد","ولا يُنسى أي شيء."]},{"id":"poem-4-22","title":"كعندليب حزين يطير نحوي","lines":["كعندليب حزين يطير نحوي،","تعود ذكراها","في كل مساء صحراوي،","ومع كل هلال قمر.","","أفتح ذراعي لألتقطه،","طائر الذاكرة الداكن هذا،","وأضمه إلى صدري،","وأستمع إلى أغنيته:","","من أجل الحب، فإن بغداد ليست ببعيدة حقاً.","ومن أجل الحب، لا توجد مسافة شاسعة جداً.","ومن أجل الحب، الصحراء ليست بصحراء","بل حديقة تنتظر المطر.","","كعندليب حزين يطير نحوي،","إنها تعود وتعود،","وأنا، أنا من بقيت،","أزداد ثراءً لذلك."]}]}]},"children":[["$","div",null,{"className":"fixed top-4 right-4 z-50","children":["$","$L9",null,{"currentLocale":"ar"}]}],["$","div",null,{"className":"max-w-4xl mx-auto pb-32","children":[["$","header",null,{"className":"pt-24 pb-12 px-8 text-center border-b border-gray-100 mb-12","children":[["$","h1",null,{"className":"text-4xl font-serif font-bold text-gray-900 mb-4","children":"قصائد من جونغار"}],["$","p",null,{"className":"text-sm text-gray-400 font-sans","children":["لي يوي"," / ","1984"]}]]}],[["$","div","chapter-1",{"className":"mb-24 px-4","children":[["$","h2",null,{"className":"text-xl font-sans font-bold text-gray-300 uppercase tracking-widest pl-8 mb-8 border-l-4 border-gray-100","children":"المجلد الأول: نار المخيم المتراقصة"}],[["$","article",null,{"id":"poem-1-1","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"أغنية المنجل الأول"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"احصد، احصد، احصد!"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"احصد مساحة من غروب الشمس، واحصد عشرة آلاف موجة من القمح؛"}],["$","p","2",{"className":"min-h-[1.5em] ","children":"لقد عشنا أخيراً لنشهد هذا اليوم،"}],["$","p","3",{"className":"min-h-[1.5em] ","children":"يوم نسترد فيه من الصحراء"}],["$","p","4",{"className":"min-h-[1.5em] ","children":"هذا المحيط الذهبي"}]]}],false,["$","div",null,{"className":"mt-20 pt-6 border-t border-gray-200","children":[["$","div",null,{"className":"flex justify-between items-center text-sm text-gray-500 font-sans","children":[["$","span",null,{"children":["《","قصائد من جونغار","》 · ","المجلد الأول: نار المخيم المتراقصة"]}],"$undefined"]}],["$","p",null,{"className":"mt-2 text-xs text-gray-400 text-center","children":["لي يوي"," / ","1984"]}]]}]]}],["$","article",null,{"id":"poem-1-2","className":"max-w-2xl mx-auto py-32 px-8 scroll-mt-12","children":[["$","div",null,{"className":"mb-16","children":["$","h3",null,{"className":"text-3xl font-bold text-gray-900 font-serif leading-relaxed","children":"تتفتح في اندفاعة"}]}],["$","div",null,{"className":"space-y-1 font-serif text-xl text-gray-800 leading-[2.2]","children":[["$","p","0",{"className":"min-h-[1.5em] ","children":"نبحر في بحر قربانتونغوت،"}],["$","p","1",{"className":"min-h-[1.5em] ","children":"تنطلق الحصادة المجمعة في ضوء الفجر الخافت،"}],["$","p","2"