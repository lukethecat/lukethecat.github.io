2:["$","div",null,{"className":"min-h-screen bg-gradient-to-b from-gray-50 to-white","children":[["$","div",null,{"className":"fixed top-4 right-4 z-50","children":["$","$L7",null,{"currentLocale":"ar"}]}],["$","section",null,{"className":"max-w-5xl mx-auto px-8 pt-32 pb-20","children":["$","div",null,{"className":"text-center","children":[["$","h1",null,{"className":"text-6xl font-serif font-bold text-gray-900 mb-12","children":"لي يوي"}],["$","div",null,{"className":"max-w-2xl mx-auto min-h-[160px] flex items-center justify-center","children":["$","$L8",null,{"poems":[{"id":"hanxuema-soul","lines":["诗魂还在奔驰","突然想到要写一首诗","当然是豪壮的","是一首战争诗","确只以挥动骑刀的手","匆匆抚摩了一下腰中的诗囊"],"source":"《汗血马》· 诗魂还在奔驰","author":"李瑜"},{"id":"hanxuema-wild-poppy","lines":["她再也没有看到那枚","载着她童心的红叶了","她面前的伊犁河","没有那枚载着她童心的红叶","只有野罂粟的落英","虽然也是红色的"],"source":"《汗血马》 · 野罂粟","author":"李瑜"},{"id":"zhungaer-bonfire-night","lines":["夜也不平静，生命都在滋长，","欢腾的雪浪是准噶尔跳跃的血浆；","苞谷拔节的声音这么清脆，","惊走了调皮的小鹿、胆小的黄羊。"],"source":"《准噶尔诗草》 · 卷之一：飘动的篝火","author":"李瑜"}]}]}]]}]}],["$","section",null,{"className":"max-w-3xl mx-auto px-8 pb-20","children":["$","div",null,{"className":"bg-white rounded-2xl shadow-sm border border-gray-100 p-12","children":[["$","h2",null,{"className":"text-2xl font-serif font-bold text-gray-900 mb-6 text-center","children":"عن الشاعر"}],["$","p",null,{"className":"font-serif text-gray-700 leading-relaxed text-lg","children":"لي يوي، شاعر صيني معاصر بارز من شعراء الحدود الغربية، وُلد في تشونغتشينغ وأصوله من مقاطعة تشاو في آنهوي. نشأ في ووهان وتجوّل في أرجاء واسعة من الصين، لكنه أمضى معظم عمره بين ثلوج وظلال أشجار السفح الشمالي لجبال تيانشان. التصقت بشعره موضوعات الحب والموت الخالدة التصاقاً لا انفكاك منه. بُثّت أشعاره وسيرته الإبداعية عبر إذاعة الصين الدولية بأكثر من اثنتي عشرة لغة، وتُرجمت إلى لغات عديدة من لغات القوميات في الصين. من أبرز مؤلفاته الدواوين الشعرية: *قصائد من جونغار*، *آه، مياه نهر إيلي بيّضت بزّتي العسكرية*، *الحرب والمدينة*، *من أجل الحب، بغداد ليست بعيدة*، ومجموعة النثر *سلسلة الأزقة*."}]]}]}],["$","section",null,{"className":"max-w-5xl mx-auto px-8 pb-32","children":[["$","h2",null,{"className":"text-3xl font-serif font-bold text-gray-900 mb-12 text-center","children":"الأعمال الكاملة"}],["$","div",null,{"className":"mb-16","children":[["$","h3",null,{"className":"text-xl font-sans font-semibold text-gray-700 mb-6 uppercase tracking-wider","children":"الدواوين الشعرية"}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-6","children":[["$","div","hanxuema1995",{"className":"bg-white rounded-xl border border-gray-200 hover:border-gray-400 hover:shadow-lg transition-all duration-300 p-8","children":[["$","$L9",null,{"href":"/ar/books/hanxuema1995","className":"group block","children":[["$","h4",null,{"className":"text-2xl font-serif font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition","children":"خيول الدم المتعرّق"}],["$","p",null,{"className":"text-gray-500 text-sm mb-4","children":"١٩٩٥"}],["$","p",null,{"className":"text-gray-600 leading-relaxed","children":"إحدى وعشرون مجموعة من القصائد التاريخية في المناطق الغربية، تمتد على مدى ألفي عام من بداية أسرة هان الغربية حتى حروب الأفيون. الخيول المتعرقة دماً تجسّد روح الحياة وعظمة حضارة تولد من جديد."}]]}],["$","div",null,{"className":"mt-6 pt-6 border-t-2 border-gray-200 bg-gray-50 -mx-8 -mb-8 px-8 pb-8 rounded-b-xl","children":[["$","p",null,{"className":"text-sm font-semibold text-gray-700 mb-4 flex items-center","children":[["$","svg",null,{"className":"w-4 h-4 mr-2 text-blue-600","fill":"none","stroke":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","strokeWidth":2,"d":"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"}]}],"مقالات ذات صلة"]}],["$","div",null,{"className":"space-y-2","children":[["$","$L9","hanxuema-introduction",{"href":"/ar/essays/hanxuema-introduction","className":"flex items-center text-sm text-gray-700 hover:text-b