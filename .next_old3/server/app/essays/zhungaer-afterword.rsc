7:I[1381,["381","static/chunks/381-69b2da2ba8d09540.js","627","static/chunks/app/essays/%5BessayId%5D/page-01867f221d08e270.js"],""]
2:["$","div",null,{"className":"min-h-screen bg-gradient-to-b from-gray-50 to-white","children":[["$","header",null,{"className":"border-b border-gray-100 bg-white","children":["$","div",null,{"className":"max-w-4xl mx-auto px-8 py-6","children":["$","$L7",null,{"href":"/","className":"inline-flex items-center text-gray-600 hover:text-gray-900 transition","children":[["$","svg",null,{"className":"w-5 h-5 mr-2","fill":"none","stroke":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","strokeWidth":2,"d":"M10 19l-7-7m0 0l7-7m-7 7h18"}]}],"返回首页"]}]}]}],["$","article",null,{"className":"max-w-4xl mx-auto px-8 py-16","children":["$","div",null,{"className":"prose prose-lg max-w-none","children":["$","div",null,{"className":"text-gray-800 font-serif text-lg","children":[["$","h1","h1-0",{"className":"text-4xl font-serif font-bold mb-8 text-center","children":"从大漠升起袅袅的笛声——读《准噶尔诗草》"}],["$","p","p-1",{"className":"mb-6 leading-relaxed","children":["",["$","strong","bold-1-1",{"children":"阿红"}],""]}],["$","h2","h2-2",{"className":"text-3xl font-serif font-bold mt-16 mb-6","children":"A"}],["$","p","p-3",{"className":"mb-6 leading-relaxed","children":"李瑜邀我为他即将出版的处女集《准噶尔诗草》写篇读后。"}],["$","p","p-4",{"className":"mb-6 leading-relaxed","children":"我心怵。"}],["$","p","p-5",{"className":"mb-6 leading-relaxed","children":"哪能不怵呢？"}],["$","p","p-6",{"className":"mb-6 leading-relaxed","children":"车尔尼雪夫斯基说：\"关于诗人的性格、生平和他所接触的人们,我们知道的愈多,就愈能在他的作品中看出活人的肖像。\""}],["$","p","p-7",{"className":"mb-6 leading-relaxed","children":"我后悔去年九月在\"绿风\"诗会与李瑜相识时,没做个有心人多和他谈学。那是一个了解他的生平的机会哪！"}],["$","p","p-8",{"className":"mb-6 leading-relaxed","children":"而今天遥地远,云飞鹰旋,迢迢万里,问答艰难。"}],["$","p","p-9",{"className":"mb-6 leading-relaxed","children":"仅仅只能从他早期发表诗作署名前的仿宋字知他曾是\"知识青年\"。"}],["$","p","p-10",{"className":"mb-6 leading-relaxed","children":"仅仅只能从一篇评论边塞新诗的文章里,知他在\"史无前例\"的日子里\"曾度过一段悲怆的流浪生活\"；知他从绿洲新城被放逐到古尔班通古特沙漠边缘的一个军垦农场,于1972年唱着《开镰歌》走上诗坛的。"}],["$","p","p-11",{"className":"mb-6 leading-relaxed","children":"仅仅知他最近结束了二十余年的教学生涯,调往乌鲁木齐市一家报社工作。他负责的那副刊名家如星,编得出色。"}],["$","p","p-12",{"className":"mb-6 leading-relaxed","children":"再呢,就是这部《准噶尔诗草》。"}],["$","p","p-13",{"className":"mb-6 leading-relaxed","children":"种种信息互相碰撞、融会,我对李瑜得出了如下的印象："}],["$","p","p-14",{"className":"mb-6 leading-relaxed","children":"他是地地道道垦区的建设者和绿洲的开拓者。在准噶尔,在古尔班通古特,他在那儿辛勤地劳动着,他在那儿抛洒过汗滴,说不定在那儿也抛洒过泪滴呢！"}],["$","p","p-15",{"className":"mb-6 leading-relaxed","children":"他有理想,有信念,有落到大海也不会沉没的精神。"}],["$","p","p-16",{"className":"mb-6 leading-relaxed","children":"他劳动着,生活着,写着诗。开拓绿洲的战场上,他是随军记者,是拿坎土曼的诗人。"}],["$","p","p-17",{"className":"mb-6 leading-relaxed","children":"他有不少的梦。他也会做梦。他在物质的荒原上,负着精神上的重压,为实现自己的梦,他以\"为了爱情,巴格达不嫌远\"的精神,不屈不挠地拼搏着、跋涉着。应该说,他的梦在一一实现。"}],["$","p","p-18",{"className":"mb-6 leading-relaxed","children":"或许说：李瑜生活之路也够崎岖坎坷的。可也是,请原谅我说句不讨人喜欢的话,这崎岖坎坷的生活之路倒也成全了李瑜。试想古今诗人,有几位是糖水里泡大的？相反,大多有过不平常的经历。王安石说：\"岁老根弥壮,阳骄叶更明。\"拜伦也说:\"逆境是达到真理的一条通路。\"别林斯基也说：\"不幸是一所最好的大学。\"李瑜从南国故乡到新疆开拓绿洲,投入了将永远被史籍称道的开发新疆的战斗。当然,生活是艰苦的,不正是这艰苦的生活,使他深切地熟悉了、认识了开拓者吗？使他锤炼了意志、心灵吗？使他献出这本《准噶尔诗草》吗?使他成为一颗诗的新星吗？"}],["$","p","p-19",{"className":"mb-6 leading-relaxed","children":"这本《准噶尔诗草》,"}],["$","p","p-20",{"className":"mb-6 leading-relaxed","children":"就是他人生经历的画卷,"}],["$","p","p-21",{"className":"mb-6 leading-relaxed","children":"就是他精神境界的荧光屏,"}],["$","p","p-22",{"className":"mb-6 leading-relaxed","children":"就是他从大漠升起的袅袅的笛声！"}],["$","h2","h2-23",{"className":"text-3xl font-serif font-bold mt-16 mb-6","children":"B"}],["$","p","p-24",{"className":"mb-6 leading-relaxed","children":"想当年俄罗斯诗人涅克拉索夫也曾写过些被批评家别林斯基认为是人云亦云的诗稿。这时的涅克拉索夫是在诗创作的童年阶段。"}],["$","p","p-25",{"className":"mb-6 leading-relaxed","children":"我漫读李瑜的诗,发现他也有创作的童年阶段。"}],["$","p","p-26",{"className":"mb-6 leading-relaxed","children":"《开镰歌》是他问世的处女作。1972年发表的,免不了还有那个时期的生活印记。这次收集放在首篇,可能是出于纪念的心情。"}],["$","p","p-27",{"className":"mb-6 leading-relaxed","children":"这首诗的构思、语言都一般,思想开掘也较浮浅。是的,我看到的这个集子初选稿里确实有一些这样的诗。"}],["$","p","p-28",{"className":"mb-6 leading-relaxed","children":"我指出这个问题,是因为我想到任何一个文学刊物接到的诗稿里有不少这样的诗,情绪健康,结构完整,可就是少了一点作为诗歌艺术必不可少的东西。"}],["$","p","p-29",{"className":"mb-6 leading-relaxed","children":"我是认为抒情诗,终究抒的是诗人之我的情思,终究是以诗人之我的方式抒诗人之我的情思。诗,是诗人这个人写的。他在某种境遇里对某种事物有所见,有所感,有所思,就用诗来坦露自己的心灵,传达自己的心灵信息。勿论他是自觉或是不自觉,是想使别人也能见诗人所见,感诗人所感,思诗人所思。因此,抒情诗这种艺术强烈要求显示诗人的个性。"}],["$","p","p-30",{"className":"mb-6 leading-relaxed","children":"戴复古说：\"须教自我胸中出,切忌随人脚后行。\""}],["$","p","p-31",{"className":"mb-6 leading-relaxed","children":"何绍基说:\"诗是自家作的,便要说自家的话,凡可以彼此公共通融的话头,都与自己无涉。\""}],["$","p","p-32",{"className":"mb-6 leading-relaxed","children":"高尔基说：\"谁想当作家,谁就应当在自己身上找到自己。\""}],["$","p","p-33",{"className":"mb-6 leading-relaxed","children":"黑格尔说：\"人一旦从事于表达他自己,诗就开始出现了。\""}],["$","p","p-34",{"className":"mb-6 leading-relaxed","children":"当然,诗人要心灵美,志趣高,胸襟宽,理想远。他是大海里的一滴水,和大海同温凉起伏,从他这一滴水里能发现大海。"}],["$","p","p-35",{"className":"mb-6 leading-relaxed","children":"李瑜是有能耐的。他快步跨过了创作的童年阶段。"}],["$","p","p-36",{"className":"mb-6 leading-relaxed","children":"他写着自己的官能感觉,写着自己的情思、自己的心灵搏动。我不知道李瑜是如何能那么快跨越创作的童年阶段的。也许他是从中外名家诗篇领悟了诗的诀窍；也许他是从中外名家诗论体味了诗的秘密；也许他是从自己创作实践不断理解了诗的方式；也许是这些的综合。"}],["$","p","p-37",{"className":"mb-6 leading-relaxed","children":"这只有李瑜能说清楚,甚至他也不能说清楚。"}],["$","p","p-38",{"className":"mb-6 leading-relaxed","children":"横竖跨越了这个阶段：他才告别了一般化,有了打动人心的感情,他才有可能形成自己的艺术风格。"}],["$","p","p-39",{"className":"mb-6 leading-relaxed","children":"李瑜是智慧的。智慧的头脑会更倾听诗的话、理论的话、生活的话和自然的话。"}],["$","h2","h2-40",{"className":"text-3xl font-serif font-bold mt-16 mb-6","children":"C"}],["$","p","p-41",{"className":"mb-6 leading-relaxed","children":"是的,李瑜的诗有了自家的面目。"}],["$","p","p-42",{"className":"mb-6 leading-relaxed","children":"读着他的那些诗，仿佛听着一位有着流泉一样性格的人,轻声慢语地同我娓娓叙谈。他说话有自己的腔调；笑,也有自己的情状。"}],["$","p","p-43",{"className":"mb-6 leading-relaxed","children":"我认为人的自然个性和社会个性制约着人的艺术个性。从他的诗看,从他那些卓具特色的诗看,我的审美总印象是：自然、俊秀、婉曲。"}],["$","p","p-44",{"className":"mb-6 leading-relaxed","children":["",["$","strong","bold-44-1",{"children":"自然"}],",我理解的自然,一是情思生得自然。一是情思写得自然。按着情思的形态、节奏、路儿去写,不装饰,不捏弯,云舒于天,水行于地。自然的生命是真实,是抒情主人公在特定境遇中情绪、感情、思想的真实。"]}],["$","p","p-45",{"className":"mb-6 leading-relaxed","children":["",["$","strong","bold-45-1",{"children":"俊秀"}],"：我是说他的那些好诗虽然并未特别梳妆打扮,但是眉清目秀,有神采,有风致,有几分妩媚。像他在《闪耀着月光》里,写月下流过绿洲的水渠,都给读者一种俊秀的感觉。"]}],["$","p","p-46",{"className":"mb-6 leading-relaxed","children":["",["$","strong","bold-46-1",{"children":"婉曲"}],"：也有两层意思,一是用意表达上的婉曲,一是诗情内涵及其流动态势的婉曲。李瑜有不少的诗,是婉曲的。诗中情思的脉动,不像人工渠水,直通通的；而像自然的溪流,有那么几个弯儿。"]}],["$","p","p-47",{"className":"mb-6 leading-relaxed","children":"李瑜在语言的运用上好像从维吾尔族民歌汲收了点什么。过去许多诗人都曾从有着永久魅力的民间创作中汲取营养。当代诗就不能从民间文学汲取营养吗？能的。这有利于诗的群众化、民族化。李瑜从维吾尔族民歌汲取了点东西,看来和他诗的总格调还是统一的,谐调的。"}],["$","p","p-48",{"className":"mb-6 leading-relaxed","children":"如果说李瑜诗歌情思的质地,那是刚性的。诗里活跃着的是开拓的理想、开拓的勇敢、开拓的韧性,而且有一些诗里也有刚性的意境、形象。但他的诗给人的总体审美感觉还是自然、俊秀、婉曲。李瑜使自己的诗具有这样的特征,在新疆众多诗人的画廊里就能够占有自己的位置。"}],["$","h2","h2-49",{"className":"text-3xl font-serif font-bold mt-16 mb-6","children":"D"}],["$","p","p-50",{"className":"mb-6 leading-relaxed","children":"我想说：李瑜的诗已大体形成自己的艺术特征,但好像他也有另外的追求,向同自己的艺术特征并不谐调的方面靠。不一定这样吧？至少,不一定现在就这样吧？使自己的诗具有自己的艺术特征、风格,不那么容易。何不稳定、巩固一个时期呢！"}],["$","p","p-51",{"className":"mb-6 leading-relaxed","children":"我想说：有些诗内涵还欠丰富、深厚；对生活的思索还显得表面些。我们的生活并非无差别境界,诗人也不必视而不见,见而无动于心。"}],["$","p","p-52",{"className":"mb-6 leading-relaxed","children":"我想说：该让每一个词儿都十分熨贴,艺术嘛,少不得精雕细琢。比如形象的雷同就是应注意的。"}],["$","p","p-53",{"className":"mb-6 leading-relaxed","children":"我想说：艺术手法还可以更多样些。"}],["$","h2","h2-54",{"className":"text-3xl font-serif font-bold mt-16 mb-6","children":"E"}],["$","p","p-55",{"className":"mb-6 leading-relaxed","children":"萨克雷《名利场》有段话说：\"一个人受了友谊的感动去办事的时候,本来胆小的变得勇敢了,本来怕羞的有了自信了,懒怠的也肯动了。\""}],["$","p","p-56",{"className":"mb-6 leading-relaxed","children":"是李瑜的挚情使我由怵到勇。"}],["$","p","p-57",{"className":"mb-6 leading-relaxed","children":"生孩子要节育,一对夫妻一个孩。"}],["$","p","p-58",{"className":"mb-6 leading-relaxed","children":"写诗,多多益善！李瑜的处女集诞生了,我盼着他的第二个、第三个……他正当壮年,好时候哪！"}],["$","p","p-59",{"className":"mb-6 leading-relaxed","children":["",["$","strong","bold-59-1",{"children":"1984年5月6日 沈阳辽宁协作"}],""]}]]}]}]}],["$","footer",null,{"className":"border-t border-gray-100 py-8 mt-24","children":["$","div",null,{"className":"max-w-4xl mx-auto px-8 text-center","children":["$","$L7",null,{"href":"/","className":"text-gray-600 hover:text-gray-900 transition","children":"返回首页"}]}]}]]}]
